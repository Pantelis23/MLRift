// Tier 1 bisection: small-scale csr_build test. Runs the native
// csr_build emitter at N=32, syn_per=4 and reads back col_tgt /
// col_w / col_is_inh, comparing the output of every (src, k) pair
// against a CPU splitmix64 reference. Helps narrow which part of
// the emitter is wrong without burning a 60M-thread launch each
// iteration.
//
// Build:
//   ./build/mlrc --target=amdgpu-native --arch=x86_64 \
//                examples/noesis_60m_gpu.mlr -o /tmp/_csr_kernels
//   ./build/mlrc --target=amdgpu-native --arch=x86_64 \
//                examples/b5f_kfd_csr_build_test.mlr -o /tmp/b5f_csr
//   /tmp/b5f_csr

import "../std/kfd.mlr"

static uint64 N = 32
static uint64 SYN_PER = 4
static uint64 SEED = 42

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 zero = 48; unsafe { *(buf as uint8) = zero }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 {
        i = i - 1
        uint64 d = tmp - (tmp / 10) * 10
        uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }
        tmp = tmp / 10
    }
    return n
}

fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(160)
    uint64 i = 0
    while i < label_len {
        uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 sp = 32; unsafe { *(sp2 as uint8) = sp }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}

// CPU splitmix64 reference (matches the kernel's hash chain).
fn cpu_splitmix64(uint64 seed, uint64 ctr) -> uint64 {
    uint64 z = seed + ctr * 0x9E3779B97F4A7C15
    z = (z ^ (z >> 30)) * 0xBF58476D1CE4E5B9
    z = (z ^ (z >> 27)) * 0x94D049BB133111EB
    z = z ^ (z >> 31)
    return z
}

fn main() {
    kfd_init()
    uint64 q = kfd_create_queue(KFD_WAIT_BUSY_POLL)
    uint64 signal = kfd_signal_alloc()

    uint64 mod = kernel_load("/tmp/_csr_kernels.co")
    uint64 kernel = kernel_get_function(mod, "csr_build")

    uint64 n_syn = N * SYN_PER

    // Allocate device buffers + populate cell_type (alternating E/I).
    uint64 d_tgt = dev_alloc_host_visible(n_syn * 8); uint64 d_tgt_h = dev_host_ptr(d_tgt)
    uint64 d_w   = dev_alloc_host_visible(n_syn * 8); uint64 d_w_h   = dev_host_ptr(d_w)
    uint64 d_inh = dev_alloc_host_visible(n_syn * 8); uint64 d_inh_h = dev_host_ptr(d_inh)
    uint64 d_ct  = dev_alloc_host_visible(N * 8);     uint64 d_ct_h  = dev_host_ptr(d_ct)

    // First half E (ct=0), second half I (ct=1).
    uint64 i = 0
    while i < N {
        uint64 ct_val = 0
        if i >= (N / 2) { ct_val = 1 }
        unsafe { *((d_ct_h + i * 8) as uint64) = ct_val }
        i = i + 1
    }
    // Zero-initialise the output buffers so a missing store is visible.
    i = 0
    while i < n_syn {
        uint64 z = 0
        unsafe { *((d_tgt_h + i * 8) as uint64) = z }
        unsafe { *((d_w_h   + i * 8) as uint64) = z }
        unsafe { *((d_inh_h + i * 8) as uint64) = z }
        i = i + 1
    }

    // Pack kernarg blob — 80 bytes, 10 args × 8.
    uint64 kernarg = dev_alloc_host_visible(80)
    uint64 kh = dev_host_ptr(kernarg)
    unsafe { *((kh + 0x00) as uint64) = d_tgt }
    unsafe { *((kh + 0x08) as uint64) = d_w }
    unsafe { *((kh + 0x10) as uint64) = d_inh }
    unsafe { *((kh + 0x18) as uint64) = d_ct }
    unsafe { *((kh + 0x20) as uint64) = N }
    unsafe { *((kh + 0x28) as uint64) = SYN_PER }
    unsafe { *((kh + 0x30) as uint64) = SEED }
    f64 wee = 1.0; unsafe { *((kh + 0x38) as f64) = wee }
    f64 wei = 2.0; unsafe { *((kh + 0x40) as f64) = wei }
    f64 wie = 3.0; unsafe { *((kh + 0x48) as f64) = wie }

    // Launch. block=N (=32) lanes, grid=1 workgroup.
    kfd_dispatch(q, kernel, 1, 1, 1, N, 1, 1, kernarg, 80, signal)
    kfd_wait(q, signal)

    puts("csr_build returned; comparing first few entries against CPU reference")

    // Compare every (src, k) entry against CPU reference.
    uint64 fails = 0
    uint64 src = 0
    while src < N {
        uint64 src_ct = 0; if src >= (N / 2) { src_ct = 1 }
        uint64 src_e = 0; if src_ct == 0 { src_e = 1 }
        uint64 base = src * SYN_PER
        uint64 k = 0
        while k < SYN_PER {
            uint64 ctr = base + k
            uint64 z = cpu_splitmix64(SEED, ctr)
            uint64 expected_tgt = z - (z / N) * N
            // (skip the tgt==src fixup — emitter doesn't apply it either)
            uint64 tgt_ct = 0; if expected_tgt >= (N / 2) { tgt_ct = 1 }
            uint64 tgt_e = 0; if tgt_ct == 0 { tgt_e = 1 }
            f64 expected_w = 3.0
            uint64 expected_inh = 1
            if src_e == 1 {
                if tgt_e == 1 { expected_w = 1.0 } else { expected_w = 2.0 }
                expected_inh = 0
            }

            uint64 slot = base + k
            uint64 got_tgt = 0; unsafe { *((d_tgt_h + slot * 8) as uint64) -> got_tgt }
            uint64 got_inh = 0; unsafe { *((d_inh_h + slot * 8) as uint64) -> got_inh }
            uint64 got_w_bits = 0; unsafe { *((d_w_h + slot * 8) as uint64) -> got_w_bits }
            uint64 exp_w_bits = 0
            uint64 exp_w_slot = alloc(8)
            unsafe { *(exp_w_slot as f64) = expected_w }
            unsafe { *(exp_w_slot as uint64) -> exp_w_bits }

            if got_tgt != expected_tgt {
                if fails < 8 {
                    print_label_val("MISMATCH src", 12, src)
                    print_label_val("  k         ", 12, k)
                    print_label_val("  exp_tgt   ", 12, expected_tgt)
                    print_label_val("  got_tgt   ", 12, got_tgt)
                }
                fails = fails + 1
            } else if got_inh != expected_inh {
                if fails < 8 {
                    print_label_val("INH MISMATCH src", 16, src)
                    print_label_val("  k         ", 12, k)
                    print_label_val("  exp_inh   ", 12, expected_inh)
                    print_label_val("  got_inh   ", 12, got_inh)
                }
                fails = fails + 1
            } else if got_w_bits != exp_w_bits {
                if fails < 8 {
                    print_label_val("W MISMATCH src", 14, src)
                    print_label_val("  k         ", 12, k)
                    print_label_val("  exp_w_bits", 12, exp_w_bits)
                    print_label_val("  got_w_bits", 12, got_w_bits)
                }
                fails = fails + 1
            }
            k = k + 1
        }
        src = src + 1
    }

    print_label_val("total fails", 11, fails)
    if fails == 0 { puts("b5f csr_build (N=32, native): GREEN"); exit(0) }
    puts("FAIL: native csr_build output mismatched CPU reference")
    exit(1)
}
