// KernRift self-hosted compiler — AArch64 Code Generator
//
// AArch64 instruction encoding: all instructions are 4 bytes, little-endian.
// Calling convention (AAPCS64):
//   x0-x7: argument/return registers
//   x8: indirect result / syscall number (Linux)
//   x9-x15: temporary (caller-saved)
//   x16-x17: intra-procedure-call (IP0/IP1)
//   x18: platform register
//   x19-x28: callee-saved
//   x29: frame pointer (FP)
//   x30: link register (LR)
//   sp: stack pointer
//
// Linux syscall: x8=nr, x0-x5=args, svc #0
// Windows ARM64: IAT indirect calls via MOVZ/MOVK/LDR/BLR sequence

// Static digit buffer for integer print (avoids large stack offsets on ARM64)
static uint64 a64_digit_buf = 0

// ---------------------------------------------------------------------------
// ARM64 Windows IAT fixup table
// ---------------------------------------------------------------------------
// [patch_offset(4), iat_slot(4)] × 1024
// patch_offset points to the MOVZ instruction that starts the IAT call sequence
static uint64 a64_win_iat_fixups = 0
static uint64 a64_win_iat_fixup_count = 0

// ---------------------------------------------------------------------------
// AArch64 instruction emitters
// ---------------------------------------------------------------------------

// Emit a 4-byte AArch64 instruction (little-endian)
fn emit_a64(uint64 insn) {
    emit_byte(insn & 0xFF)
    emit_byte((insn >> 8) & 0xFF)
    emit_byte((insn >> 16) & 0xFF)
    emit_byte((insn >> 24) & 0xFF)
}

// MOV Xd, #imm16 (MOVZ with shift=0)
// Encoding: 1_10_100101_00_imm16_Rd
fn emit_a64_movz(uint64 rd, uint64 imm16) {
    uint64 insn = 0xD2800000 | (imm16 << 5) | rd
    emit_a64(insn)
}

// MOVK Xd, #imm16, LSL #shift (shift = 0,16,32,48)
// Encoding: 1_11_100101_hw_imm16_Rd
fn emit_a64_movk(uint64 rd, uint64 imm16, uint64 shift) {
    uint64 hw = shift / 16
    uint64 insn = 0xF2800000 | (hw << 21) | (imm16 << 5) | rd
    emit_a64(insn)
}

// Load a full 64-bit immediate into Xd (up to 4 instructions)
fn emit_a64_mov_imm(uint64 rd, uint64 val) {
    uint64 lo16 = val & 0xFFFF
    emit_a64_movz(rd, lo16)
    uint64 hi16 = (val >> 16) & 0xFFFF
    if hi16 != 0 {
        emit_a64_movk(rd, hi16, 16)
    }
    uint64 hi32 = (val >> 32) & 0xFFFF
    if hi32 != 0 {
        emit_a64_movk(rd, hi32, 32)
    }
    uint64 hi48 = (val >> 48) & 0xFFFF
    if hi48 != 0 {
        emit_a64_movk(rd, hi48, 48)
    }
}

// ADD Xd, Xn, Xm
fn emit_a64_add(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0x8B000000 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// ADD Xd, Xn, Xm, LSL #shift — shifted add for scaled addressing.
fn emit_a64_add_lsl(uint64 rd, uint64 rn, uint64 rm, uint64 shift) {
    uint64 insn = 0x8B000000 | (shift << 10) | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// SUB Xd, Xn, Xm
fn emit_a64_sub(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0xCB000000 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// MUL Xd, Xn, Xm (alias for MADD Xd, Xn, Xm, XZR)
fn emit_a64_mul(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0x9B007C00 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// AND Xd, Xn, Xm
fn emit_a64_and(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0x8A000000 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// ORR Xd, Xn, Xm
fn emit_a64_orr(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0xAA000000 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// MOV Xd, Xn (alias for ORR Xd, XZR, Xn)
fn emit_a64_mov(uint64 rd, uint64 rn) {
    // Self-move is a 4-byte no-op (mov xN, xN). Skip to shave bytes
    // off every regalloc coalescing path that ends up same-color.
    if rd == rn { return }
    emit_a64_orr(rd, 31, rn)
}

// STR Xt, [Xn, #imm12*8] (store 64-bit, unsigned offset)
fn emit_a64_str(uint64 rt, uint64 rn, uint64 offset) {
    uint64 imm12 = offset / 8
    uint64 insn = 0xF9000000 | (imm12 << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// LDR Xt, [Xn, #imm12*8] (load 64-bit, unsigned offset)
fn emit_a64_ldr(uint64 rt, uint64 rn, uint64 offset) {
    uint64 imm12 = offset / 8
    uint64 insn = 0xF9400000 | (imm12 << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// STRB Wt, [Xn, #imm12] (store byte, unsigned offset)
fn emit_a64_strb(uint64 rt, uint64 rn, uint64 offset) {
    uint64 insn = 0x39000000 | (offset << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// LDRB Wt, [Xn, #imm12] (load byte, unsigned offset)
fn emit_a64_ldrb(uint64 rt, uint64 rn, uint64 offset) {
    uint64 insn = 0x39400000 | (offset << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// LDRH Wt, [Xn, #imm12*2] (load halfword, unsigned offset)
fn emit_a64_ldrh(uint64 rt, uint64 rn, uint64 offset) {
    uint64 imm12 = offset / 2
    uint64 insn = 0x79400000 | (imm12 << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// STRH Wt, [Xn, #imm12*2] (store halfword, unsigned offset)
fn emit_a64_strh(uint64 rt, uint64 rn, uint64 offset) {
    uint64 imm12 = offset / 2
    uint64 insn = 0x79000000 | (imm12 << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// LDR Wt, [Xn, #imm12*4] (load 32-bit, unsigned offset)
fn emit_a64_ldr32(uint64 rt, uint64 rn, uint64 offset) {
    uint64 imm12 = offset / 4
    uint64 insn = 0xB9400000 | (imm12 << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// STR Wt, [Xn, #imm12*4] (store 32-bit, unsigned offset)
fn emit_a64_str32(uint64 rt, uint64 rn, uint64 offset) {
    uint64 imm12 = offset / 4
    uint64 insn = 0xB9000000 | (imm12 << 10) | (rn << 5) | rt
    emit_a64(insn)
}

// STP X29, X30, [SP, #imm7*8]! (pre-index, for prologue)
fn emit_a64_stp_pre(uint64 rt1, uint64 rt2, uint64 rn, uint64 offset) {
    uint64 imm7 = (offset / 8) & 0x7F
    uint64 insn = 0xA9800000 | (imm7 << 15) | (rt2 << 10) | (rn << 5) | rt1
    emit_a64(insn)
}

// LDP X29, X30, [SP], #imm7*8 (post-index, for epilogue)
fn emit_a64_ldp_post(uint64 rt1, uint64 rt2, uint64 rn, uint64 offset) {
    uint64 imm7 = (offset / 8) & 0x7F
    uint64 insn = 0xA8C00000 | (imm7 << 15) | (rt2 << 10) | (rn << 5) | rt1
    emit_a64(insn)
}

// SUB SP, SP, #imm (large-frame safe)
fn emit_a64_sub_sp_imm(uint64 imm) {
    if imm <= 4095 {
        uint64 insn = 0xD1000000 | (imm << 10) | (31 << 5) | 31
        emit_a64(insn)
    } else {
        emit_a64_mov_imm(16, imm)
        emit_a64(0xCB3063FF)
    }
}

// ADD SP, SP, #imm (large-frame safe)
fn emit_a64_add_sp_imm(uint64 imm) {
    if imm <= 4095 {
        uint64 insn = 0x91000000 | (imm << 10) | (31 << 5) | 31
        emit_a64(insn)
    } else {
        emit_a64_mov_imm(16, imm)
        emit_a64(0x8B3063FF)
    }
}

// BL offset (branch with link, rel26*4)
fn emit_a64_bl(uint64 offset) {
    uint64 rel26 = (offset / 4) & 0x3FFFFFF
    uint64 insn = 0x94000000 | rel26
    emit_a64(insn)
}

// B offset (unconditional branch, rel26*4)
fn emit_a64_b(uint64 offset) {
    uint64 rel26 = (offset / 4) & 0x3FFFFFF
    uint64 insn = 0x14000000 | rel26
    emit_a64(insn)
}

// B.cond offset (conditional branch, rel19*4)
fn emit_a64_bcond(uint64 cond, uint64 offset) {
    uint64 rel19 = (offset / 4) & 0x7FFFF
    uint64 insn = 0x54000000 | (rel19 << 5) | cond
    emit_a64(insn)
}

// CBZ Xt, offset (compare and branch if zero)
fn emit_a64_cbz(uint64 rt, uint64 offset) {
    uint64 rel19 = (offset / 4) & 0x7FFFF
    uint64 insn = 0xB4000000 | (rel19 << 5) | rt
    emit_a64(insn)
}

// CBNZ Xt, offset (compare and branch if non-zero)
fn emit_a64_cbnz(uint64 rt, uint64 offset) {
    uint64 rel19 = (offset / 4) & 0x7FFFF
    uint64 insn = 0xB5000000 | (rel19 << 5) | rt
    emit_a64(insn)
}

// CMP Xn, Xm (alias for SUBS XZR, Xn, Xm)
fn emit_a64_cmp(uint64 rn, uint64 rm) {
    uint64 insn = 0xEB000000 | (rm << 16) | (rn << 5) | 31
    emit_a64(insn)
}

// CSET Xd, cond (alias for CSINC Xd, XZR, XZR, invert(cond))
fn emit_a64_cset(uint64 rd, uint64 cond) {
    uint64 inv_cond = cond ^ 1
    uint64 insn = 0x9A9F07E0 | (inv_cond << 12) | rd
    emit_a64(insn)
}

// SVC #0 (supervisor call, Linux syscall)
fn emit_a64_svc() {
    if target_os == 1 {
        emit_a64(0xD4001001)
    } else {
        emit_a64(0xD4000001)
    }
}

// Load syscall number: X8 on Linux, X16 on macOS
fn emit_a64_syscall_nr(uint64 nr) {
    if target_os == 1 {
        emit_a64_mov_imm(16, nr)
    } else {
        emit_a64_mov_imm(8, nr)
    }
}

// RET (return via X30)
fn emit_a64_ret() {
    emit_a64(0xD65F03C0)
}

// NEG Xd, Xm (alias for SUB Xd, XZR, Xm)
fn emit_a64_neg(uint64 rd, uint64 rm) {
    emit_a64_sub(rd, 31, rm)
}

// MVN Xd, Xm (alias for ORN Xd, XZR, Xm)
fn emit_a64_mvn(uint64 rd, uint64 rm) {
    uint64 insn = 0xAA200000 | (rm << 16) | (31 << 5) | rd
    emit_a64(insn)
}

// LSL Xd, Xn, Xm (alias for LSLV)
fn emit_a64_lsl(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0x9AC02000 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// LSR Xd, Xn, Xm (alias for LSRV)
fn emit_a64_lsr(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0x9AC02400 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// UDIV Xd, Xn, Xm
fn emit_a64_udiv(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0x9AC00800 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// MSUB Xd, Xn, Xm, Xa (Xd = Xa - Xn*Xm, for modulo)
fn emit_a64_msub(uint64 rd, uint64 rn, uint64 rm, uint64 ra) {
    uint64 insn = 0x9B008000 | (rm << 16) | (ra << 10) | (rn << 5) | rd
    emit_a64(insn)
}

// EOR Xd, Xn, Xm (XOR)
fn emit_a64_eor(uint64 rd, uint64 rn, uint64 rm) {
    uint64 insn = 0xCA000000 | (rm << 16) | (rn << 5) | rd
    emit_a64(insn)
}

// ADRP Xd, label (page-relative address)
fn emit_a64_adrp(uint64 rd, uint64 imm_hi) {
    uint64 insn = 0x90000000 | ((imm_hi & 3) << 29) | ((imm_hi >> 2) << 5) | rd
    emit_a64(insn)
}

// ADD Xd, Xn, #imm — handles values > 4095 with two-instruction sequence
fn emit_a64_add_imm(uint64 rd, uint64 rn, uint64 imm) {
    if imm <= 4095 {
        uint64 insn = 0x91000000 | (imm << 10) | (rn << 5) | rd
        emit_a64(insn)
    } else {
        // Large offset: MOVZ rd, #imm then ADD rd, rn, rd
        emit_a64_mov_imm(rd, imm)
        if rn == 31 {
            // SP requires extended register form (shifted form uses XZR for reg 31)
            // ADD Xd, SP, Xd, UXTX: 0x8B206000 | (Xd << 16) | (31 << 5) | Xd
            uint64 insn = 0x8B206000 | (rd << 16) | (31 << 5) | rd
            emit_a64(insn)
        } else {
            uint64 insn = 0x8B000000 | (rd << 16) | (rn << 5) | rd
            emit_a64(insn)
        }
    }
}

// NOP
fn emit_a64_nop() {
    emit_a64(0xD503201F)
}

// BLR Xn (branch with link to register)
fn emit_a64_blr(uint64 rn) {
    uint64 insn = 0xD63F0000 | (rn << 5)
    emit_a64(insn)
}

// ---------------------------------------------------------------------------
// ARM64 Windows IAT call helpers
// ---------------------------------------------------------------------------

// Record an IAT fixup: patch_off = output offset of MOVZ instruction, slot = IAT slot index
fn a64_win_fixup_add(uint64 patch_off, uint64 slot) {
    if a64_win_iat_fixup_count >= 4096 {
        write(2, "error: a64_win_iat_fixups overflow (max 4096)\n", 46)
        exit(1)
    }
    uint64 entry = a64_win_iat_fixups + a64_win_iat_fixup_count * 8
    uint32 po = patch_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 sl = slot
    unsafe { *(e4 as uint32) = sl }
    a64_win_iat_fixup_count = a64_win_iat_fixup_count + 1
}

// Emit an indirect call through IAT on ARM64 Windows
// Position-independent sequence (12 bytes = 3 instructions):
//   ADRP X16, #page_delta    ; load page of IAT slot (PC-relative)
//   LDR  X16, [X16, #lo12]   ; load function pointer from IAT slot
//   BLR  X16                  ; call
// call qword via IAT — all 13 entries are loader-resolved; slot 0-12 maps directly
fn emit_a64_win_call_iat(uint64 slot) {
    uint64 patch_off = out_len
    emit_a64(0x90000010)          // ADRP X16, #0 (placeholder)
    emit_a64(0xF9400210)          // LDR X16, [X16, #0] (placeholder)
    emit_a64_blr(16)
    a64_win_fixup_add(patch_off, slot)
}

fn emit_a64_win_store_iat(uint64 slot) {
    uint64 patch_off = out_len
    emit_a64(0x90000010)          // ADRP X16, #0 (placeholder)
    emit_a64(0xF9000200)          // STR X0, [X16, #0] (placeholder, patched for offset)
    a64_win_fixup_add(patch_off, slot)
}

// Resolve ARM64 Windows IAT fixups
// Patches ADRP + LDR with PC-relative offsets to IAT slots
// text_start: file offset where .text begins, iat_rva: RVA of IAT in .idata
@export
fn resolve_a64_win_iat_fixups(uint64 text_start, uint64 iat_rva) {
    // Code at file offset X has RVA = 0x1000 + (X - text_start)
    // Target IAT slot RVA = iat_rva + slot * 8
    uint64 i = 0
    while i < a64_win_iat_fixup_count {
        uint64 entry = a64_win_iat_fixups + i * 8
        uint32 patch_off = 0
        unsafe { *(entry as uint32) -> patch_off }
        uint64 e4 = entry + 4
        uint32 slot = 0
        unsafe { *(e4 as uint32) -> slot }
        uint64 wpatch = patch_off
        uint64 wslot = slot
        // ADRP is at wpatch (file offset), its RVA = 0x1000 + (wpatch - text_start)
        uint64 adrp_rva = 0x1000 + wpatch - text_start
        uint64 target_rva = iat_rva + wslot * 8
        // ADRP: page delta = (target_rva >> 12) - (adrp_rva >> 12)
        uint64 target_page = target_rva >> 12
        uint64 adrp_page = adrp_rva >> 12
        uint64 page_delta = target_page - adrp_page
        // ADRP encoding: immhi (bits 23:5) = page_delta[20:2], immlo (bits 30:29) = page_delta[1:0]
        uint64 immlo = page_delta & 3
        uint64 immhi = (page_delta >> 2) & 0x7FFFF
        uint64 adrp_insn = 0x90000010 | (immlo << 29) | (immhi << 5)
        patch_u32(wpatch, adrp_insn)
        // Second instruction: LDR or STR X0/X16, [X16, #offset]
        // Preserve the opcode (LDR vs STR), only patch the imm12 field (bits 21:10)
        uint64 page_off = target_rva & 0xFFF
        uint64 imm12 = page_off >> 3
        uint32 existing_insn = 0
        uint64 insn_addr = out_buf + wpatch + 4
        unsafe { *(insn_addr as uint32) -> existing_insn }
        uint64 we = existing_insn
        uint64 patched_insn = (we & 0xFFC003FF) | (imm12 << 10)
        patch_u32(wpatch + 4, patched_insn)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// AArch64 variable access helpers
// ---------------------------------------------------------------------------
// Register allocation:
//   x0: expression result / return value / arg 0
//   x1-x7: args 1-7
//   x9: temp for binop rhs
//   x10: temp for address computation
//   x19: callee-saved temp (like rbx on x86_64)
//   x29: frame pointer (FP)
//   x30: link register (LR)
//   sp: stack pointer
//
// Stack frame layout:
//   [sp + 0]          saved x29 (FP)
//   [sp + 8]          saved x30 (LR)
//   [sp + 16]         saved x19
//   [sp + 24]         local variable 0
//   [sp + 32]         local variable 1
//   ...
// Frame overhead: 24 bytes (FP + LR + x19), then 8 bytes per variable

// a64_var_base: offset where variables start on the AArch64 stack frame
// After saved registers: x29(8) + x30(8) + x19(8) + x20(8) = 32 bytes
// For freestanding/naked: no saved regs, a64_var_base = 0
static uint64 a64_var_base = 32

// Float tracking for ARM64 (mirrors x86_64 expr_is_float):
// 0 = integer, 1 = f64 (in d0), 2 = f32 (in s0)
static uint64 expr_is_float_a64 = 0
// Struct literal tracking for ARM64: 0xFFFFFFFF = not a struct, otherwise struct index
static uint64 expr_is_struct_a64 = 0xFFFFFFFF

// sret hidden pointer slot for ARM64: when a function returns a MEMORY-class
// struct (>16 bytes), the caller passes the return address in x8 (AAPCS64).
// The callee saves x8 here at entry so the return path can copy struct data.
// 0xFFFFFFFF means "not an sret function".
static uint64 sret_slot_a64 = 0xFFFFFFFF

// Store x0 to variable slot on stack
fn emit_a64_store_x0(uint64 var_offset) {
    emit_a64_str(0, 31, a64_var_base + var_offset)
}

// Load variable from stack into x0
fn emit_a64_load_x0(uint64 var_offset) {
    emit_a64_ldr(0, 31, a64_var_base + var_offset)
}

// ---------------------------------------------------------------------------
// ARM64 FP load/store helpers (d0/s0 and d1/s1)
// ---------------------------------------------------------------------------

// STR d0, [sp, #(a64_var_base + offset)] — store 64-bit float
fn emit_a64_store_d0(uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 8
    uint64 insn = 0xFD000000 | (imm12 << 10) | (31 << 5) | 0
    emit_a64(insn)
}

// LDR d0, [sp, #(a64_var_base + offset)] — load 64-bit float
fn emit_a64_load_d0(uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 8
    uint64 insn = 0xFD400000 | (imm12 << 10) | (31 << 5) | 0
    emit_a64(insn)
}

// STR s0, [sp, #(a64_var_base + offset)] — store 32-bit float
fn emit_a64_store_s0(uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 4
    uint64 insn = 0xBD000000 | (imm12 << 10) | (31 << 5) | 0
    emit_a64(insn)
}

// LDR s0, [sp, #(a64_var_base + offset)] — load 32-bit float
fn emit_a64_load_s0(uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 4
    uint64 insn = 0xBD400000 | (imm12 << 10) | (31 << 5) | 0
    emit_a64(insn)
}

// LDR dN, [sp, #(a64_var_base + offset)] — load 64-bit float into dN
fn emit_a64_load_dN(uint64 reg, uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 8
    uint64 insn = 0xFD400000 | (imm12 << 10) | (31 << 5) | reg
    emit_a64(insn)
}

// STR dN, [sp, #(a64_var_base + offset)] — store 64-bit float from dN
fn emit_a64_store_dN(uint64 reg, uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 8
    uint64 insn = 0xFD000000 | (imm12 << 10) | (31 << 5) | reg
    emit_a64(insn)
}

// STR sN, [sp, #(a64_var_base + offset)] — store 32-bit float from sN
fn emit_a64_store_sN(uint64 reg, uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 4
    uint64 insn = 0xBD000000 | (imm12 << 10) | (31 << 5) | reg
    emit_a64(insn)
}

// LDR sN, [sp, #(a64_var_base + offset)] — load 32-bit float into sN
fn emit_a64_load_sN(uint64 reg, uint64 var_offset) {
    uint64 abs_off = a64_var_base + var_offset
    uint64 imm12 = abs_off / 4
    uint64 insn = 0xBD400000 | (imm12 << 10) | (31 << 5) | reg
    emit_a64(insn)
}

// LDR dN, [Xbase, #offset] — load 64-bit float from pointer
fn emit_a64_load_dN_from_ptr(uint64 dreg, uint64 base_reg, uint64 offset) {
    uint64 imm12 = offset / 8
    uint64 insn = 0xFD400000 | (imm12 << 10) | (base_reg << 5) | dreg
    emit_a64(insn)
}

// LDR sN, [Xbase, #offset] — load 32-bit float from pointer
fn emit_a64_load_sN_from_ptr(uint64 sreg, uint64 base_reg, uint64 offset) {
    uint64 imm12 = offset / 4
    uint64 insn = 0xBD400000 | (imm12 << 10) | (base_reg << 5) | sreg
    emit_a64(insn)
}

// STR dN, [Xbase, #offset] — store 64-bit float to pointer
fn emit_a64_store_dN_to_ptr(uint64 dreg, uint64 base_reg, uint64 offset) {
    uint64 imm12 = offset / 8
    uint64 insn = 0xFD000000 | (imm12 << 10) | (base_reg << 5) | dreg
    emit_a64(insn)
}

// STR sN, [Xbase, #offset] — store 32-bit float to pointer
fn emit_a64_store_sN_to_ptr(uint64 sreg, uint64 base_reg, uint64 offset) {
    uint64 imm12 = offset / 4
    uint64 insn = 0xBD000000 | (imm12 << 10) | (base_reg << 5) | sreg
    emit_a64(insn)
}

// Parse an AArch64 register name token into a 5-bit register code (0..30).
// Accepts x0..x30. Returns 0xFFFF for unknown names (including xzr/sp).
fn a64_reg_code(uint64 name_tok) -> uint64 {
    uint64 tlen = tok_text_len(name_tok)
    if tlen < 2 || tlen > 3 { return 0xFFFF }
    uint64 ts = tok_text_start(name_tok)
    uint64 p0 = cg_source + ts
    uint64 c0 = 0
    unsafe { *(p0 as uint8) -> c0 }
    if c0 != 120 { return 0xFFFF }     // 'x'
    uint64 p1 = cg_source + ts + 1
    uint64 c1 = 0
    unsafe { *(p1 as uint8) -> c1 }
    if c1 < 48 || c1 > 57 { return 0xFFFF }
    uint64 n = c1 - 48
    if tlen == 3 {
        uint64 p2 = cg_source + ts + 2
        uint64 c2 = 0
        unsafe { *(p2 as uint8) -> c2 }
        if c2 < 48 || c2 > 57 { return 0xFFFF }
        n = n * 10 + (c2 - 48)
    }
    if n > 30 { return 0xFFFF }
    return n
}

// ARM64 static access: emit MOVZ/MOVK to load address into x10, then LDR/STR
fn emit_a64_static_load(uint64 data_offset) {
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    // All ARM64 targets: ADRP + LDR (PC-relative, position-independent)
    // This works for executables, relocatables (.o), and PIE binaries
    emit_a64(0x90000010)           // ADRP X16, #0 (patched)
    emit_a64(0xF9400200)           // LDR X0, [X16, #0] (patched)
}

// Emit LEA-equivalent: load the ADDRESS of a static into X0.
// Uses ADRP + ADD (page_base + page_offset). The fixup resolver detects
// the ADD opcode and patches both instructions accordingly.
fn emit_a64_static_lea(uint64 data_offset) {
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_a64(0x90000010)           // ADRP X16, #0 (patched)
    emit_a64(0x91000200)           // ADD X0, X16, #0 (patched, Rd=X0, Rn=X16)
}

fn emit_a64_static_store(uint64 data_offset) {
    // Save x0 to temp register first
    emit_a64_mov(9, 0)
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    // All ARM64 targets: ADRP + STR (PC-relative, position-independent)
    emit_a64(0x90000010)           // ADRP X16, #0 (patched)
    emit_a64(0xF9000209)           // STR X9, [X16, #0] (patched)
}

// ---------------------------------------------------------------------------
// AArch64 expression codegen — result in x0
// ---------------------------------------------------------------------------

fn gen_expr_a64(uint64 node) {
    expr_is_struct_a64 = 0xFFFFFFFF

    // Record line for debug info
    uint32 dbg_tok_a = ast_tok(node)
    if dbg_tok_a == 0 { dbg_tok_a = ast_data1(node) }
    uint64 wdbg_a = dbg_tok_a
    if wdbg_a != 0 { line_table_record(wdbg_a) }

    uint32 kind = ast_kind(node)

    // Unary operator
    if kind == 34 {
        uint32 operand_idx = ast_child(node)
        uint64 wop = operand_idx
        gen_expr_a64(wop)
        uint32 op_tok = ast_data1(node)
        uint64 wot = op_tok
        uint64 p = cg_tokens + wot * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }
        uint64 wok = op_kind
        if wok == 27 {
            // ! logical NOT: cmp x0, #0; cset x0, eq
            emit_a64_cmp(0, 31)
            emit_a64_cset(0, 0)
        } else if wok == 31 {
            // - negate: neg x0, x0
            emit_a64_neg(0, 0)
        } else if wok == 26 {
            // ~ bitwise NOT: mvn x0, x0
            emit_a64_mvn(0, 0)
        }
        return
    }

    // sizeof literal → mov x0, compile-time size
    if kind == 49 {
        uint32 sz_lo = ast_data1(node)
        uint64 val = sz_lo
        emit_a64_mov_imm(0, val)
        expr_is_float_a64 = 0
        return
    }

    // StructLit — struct literal expression (ARM64)
    if kind == 48 {
        uint32 sname_tok = ast_data1(node)
        uint64 wsn = sname_tok
        uint64 si = struct_lookup(wsn)
        uint64 ssize = struct_total_size(si)
        // Allocate temp stack area for struct
        uint64 slit_base = var_count * 8
        uint64 slots_needed = (ssize + 7) / 8
        var_count = var_count + slots_needed
        var_frame_size = var_count * 8
        uint64 srem = var_frame_size & 15
        if srem != 0 { var_frame_size = var_frame_size + 16 - srem }

        // Walk field expressions and store each
        uint32 is_named = ast_data2(node)
        uint64 wnamed = is_named
        uint32 fchild = ast_child(node)
        uint64 wfchild = fchild
        uint64 fidx = 0
        while wfchild != 0 {
            gen_expr_a64(wfchild)
            // x0 = field value
            uint64 foff = 0
            uint64 fsize = 8
            if wnamed != 0 {
                uint32 fname = ast_tok(wfchild)
                uint64 wfn = fname
                foff = struct_field_offset(si, wfn)
                fsize = struct_field_size(si, wfn)
            } else {
                uint64 fbase = struct_table + si * 272 + 16 + fidx * 16
                uint64 foff_addr = fbase + 4
                uint32 fo32 = 0
                unsafe { *(foff_addr as uint32) -> fo32 }
                foff = fo32
                uint64 fs_addr = fbase + 8
                uint32 fs32 = 0
                unsafe { *(fs_addr as uint32) -> fs32 }
                fsize = fs32
            }
            // Store x0 to [sp + a64_var_base + slit_base + foff]
            uint64 dest = a64_var_base + slit_base + foff
            if fsize == 8 {
                emit_a64_str(0, 31, dest)
            } else if fsize == 4 {
                emit_a64_str32(0, 31, dest)
            } else if fsize == 2 {
                emit_a64_strh(0, 31, dest)
            } else {
                emit_a64_strb(0, 31, dest)
            }
            fidx = fidx + 1
            uint32 fnxt = ast_next(wfchild)
            wfchild = fnxt
        }
        // Result: add x0, sp, #(a64_var_base + slit_base)
        uint64 slit_addr = a64_var_base + slit_base
        emit_a64_add_imm(0, 31, slit_addr)
        expr_is_struct_a64 = si
        expr_is_float_a64 = 0
        return
    }

    // Integer literal
    if kind == 30 {
        uint32 tok = ast_data1(node)
        uint64 val = parse_int_token(tok)
        emit_a64_mov_imm(0, val)
        expr_is_float_a64 = 0
        return
    }

    // Float literal (kind 46): parse int + frac parts, compute full value
    if kind == 46 {
        uint32 lit_tok_f = ast_data1(node)
        uint64 tstart_f = tok_text_start(lit_tok_f)
        uint64 tlen_f = tok_text_len(lit_tok_f)
        uint64 int_val = 0
        uint64 frac_val = 0
        uint64 frac_divisor = 1
        uint64 past_dot = 0
        uint64 fi = 0
        while fi < tlen_f {
            uint64 cp_f = cg_source + tstart_f + fi
            uint64 ch_f = 0
            unsafe { *(cp_f as uint8) -> ch_f }
            if ch_f == 46 { past_dot = 1; fi = fi + 1; continue }
            if ch_f == 102 { fi = fi + 1; continue }
            if ch_f >= 48 && ch_f <= 57 {
                if past_dot == 0 {
                    int_val = int_val * 10 + (ch_f - 48)
                } else {
                    frac_val = frac_val * 10 + (ch_f - 48)
                    frac_divisor = frac_divisor * 10
                }
            }
            fi = fi + 1
        }

        if frac_val == 0 {
            emit_a64_mov_imm(0, int_val)
            emit_a64(0x9E620000)  // scvtf d0, x0
        } else {
            // d0 = int_to_f64(int_val), save to temp
            emit_a64_mov_imm(0, int_val)
            emit_a64(0x9E620000)  // scvtf d0, x0
            emit_a64_store_d0(temp_slot_0)

            // d0 = int_to_f64(frac_val)
            emit_a64_mov_imm(0, frac_val)
            emit_a64(0x9E620000)  // scvtf d0, x0

            // d1 = int_to_f64(frac_divisor)
            emit_a64_store_d0(temp_slot_1)
            emit_a64_mov_imm(0, frac_divisor)
            emit_a64(0x9E620000)  // scvtf d0, x0
            // fmov d1, d0
            emit_a64(0x1E604001)
            emit_a64_load_d0(temp_slot_1)

            // d0 = frac_val / frac_divisor
            // fdiv d0, d0, d1: 0x1E611800
            emit_a64(0x1E611800)

            // d0 += int_part from temp
            emit_a64_load_dN(1, temp_slot_0)
            // fadd d0, d0, d1: 0x1E612800
            emit_a64(0x1E612800)
        }

        // Check for 'f' suffix → f32
        uint64 last_p = cg_source + tstart_f + tlen_f - 1
        uint64 last_c = 0
        unsafe { *(last_p as uint8) -> last_c }
        if last_c == 102 {
            emit_a64(0x1E624000)  // fcvt s0, d0
            expr_is_float_a64 = 2
        } else {
            expr_is_float_a64 = 1
        }
        return
    }

    // String literal
    if kind == 31 {
        uint32 tok = ast_data1(node)
        uint64 wtok = tok
        uint64 tstart = tok_text_start(wtok)
        uint64 tlen = tok_text_len(wtok)
        uint64 str_offset = str_len
        uint64 si = 1
        while si < tlen - 1 {
            uint64 ch = tok_source_byte(wtok, si)
            if ch == 92 {
                si = si + 1
                uint64 esc = tok_source_byte(wtok, si)
                if esc == 120 && si + 2 < tlen {
                    ch = hex_digit_pair_to_byte(tok_source_byte(wtok, si + 1),
                                                tok_source_byte(wtok, si + 2))
                    si = si + 2
                } else {
                    uint64 mapped = escape_char_to_byte(esc)
                    if mapped != 0xFFFFFFFFFFFFFFFF { ch = mapped }
                    else { ch = esc }
                }
            }
            uint64 sp = str_buf + str_len
            uint8 cb = ch
            unsafe { *(sp as uint8) = cb }
            str_len = str_len + 1
            si = si + 1
        }
        uint64 sp = str_buf + str_len
        uint8 zero = 0
        unsafe { *(sp as uint8) = zero }
        str_len = str_len + 1
        // ADRP + ADD to load string address (placeholder, patched later)
        // For now, use a simpler approach: store offset in str_fixups
        // and emit a 2-instruction sequence (8 bytes)
        uint64 fentry = str_fixups + str_fixup_count * 8
        uint32 cp = out_len
        unsafe { *(fentry as uint32) = cp }
        uint64 fe4 = fentry + 4
        uint32 so = str_offset
        unsafe { *(fe4 as uint32) = so }
        str_fixup_count = str_fixup_count + 1
        if target_os == 2 || target_os == 3 {
            // PE/Android: ADRP + ADD (PC-relative, patched later)
            emit_a64(0x90000010)       // ADRP X16, #0
            emit_a64(0x91000200)       // ADD X0, X16, #0
        } else {
            // ELF/Mach-O: ADRP + ADD (PC-relative, position-independent)
            emit_a64(0x90000010)       // ADRP X16, #0
            emit_a64(0x91000200)       // ADD X0, X16, #0
        }
        return
    }

    // FString (50) — legacy ARM64: bake StrPart content into str_buf,
    // evaluate expressions and concatenate into a stack buffer.
    // Returns x0 = pointer to null-terminated result.
    // Note: expression formatting uses a '?' placeholder for non-string types.
    if kind == 50 {
        // Use str_buf to build a compile-time concatenation of all StrParts.
        // For runtime expressions: store literal '?' as placeholder.
        uint64 fs_soff = str_len
        uint32 fs_ch2 = ast_child(node)
        uint64 wfs_ch2 = fs_ch2
        while wfs_ch2 != 0 {
            uint32 fs_ck2 = ast_kind(wfs_ch2)
            if fs_ck2 == 31 {
                uint32 fs_raw2 = ast_data2(wfs_ch2)
                uint64 wfs_raw2 = fs_raw2
                if wfs_raw2 != 0 {
                    // Raw StrPart
                    uint32 fs_tok2 = ast_data1(wfs_ch2)
                    uint64 wfs_tok2 = fs_tok2
                    uint64 fs_tlen2 = tok_text_len(wfs_tok2)
                    uint64 fs_si2 = 0
                    while fs_si2 < fs_tlen2 {
                        uint64 fs_ch3 = tok_source_byte(wfs_tok2, fs_si2)
                        if str_len < 65535 {
                            uint64 fs_sp2 = str_buf + str_len
                            uint8 fs_cb2 = fs_ch3
                            unsafe { *(fs_sp2 as uint8) = fs_cb2 }
                            str_len = str_len + 1
                        }
                        fs_si2 = fs_si2 + 1
                    }
                } else {
                    // StrLit — copy content (skip quotes)
                    uint32 fs_tok3 = ast_data1(wfs_ch2)
                    uint64 wfs_tok3 = fs_tok3
                    uint64 fs_tlen3 = tok_text_len(wfs_tok3)
                    uint64 fs_si3 = 1
                    while fs_si3 < fs_tlen3 - 1 {
                        uint64 fs_ch4 = tok_source_byte(wfs_tok3, fs_si3)
                        if str_len < 65535 {
                            uint64 fs_sp3 = str_buf + str_len
                            uint8 fs_cb3 = fs_ch4
                            unsafe { *(fs_sp3 as uint8) = fs_cb3 }
                            str_len = str_len + 1
                        }
                        fs_si3 = fs_si3 + 1
                    }
                }
            } else {
                // Runtime expr: insert '?' placeholder
                if str_len < 65535 {
                    uint64 fs_qp = str_buf + str_len
                    uint8 fs_q = 63  // '?'
                    unsafe { *(fs_qp as uint8) = fs_q }
                    str_len = str_len + 1
                }
            }
            uint32 fs_nxt2 = ast_next(wfs_ch2)
            wfs_ch2 = fs_nxt2
        }
        // Null-terminate
        uint64 fs_nterm = str_buf + str_len
        uint8 fs_ntz = 0
        unsafe { *(fs_nterm as uint8) = fs_ntz }
        str_len = str_len + 1
        // Emit ADRP + ADD to load string address
        if str_fixup_count >= 4096 {
            write(2, "error: str_fixups overflow\n", 27)
            exit(1)
        }
        uint64 fs_fea64 = str_fixups + str_fixup_count * 8
        uint32 fs_cpa64 = out_len
        unsafe { *(fs_fea64 as uint32) = fs_cpa64 }
        uint64 fs_fe4a64 = fs_fea64 + 4
        uint32 fs_soa64 = fs_soff
        unsafe { *(fs_fe4a64 as uint32) = fs_soa64 }
        str_fixup_count = str_fixup_count + 1
        emit_a64(0x90000010)  // ADRP X16, #0
        emit_a64(0x91000200)  // ADD X0, X16, #0
        return
    }

    // Field access (enum value or struct field)
    if kind == 36 {
        uint32 child_idx = ast_child(node)
        uint64 wchild = child_idx
        uint32 field_tok = ast_data2(node)
        // Struct array element field read: arr[i].field
        if wchild != 0 {
            uint32 afak = ast_kind(wchild)
            uint64 wafak = afak
            if wafak == 37 {
                uint32 ai_tok = ast_data1(wchild)
                uint64 wait2 = ai_tok
                uint64 sia = struct_var_lookup(ai_tok)
                if sia != 0xFFFFFFFF {
                    uint64 stride = struct_total_size(sia)
                    uint64 foff_i = struct_field_offset(sia, field_tok)
                    uint64 fsz_i = struct_field_size(sia, field_tok)
                    // Evaluate index into x0
                    uint32 idx_ch = ast_child(wchild)
                    uint64 widx = idx_ch
                    gen_expr_a64(widx)
                    // x0 = index. Multiply by stride (literal): x0 = x0 * stride
                    emit_a64_mov_imm(10, stride)
                    // MUL X0, X0, X10 — 0x9B0A7C00 (umadd/mul) — use simple MADD Rm=10 Ra=31
                    // ARM MUL Xd, Xn, Xm encoding: 0x9B007C00 | (Xm<<16) | (Xn<<5) | Xd
                    uint64 mulinsn = 0x9B007C00 | (10 << 16) | (0 << 5) | 0
                    emit_a64(mulinsn)
                    emit_a64_mov(11, 0)
                    // Load base address
                    uint64 aoff = var_lookup(wait2)
                    if aoff != 0xFFFFFFFF {
                        emit_a64_load_x0(aoff)
                    }
                    // x0 = base + x11
                    emit_a64_add(0, 0, 11)
                    if foff_i != 0 {
                        emit_a64_add_imm(0, 0, foff_i)
                    }
                    if fsz_i == 1 {
                        emit_a64_ldrb(0, 0, 0)
                    } else if fsz_i == 2 {
                        emit_a64_ldrh(0, 0, 0)
                    } else if fsz_i == 4 {
                        emit_a64_ldr32(0, 0, 0)
                    } else {
                        emit_a64_ldr(0, 0, 0)
                    }
                    return
                }
            }
        }
        // Nested struct field read: child is another FieldAccess
        if wchild != 0 {
            uint32 cfk2_a = ast_kind(wchild)
            uint64 wcfk2_a = cfk2_a
            if wcfk2_a == 36 {
                gen_expr_a64(wchild)
                uint64 nsi_a = expr_is_struct_a64
                if nsi_a != 0xFFFFFFFF {
                    uint64 nfoff_a = struct_field_offset(nsi_a, field_tok)
                    uint64 nfsz_a = struct_field_size(nsi_a, field_tok)
                    if nfoff_a != 0 {
                        emit_a64_add_imm(0, 0, nfoff_a)
                    }
                    uint64 nftk_a = struct_field_type_kind_by_tok(nsi_a, field_tok)
                    if nftk_a >= 256 {
                        expr_is_struct_a64 = nftk_a - 256
                        return
                    }
                    expr_is_struct_a64 = 0xFFFFFFFF
                    if nftk_a == 96 {
                        emit_a64_load_dN_from_ptr(0, 0, 0)
                        expr_is_float_a64 = 1
                        return
                    }
                    if nftk_a == 95 {
                        emit_a64_load_sN_from_ptr(0, 0, 0)
                        expr_is_float_a64 = 2
                        return
                    }
                    if nfsz_a == 1 {
                        emit_a64_ldrb(0, 0, 0)
                    } else if nfsz_a == 2 {
                        emit_a64_ldrh(0, 0, 0)
                    } else if nfsz_a == 4 {
                        emit_a64_ldr32(0, 0, 0)
                    } else {
                        emit_a64_ldr(0, 0, 0)
                    }
                    return
                }
            }
        }
        // Extract object token from child Ident node
        uint32 obj_tok = 0
        if wchild != 0 {
            uint32 child_kind = ast_kind(wchild)
            uint64 wck = child_kind
            if wck == 32 {
                obj_tok = ast_data1(wchild)
            }
        }
        // Slice length access: slice_var.len
        if obj_tok != 0 {
            uint64 wot_sla = obj_tok
            uint64 ptr_off_sla = var_lookup(wot_sla)
            if ptr_off_sla != 0xFFFFFFFF {
                uint64 len_off_sla = slice_len_lookup(ptr_off_sla)
                if len_off_sla != 0xFFFFFFFF {
                    uint64 wft_sla = field_tok
                    if tok_matches(wft_sla, "len", 3) != 0 {
                        emit_a64_load_x0(len_off_sla)
                        return
                    }
                }
            }
        }
        // Device field read: UART0.Data → vloadN
        if obj_tok != 0 {
            uint64 wdta = obj_tok
            uint64 dev_idx_a = device_lookup(wdta)
            if dev_idx_a != 0xFFFFFFFF {
                uint64 wftd_a = field_tok
                uint64 dev_off_a = device_field_offset_of(dev_idx_a, wftd_a)
                if dev_off_a != 0xFFFFFFFF {
                    uint64 dev_sz_a = device_field_size_of(dev_idx_a, wftd_a)
                    uint64 dev_addr_a = device_base(dev_idx_a) + dev_off_a
                    // x0 = absolute address
                    emit_a64_mov_imm(0, dev_addr_a)
                    if dev_sz_a == 1 {
                        emit_a64_ldrb(0, 0, 0)
                    } else if dev_sz_a == 2 {
                        emit_a64_ldrh(0, 0, 0)
                    } else if dev_sz_a == 4 {
                        emit_a64_ldr32(0, 0, 0)
                    } else {
                        emit_a64_ldr(0, 0, 0)
                    }
                    // DSB SY
                    emit_a64(0xD5033F9F)
                    return
                }
            }
        }
        uint64 si = struct_var_lookup(obj_tok)
        if si != 0xFFFFFFFF {
            uint64 var_off = var_lookup(obj_tok)
            if var_off == 0xFFFFFFFF { var_off = 0 }
            uint64 foff = struct_field_offset(si, field_tok)
            uint64 fsz = struct_field_size(si, field_tok)
            emit_a64_load_x0(var_off)
            if foff != 0 {
                emit_a64_add_imm(0, 0, foff)
            }
            // Check if field is a float type or nested struct
            uint64 fftk_a = struct_field_type_kind_by_tok(si, field_tok)
            if fftk_a >= 256 {
                expr_is_struct_a64 = fftk_a - 256
                return
            }
            if fftk_a == 96 {
                // f64 field: ldr d0, [x0, #0]
                emit_a64_load_dN_from_ptr(0, 0, 0)
                expr_is_float_a64 = 1
                return
            }
            if fftk_a == 95 {
                // f32 field: ldr s0, [x0, #0]
                emit_a64_load_sN_from_ptr(0, 0, 0)
                expr_is_float_a64 = 2
                return
            }
            if fsz == 1 {
                emit_a64_ldrb(0, 0, 0)
            } else if fsz == 2 {
                emit_a64_ldrh(0, 0, 0)
            } else if fsz == 4 {
                emit_a64_ldr32(0, 0, 0)
            } else {
                emit_a64_ldr(0, 0, 0)
            }
            return
        }
        uint64 val = enum_lookup(obj_tok, field_tok)
        emit_a64_mov_imm(0, val)
        return
    }

    // Identifier
    if kind == 32 {
        uint32 tok = ast_data1(node)
        uint64 wait_tok = tok
        uint64 offset = var_lookup(tok)
        if offset != 0xFFFFFFFF {
            // Check if this variable is float-typed
            uint64 vtype_a = var_type_lookup(tok)
            if is_float_type(vtype_a) != 0 {
                if is_f32_type(vtype_a) != 0 {
                    emit_a64_load_s0(offset)
                    expr_is_float_a64 = 2
                } else {
                    emit_a64_load_d0(offset)
                    expr_is_float_a64 = 1
                }
                return
            }
            emit_a64_load_x0(offset)
            expr_is_float_a64 = 0
            // Track if this is a struct variable
            uint64 svi_a = struct_var_lookup(wait_tok)
            if svi_a != 0xFFFFFFFF {
                expr_is_struct_a64 = svi_a
            }
        } else {
            uint64 soff = static_lookup(tok)
            if soff != 0xFFFFFFFF {
                uint64 sas_ia = static_array_size_of(wait_tok)
                if sas_ia != 0xFFFFFFFF && sas_ia != 0 {
                    emit_a64_static_lea(soff)
                } else {
                    emit_a64_static_load(soff)
                }
            } else {
                uint64 id_len = tok_text_len(tok)
                if id_len != 0 {
                    write(2, "error: use of undeclared identifier '", 37)
                    write(2, cg_source + tok_text_start(tok), id_len)
                    write(2, "'\n", 2)
                    exit(1)
                }
            }
        }
        return
    }

    // Array indexing: scale index by elem_size, load elem_size bytes.
    if kind == 37 {
        uint32 arr_tok = ast_data1(node)
        uint64 warrta = arr_tok
        uint64 arr_offset = var_lookup(arr_tok)
        uint64 elem_sz_r = arr_elem_lookup(arr_tok)
        uint32 idx_child = ast_child(node)
        uint64 wi = idx_child
        gen_expr_a64(wi)
        emit_a64_mov(10, 0)
        if arr_offset != 0xFFFFFFFF {
            emit_a64_load_x0(arr_offset)
        } else {
            uint64 sasa = static_array_size_of(warrta)
            if sasa != 0xFFFFFFFF && sasa != 0 {
                uint64 soffa = static_lookup(warrta)
                emit_a64_static_lea(soffa)
            } else {
                arr_offset = 0
                emit_a64_load_x0(arr_offset)
            }
        }
        // x0 = base, x10 = index. Compute x0 = base + (index << log2(elem_sz)).
        uint64 shift_r = 0
        if elem_sz_r == 2 { shift_r = 1 }
        if elem_sz_r == 4 { shift_r = 2 }
        if elem_sz_r == 8 { shift_r = 3 }
        emit_a64_add_lsl(0, 0, 10, shift_r)
        if elem_sz_r == 1 {
            emit_a64_ldrb(0, 0, 0)
        } else if elem_sz_r == 2 {
            emit_a64_ldrh(0, 0, 0)
        } else if elem_sz_r == 4 {
            emit_a64_ldr32(0, 0, 0)
        } else {
            emit_a64_ldr(0, 0, 0)
        }
        return
    }

    // Binary operation
    if kind == 33 {
        // Constant folding for ARM64
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_cf = ast_data2(node)
        uint64 wrhs_cf = rhs_cf
        uint32 lk = ast_kind(wlhs)
        uint32 rk = ast_kind(wrhs_cf)
        if lk == 30 && rk == 30 {
            uint32 lt = ast_data1(wlhs)
            uint32 rt = ast_data1(wrhs_cf)
            uint64 lv = parse_int_token(lt)
            uint64 rv = parse_int_token(rt)
            uint32 opc = ast_data1(node)
            uint64 pf = cg_tokens + opc * 16
            uint32 ok = 0
            unsafe { *(pf as uint32) -> ok }
            uint64 res = 0
            if ok == 30 { res = lv + rv }
            else if ok == 31 { res = lv - rv }
            else if ok == 22 { res = lv * rv }
            else if ok == 32 { if rv != 0 { res = lv / rv } }
            else if ok == 33 { if rv != 0 { res = lv - lv / rv * rv } }
            else if ok == 23 { res = lv & rv }
            else if ok == 24 { res = lv | rv }
            else if ok == 25 { res = lv ^ rv }
            else if ok == 43 { res = lv << rv }
            else if ok == 44 { res = lv >> rv }
            emit_a64_mov_imm(0, res)
            return
        }

        gen_expr_a64(wlhs)
        uint64 lhs_is_float_b = expr_is_float_a64
        // Save lhs to temp slot
        uint64 binop_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 brem = var_frame_size & 15
        if brem != 0 { var_frame_size = var_frame_size + 16 - brem }

        if lhs_is_float_b != 0 {
            // Float LHS: store d0/s0 to temp, eval RHS, then float op
            if lhs_is_float_b == 2 {
                emit_a64_store_s0(binop_temp)
            } else {
                emit_a64_store_d0(binop_temp)
            }
            uint32 rhs_idx = ast_data2(node)
            uint64 wrhs = rhs_idx
            gen_expr_a64(wrhs)
            // RHS in d0/s0 → move to d1/s1
            if lhs_is_float_b == 2 {
                emit_a64(0x1E204001) // fmov s1, s0
            } else {
                emit_a64(0x1E604001) // fmov d1, d0
            }
            // Reload LHS into d0/s0
            if lhs_is_float_b == 2 {
                emit_a64_load_s0(binop_temp)
            } else {
                emit_a64_load_d0(binop_temp)
            }
            // d0 = LHS, d1 = RHS (or s0/s1 for f32)
            uint32 op_tok_fb = ast_data1(node)
            uint64 wop_fb = op_tok_fb
            uint64 pfb = cg_tokens + wop_fb * 16
            uint32 op_kind_fb = 0
            unsafe { *(pfb as uint32) -> op_kind_fb }
            if lhs_is_float_b == 2 {
                if op_kind_fb == 30 { emit_a64(0x1E212800) } // fadd s0, s0, s1
                if op_kind_fb == 31 { emit_a64(0x1E213800) } // fsub s0, s0, s1
                if op_kind_fb == 22 { emit_a64(0x1E210800) } // fmul s0, s0, s1
                if op_kind_fb == 32 { emit_a64(0x1E211800) } // fdiv s0, s0, s1
            } else {
                if op_kind_fb == 30 { emit_a64(0x1E612800) } // fadd d0, d0, d1
                if op_kind_fb == 31 { emit_a64(0x1E613800) } // fsub d0, d0, d1
                if op_kind_fb == 22 { emit_a64(0x1E610800) } // fmul d0, d0, d1
                if op_kind_fb == 32 { emit_a64(0x1E611800) } // fdiv d0, d0, d1
            }
            expr_is_float_a64 = lhs_is_float_b
            return
        }

        emit_a64_store_x0(binop_temp)

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr_a64(wrhs)
        // x0 = rhs. Load lhs into x9
        emit_a64_mov(9, 0)
        emit_a64_load_x0(binop_temp)
        // x0 = lhs, x9 = rhs

        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        if op_kind == 30 || op_kind == 45 {
            if debug_mode != 0 {
                // Overflow check: adds x0, x0, x9 (sets flags) + b.vc skip (no signed overflow)
                uint64 insn_adds = 0xAB000000 | (9 << 16) | (0 << 5) | 0
                emit_a64(insn_adds)
                uint64 bvc_add = out_len
                emit_a64(0x54000007)  // b.vc +0 (placeholder, cond=7=VC)
                emit_a64_mov_imm(0, 1)
                if target_os == 2 { emit_a64_win_call_iat(0) }
                else { if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }; emit_a64_svc() }
                uint64 bvc_add_off = (out_len - bvc_add) / 4
                patch_u32(bvc_add, 0x54000007 | ((bvc_add_off & 0x7FFFF) << 5))
            } else {
                emit_a64_add(0, 0, 9)
            }
        }
        else if op_kind == 31 || op_kind == 46 {
            if debug_mode != 0 {
                // Overflow check: subs x0, x0, x9 (sets flags) + b.vc skip (no signed overflow)
                uint64 insn_subs = 0xEB000000 | (9 << 16) | (0 << 5) | 0
                emit_a64(insn_subs)
                uint64 bvc_sub = out_len
                emit_a64(0x54000007)  // b.vc +0 (placeholder, cond=7=VC)
                emit_a64_mov_imm(0, 1)
                if target_os == 2 { emit_a64_win_call_iat(0) }
                else { if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }; emit_a64_svc() }
                uint64 bvc_sub_off = (out_len - bvc_sub) / 4
                patch_u32(bvc_sub, 0x54000007 | ((bvc_sub_off & 0x7FFFF) << 5))
            } else {
                emit_a64_sub(0, 0, 9)
            }
        }
        else if op_kind == 22 || op_kind == 47 {
            if debug_mode != 0 {
                // Overflow check: umulh x10, x0, x9 then mul x0, x0, x9
                // UMULH X10, X0, X9: 0x9BC00000 | (Rm<<16) | (Ra=0x1F<<10) | (Rn<<5) | Rd
                uint64 insn_umulh = 0x9BC07C00 | (9 << 16) | (0 << 5) | 10
                emit_a64(insn_umulh)
                emit_a64_mul(0, 0, 9)
                // CBZ X10, skip — if high bits zero, no overflow
                uint64 cbz_mul = out_len
                emit_a64(0xB4000000 | 10)  // cbz x10, +0 (placeholder)
                emit_a64_mov_imm(0, 1)
                if target_os == 2 { emit_a64_win_call_iat(0) }
                else { if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }; emit_a64_svc() }
                uint64 cbz_mul_off = (out_len - cbz_mul) / 4
                patch_u32(cbz_mul, 0xB4000000 | ((cbz_mul_off & 0x7FFFF) << 5) | 10)
            } else {
                emit_a64_mul(0, 0, 9)
            }
        }
        else if op_kind == 32 {
            if debug_mode != 0 {
                // Division by zero check: cbnz x9, skip; exit(1)
                uint64 cbnz_div = out_len
                emit_a64(0xB5000000 | 9)  // cbnz x9, +0 (placeholder)
                emit_a64_mov_imm(0, 1)
                if target_os == 2 { emit_a64_win_call_iat(0) }
                else { if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }; emit_a64_svc() }
                uint64 cbnz_div_off = (out_len - cbnz_div) / 4
                patch_u32(cbnz_div, 0xB5000000 | ((cbnz_div_off & 0x7FFFF) << 5) | 9)
            }
            emit_a64_udiv(0, 0, 9)
        }
        else if op_kind == 33 {
            // modulo: x0 = x0 - (x0/x9)*x9
            if debug_mode != 0 {
                // Division by zero check: cbnz x9, skip; exit(1)
                uint64 cbnz_mod = out_len
                emit_a64(0xB5000000 | 9)  // cbnz x9, +0 (placeholder)
                emit_a64_mov_imm(0, 1)
                if target_os == 2 { emit_a64_win_call_iat(0) }
                else { if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }; emit_a64_svc() }
                uint64 cbnz_mod_off = (out_len - cbnz_mod) / 4
                patch_u32(cbnz_mod, 0xB5000000 | ((cbnz_mod_off & 0x7FFFF) << 5) | 9)
            }
            emit_a64_udiv(10, 0, 9)
            emit_a64_msub(0, 10, 9, 0)
        }
        else if op_kind == 23 || op_kind == 50 { emit_a64_and(0, 0, 9) }
        else if op_kind == 24 || op_kind == 51 { emit_a64_orr(0, 0, 9) }
        else if op_kind == 25 || op_kind == 52 { emit_a64_eor(0, 0, 9) }
        else if op_kind == 43 { emit_a64_lsl(0, 0, 9) }
        else if op_kind == 44 { emit_a64_lsr(0, 0, 9) }
        return
    }

    // Comparison
    if kind == 38 {
        // Constant comparison folding for ARM64
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_cc = ast_data2(node)
        uint64 wrhs_cc = rhs_cc
        uint32 lkc = ast_kind(wlhs)
        uint32 rkc = ast_kind(wrhs_cc)
        if lkc == 30 && rkc == 30 {
            uint32 ltc = ast_data1(wlhs)
            uint32 rtc = ast_data1(wrhs_cc)
            uint64 lvc = parse_int_token(ltc)
            uint64 rvc = parse_int_token(rtc)
            uint32 occ = ast_data1(node)
            uint64 pcc = cg_tokens + occ * 16
            uint32 okc = 0
            unsafe { *(pcc as uint32) -> okc }
            uint64 res = 0
            if okc == 35 { if lvc == rvc { res = 1 } }
            else if okc == 36 { if lvc != rvc { res = 1 } }
            else if okc == 37 { if lvc < rvc { res = 1 } }
            else if okc == 38 { if lvc <= rvc { res = 1 } }
            else if okc == 39 { if lvc > rvc { res = 1 } }
            else if okc == 40 { if lvc >= rvc { res = 1 } }
            emit_a64_mov_imm(0, res)
            return
        }

        // Struct comparison: == and != on struct values
        uint32 rhs_idx_pre_a = ast_data2(node)
        uint64 wrhs_pre_a = rhs_idx_pre_a
        uint32 lhs_k_pre_a = ast_kind(wlhs)
        uint32 rhs_k_pre_a = ast_kind(wrhs_pre_a)
        uint64 lhs_si_pre_a = 0xFFFFFFFF
        uint64 rhs_si_pre_a = 0xFFFFFFFF
        if lhs_k_pre_a == 32 {
            uint32 lt_pre_a = ast_data1(wlhs)
            uint64 wlt_pre_a = lt_pre_a
            lhs_si_pre_a = struct_var_lookup(wlt_pre_a)
        }
        if lhs_si_pre_a != 0xFFFFFFFF && rhs_k_pre_a == 32 {
            uint32 rt_pre_a = ast_data1(wrhs_pre_a)
            uint64 wrt_pre_a = rt_pre_a
            rhs_si_pre_a = struct_var_lookup(wrt_pre_a)
        }
        if lhs_si_pre_a != 0xFFFFFFFF && rhs_si_pre_a != 0xFFFFFFFF {
            // Both operands are struct variables — emit qword-by-qword comparison
            gen_expr_a64(wlhs)
            uint64 sc_lhs_a = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 scr1a = var_frame_size & 15
            if scr1a != 0 { var_frame_size = var_frame_size + 16 - scr1a }
            emit_a64_store_x0(sc_lhs_a)

            gen_expr_a64(wrhs_pre_a)
            uint64 sc_rhs_a = var_count * 8
            var_count = var_count + 1
            uint64 sc_acc_a = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 scr2a = var_frame_size & 15
            if scr2a != 0 { var_frame_size = var_frame_size + 16 - scr2a }
            emit_a64_store_x0(sc_rhs_a)

            uint64 sc_sz_a = struct_total_size(lhs_si_pre_a)
            uint64 sc_sl_a = (sc_sz_a + 7) / 8

            // Start with result = 1 (assume equal)
            emit_a64_mov_imm(0, 1)
            emit_a64_store_x0(sc_acc_a)

            uint64 qi_a = 0
            while qi_a < sc_sl_a {
                uint64 qoff_a = qi_a * 8
                // Load lhs qword: ldr x0, [x0, #qoff_a] (x0 = lhs ptr from stack)
                emit_a64_load_x0(sc_lhs_a)
                emit_a64_ldr(0, 0, qoff_a)
                // mov x9, x0 (save lhs qword)
                emit_a64_mov(9, 0)
                // Load rhs qword
                emit_a64_load_x0(sc_rhs_a)
                emit_a64_ldr(0, 0, qoff_a)
                // cmp x9, x0
                emit_a64_cmp(9, 0)
                // cset x0, eq (1 if equal, 0 if not)
                emit_a64_cset(0, 0)
                // AND with accumulated result: load acc into x9, and x0, x0, x9
                emit_a64_mov(10, 0)
                emit_a64_load_x0(sc_acc_a)
                emit_a64_and(0, 0, 10)
                emit_a64_store_x0(sc_acc_a)

                qi_a = qi_a + 1
            }

            emit_a64_load_x0(sc_acc_a)

            // Check operator: == (35) or != (36)
            uint32 op_tok_sca = ast_data1(node)
            uint64 wop_sca = op_tok_sca
            uint64 p_sca = cg_tokens + wop_sca * 16
            uint32 op_kind_sca = 0
            unsafe { *(p_sca as uint32) -> op_kind_sca }
            if op_kind_sca == 36 {
                // != : invert (eor x0, x0, x9 where x9=1)
                emit_a64_mov_imm(9, 1)
                emit_a64_eor(0, 0, 9)
            }

            expr_is_float_a64 = 0
            expr_is_struct_a64 = 0xFFFFFFFF
            return
        }

        gen_expr_a64(wlhs)
        uint64 lhs_is_float_c = expr_is_float_a64
        uint64 cmp_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 crem = var_frame_size & 15
        if crem != 0 { var_frame_size = var_frame_size + 16 - crem }

        if lhs_is_float_c != 0 {
            // Float compare: store d0/s0 temp, eval RHS, fcmp, cset
            if lhs_is_float_c == 2 {
                emit_a64_store_s0(cmp_temp)
            } else {
                emit_a64_store_d0(cmp_temp)
            }
            uint32 rhs_idx = ast_data2(node)
            uint64 wrhs = rhs_idx
            gen_expr_a64(wrhs)
            // RHS in d0/s0 → move to d1/s1
            if lhs_is_float_c == 2 {
                emit_a64(0x1E204001) // fmov s1, s0
                emit_a64_load_s0(cmp_temp)
                emit_a64(0x1E212000) // fcmp s0, s1
            } else {
                emit_a64(0x1E604001) // fmov d1, d0
                emit_a64_load_d0(cmp_temp)
                emit_a64(0x1E612000) // fcmp d0, d1
            }
            // fcmp sets NZCV. Use same condition codes as integer unsigned:
            // For float, after fcmp: EQ→eq, NE→ne, LT→mi(4), LE→ls(9), GT→gt(12), GE→ge(10)
            // Actually, ARM64 fcmp: LT→MI(4), GT→GT(0xC), LE→LS(9), GE→GE(0xA)
            uint32 op_tok_fc = ast_data1(node)
            uint64 wop_fc = op_tok_fc
            uint64 pfc = cg_tokens + wop_fc * 16
            uint32 op_kind_fc = 0
            unsafe { *(pfc as uint32) -> op_kind_fc }
            if op_kind_fc == 35 { emit_a64_cset(0, 0) }       // == → eq
            else if op_kind_fc == 36 { emit_a64_cset(0, 1) }   // != → ne
            else if op_kind_fc == 37 { emit_a64_cset(0, 0xB) } // < → lt (signed, works for float NZCV)
            else if op_kind_fc == 38 { emit_a64_cset(0, 0xD) } // <= → le
            else if op_kind_fc == 39 { emit_a64_cset(0, 0xC) } // > → gt
            else if op_kind_fc == 40 { emit_a64_cset(0, 0xA) } // >= → ge
            expr_is_float_a64 = 0
            return
        }

        emit_a64_store_x0(cmp_temp)

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr_a64(wrhs)
        emit_a64_mov(9, 0)
        emit_a64_load_x0(cmp_temp)
        emit_a64_cmp(0, 9)

        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        // Map comparison op to AArch64 condition code
        // EQ=0, NE=1, LT=11, LE=13, GT=12, GE=10
        if op_kind == 35 { emit_a64_cset(0, 0) }       // == → eq
        else if op_kind == 36 { emit_a64_cset(0, 1) }   // != → ne
        else if op_kind == 37 { emit_a64_cset(0, 3) }  // < → lo (unsigned below)
        else if op_kind == 38 { emit_a64_cset(0, 9) }  // <= → ls (unsigned below or equal)
        else if op_kind == 39 { emit_a64_cset(0, 8) }  // > → hi (unsigned above)
        else if op_kind == 40 { emit_a64_cset(0, 2) }  // >= → hs (unsigned above or equal)
        return
    }

    // LogicalAnd
    if kind == 39 {
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        gen_expr_a64(wlhs)
        uint64 and_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 arem = var_frame_size & 15
        if arem != 0 { var_frame_size = var_frame_size + 16 - arem }
        emit_a64_store_x0(and_temp)
        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr_a64(wrhs)
        // x0 = rhs. Check both non-zero
        emit_a64_cmp(0, 31)
        emit_a64_cset(9, 1)
        emit_a64_load_x0(and_temp)
        emit_a64_cmp(0, 31)
        emit_a64_cset(0, 1)
        emit_a64_and(0, 0, 9)
        return
    }

    // LogicalOr
    if kind == 40 {
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        gen_expr_a64(wlhs)
        uint64 or_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 orem = var_frame_size & 15
        if orem != 0 { var_frame_size = var_frame_size + 16 - orem }
        emit_a64_store_x0(or_temp)
        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr_a64(wrhs)
        emit_a64_mov(9, 0)
        emit_a64_load_x0(or_temp)
        emit_a64_orr(0, 0, 9)
        emit_a64_cmp(0, 31)
        emit_a64_cset(0, 1)
        return
    }

    // Function call
    if kind == 35 {
        uint32 callee_tok = ast_data1(node)
        uint64 wct = callee_tok

        // User-declared extern fn shadows builtins.
        uint64 wct_pre_a = callee_tok
        uint64 ext_pre_a = extern_fn_lookup(wct_pre_a)
        uint64 is_extern_call = 0
        if ext_pre_a != 0xFFFFFFFF { is_extern_call = 1 }

        // Built-in: exit(code)
        if is_extern_call == 0 && tok_matches(wct, "exit", 4) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr_a64(wfa)
            if target_os == 2 {
                // Windows ARM64: ExitProcess(code)
                // x0 = exit code (already in place)
                emit_a64_win_call_iat(0)
            } else {
                // x0 already has exit code
                if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }
                emit_a64_svc()
            }
            return
        }

        // Built-in: write(fd, buf, len)
        if is_extern_call == 0 && tok_matches(wct, "write", 5) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr_a64(wa1)
            emit_a64_store_x0(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr_a64(wa2)
            emit_a64_store_x0(temp_slot_1)
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr_a64(wa3)
            if target_os == 2 {
