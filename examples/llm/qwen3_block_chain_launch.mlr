// Qwen3 MLP-block forward chain at production shape (#30 cont.).
//
// Demonstrates that the shape-parametric Phase 2 kernels chain end-to-
// end at Qwen3-1.5B hidden_dim (1536) — a non-power-of-two N that the
// thread-coarsened large-N path has to cover.  Three kernels chained
// through five device-resident buffers with no host roundtrips:
//
//   norm   = rmsnorm_f32(input, gamma)            // [M, 1536]
//   act    = silu_mul_f32(gate, up)               // [M*1536] flat
//   output = residual_add_f32(norm, act)          // [M*1536] flat
//
// Approximates the elementwise leg of the Qwen3 transformer MLP block
// (the matmul projections gate = norm @ W_gate and up = norm @ W_up
// and down = act @ W_down are skipped — gate / up are precomputed by
// the host).
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-rmsnorm-f32-N=1536:/tmp/rmsnorm_n1536.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/silu_mul_f32.mlr        -o /tmp/silu_mul_f32
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/residual_add_f32.mlr    -o /tmp/residual_add_f32
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/qwen3_block_chain_launch.mlr -o /tmp/qwen3_block_chain_kfd
// Run:
//   M=4 /tmp/qwen3_block_chain_kfd

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 { i = i - 1; uint64 d = tmp - (tmp / 10) * 10; uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }; tmp = tmp / 10 }
    return n
}
fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len { uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }; uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }; i = i + 1 }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}
fn die(uint64 msg, uint64 code) { puts(msg); print_label_val("e", 1, code); exit(1) }
fn parse_env_count(uint64 name) -> uint64 {
    uint64 s = getenv(name); if s == 0 { return 0 }
    uint64 v = 0; uint64 i = 0
    while 1 == 1 { uint64 cp = s + i; uint64 c = 0; unsafe { *(cp as uint8) -> c }; if c == 0 { break }; if c >= 48 && c <= 57 { v = v * 10 + (c - 48); i = i + 1; continue }; break }
    return v
}
fn host_exp_f64(f64 x) -> f64 {
    f64 LN2 = 0.6931471805599453
    f64 INV_LN2 = 1.4426950408889634
    f64 kf = x * INV_LN2
    if kf < 0.0 { kf = kf - 0.5 } else { kf = kf + 0.5 }
    int64 k = f64_to_int(kf)
    f64 kd = int_to_f64(k)
    f64 r = x - kd * LN2
    f64 r2 = r * r; f64 r3 = r2 * r; f64 r4 = r2 * r2
    f64 r5 = r4 * r; f64 r6 = r4 * r2; f64 r7 = r6 * r
    f64 e_r = 1.0 + r + r2 * 0.5 + r3 * 0.16666666666666666
                  + r4 * 0.041666666666666664 + r5 * 0.008333333333333333
                  + r6 * 0.001388888888888889 + r7 * 0.0001984126984126984
    f64 two_k = 1.0
    if k >= 0 { int64 i = 0; while i < k { two_k = two_k * 2.0; i = i + 1 } }
    else { int64 i = 0; int64 nk = 0 - k; while i < nk { two_k = two_k * 0.5; i = i + 1 } }
    return two_k * e_r
}
fn load_kernel(uint64 co_path, uint64 fname) -> uint64 {
    uint64 fd = file_open(co_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("missing co"); puts(co_path); exit(1) }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    uint32 err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, fname)
    if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }
    return fh
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    uint64 M = 4
    uint64 me = parse_env_count("M"); if me != 0 { M = me }
    uint64 N = 1536        // Qwen3-1.5B hidden_dim (non-pow2)
    uint64 N_total = M * N

    uint64 fh_rmsnorm = load_kernel("/tmp/rmsnorm_n1536.co",     "rmsnorm_f32")
    uint64 fh_silumul = load_kernel("/tmp/silu_mul_f32.co",      "silu_mul_f32")
    uint64 fh_residadd = load_kernel("/tmp/residual_add_f32.co", "residual_add_f32")

    uint64 row_bytes = N * 4
    uint64 flat_bytes = N_total * 4

    uint64 d_input = 0; uint64 d_gamma = 0; uint64 d_gate = 0; uint64 d_up = 0
    uint64 d_norm = 0; uint64 d_act = 0; uint64 d_output = 0
    uint64 slot
    slot = alloc(8); err = hipMalloc(slot, flat_bytes); if err != 0 { die("mIn",   err) }; unsafe { *(slot as uint64) -> d_input }
    slot = alloc(8); err = hipMalloc(slot, row_bytes);  if err != 0 { die("mGam",  err) }; unsafe { *(slot as uint64) -> d_gamma }
    slot = alloc(8); err = hipMalloc(slot, flat_bytes); if err != 0 { die("mG",    err) }; unsafe { *(slot as uint64) -> d_gate }
    slot = alloc(8); err = hipMalloc(slot, flat_bytes); if err != 0 { die("mU",    err) }; unsafe { *(slot as uint64) -> d_up }
    slot = alloc(8); err = hipMalloc(slot, flat_bytes); if err != 0 { die("mNorm", err) }; unsafe { *(slot as uint64) -> d_norm }
    slot = alloc(8); err = hipMalloc(slot, flat_bytes); if err != 0 { die("mAct",  err) }; unsafe { *(slot as uint64) -> d_act }
    slot = alloc(8); err = hipMalloc(slot, flat_bytes); if err != 0 { die("mOut",  err) }; unsafe { *(slot as uint64) -> d_output }

    // Initialise host buffers.
    uint64 h_input = alloc(flat_bytes)
    uint64 h_gamma = alloc(row_bytes)
    uint64 h_gate  = alloc(flat_bytes)
    uint64 h_up    = alloc(flat_bytes)
    uint64 r = 0
    while r < M {
        uint64 c = 0
        while c < N {
            f64 frac = int_to_f64(c) / int_to_f64(N - 1)
            f64 ix = int_to_f64(r + 1) * 0.1 + (frac - 0.5) * 0.4
            f64 gv = frac * 16.0 - 8.0
            f64 uv = 0.5 + frac
            uint64 p = h_input + (r * N + c) * 4; unsafe { *(p as f32) = f64_to_f32(ix) }
            uint64 pg = h_gate + (r * N + c) * 4; unsafe { *(pg as f32) = f64_to_f32(gv) }
            uint64 pu = h_up   + (r * N + c) * 4; unsafe { *(pu as f32) = f64_to_f32(uv) }
            c = c + 1
        }
        r = r + 1
    }
    uint64 c2 = 0
    while c2 < N {
        f64 g = 0.5 + int_to_f64(c2) / int_to_f64(N)
        uint64 p = h_gamma + c2 * 4; unsafe { *(p as f32) = f64_to_f32(g) }
        c2 = c2 + 1
    }
    err = hipMemcpy(d_input, h_input, flat_bytes, 1); if err != 0 { die("H2D in", err) }
    err = hipMemcpy(d_gamma, h_gamma, row_bytes,  1); if err != 0 { die("H2D ga", err) }
    err = hipMemcpy(d_gate,  h_gate,  flat_bytes, 1); if err != 0 { die("H2D ga2", err) }
    err = hipMemcpy(d_up,    h_up,    flat_bytes, 1); if err != 0 { die("H2D up", err) }

    // Stage 1: rmsnorm(input, gamma) → d_norm
    uint64 k_in    = alloc(8); unsafe { *(k_in    as uint64) = d_input }
    uint64 k_no    = alloc(8); unsafe { *(k_no    as uint64) = d_norm }
    uint64 k_gam   = alloc(8); unsafe { *(k_gam   as uint64) = d_gamma }
    uint64 k_m     = alloc(8); unsafe { *(k_m     as uint64) = M }
    uint64 k_n     = alloc(8); unsafe { *(k_n     as uint64) = N }
    uint64 kp1 = alloc(5 * 8)
    unsafe { *(kp1        as uint64) = k_in }
    unsafe { *((kp1 +  8) as uint64) = k_no }
    unsafe { *((kp1 + 16) as uint64) = k_gam }
    unsafe { *((kp1 + 24) as uint64) = k_m }
    unsafe { *((kp1 + 32) as uint64) = k_n }
    // N=1536 large-N path: block = 1024 (clamped from round_up_pow2(1536) = 2048).
    err = hipModuleLaunchKernel(fh_rmsnorm, M, 1, 1, 1024, 1, 1, 0, 0, kp1, 0)
    if err != 0 { die("launch rmsnorm", err) }

    // Stage 2: silu_mul(gate, up) → d_act    (flat shape, N_total)
    uint64 k_g  = alloc(8); unsafe { *(k_g  as uint64) = d_gate }
    uint64 k_u  = alloc(8); unsafe { *(k_u  as uint64) = d_up }
    uint64 k_a  = alloc(8); unsafe { *(k_a  as uint64) = d_act }
    uint64 k_nf = alloc(8); unsafe { *(k_nf as uint64) = N_total }
    uint64 kp2 = alloc(4 * 8)
    unsafe { *(kp2        as uint64) = k_g }
    unsafe { *((kp2 +  8) as uint64) = k_u }
    unsafe { *((kp2 + 16) as uint64) = k_a }
    unsafe { *((kp2 + 24) as uint64) = k_nf }
    uint32 grid_sm = (N_total + 255) / 256
    err = hipModuleLaunchKernel(fh_silumul, grid_sm, 1, 1, 256, 1, 1, 0, 0, kp2, 0)
    if err != 0 { die("launch silu_mul", err) }

    // Stage 3: residual_add(d_norm, d_act) → d_output    (flat shape)
    uint64 k_no2 = alloc(8); unsafe { *(k_no2 as uint64) = d_norm }
    uint64 k_a2  = alloc(8); unsafe { *(k_a2  as uint64) = d_act }
    uint64 k_o   = alloc(8); unsafe { *(k_o   as uint64) = d_output }
    uint64 k_nf2 = alloc(8); unsafe { *(k_nf2 as uint64) = N_total }
    uint64 kp3 = alloc(4 * 8)
    unsafe { *(kp3        as uint64) = k_no2 }
    unsafe { *((kp3 +  8) as uint64) = k_a2 }
    unsafe { *((kp3 + 16) as uint64) = k_o }
    unsafe { *((kp3 + 24) as uint64) = k_nf2 }
    err = hipModuleLaunchKernel(fh_residadd, grid_sm, 1, 1, 256, 1, 1, 0, 0, kp3, 0)
    if err != 0 { die("launch residadd", err) }

    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    uint64 h_output = alloc(flat_bytes)
    err = hipMemcpy(h_output, d_output, flat_bytes, 2); if err != 0 { die("D2H", err) }

    // Verify: chain reference per row.
    uint64 fail = 0
    f32 thresh = 0.001
    f32 floor  = 0.000001
    r = 0
    while r < M {
        // ref_norm = x * rsqrt(mean(x²) + eps) * gamma
        f32 sumsq = 0.0
        uint64 c = 0
        while c < N {
            uint64 p = h_input + (r * N + c) * 4
            f32 x = 0.0; unsafe { *(p as f32) -> x }
            sumsq = sumsq + x * x
            c = c + 1
        }
        f32 inv_n = 1.0 / int_to_f32(N)
        f32 ms = sumsq * inv_n
        f32 eps = 0.00001
        f32 inv_rms = 1.0 / sqrt_f32(ms + eps)

        c = 0
        while c < N {
            uint64 idx = r * N + c
            uint64 ip = h_input + idx * 4; f32 x = 0.0; unsafe { *(ip as f32) -> x }
            uint64 gp = h_gamma + c * 4;   f32 g = 0.0; unsafe { *(gp as f32) -> g }
            f32 ref_norm = x * inv_rms * g

            uint64 gate_p = h_gate + idx * 4; f32 gv = 0.0; unsafe { *(gate_p as f32) -> gv }
            uint64 up_p   = h_up   + idx * 4; f32 uv = 0.0; unsafe { *(up_p   as f32) -> uv }
            f64 gd = f32_to_f64(gv); f64 ud = f32_to_f64(uv)
            f64 e = host_exp_f64(0.0 - gd)
            f64 silu_g = gd / (1.0 + e)
            f32 ref_act = f64_to_f32(silu_g * ud)

            f32 ref_out = ref_norm + ref_act

            uint64 op = h_output + idx * 4; f32 dev = 0.0; unsafe { *(op as f32) -> dev }
            f32 d = ref_out - dev; if d < 0.0 { d = 0.0 - d }
            f32 ar = ref_out; if ar < 0.0 { ar = 0.0 - ar }
            if ar < floor { ar = floor }
            f32 rel = d / ar
            if rel > thresh { fail = fail + 1 }
            c = c + 1
        }
        r = r + 1
    }

    print_label_val("M",                  1, M)
    print_label_val("N",                  1, N)
    print_label_val("kernels_launched",  16, 3)
    print_label_val("cells_failed",      12, fail)

    hipFree(d_input); hipFree(d_gamma); hipFree(d_gate); hipFree(d_up)
    hipFree(d_norm); hipFree(d_act); hipFree(d_output)
    exit(0)
}
