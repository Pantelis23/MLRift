@export
fn emit_amdgpu_layernorm_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_layernorm_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("layernorm_f32", 13,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 14,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1024)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_layernorm_f32_blob: cannot open output\n", 52)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

fn amdgpu_lower_llm_layernorm_f32(uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 args_desc = alloc(8 * 8)
    _emit_layernorm_f32_body(args_desc)
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }
    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 14,
                0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                1024)
    return 0
}

// Shape-parametric layernorm_f32. N must be a power of two in [32, 1024].
// Same kernel structure as _emit_layernorm_f32_body with the LDS
// reductions parameterised by log2(N) and the two `1/N` constants
// computed from N at emit time.  No gamma/beta (output =
// (x - mean) / sqrt(var + eps), eps = 1e-5).
fn _emit_layernorm_f32_body_N(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 Np = _round_up_pow2(N)
    uint64 inv_n_bits = _f32_bits_recip(N)

    // ── Prologue (kernarg + bounds + setup + initial store) ─────────
    asm_u32(0xF40C0100)             // s_load_b256 s[4:11], s[0:1], 0x0
    asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF09080F)             // s_cmp_ge_u32 s15, s8
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)             // s_cbranch_scc1 → .Lend (patched)
    asm_u32(0x960C0A0F)             // s_mul_i32 s12, s15, s10
    asm_u32(0x4A02000C)
    asm_u32(0x30080282)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02)
    asm_u32(0x00020804)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0605)
    asm_u32(0x7E1A0280)
    asm_u32(0xD7006A0C)
    asm_u32(0x00020806)
    asm_u32(0xD5207C0D)
    asm_u32(0x01AA1A07)
    // Load x. For non-pow2 N: gate to lane<N (default v10 = 0, the
    // identity for sum-of-x reduce).
    if N != Np {
        _emit_gated_load_v10(12, 10, 0x00000000)
    } else {
        asm_u32(0xDC520000)         // global_load_b32 v10, v[2:3], off
        asm_u32(0x0A7C0002)
        asm_u32(0xBF8903F7)
    }
    asm_u32(0x7E0A030A)             // v5 = x  (for sum-of-x reduce)
    asm_u32(0x300C0082)             // v6 = lane*4
    asm_u32(0x7E120280)             // v9 = 0
    asm_u32(0xD8340000)             // ds_store v6, v5
    asm_u32(0x00000506)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)

    // ── Phase A: sum-reduce x ───────────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 12)

    // ── Mid: mean = sum/N; diff = x - mean; v5 = diff² for Phase B ──
    asm_u32(0xD8D80000)             // ds_load v8, v9 (LDS[0] = sum)
    asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8C00FF)             // s_mov_b32 s12, lit
    asm_u32(inv_n_bits)             //   1/N
    asm_u32(0x1010100C)             // v_mul_f32 v8, s12, v8  (mean)
    asm_u32(0x0816110A)             // v_sub_f32 v11, v10, v8 (diff)
    asm_u32(0x100A170B)             // v_mul_f32 v5, v11, v11 (diff²)
    // For non-pow2 N: padding lanes have v10=0 → diff=-mean → v5=mean².
    // Overwrite v5 = 0 for lane >= N so they contribute the identity to
    // Phase B's sum-reduce.  Recompute the lane<N predicate in s12
    // (which is dead at this point — the v_mul above uses literal-
    // escape s_mov for the constant, so s12 was reused).  Note: this
    // helper writes v15 too; v15 is dead.
    if N != Np { _emit_identity_fill_v5(12, 10, 0x00000000) }
    asm_u32(0xBFBD0000)             // s_barrier
    asm_u32(0xD8340000)             // ds_store v6, v5
    asm_u32(0x00000506)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)

    // ── Phase B: sum-reduce diff² ───────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 12)

    // ── Finalize: var = sumsq/N; out = diff * rsqrt(var + eps) ─────
    asm_u32(0xD8D80000)             // ds_load v8, v9 (LDS[0] = sumsq)
    asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8C00FF)             // s_mov_b32 s12, lit
    asm_u32(inv_n_bits)             //   1/N
    asm_u32(0x1010100C)             // v_mul_f32 v8, s12, v8  (var)
    asm_u32(0xBE8C00FF)             // s_mov_b32 s12, lit
    asm_u32(0x3727C5AC)             //   eps = 1e-5
    asm_u32(0x0610100C)             // v_add_f32 v8, s12, v8  (var+eps)
    asm_u32(0x7E105D08)             // v_rsq_f32 v8, v8       (1/sqrt)
    asm_u32(0x100A110B)             // v_mul_f32 v5, v11, v8  (out)
    if N != Np { _emit_store_gate(12, 10) }
    asm_u32(0xDC6A0000)             // global_store
    asm_u32(0x007C050C)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)             // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Thread-coarsened layernorm body for N > 1024. Three passes (sum-of-x,
// sum-of-(x-mean)², apply). Padding lanes in PASS 2 must contribute 0
// to variance — gated load defaults v10 = 0, then `diff = -mean`
// pollutes if not zeroed; we cndmask v11 (= diff) to 0 for padding
// lanes before the diff² accumulate via v_fmac.
fn _emit_layernorm_f32_body_NL(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 K = (N + 1023) / 1024
    uint64 last_chunk_size = N - (K - 1) * 1024
    uint64 last_partial = 0
    if last_chunk_size != 1024 { last_partial = 1 }
    uint64 inv_n_bits = _f32_bits_recip(N)

    // ── Prologue ────────────────────────────────────────────────────
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF09080F)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)
    asm_u32(0x960C0A0F)             // s_mul_i32 s12, s15, s10
    asm_u32(0x4A02000C)
    asm_u32(0x30080282)
    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)
    asm_u32(0x300C0082); asm_u32(0x7E120280)
    asm_u32(0x7E0A0280)             // v5 = 0

    // ── PASS 1: sum-of-x ────────────────────────────────────────────
    uint64 c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x060A1505)             // v_add_f32 v5, v5, v10
        c = c + 1
    }
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07); asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 12)

    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8C00FF); asm_u32(inv_n_bits)
    asm_u32(0x1010100C)             // v_mul_f32 v8, s12, v8 (mean)
    asm_u32(0x7E260308)             // v19 = v8 (save mean)
    asm_u32(0xBFBD0000)
    _emit_vpair_build_from_sbase(2, 4, 4)
    asm_u32(0x7E0A0280)             // v5 = 0

    // ── PASS 2: sum-of-(x - mean)² ──────────────────────────────────
    c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x0816270A)             // v11 = v10 - v19 (diff)
        if c == K - 1 && last_partial != 0 {
            // Zero out v11 for padding lanes (lane >= last_chunk_size).
            // gated_load clobbered s12 with old-exec; re-load the
            // last_chunk_size into s12 so the comparison is correct.
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            asm_u32(0xD449000C); asm_u32(0x00001900)   // v_cmp_lt_u32_e64 s12, v0, s12
            asm_u32(0xD501000B); asm_u32(0x00321680)   // v_cndmask v11, 0, v11, s12
        }
        // v_fmac_f32 v5, v11, v11  (v5 += v11²)
        asm_u32(0x560A170B)
        c = c + 1
    }
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07); asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 12)

    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8C00FF); asm_u32(inv_n_bits)
    asm_u32(0x1010100C)             // v_mul_f32 v8, s12, v8 (variance)
    asm_u32(0xBE8C00FF); asm_u32(0x3727C5AC)   // eps
    asm_u32(0x0610100C)             // v_add_f32 v8, s12, v8 (var+eps)
    asm_u32(0x7E105D08)             // v_rsq_f32 v8, v8 (inv_stddev)

    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)

    // ── PASS 3: apply (out = (x - mean) * inv_stddev) ──────────────
    c = 0
    while c < K {
        if c > 0 {
            _emit_vpair_add_imm(2, 4096)
            _emit_vpair_add_imm(12, 4096)
        }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x0816270A)             // v11 = v10 - v19 (diff)
        asm_u32(0x100A110B)             // v_mul_f32 v5, v11, v8 (out)
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_store_gate(12, 12)
        }
        asm_u32(0xDC6A0000); asm_u32(0x007C050C)
        c = c + 1
    }

    asm_u32(0xBC7C0000); asm_u32(0xBFB00000)

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_layernorm_f32_N_blob(uint64 out_path, uint64 N) -> uint64 {
    if N < 32 || N > 8192 {
        write(2, "emit_amdgpu_layernorm_f32_N_blob: N must be in [32, 8192]\n", 58)
        return 1
    }
    uint64[8] args_desc
    uint64 lds_bytes = 0
    if N <= 1024 {
        _emit_layernorm_f32_body_N(args_desc, N)
        uint64 Np = _round_up_pow2(N)
        lds_bytes = Np * 4
    } else {
        _emit_layernorm_f32_body_NL(args_desc, N)
        lds_bytes = 4096
    }
    uint64 rsrc1 = 0xE0AF0001
    if N > 1024 { rsrc1 = 0xE0AF0002 }
    uint64 size = emit_amdgpu_code_object_lds("layernorm_f32", 13,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 20,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_layernorm_f32_N_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// LLM Phase 2 — rmsnorm_f32 native emit. Same shape as layernorm but
// only one reduction (sum of x²) — RMSNorm has no mean-subtraction.
// Output: out_i = x_i * rsqrt(mean(x²) + eps) * gamma_i.
// Hardcoded N = 256, eps = 1e-5; gamma is mandatory (per-element row-
// shared weight).
//
// Kernarg layout (40 bytes, 5 args):
//   [0x00] uint64 in_ptr     (M × N f32)
//   [0x08] uint64 out_ptr    (M × N f32)
//   [0x10] uint64 gamma_ptr  (N f32, row-shared)
//   [0x18] uint64 m
//   [0x20] uint64 n          (only low 32 used; must equal 256)
fn _emit_rmsnorm_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32(0xF40C0100)
    asm_u32(0xF8000000)
    asm_u32(0xF4040300)
    asm_u32(0xF8000020)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF090A0F)
    asm_u32(0xBFA20088)
    asm_u32(0x960E0C0F)
    asm_u32(0x4A02000E)
    asm_u32(0x30080282)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02)
    asm_u32(0x00020804)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0605)
    asm_u32(0x7E1A0280)
    asm_u32(0xD7006A0C)
    asm_u32(0x00020806)
    asm_u32(0xD5207C0D)
    asm_u32(0x01AA1A07)
    asm_u32(0xDC520000)
    asm_u32(0x0A7C0002)
    asm_u32(0xBF8903F7)
    asm_u32(0x30040082)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02)
    asm_u32(0x00020408)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0609)
    asm_u32(0xDC520000)
    asm_u32(0x0B7C0002)
    asm_u32(0xBF8903F7)
    asm_u32(0x100A150A)
    asm_u32(0x300C0082)
    asm_u32(0x7E120280)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xD8D80200)
    asm_u32(0x07000006)
    asm_u32(0xBF89FC07)
    asm_u32(0x060A0F05)
    asm_u32(0x7C9800FF)
    asm_u32(0x00000080)
    asm_u32(0xBE8E206A)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    asm_u32(0xBEFE000E)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xD8D80100)
    asm_u32(0x07000006)
    asm_u32(0xBF89FC07)
    asm_u32(0x060A0F05)
    asm_u32(0x7C9800C0)
    asm_u32(0xBE8E206A)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    asm_u32(0xBEFE000E)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xD8D80080)
    asm_u32(0x07000006)
    asm_u32(0xBF89FC07)
    asm_u32(0x060A0F05)
    asm_u32(0x7C9800A0)
    asm_u32(0xBE8E206A)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    asm_u32(0xBEFE000E)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xD8D80040)
    asm_u32(0x07000006)
    asm_u32(0xBF89FC07)
    asm_u32(0x060A0F05)
    asm_u32(0x7C980090)
    asm_u32(0xBE8E206A)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    asm_u32(0xBEFE000E)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xD8D80020)
    asm_u32(0x07000006)
    asm_u32(0xBF89FC07)
    asm_u32(0x060A0F05)
    asm_u32(0x7C980088)
    asm_u32(0xBE8E206A)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    asm_u32(0xBEFE000E)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
