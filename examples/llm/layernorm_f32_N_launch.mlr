// Launcher for shape-parametric layernorm_f32. Picks /tmp/layernorm_n<N>.co
// based on env var N. Block = N, grid = M.

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 { i = i - 1; uint64 d = tmp - (tmp / 10) * 10; uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }; tmp = tmp / 10 }
    return n
}
fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len { uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }; uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }; i = i + 1 }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}
fn die(uint64 msg, uint64 code) { puts(msg); print_label_val("e", 1, code); exit(1) }
fn parse_env_count(uint64 name) -> uint64 {
    uint64 s = getenv(name)
    if s == 0 { return 0 }
    uint64 v = 0; uint64 i = 0
    while 1 == 1 { uint64 cp = s + i; uint64 c = 0; unsafe { *(cp as uint8) -> c }; if c == 0 { break }; if c >= 48 && c <= 57 { v = v * 10 + (c - 48); i = i + 1; continue }; break }
    return v
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    uint64 M = 4
    uint64 me = parse_env_count("M"); if me != 0 { M = me }
    uint64 N = 256
    uint64 ne = parse_env_count("N"); if ne != 0 { N = ne }

    uint64 path = alloc(64)
    uint64 prefix = "/tmp/layernorm_n"
    uint64 pi = 0
    while pi < 16 {
        uint64 sp = prefix + pi; uint64 c = 0; unsafe { *(sp as uint8) -> c }
        uint64 dp = path + pi; uint8 cb = c; unsafe { *(dp as uint8) = cb }
        pi = pi + 1
    }
    uint64 nlen = u64_to_ascii_decimal(N, path + 16)
    uint64 suffix = ".co"
    uint64 si = 0
    while si < 3 {
        uint64 sp = suffix + si; uint64 c = 0; unsafe { *(sp as uint8) -> c }
        uint64 dp = path + 16 + nlen + si; uint8 cb = c; unsafe { *(dp as uint8) = cb }
        si = si + 1
    }
    uint64 nul_p = path + 16 + nlen + 3; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }

    uint64 fd = file_open(path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("missing co:"); puts(path); exit(1) }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "layernorm_f32"); if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    uint64 bytes = M * N * 4
    uint64 d_in = 0; uint64 d_out = 0
    uint64 slot = alloc(8); err = hipMalloc(slot, bytes); if err != 0 { die("mIn", err) }; unsafe { *(slot as uint64) -> d_in }
    slot = alloc(8); err = hipMalloc(slot, bytes); if err != 0 { die("mOut", err) }; unsafe { *(slot as uint64) -> d_out }

    uint64 h_in = alloc(bytes)
    uint64 r = 0
    while r < M {
        uint64 c = 0
        while c < N {
            f64 vd = int_to_f64(c) * 0.01 + int_to_f64(r) * 0.5
            f32 v = f64_to_f32(vd)
            uint64 p = h_in + (r * N + c) * 4
            unsafe { *(p as f32) = v }
            c = c + 1
        }
        r = r + 1
    }
    err = hipMemcpy(d_in, h_in, bytes, 1); if err != 0 { die("H2D", err) }

    uint64 k_in = alloc(8); unsafe { *(k_in as uint64) = d_in }
    uint64 k_out = alloc(8); unsafe { *(k_out as uint64) = d_out }
    uint64 k_m = alloc(8); uint64 mv = M; unsafe { *(k_m as uint64) = mv }
    uint64 k_n = alloc(8); unsafe { *(k_n as uint64) = N }
    uint64 kp = alloc(4 * 8)
    unsafe { *(kp        as uint64) = k_in }
    unsafe { *((kp +  8) as uint64) = k_out }
    unsafe { *((kp + 16) as uint64) = k_m }
    unsafe { *((kp + 24) as uint64) = k_n }

    uint64 Np = 1
    while Np < N { Np = Np << 1 }
    uint32 grid_x = M
    uint32 block_x = Np
    err = hipModuleLaunchKernel(fh, grid_x, 1, 1, block_x, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    uint64 h_out = alloc(bytes)
    err = hipMemcpy(h_out, d_out, bytes, 2); if err != 0 { die("D2H", err) }

    uint64 fail = 0
    r = 0
    while r < M {
        f32 row_sum = 0.0
        uint64 c = 0
        while c < N { uint64 p = h_out + (r * N + c) * 4; f32 v = 0.0; unsafe { *(p as f32) -> v }; row_sum = row_sum + v; c = c + 1 }
        f32 inv_n = 1.0 / int_to_f32(N)
        f32 row_mean = row_sum * inv_n
        f32 row_sumsq = 0.0
        c = 0
        while c < N { uint64 p = h_out + (r * N + c) * 4; f32 v = 0.0; unsafe { *(p as f32) -> v }; f32 d = v - row_mean; row_sumsq = row_sumsq + d * d; c = c + 1 }
        f32 row_var = row_sumsq * inv_n
        f32 mean_d = row_mean; if mean_d < 0.0 { mean_d = 0.0 - mean_d }
        f32 var_d = row_var - 1.0; if var_d < 0.0 { var_d = 0.0 - var_d }
        if mean_d > 0.01 || var_d > 0.01 { fail = fail + 1 }
        r = r + 1
    }

    print_label_val("M", 1, M)
    print_label_val("N", 1, N)
    print_label_val("rows_failed", 11, fail)

    hipFree(d_in); hipFree(d_out)
    exit(0)
}
