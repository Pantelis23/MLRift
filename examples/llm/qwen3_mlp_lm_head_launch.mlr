// MLRift LLM end-to-end forward driver — embedding → MLP block →
// final norm → LM head → argmax.  Skips attention (demonstrated
// separately in qwen3_attention_full_launch.mlr); chains 11 operators
// for a token_ids → next_tokens demonstration on synthetic weights.
//
// Forward pipeline (all device-resident):
//   x       = embedding_lookup(token_ids, W_embed)     [SEQ, H]
//   resid   = x
//   x_n     = rmsnorm(x, γ_ffn)                        [SEQ, H]
//   gate    = x_n @ W_gate                             [SEQ, I]   (gemm)
//   up      = x_n @ W_up                               [SEQ, I]   (gemm)
//   ffn     = silu_mul(gate, up)                       [SEQ * I]  (flat)
//   x_proj  = ffn @ W_down                             [SEQ, H]   (gemm)
//   x       = residual_add(resid, x_proj)              [SEQ * H]  (flat)
//   x_n     = rmsnorm(x, γ_final)                      [SEQ, H]
//   logits  = x_n @ W_lm_head                          [SEQ, V]   (gemm)
//   tokens  = argmax_logits(logits)                    [SEQ]
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-embedding-lookup-f32=/tmp/embedding_lookup_f32.co dummy
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-rmsnorm-f32-N=1024:/tmp/rmsnorm_n1024.co dummy
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-gemm-f32=/tmp/gemm_f32.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/silu_mul_f32.mlr     -o /tmp/silu_mul_f32
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/residual_add_f32.mlr -o /tmp/residual_add_f32
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-argmax-logits-f32=/tmp/argmax_logits_f32.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/qwen3_mlp_lm_head_launch.mlr -o /tmp/qwen3_mlp_lm_head_kfd
// Run:
//   /tmp/qwen3_mlp_lm_head_kfd

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 { i = i - 1; uint64 d = tmp - (tmp / 10) * 10; uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }; tmp = tmp / 10 }
    return n
}
fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len { uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }; uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }; i = i + 1 }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}
fn die(uint64 msg, uint64 code) { puts(msg); print_label_val("e", 1, code); exit(1) }

fn load_kernel(uint64 co_path, uint64 fname) -> uint64 {
    uint64 fd = file_open(co_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("missing co"); puts(co_path); exit(1) }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    uint32 err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, fname)
    if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }
    return fh
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    // Toy Qwen3-ish config — every dimension matches a kernel's supported range:
    //   HIDDEN ≤ 1024 (embedding lookup cap);
    //   INTER  ≤ 8192 (rmsnorm/silu_mul N cap);
    //   VOCAB any (argmax handles strided scan).
    uint64 SEQ    = 32
    uint64 HIDDEN = 1024
    uint64 INTER  = 2048
    uint64 VOCAB  = 4096

    uint64 fh_embed   = load_kernel("/tmp/embedding_lookup_f32.co", "embedding_lookup_f32")
    uint64 fh_norm    = load_kernel("/tmp/rmsnorm_n1024.co",         "rmsnorm_f32")
    uint64 fh_gemm    = load_kernel("/tmp/gemm_f32.co",              "gemm_f32")
    uint64 fh_silumul = load_kernel("/tmp/silu_mul_f32.co",          "silu_mul_f32")
    uint64 fh_resadd  = load_kernel("/tmp/residual_add_f32.co",      "residual_add_f32")
    uint64 fh_argmax  = load_kernel("/tmp/argmax_logits_f32.co",     "argmax_logits_f32")

    // Buffer sizes.
    uint64 tok_bytes    = SEQ * 4
    uint64 act_bytes    = SEQ * HIDDEN * 4
    uint64 inter_bytes  = SEQ * INTER * 4
    uint64 logits_bytes = SEQ * VOCAB * 4
    uint64 W_embed_bytes  = VOCAB * HIDDEN * 4
    uint64 W_gate_bytes   = HIDDEN * INTER * 4
    uint64 W_up_bytes     = HIDDEN * INTER * 4
    uint64 W_down_bytes   = INTER * HIDDEN * 4
    uint64 W_lm_head_bytes = HIDDEN * VOCAB * 4
    uint64 gamma_bytes    = HIDDEN * 4

    // Allocate device buffers.
    uint64 d_tok       = 0
    uint64 d_W_embed   = 0
    uint64 d_x         = 0
    uint64 d_resid     = 0
    uint64 d_x_n       = 0
    uint64 d_gate      = 0
    uint64 d_up        = 0
    uint64 d_ffn       = 0
    uint64 d_x_proj    = 0
    uint64 d_logits    = 0
    uint64 d_tokens    = 0
    uint64 d_W_gate    = 0
    uint64 d_W_up      = 0
    uint64 d_W_down    = 0
    uint64 d_W_lmhead  = 0
    uint64 d_gamma_ffn = 0
    uint64 d_gamma_fin = 0

    uint64 slot
    slot = alloc(8); err = hipMalloc(slot, tok_bytes);     if err != 0 { die("mTok",   err) }; unsafe { *(slot as uint64) -> d_tok }
    slot = alloc(8); err = hipMalloc(slot, W_embed_bytes); if err != 0 { die("mWemb",  err) }; unsafe { *(slot as uint64) -> d_W_embed }
    slot = alloc(8); err = hipMalloc(slot, act_bytes);     if err != 0 { die("mX",     err) }; unsafe { *(slot as uint64) -> d_x }
    slot = alloc(8); err = hipMalloc(slot, act_bytes);     if err != 0 { die("mResid", err) }; unsafe { *(slot as uint64) -> d_resid }
    slot = alloc(8); err = hipMalloc(slot, act_bytes);     if err != 0 { die("mXn",    err) }; unsafe { *(slot as uint64) -> d_x_n }
    slot = alloc(8); err = hipMalloc(slot, inter_bytes);   if err != 0 { die("mGate",  err) }; unsafe { *(slot as uint64) -> d_gate }
    slot = alloc(8); err = hipMalloc(slot, inter_bytes);   if err != 0 { die("mUp",    err) }; unsafe { *(slot as uint64) -> d_up }
    slot = alloc(8); err = hipMalloc(slot, inter_bytes);   if err != 0 { die("mFfn",   err) }; unsafe { *(slot as uint64) -> d_ffn }
    slot = alloc(8); err = hipMalloc(slot, act_bytes);     if err != 0 { die("mXp",    err) }; unsafe { *(slot as uint64) -> d_x_proj }
    slot = alloc(8); err = hipMalloc(slot, logits_bytes);  if err != 0 { die("mLog",   err) }; unsafe { *(slot as uint64) -> d_logits }
    slot = alloc(8); err = hipMalloc(slot, tok_bytes);     if err != 0 { die("mNtok",  err) }; unsafe { *(slot as uint64) -> d_tokens }
    slot = alloc(8); err = hipMalloc(slot, W_gate_bytes);  if err != 0 { die("mWg",    err) }; unsafe { *(slot as uint64) -> d_W_gate }
    slot = alloc(8); err = hipMalloc(slot, W_up_bytes);    if err != 0 { die("mWu",    err) }; unsafe { *(slot as uint64) -> d_W_up }
    slot = alloc(8); err = hipMalloc(slot, W_down_bytes);  if err != 0 { die("mWd",    err) }; unsafe { *(slot as uint64) -> d_W_down }
    slot = alloc(8); err = hipMalloc(slot, W_lm_head_bytes); if err != 0 { die("mWlm", err) }; unsafe { *(slot as uint64) -> d_W_lmhead }
    slot = alloc(8); err = hipMalloc(slot, gamma_bytes);   if err != 0 { die("mGff",   err) }; unsafe { *(slot as uint64) -> d_gamma_ffn }
    slot = alloc(8); err = hipMalloc(slot, gamma_bytes);   if err != 0 { die("mGfn",   err) }; unsafe { *(slot as uint64) -> d_gamma_fin }

    // === Host-side fill ===
    // Token IDs: deterministic [0, VOCAB).
    uint64 h_tok = alloc(tok_bytes)
    uint64 i = 0
    while i < SEQ {
        uint64 hash = (i + 1) * 2654435761
        uint64 tok = hash - (hash / VOCAB) * VOCAB
        uint32 tid = tok
        uint64 p = h_tok + i * 4
        unsafe { *(p as uint32) = tid }
        i = i + 1
    }
    err = hipMemcpy(d_tok, h_tok, tok_bytes, 1); if err != 0 { die("H2D tok", err) }

    // Print input tokens for the demo.
    puts("input_token_ids:")
    i = 0
    while i < SEQ {
        uint64 p = h_tok + i * 4
        uint32 tid = 0; unsafe { *(p as uint32) -> tid }
        uint64 tid64 = tid
        print_label_val("  in", 4, tid64)
        i = i + 1
    }

    // Embedding table — small deterministic values so we don't NaN through softmax.
    uint64 h_W_embed = alloc(W_embed_bytes)
    uint64 v = 0
    while v < VOCAB {
        uint64 d = 0
        while d < HIDDEN {
            f64 x = (int_to_f64(v) * 0.0001 + int_to_f64(d) * 0.0002) - 0.05
            uint64 p = h_W_embed + (v * HIDDEN + d) * 4
            unsafe { *(p as f32) = f64_to_f32(x) }
            d = d + 1
        }
        v = v + 1
    }
    err = hipMemcpy(d_W_embed, h_W_embed, W_embed_bytes, 1); if err != 0 { die("H2D Wemb", err) }

    // γ_ffn, γ_final = ones (no-op weight; correct fill for "initialized but no scaling").
    uint64 h_gamma = alloc(gamma_bytes)
    uint64 g = 0
    while g < HIDDEN {
        uint64 p = h_gamma + g * 4
        f32 one = 1.0
        unsafe { *(p as f32) = one }
        g = g + 1
    }
    err = hipMemcpy(d_gamma_ffn, h_gamma, gamma_bytes, 1); if err != 0 { die("H2D γff", err) }
    err = hipMemcpy(d_gamma_fin, h_gamma, gamma_bytes, 1); if err != 0 { die("H2D γfn", err) }

    // Weight matrices — small randomized values via splitmix.
    uint64 h_W = alloc(W_embed_bytes)        // reused max-size scratch
    // W_gate [HIDDEN, INTER]
    uint64 ri = 0
    while ri < HIDDEN {
        uint64 ci = 0
        while ci < INTER {
            uint64 mix = ((ri * 13 + ci * 7) * 2654435761) & 0xFFFF
            f64 vd = (int_to_f64(mix) - 32768.0) * 0.0001
            uint64 p = h_W + (ri * INTER + ci) * 4
            unsafe { *(p as f32) = f64_to_f32(vd) }
            ci = ci + 1
        }
        ri = ri + 1
    }
    err = hipMemcpy(d_W_gate, h_W, W_gate_bytes, 1); if err != 0 { die("H2D Wg", err) }

    // W_up [HIDDEN, INTER]
    ri = 0
    while ri < HIDDEN {
        uint64 ci = 0
        while ci < INTER {
            uint64 mix = ((ri * 17 + ci * 11) * 2654435761) & 0xFFFF
            f64 vd = (int_to_f64(mix) - 32768.0) * 0.0001
            uint64 p = h_W + (ri * INTER + ci) * 4
            unsafe { *(p as f32) = f64_to_f32(vd) }
            ci = ci + 1
        }
        ri = ri + 1
    }
    err = hipMemcpy(d_W_up, h_W, W_up_bytes, 1); if err != 0 { die("H2D Wu", err) }

    // W_down [INTER, HIDDEN]
    ri = 0
    while ri < INTER {
        uint64 ci = 0
        while ci < HIDDEN {
            uint64 mix = ((ri * 23 + ci * 19) * 2654435761) & 0xFFFF
            f64 vd = (int_to_f64(mix) - 32768.0) * 0.0001
            uint64 p = h_W + (ri * HIDDEN + ci) * 4
            unsafe { *(p as f32) = f64_to_f32(vd) }
            ci = ci + 1
        }
        ri = ri + 1
    }
    err = hipMemcpy(d_W_down, h_W, W_down_bytes, 1); if err != 0 { die("H2D Wd", err) }

    // W_lm_head [HIDDEN, VOCAB]
    ri = 0
    while ri < HIDDEN {
        uint64 ci = 0
        while ci < VOCAB {
            uint64 mix = ((ri * 29 + ci * 31) * 2654435761) & 0xFFFF
            f64 vd = (int_to_f64(mix) - 32768.0) * 0.0001
            uint64 p = h_W + (ri * VOCAB + ci) * 4
            unsafe { *(p as f32) = f64_to_f32(vd) }
            ci = ci + 1
        }
        ri = ri + 1
    }
    err = hipMemcpy(d_W_lmhead, h_W, W_lm_head_bytes, 1); if err != 0 { die("H2D Wlm", err) }

    // === Forward pass ===
    // 1. embedding_lookup
    uint64 e_tok = alloc(8); unsafe { *(e_tok as uint64) = d_tok }
    uint64 e_emb = alloc(8); unsafe { *(e_emb as uint64) = d_W_embed }
    uint64 e_out = alloc(8); unsafe { *(e_out as uint64) = d_x }
    uint64 e_d   = alloc(8); unsafe { *(e_d   as uint64) = HIDDEN }
    uint64 kp_e = alloc(4 * 8)
    unsafe { *(kp_e        as uint64) = e_tok }
    unsafe { *((kp_e +  8) as uint64) = e_emb }
    unsafe { *((kp_e + 16) as uint64) = e_out }
    unsafe { *((kp_e + 24) as uint64) = e_d }
    err = hipModuleLaunchKernel(fh_embed, SEQ, 1, 1, HIDDEN, 1, 1, 0, 0, kp_e, 0)
    if err != 0 { die("launch embed", err) }

    // resid = x  (device-side memcpy via hipMemcpy D2D, kind=3)
    err = hipMemcpy(d_resid, d_x, act_bytes, 3); if err != 0 { die("D2D resid", err) }

    // 2. rmsnorm(x, γ_ffn) → x_n  (kernel: in, out, gamma, m, n)
    uint64 r_in  = alloc(8); unsafe { *(r_in  as uint64) = d_x }
    uint64 r_out = alloc(8); unsafe { *(r_out as uint64) = d_x_n }
    uint64 r_g   = alloc(8); unsafe { *(r_g   as uint64) = d_gamma_ffn }
    uint64 r_m   = alloc(8); unsafe { *(r_m   as uint64) = SEQ }
    uint64 r_n   = alloc(8); unsafe { *(r_n   as uint64) = HIDDEN }
    uint64 kp_r1 = alloc(5 * 8)
    unsafe { *(kp_r1        as uint64) = r_in }
    unsafe { *((kp_r1 +  8) as uint64) = r_out }
    unsafe { *((kp_r1 + 16) as uint64) = r_g }
    unsafe { *((kp_r1 + 24) as uint64) = r_m }
    unsafe { *((kp_r1 + 32) as uint64) = r_n }
    err = hipModuleLaunchKernel(fh_norm, SEQ, 1, 1, HIDDEN, 1, 1, 0, 0, kp_r1, 0)
    if err != 0 { die("launch rmsn1", err) }

    // 3a. gate = x_n @ W_gate     (gemm: A, B, C, M, N, K)  M=SEQ, N=INTER, K=HIDDEN
    uint64 g_a = alloc(8); unsafe { *(g_a as uint64) = d_x_n }
    uint64 g_b = alloc(8); unsafe { *(g_b as uint64) = d_W_gate }
    uint64 g_c = alloc(8); unsafe { *(g_c as uint64) = d_gate }
    uint64 g_m = alloc(8); unsafe { *(g_m as uint64) = SEQ }
    uint64 g_n = alloc(8); unsafe { *(g_n as uint64) = INTER }
    uint64 g_k = alloc(8); unsafe { *(g_k as uint64) = HIDDEN }
    uint64 kp_g = alloc(6 * 8)
    unsafe { *(kp_g        as uint64) = g_a }
    unsafe { *((kp_g +  8) as uint64) = g_b }
    unsafe { *((kp_g + 16) as uint64) = g_c }
    unsafe { *((kp_g + 24) as uint64) = g_m }
    unsafe { *((kp_g + 32) as uint64) = g_n }
    unsafe { *((kp_g + 40) as uint64) = g_k }
    uint32 grid_g = (SEQ / 16) * (INTER / 16)
    err = hipModuleLaunchKernel(fh_gemm, grid_g, 1, 1, 256, 1, 1, 0, 0, kp_g, 0)
    if err != 0 { die("launch gemm gate", err) }

    // 3b. up = x_n @ W_up
    uint64 u_a = alloc(8); unsafe { *(u_a as uint64) = d_x_n }
    uint64 u_b = alloc(8); unsafe { *(u_b as uint64) = d_W_up }
    uint64 u_c = alloc(8); unsafe { *(u_c as uint64) = d_up }
    uint64 u_m = alloc(8); unsafe { *(u_m as uint64) = SEQ }
    uint64 u_n = alloc(8); unsafe { *(u_n as uint64) = INTER }
    uint64 u_k = alloc(8); unsafe { *(u_k as uint64) = HIDDEN }
    uint64 kp_u = alloc(6 * 8)
    unsafe { *(kp_u        as uint64) = u_a }
    unsafe { *((kp_u +  8) as uint64) = u_b }
    unsafe { *((kp_u + 16) as uint64) = u_c }
    unsafe { *((kp_u + 24) as uint64) = u_m }
    unsafe { *((kp_u + 32) as uint64) = u_n }
    unsafe { *((kp_u + 40) as uint64) = u_k }
    err = hipModuleLaunchKernel(fh_gemm, grid_g, 1, 1, 256, 1, 1, 0, 0, kp_u, 0)
    if err != 0 { die("launch gemm up", err) }

    // 4. ffn = silu_mul(gate, up)   kernel: gate, up, out, n  (n = SEQ * INTER)
    uint64 sm_g = alloc(8); unsafe { *(sm_g as uint64) = d_gate }
    uint64 sm_u = alloc(8); unsafe { *(sm_u as uint64) = d_up }
    uint64 sm_o = alloc(8); unsafe { *(sm_o as uint64) = d_ffn }
    uint64 sm_n = alloc(8); unsafe { *(sm_n as uint64) = SEQ * INTER }
    uint64 kp_sm = alloc(4 * 8)
    unsafe { *(kp_sm        as uint64) = sm_g }
    unsafe { *((kp_sm +  8) as uint64) = sm_u }
    unsafe { *((kp_sm + 16) as uint64) = sm_o }
    unsafe { *((kp_sm + 24) as uint64) = sm_n }
    uint32 grid_sm = (SEQ * INTER + 255) / 256
    err = hipModuleLaunchKernel(fh_silumul, grid_sm, 1, 1, 256, 1, 1, 0, 0, kp_sm, 0)
    if err != 0 { die("launch silu_mul", err) }

    // 5. x_proj = ffn @ W_down     M=SEQ, N=HIDDEN, K=INTER
    uint64 d_a = alloc(8); unsafe { *(d_a as uint64) = d_ffn }
    uint64 d_b = alloc(8); unsafe { *(d_b as uint64) = d_W_down }
    uint64 d_c = alloc(8); unsafe { *(d_c as uint64) = d_x_proj }
    uint64 d_m = alloc(8); unsafe { *(d_m as uint64) = SEQ }
    uint64 d_n = alloc(8); unsafe { *(d_n as uint64) = HIDDEN }
    uint64 d_k = alloc(8); unsafe { *(d_k as uint64) = INTER }
    uint64 kp_d = alloc(6 * 8)
    unsafe { *(kp_d        as uint64) = d_a }
    unsafe { *((kp_d +  8) as uint64) = d_b }
    unsafe { *((kp_d + 16) as uint64) = d_c }
    unsafe { *((kp_d + 24) as uint64) = d_m }
    unsafe { *((kp_d + 32) as uint64) = d_n }
    unsafe { *((kp_d + 40) as uint64) = d_k }
    uint32 grid_d = (SEQ / 16) * (HIDDEN / 16)
    err = hipModuleLaunchKernel(fh_gemm, grid_d, 1, 1, 256, 1, 1, 0, 0, kp_d, 0)
    if err != 0 { die("launch gemm down", err) }

    // 6. x = residual_add(resid, x_proj)   kernel: a, b, out, n  (n = SEQ * HIDDEN)
    uint64 ra_a = alloc(8); unsafe { *(ra_a as uint64) = d_resid }
    uint64 ra_b = alloc(8); unsafe { *(ra_b as uint64) = d_x_proj }
    uint64 ra_o = alloc(8); unsafe { *(ra_o as uint64) = d_x }
    uint64 ra_n = alloc(8); unsafe { *(ra_n as uint64) = SEQ * HIDDEN }
    uint64 kp_ra = alloc(4 * 8)
    unsafe { *(kp_ra        as uint64) = ra_a }
    unsafe { *((kp_ra +  8) as uint64) = ra_b }
    unsafe { *((kp_ra + 16) as uint64) = ra_o }
    unsafe { *((kp_ra + 24) as uint64) = ra_n }
    uint32 grid_ra = (SEQ * HIDDEN + 255) / 256
    err = hipModuleLaunchKernel(fh_resadd, grid_ra, 1, 1, 256, 1, 1, 0, 0, kp_ra, 0)
    if err != 0 { die("launch resadd", err) }

    // 7. x_n = rmsnorm(x, γ_final)
    uint64 r2_in  = alloc(8); unsafe { *(r2_in  as uint64) = d_x }
    uint64 r2_out = alloc(8); unsafe { *(r2_out as uint64) = d_x_n }
    uint64 r2_g   = alloc(8); unsafe { *(r2_g   as uint64) = d_gamma_fin }
    uint64 r2_m   = alloc(8); unsafe { *(r2_m   as uint64) = SEQ }
    uint64 r2_n   = alloc(8); unsafe { *(r2_n   as uint64) = HIDDEN }
    uint64 kp_r2 = alloc(5 * 8)
    unsafe { *(kp_r2        as uint64) = r2_in }
    unsafe { *((kp_r2 +  8) as uint64) = r2_out }
    unsafe { *((kp_r2 + 16) as uint64) = r2_g }
    unsafe { *((kp_r2 + 24) as uint64) = r2_m }
    unsafe { *((kp_r2 + 32) as uint64) = r2_n }
    err = hipModuleLaunchKernel(fh_norm, SEQ, 1, 1, HIDDEN, 1, 1, 0, 0, kp_r2, 0)
    if err != 0 { die("launch rmsn2", err) }

    // 8. logits = x_n @ W_lm_head    M=SEQ, N=VOCAB, K=HIDDEN
    uint64 lm_a = alloc(8); unsafe { *(lm_a as uint64) = d_x_n }
    uint64 lm_b = alloc(8); unsafe { *(lm_b as uint64) = d_W_lmhead }
    uint64 lm_c = alloc(8); unsafe { *(lm_c as uint64) = d_logits }
    uint64 lm_m = alloc(8); unsafe { *(lm_m as uint64) = SEQ }
    uint64 lm_n = alloc(8); unsafe { *(lm_n as uint64) = VOCAB }
    uint64 lm_k = alloc(8); unsafe { *(lm_k as uint64) = HIDDEN }
    uint64 kp_lm = alloc(6 * 8)
    unsafe { *(kp_lm        as uint64) = lm_a }
    unsafe { *((kp_lm +  8) as uint64) = lm_b }
    unsafe { *((kp_lm + 16) as uint64) = lm_c }
    unsafe { *((kp_lm + 24) as uint64) = lm_m }
    unsafe { *((kp_lm + 32) as uint64) = lm_n }
    unsafe { *((kp_lm + 40) as uint64) = lm_k }
    uint32 grid_lm = (SEQ / 16) * (VOCAB / 16)
    err = hipModuleLaunchKernel(fh_gemm, grid_lm, 1, 1, 256, 1, 1, 0, 0, kp_lm, 0)
    if err != 0 { die("launch gemm lm_head", err) }

    // 9. tokens = argmax_logits(logits)   kernel: logits, out, V, pad
    uint64 am_l = alloc(8); unsafe { *(am_l as uint64) = d_logits }
    uint64 am_o = alloc(8); unsafe { *(am_o as uint64) = d_tokens }
    uint64 am_v = alloc(8); unsafe { *(am_v as uint64) = VOCAB }
    uint64 am_p = alloc(8); unsafe { *(am_p as uint64) = 0 }
    uint64 kp_am = alloc(4 * 8)
    unsafe { *(kp_am        as uint64) = am_l }
    unsafe { *((kp_am +  8) as uint64) = am_o }
    unsafe { *((kp_am + 16) as uint64) = am_v }
    unsafe { *((kp_am + 24) as uint64) = am_p }
    err = hipModuleLaunchKernel(fh_argmax, SEQ, 1, 1, 32, 1, 1, 0, 0, kp_am, 0)
    if err != 0 { die("launch argmax", err) }

    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    // === D2H + report ===
    uint64 h_tokens = alloc(tok_bytes)
    err = hipMemcpy(h_tokens, d_tokens, tok_bytes, 2); if err != 0 { die("D2H tokens", err) }

    // Sanity: count finite-and-in-range output tokens.
    uint64 valid = 0
    uint64 max_seen = 0
    i = 0
    while i < SEQ {
        uint64 p = h_tokens + i * 4
        uint32 tid = 0; unsafe { *(p as uint32) -> tid }
        uint64 tid64 = tid
        if tid64 < VOCAB { valid = valid + 1 }
        if tid64 > max_seen { max_seen = tid64 }
        i = i + 1
    }

    puts("output_token_ids:")
    i = 0
    while i < SEQ {
        uint64 p = h_tokens + i * 4
        uint32 tid = 0; unsafe { *(p as uint32) -> tid }
        uint64 tid64 = tid
        print_label_val("  out", 5, tid64)
        i = i + 1
    }

    print_label_val("SEQ",            3, SEQ)
    print_label_val("HIDDEN",         6, HIDDEN)
    print_label_val("INTER",          5, INTER)
    print_label_val("VOCAB",          5, VOCAB)
    print_label_val("kernels_chained",15, 11)
    print_label_val("valid_tokens",  12, valid)
    print_label_val("max_token_id",  12, max_seen)

    hipFree(d_tok); hipFree(d_W_embed); hipFree(d_x); hipFree(d_resid); hipFree(d_x_n)
    hipFree(d_gate); hipFree(d_up); hipFree(d_ffn); hipFree(d_x_proj); hipFree(d_logits); hipFree(d_tokens)
    hipFree(d_W_gate); hipFree(d_W_up); hipFree(d_W_down); hipFree(d_W_lmhead)
    hipFree(d_gamma_ffn); hipFree(d_gamma_fin)
    exit(0)
}
