@export
fn emit_amdgpu_argmax_logits_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_argmax_logits_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("argmax_logits_f32", 17,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 24, 9,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_argmax_logits_f32_blob: cannot open output\n", 55)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}
