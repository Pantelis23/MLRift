        emit_a64_mov_imm(12, 0x3FF)
        emit_a64_and(12, 10, 12)
        emit_a64_mov_imm(13, 13)
        emit_a64_lsl(12, 12, 13)
        // result = sign | exp | mantissa
        emit_a64_orr(d, 11, 12)
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }

    // ----- IR_ITOF32 (107): int64 to f32 -----
    if op == 107 {
        uint64 a = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        // SCVTF Sd, Xn (sf=1, type=00) — encode 0x9E220000. The old
        // constant 0x1E620000 decoded to SCVTF Dd, Wn (double destination,
        // 32-bit source), so a 64-bit int turned into a *double*, then
        // FMOV w, s read the low 32 bits of the double bit-pattern —
        // always garbage that rounded to 0 on the round-trip.
        emit_a64(0x9E220000 | (a << 5) | 0)           // scvtf s0, xA
        emit_a64(0x1E260000 | (0 << 5) | d)           // fmov wDst, s0
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }

    // ----- IR_FTOI32 (108): f32 to int64 (truncating) -----
    if op == 108 {
        uint64 a = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64(0x1E270000 | (a << 5) | 0)           // fmov s0, wA
        // FCVTZS Xd, Sn (sf=1, type=00, rmode=11, opcode=000) — encode
        // 0x9E380000. Old constant 0x1E380000 was FCVTZS Wd which did
        // a 32-bit result write that zeroed the upper half of Xd; this
        // was only correct by accident for small values.
        emit_a64(0x9E380000 | (0 << 5) | d)           // fcvtzs xDst, s0
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }

    // ----- IR_FSQRT32 (118): f32 square root -----
    if op == 118 {
        uint64 a = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64(0x1E270000 | (a << 5) | 0)           // fmov s0, wA
        emit_a64(0x1E21C000 | (0 << 5) | 0)           // fsqrt s0, s0
        emit_a64(0x1E260000 | (0 << 5) | d)           // fmov wDst, s0
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }

    // ----- IR_FMT_BOOL (124): format bool as "true"/"false" -----
    // src1=buf, src2=val, dest=length
    if op == 124 {
        uint64 fb_buf = ir_a64_resolve_src(s1_v, 9)
        uint64 fb_val = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        // x13 = buf write ptr, x14 = val
        emit_a64_mov(13, fb_buf)
        emit_a64_mov(14, fb_val)
        // CBZ x14, false_path (5 true_path insns=20 bytes; false_path at CBZ_PC+24)
        emit_a64_cbz(14, 24)
        // true_path: store 'true' (0x65757274 LE) as 32-bit, then len=4, branch done
        emit_a64_mov_imm(11, 0x65757274)   // 2 insns: MOVZ+MOVK
        emit_a64_str32(11, 13, 0)          // STR W11, [X13]
        emit_a64_mov_imm(d, 4)             // len = 4 (1 insn)
        emit_a64_b(28)                     // B done (6 false_path insns=24 bytes; done at B_PC+28)
        // false_path: store 'fals' (0x736C6166 LE) then 'e' (0x65), len=5
        emit_a64_mov_imm(11, 0x736C6166)   // 2 insns: MOVZ+MOVK
        emit_a64_str32(11, 13, 0)          // STR W11, [X13]
        emit_a64_mov_imm(11, 0x65)         // 'e' = 101 (1 insn)
        emit_a64_strb(11, 13, 4)           // STRB W11, [X13, #4]
        emit_a64_mov_imm(d, 5)             // len = 5 (1 insn)
        // done:
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }

    // ----- IR_FMT_F64 (125): format f64 as "[sign][int].[6frac]" -----
    // src1=buf, src2=f64-bits, dest=length
    // Registers: x9=buf_ptr, x10=len, x11=temp/int_part, x12=digit_scratch,
    //            x13=divisor10, x14=digit_count/pad, x15=saved_count
    // Float: d0=working_val, d1=constant, d2=saved abs_val
    if op == 125 {
        uint64 ff_buf  = ir_a64_resolve_src(s1_v, 9)
        uint64 ff_val  = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }

        // Set x9 = buf (safe, ff_val might be in x10 — do NOT set x10 yet)
        emit_a64_mov(9, ff_buf)

        // Load f64 bits into d0: fmov d0, ff_val (before possibly clobbering ff_val)
        emit_a64(0x9E670000 | (ff_val << 5) | 0)   // fmov d0, ff_val

        // Extract bits back to x11 for sign check: fmov x11, d0
        emit_a64(0x9E660000 | (0 << 5) | 11)        // fmov x11, d0

        // Now safe to set x10 = len = 0 (ff_val bits are in x11 and d0)
        emit_a64_mov_imm(10, 0)

        // Sign check via bit 63 of x11: TST x11, sign_mask
        // Load sign mask 0x8000000000000000 into x13 (2 insns: MOVZ+MOVK)
        emit_a64_mov_imm(13, 0x8000000000000000)    // 2 insns; x13 reused as divisor10 later
        // ANDS XZR, x11, x13 — sets flags; ZR==1 means non-negative
        emit_a64(0xEA000000 | (13 << 16) | (11 << 5) | 31)  // TST x11, x13
        // B.EQ .ff_pos (cond=0=EQ, non-negative → skip neg path)
        // neg path = FNEG(1)+mov_imm_minus(1)+strb(1)+add9(1)+add10(1) = 5 insns=20 bytes
        // .ff_pos is at B_PC + 4 + 20 = B_PC + 24
        emit_a64_bcond(0, 24)                       // B.EQ .ff_pos
        // Negative: negate d0, write '-', update x9 and x10
        emit_a64(0x1E614000)                        // FNEG d0, d0
        emit_a64_mov_imm(11, 0x2D)                  // '-' = 45 (1 insn)
        emit_a64_strb(11, 9, 0)                     // STRB W11, [X9]
        emit_a64_add_imm(9, 9, 1)                   // x9++
        emit_a64_add_imm(10, 10, 1)                 // x10++
        // .ff_pos: check for big value
        // Load 1e18 = 0x4DE0B6B3A7640000 into x11, fmov d1, x11 (4+1=5 insns)
        emit_a64_mov_imm(11, 0x43ABC16D674EC800)    // 1e18 IEEE bits; 4 insns
        emit_a64(0x9E670000 | (11 << 5) | 1)        // fmov d1, x11
        // FCMP d0, d1
        emit_a64(0x1E602000 | (1 << 16) | (0 << 5)) // fcmp d0, d1
        // B.HS .ff_big (cond=2=HS=C set): val>=1e18 or NaN → big. PATCH LATER.
        emit_a64_bcond(2, 0)                        // placeholder; patched below
        uint64 ff_bhs_off = out_len - 4

        // .ff_normal path starts here
        // Integer part: FCVTZS x11, d0 (truncate to int)
        emit_a64(0x9E780000 | (0 << 5) | 11)        // fcvtzs x11, d0
        // Save abs_val in d2: FMOV d2, d0 (1E604002)
        emit_a64(0x1E604000 | (0 << 5) | 2)         // fmov d2, d0

        // Setup integer formatting: x12=digit_scratch, x13=10, x14=0
        emit_a64_mov_imm(12, ir_a64_scratch_off)
        ir_a64_add_sp_reg(12, 12)
        emit_a64_mov_imm(13, 10)
        emit_a64_mov_imm(14, 0)

        // Digit extraction loop: divide by 10, store remainder+0x30 at [x12+x14]
        uint64 ff_uint_loop = out_len
        emit_a64_udiv(4, 11, 13)                    // x4 = x11 / 10
        emit_a64_msub(5, 4, 13, 11)                 // x5 = x11 - x4*10 (digit)
        emit_a64_add_imm(5, 5, 48)                  // x5 += '0'
        // STRB W5, [X12, X14] — register offset (unscaled)
        emit_a64(0x38206800 | (14 << 16) | (12 << 5) | 5)
        emit_a64_add_imm(14, 14, 1)
        emit_a64_mov(11, 4)
        uint64 ff_uint_back = ff_uint_loop - out_len
        emit_a64(0xB5000000 | (((ff_uint_back / 4) & 0x7FFFF) << 5) | 11)  // CBNZ x11, loop

        // Reverse copy to [x9]: x15 = digit count
        emit_a64_mov(15, 14)
        uint64 ff_copy_loop = out_len
        emit_a64_cbz(14, 20)                        // CBZ x14, copy_done (5 insns=20 bytes)
        emit_a64(0xD1000400 | (14 << 5) | 14)       // SUB x14, x14, #1
        emit_a64(0x38606800 | (14 << 16) | (12 << 5) | 5)  // LDRB W5, [X12, X14]
        emit_a64(0x38001525)                        // STRB W5, [X9], #1 (post-index x9)
        uint64 ff_copy_back = ff_copy_loop - out_len
        emit_a64(0x14000000 | ((ff_copy_back / 4) & 0x3FFFFFF))  // B copy_loop
        // copy_done:
        emit_a64_add(10, 10, 15)                    // x10 += int_len (x15)

        // Write '.' at [x9], then x9++, x10++
        emit_a64_mov_imm(11, 0x2E)
        emit_a64_strb(11, 9, 0)
        emit_a64_add_imm(9, 9, 1)
        emit_a64_add_imm(10, 10, 1)

        // Recompute frac: fcvtzs x11, d2 → scvtf d1, x11 → fsub d0, d2, d1
        emit_a64(0x9E780000 | (2 << 5) | 11)        // fcvtzs x11, d2
        emit_a64(0x9E620000 | (11 << 5) | 1)        // scvtf d1, x11
        emit_a64(0x1E603800 | (1 << 16) | (2 << 5) | 0)  // fsub d0, d2, d1

        // Multiply by 1e6, truncate to int → frac_int in x11
        emit_a64_mov_imm(11, 0x412E848000000000)    // 1e6 IEEE bits; 4 insns
        emit_a64(0x9E670000 | (11 << 5) | 1)        // fmov d1, x11
        emit_a64(0x1E600800 | (1 << 16) | (0 << 5) | 0)  // fmul d0, d0, d1
        emit_a64(0x9E780000 | (0 << 5) | 11)        // fcvtzs x11, d0  → frac_int

        // Count digits in x11: x4=working, x14=count
        emit_a64_mov(4, 11)
        emit_a64_mov_imm(14, 0)
        emit_a64_cbz(4, 24)                         // CBZ x4, .ff_fz (5 insns+B = 24 bytes to .ff_fz)
        uint64 ff_cnt_loop = out_len
        emit_a64_udiv(5, 4, 13)
        emit_a64_add_imm(14, 14, 1)
        emit_a64_mov(4, 5)
        uint64 ff_cnt_back = ff_cnt_loop - out_len
        emit_a64(0xB5000000 | (((ff_cnt_back / 4) & 0x7FFFF) << 5) | 4)  // CBNZ x4, cnt_loop
        emit_a64_b(8)                               // B .ff_have_digits (skip .ff_fz = 1 insn = 8 bytes from B)
        // .ff_fz: frac_int=0 → digit_count=1
        emit_a64_mov_imm(14, 1)                     // 1 insn
        // .ff_have_digits: pad = 6 - x14 (always 0..5; no need for neg check since count ∈ 1..6)
        emit_a64_mov_imm(15, 6)
        emit_a64_sub(15, 15, 14)                    // x15 = pad
        // Pad zero loop. Body = 5 insns (mov+strb+add+sub+b). Use x3 as
        // the byte-constant scratch rather than x11: x11 holds frac_int
        // and is re-read by the fi_loop below. The earlier version used
        // `mov_imm x11, 48` which clobbered frac_int with the ASCII code
        // 0x30, so fi_loop then decomposed 48 into "84" — visible in
        // `println(1.0)` as "1.000004" (the trailing '8' got sliced off
        // by the `write(len)` call but the '4' landed). Also DO NOT
        // `add x10, x10, 1` here; the final `add x10, x10, 6` below
        // already accounts for every fraction byte.
        uint64 ff_pad_loop = out_len
        emit_a64_cbz(15, 24)                        // CBZ x15, pad_done (6 insns=24 bytes)
        emit_a64_mov_imm(3, 0x30)                   // x3 = '0'
        emit_a64_strb(3, 9, 0)
        emit_a64_add_imm(9, 9, 1)
        emit_a64(0xD1000400 | (15 << 5) | 15)       // SUB x15, x15, #1
        uint64 ff_pad_back = ff_pad_loop - out_len
        emit_a64(0x14000000 | ((ff_pad_back / 4) & 0x3FFFFFF))  // B pad_loop
        // pad_done:

        // Format frac_int (x11) into [x9]: digit extract + reverse copy
        emit_a64_mov_imm(14, 0)
        uint64 ff_fi_loop = out_len
        emit_a64_udiv(4, 11, 13)
        emit_a64_msub(5, 4, 13, 11)
        emit_a64_add_imm(5, 5, 48)
        emit_a64(0x38206800 | (14 << 16) | (12 << 5) | 5)
        emit_a64_add_imm(14, 14, 1)
        emit_a64_mov(11, 4)
        uint64 ff_fi_back = ff_fi_loop - out_len
        emit_a64(0xB5000000 | (((ff_fi_back / 4) & 0x7FFFF) << 5) | 11)  // CBNZ x11, fi_loop

        uint64 ff_fi_copy = out_len
        emit_a64_cbz(14, 20)                        // CBZ x14, fi_done (5 insns=20 bytes)
        emit_a64(0xD1000400 | (14 << 5) | 14)       // SUB x14, x14, #1
        emit_a64(0x38606800 | (14 << 16) | (12 << 5) | 5)  // LDRB W5, [X12, X14]
        emit_a64(0x38001525)                        // STRB W5, [X9], #1
        uint64 ff_fi_back2 = ff_fi_copy - out_len
        emit_a64(0x14000000 | ((ff_fi_back2 / 4) & 0x3FFFFFF))
        // fi_done: x10 += 6 (pad + frac digits always total 6)
        emit_a64_add_imm(10, 10, 6)

        // Jump over big path: big path = 7 insns × 4 = 28 bytes, then .ff_end
        // B at PC, big path at PC+4 (7 insns=28 bytes), ff_end at PC+32
        emit_a64_b(32)                              // B .ff_end

        // .ff_big: patch B.HS, then write "big", add 3 to len
        uint64 ff_big = out_len
        uint64 ff_bhs_disp = ff_big - ff_bhs_off
        uint64 ff_bhs_p = out_buf + ff_bhs_off
        uint64 ff_bhs_rel19 = (ff_bhs_disp / 4) & 0x7FFFF
        uint64 ff_bhs_insn = 0x54000002 | (ff_bhs_rel19 << 5)  // B.HS, cond=2
        uint32 ff_bhs_insn32 = ff_bhs_insn
        unsafe { *(ff_bhs_p as uint32) = ff_bhs_insn32 }
        // Write 'b', 'i', 'g'
        emit_a64_mov_imm(11, 0x62)
        emit_a64_strb(11, 9, 0)
        emit_a64_mov_imm(11, 0x69)
        emit_a64_strb(11, 9, 1)
        emit_a64_mov_imm(11, 0x67)
        emit_a64_strb(11, 9, 2)
        emit_a64_add_imm(10, 10, 3)
        // .ff_end:
        emit_a64_mov(d, 10)
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }
}

// ---------------------------------------------------------------------------
// Function-level emitter
// ---------------------------------------------------------------------------

@export
fn ir_emit_arm64_function(uint64 fn_node) {
    // Check for @naked attribute
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2

    // 1. Lower AST to IR
    ir_lower_function(fn_node)

    // 1a. Optimize
    if ir_opt_level > 0 {
        ir_optimize()
    }

    // 2. Compute liveness
    ir_compute_liveness()

    // 3. Set up ARM64 register allocator (10 regs)
    uint64 saved_num_regs = IR_NUM_REGS
    IR_NUM_REGS = 10
    ir_regalloc_init_arm64()
    ir_graph_color()

    // 4. Compute spill count
    ir_spill_count = 0
    if ir_vreg_next > IR_NUM_REGS + 1 {
        ir_spill_count = ir_vreg_next - IR_NUM_REGS - 1
    }

    // 4a. Snapshot the function's var map for DWARF (if -g)
    ir_snapshot_debug_vars()

    // NOTE: IR_NUM_REGS must stay at 10 through emission — ir_get_phys_reg()
    // uses it to distinguish colors from spills. Restore AFTER emission completes.

    // 5. Compute frame size
    // Callee-saved area: x29/x30 (16) + x19-x28 (80) = 96 bytes
    uint64 callee_save_size = 96
    uint64 spill_size = ir_spill_count * 8
    // 32-byte scratchpad for mid-function temp buffers (fmt_uint digits,
    // clock_gettime timespec, execve argv, etc). Using a fixed offset avoids
    // dynamic SP shifts that invalidate spill slot addresses.
    uint64 scratch_size = 32
    // Total frame = spill + scratch + callee save, must be 16-aligned
    // Layout from SP upward:
    //   [SP + 0 .. IR_A64_OVERFLOW_RESERVE)  — stack slots for outgoing calls' args 9+
    //   [spills ...]
    //   [scratchpad ...]
    //   [saved callee regs]
    // With the overflow reserve at the bottom, the caller can STR
    // outgoing args to [SP + offset] without any SUB — the callee
    // reads [SP + callee_frame + (idx-8)*8] = caller's arg slots.
    uint64 total_frame = IR_A64_OVERFLOW_RESERVE + spill_size + scratch_size + callee_save_size
    if (total_frame & 15) != 0 { total_frame = total_frame + 16 - (total_frame & 15) }
    if is_naked != 0 { total_frame = 0 }

    ir_frame_size = total_frame
    // Scratchpad sits right after spill slots (which start at the overflow reserve).
    ir_a64_scratch_off = IR_A64_OVERFLOW_RESERVE + spill_size

    // 5a. For main(): set up argc/argv BEFORE prologue
    uint32 fn_name_tok = ast_data1(fn_node)
    if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 && target_os != 2 {
        if target_os == 1 {
            // macOS Mach-O: _main receives argc in x0, argv in x1 as function params
            uint64 argc_off_m = static_lookup_by_name("cli_argc", 8)
            if argc_off_m != 0xFFFFFFFF {
                emit_a64_static_store(argc_off_m)  // store x0 (argc)
            }
            emit_a64_mov(0, 1)  // x0 = argv (x1)
            uint64 argv_off_m = static_lookup_by_name("cli_argv", 8)
            if argv_off_m != 0xFFFFFFFF {
                emit_a64_static_store(argv_off_m)  // store x0 (was x1 = argv)
            }
        } else {
            // Linux/Android ELF: argc/argv on stack. [SP]=argc, [SP+8]=&argv[0]
            emit_a64_ldr(0, 31, 0)
            uint64 argc_off = static_lookup_by_name("cli_argc", 8)
            if argc_off != 0xFFFFFFFF {
                emit_a64_static_store(argc_off)
            }
            emit_a64_add_imm(0, 31, 8)
            uint64 argv_off = static_lookup_by_name("cli_argv", 8)
            if argv_off != 0xFFFFFFFF {
                emit_a64_static_store(argv_off)
            }
        }
        // envp: Linux/Android = sp + 8 + (argc+1)*8; macOS = argv + (argc+1)*8.
        // The legacy codegen populates this; the IR path was silently leaving
        // cli_envp at 0, so exec_process() forwarded envp=NULL — fine on plain
        // Linux but breaks Android bionic which needs at least LD_* vars to
        // start the child process.
        uint64 envp_off_main = static_lookup_by_name("cli_envp", 8)
        if envp_off_main != 0xFFFFFFFF {
            if target_os == 1 {
                uint64 argc_off_env = static_lookup_by_name("cli_argc", 8)
                if argc_off_env != 0xFFFFFFFF { emit_a64_static_load(argc_off_env) }
                emit_a64_mov(9, 0)
                emit_a64_add_imm(9, 9, 1)
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)
                uint64 argv_off_env = static_lookup_by_name("cli_argv", 8)
                if argv_off_env != 0xFFFFFFFF { emit_a64_static_load(argv_off_env) }
                emit_a64_add(0, 0, 9)
            } else {
                emit_a64_ldr(9, 31, 0)
                emit_a64_add_imm(9, 9, 1)
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)
                emit_a64_add_imm(0, 31, 8)
                emit_a64_add(0, 0, 9)
            }
            emit_a64_static_store(envp_off_main)
        }
    }
    if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 && target_os == 2 {
        // Windows ARM64: GetCommandLineA via IAT
        emit_a64_win_call_iat(7)
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argv_off_w)
        }
        emit_a64_mov_imm(0, 0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argc_off_w)
        }
    }

    // 6. Emit prologue (skip for @naked)
    if is_naked == 0 {
        // SUB SP, SP, #total_frame
        emit_a64_sub_sp_imm(total_frame)
        // Save FP/LR and callee-saved regs after spill+scratch area.
        // Pair them with STP — halves the instruction count vs per-reg
        // STRs. STP's offset is imm7 scaled by 8, capped at 504; fall
        // back to individual STR for large frames to stay correct.
        uint64 cs_base = IR_A64_OVERFLOW_RESERVE + spill_size + scratch_size
        uint64 fp_off = cs_base + 80
        if fp_off + 8 <= 504 {
            ir_a64_stp_sp(19, 20, cs_base)
            ir_a64_stp_sp(21, 22, cs_base + 16)
            ir_a64_stp_sp(23, 24, cs_base + 32)
            ir_a64_stp_sp(25, 26, cs_base + 48)
            ir_a64_stp_sp(27, 28, cs_base + 64)
            ir_a64_stp_sp(29, 30, fp_off)
        } else {
            ir_a64_str_sp(29, fp_off)
            ir_a64_str_sp(30, fp_off + 8)
            ir_a64_str_sp(19, cs_base)
            ir_a64_str_sp(20, cs_base + 8)
            ir_a64_str_sp(21, cs_base + 16)
            ir_a64_str_sp(22, cs_base + 24)
            ir_a64_str_sp(23, cs_base + 32)
            ir_a64_str_sp(24, cs_base + 40)
            ir_a64_str_sp(25, cs_base + 48)
            ir_a64_str_sp(26, cs_base + 56)
            ir_a64_str_sp(27, cs_base + 64)
            ir_a64_str_sp(28, cs_base + 72)
        }
    }

    // 7. Allocate branch/return fixup tracking
    uint64 bo_need = ir_bb_count
    if bo_need < 4096 { bo_need = 4096 }
    ir_block_offsets = alloc(bo_need * 8)
    uint64 br_need = ir_bb_count * 4
    if br_need < 2048 { br_need = 2048 }
    ir_br_fixups = alloc(br_need * 8)
    uint64 ret_need = ir_bb_count
    if ret_need < 1024 { ret_need = 1024 }
    ir_ret_fixups = alloc(ret_need * 4)
    ir_br_fixup_count = 0
    ir_ret_fixup_count = 0

    // 8. Emit all basic blocks
    uint64 bi = 0
    while bi < ir_bb_count {
        // Record this block's code offset
        uint64 bop = ir_block_offsets + bi * 8
        unsafe { *(bop as uint64) = out_len }
        // Reset the spill-reload peephole at every BB boundary so a
        // branch target never lands mid-pattern.
        ir_a64_peephole_reset()

        // Emit non-terminator instructions
        uint64 ii = ir_bb_first_insn(bi)
        while ii != 0xFFFFFFFF {
            uint64 iop = ir_insn_opcode(ii)
            if iop != 40 && iop != 41 {
                ir_emit_arm64_insn(ii)
            }
            ii = ir_insn_next(ii)
        }

        // Emit block terminator
        uint64 last = ir_bb_last_insn(bi)
        if last != 0xFFFFFFFF {
            uint64 last_op = ir_insn_opcode(last)
            if last_op == 40 {
                // IR_BR: unconditional branch to target_bb
                uint64 target = ir_insn_imm(last)
                if target != bi + 1 {
                    // Record fixup [patch_offset, target_bb]
                    uint64 fp = ir_br_fixups + ir_br_fixup_count * 8
                    uint32 po = out_len
                    unsafe { *(fp as uint32) = po }
                    uint64 fp4 = fp + 4
                    uint32 tb = target
                    unsafe { *(fp4 as uint32) = tb }
                    ir_br_fixup_count = ir_br_fixup_count + 1
                    emit_a64(0x14000000)    // B #0 (placeholder)
                }
            }
            if last_op == 41 {
                // IR_BR_COND: cbnz cond_vreg, true_target; fallthrough or B false_target
                uint64 cond_v = ir_insn_src1(last)
                uint64 cond_r = ir_a64_resolve_src(cond_v, 9)
                uint64 target_true = ir_insn_imm(last)
                // Record fixup for CBNZ -> true target
                // We encode type=1 (CBNZ) in high bit of target_bb
                uint64 fp = ir_br_fixups + ir_br_fixup_count * 8
                uint32 po = out_len
                unsafe { *(fp as uint32) = po }
                uint64 fp4 = fp + 4
                // Encode: bit 31 = 1 for CBNZ, bits 0-30 = target_bb, store cond_r in the insn
                uint32 tb = target_true | 0x80000000
                unsafe { *(fp4 as uint32) = tb }
                ir_br_fixup_count = ir_br_fixup_count + 1
                // CBNZ cond_r, #0 (placeholder)
                emit_a64(0xB5000000 | cond_r)
                // Emit B to false target if not fall-through
                uint64 target_false = ir_bb_succ0(bi)
                if target_false != 0xFFFFFFFF && target_false != bi + 1 {
                    uint64 fp2 = ir_br_fixups + ir_br_fixup_count * 8
                    uint32 po2 = out_len
                    unsafe { *(fp2 as uint32) = po2 }
                    uint64 fp24 = fp2 + 4
                    uint32 tb2 = target_false
                    unsafe { *(fp24 as uint32) = tb2 }
                    ir_br_fixup_count = ir_br_fixup_count + 1
                    emit_a64(0x14000000)    // B #0 (placeholder)
                }
            }
        }

        bi = bi + 1
    }

    // 9. Patch branch fixups
    uint64 fi = 0
    while fi < ir_br_fixup_count {
        uint64 fp = ir_br_fixups + fi * 8
        uint32 patch_off = 0
        unsafe { *(fp as uint32) -> patch_off }
        uint64 fp4 = fp + 4
        uint32 target_bb_raw = 0
        unsafe { *(fp4 as uint32) -> target_bb_raw }
        uint64 wraw = target_bb_raw
        uint64 is_cbnz = wraw & 0x80000000
        uint64 wtb = wraw & 0x7FFFFFFF
        // Get target block offset
        uint64 tbp = ir_block_offsets + wtb * 8
        uint64 target_off = 0
        unsafe { *(tbp as uint64) -> target_off }
        uint64 wpo = patch_off
        uint64 disp = target_off - wpo
        uint64 rel = disp / 4
        if is_cbnz != 0 {
            // Patch CBNZ: read existing instruction to get Rt
            uint64 insn_addr = out_buf + wpo
            uint32 old_insn = 0
            unsafe { *(insn_addr as uint32) -> old_insn }
            uint64 wo = old_insn
            uint64 rt = wo & 0x1F
            uint64 new_insn = 0xB5000000 | ((rel & 0x7FFFF) << 5) | rt
            patch_u32(wpo, new_insn)
        } else {
            // Patch B
            uint64 new_insn = 0x14000000 | (rel & 0x3FFFFFF)
            patch_u32(wpo, new_insn)
        }
        fi = fi + 1
    }

    // 10. Patch return fixups — all point to epilogue
    uint64 epilogue_off = out_len
    uint64 ri2 = 0
    while ri2 < ir_ret_fixup_count {
        uint64 rfp = ir_ret_fixups + ri2 * 4
        uint32 rpatch = 0
        unsafe { *(rfp as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 rdisp = epilogue_off - wrp
        uint64 rrel = rdisp / 4
        uint64 new_insn = 0x14000000 | (rrel & 0x3FFFFFF)
        patch_u32(wrp, new_insn)
        ri2 = ri2 + 1
    }

    // 11. Epilogue (skip for @naked)
    if is_naked == 0 {
        // For main(): auto-insert exit(0) syscall. Without this, returning
        // from main() jumps to an undefined LR -> segfault.
        if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 {
            if target_os == 2 {
                // Windows: ExitProcess(0) via IAT slot 0
                emit_a64_mov_imm(0, 0)
                emit_a64_win_call_iat(0)
            } else {
                // Linux/macOS/Android: exit(0)
                emit_a64_mov_imm(0, 0)
                if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }
                emit_a64_svc()
            }
        }
        // Restore callee-saved registers. Mirror the prologue: LDP
        // pairs when the frame fits, individual LDRs otherwise.
        uint64 cs_base_e = IR_A64_OVERFLOW_RESERVE + spill_size + scratch_size
        uint64 fp_off_e = cs_base_e + 80
        if fp_off_e + 8 <= 504 {
            ir_a64_ldp_sp(19, 20, cs_base_e)
            ir_a64_ldp_sp(21, 22, cs_base_e + 16)
            ir_a64_ldp_sp(23, 24, cs_base_e + 32)
            ir_a64_ldp_sp(25, 26, cs_base_e + 48)
            ir_a64_ldp_sp(27, 28, cs_base_e + 64)
            ir_a64_ldp_sp(29, 30, fp_off_e)
        } else {
            ir_a64_ldr_sp(19, cs_base_e)
            ir_a64_ldr_sp(20, cs_base_e + 8)
            ir_a64_ldr_sp(21, cs_base_e + 16)
            ir_a64_ldr_sp(22, cs_base_e + 24)
            ir_a64_ldr_sp(23, cs_base_e + 32)
            ir_a64_ldr_sp(24, cs_base_e + 40)
            ir_a64_ldr_sp(25, cs_base_e + 48)
            ir_a64_ldr_sp(26, cs_base_e + 56)
            ir_a64_ldr_sp(27, cs_base_e + 64)
            ir_a64_ldr_sp(28, cs_base_e + 72)
            ir_a64_ldr_sp(29, fp_off_e)
            ir_a64_ldr_sp(30, fp_off_e + 8)
        }
        // ADD SP, SP, #total_frame
        emit_a64_add_sp_imm(total_frame)
        // RET
        emit_a64_ret()
    }

    // Restore IR_NUM_REGS for x86_64 functions compiled later
    IR_NUM_REGS = saved_num_regs
}
