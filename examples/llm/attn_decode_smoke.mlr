// Smoke test for the attn_decode_f32 kernel scaffold.  Just verifies
// that the kernel loads, dispatches, and the queue drains cleanly.
// Body is currently s_endpgm (no compute) — exists to validate KD +
// kernarg layout before adding the real attention body.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-attn-decode-f32=/tmp/attn_decode_f32.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/attn_decode_smoke.mlr -o /tmp/attn_decode_smoke
// Run:
//   /tmp/attn_decode_smoke

import "../../std/hip.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/time.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn die(uint64 msg, uint64 code) {
    print_str(msg); print_str(" e="); u64 s = fmt_dec(code); print_str(s); dealloc(s); print_str("\n"); exit(1)
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    u64 fd = file_open("/tmp/attn_decode_f32.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { die("missing co", 0) }
    u64 sz = file_size(fd); u64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    u64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    u64 mod = 0; unsafe { *(mod_slot as u64) -> mod }
    u64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "attn_decode_f32"); if err != 0 { die("getFn", err) }
    u64 fh = 0; unsafe { *(fh_slot as u64) -> fh }
    print_str("attn_decode_f32 loaded\n")

    // Allocate dummy device buffers.
    u64 q_bytes  = 16 * 128 * 4   // 8 KB
    u64 kv_bytes = 64 * 8 * 128 * 4   // 256 KB
    u64 d_q = 0; u64 d_kc = 0; u64 d_vc = 0; u64 d_out = 0
    u64 slot
    slot = alloc(8); err = hipMalloc(slot, q_bytes);  if err != 0 { die("mq",  err) }; unsafe { *(slot as u64) -> d_q }
    slot = alloc(8); err = hipMalloc(slot, kv_bytes); if err != 0 { die("mkc", err) }; unsafe { *(slot as u64) -> d_kc }
    slot = alloc(8); err = hipMalloc(slot, kv_bytes); if err != 0 { die("mvc", err) }; unsafe { *(slot as u64) -> d_vc }
    slot = alloc(8); err = hipMalloc(slot, q_bytes);  if err != 0 { die("mo",  err) }; unsafe { *(slot as u64) -> d_out }

    // Initialise Q with q[i] = i * 0.001 (unused this milestone).
    u64 h_q = alloc(q_bytes)
    u64 h_out = alloc(q_bytes)
    u64 h_kc = alloc(kv_bytes)
    u64 i = 0
    while i < 16 * 128 {
        f64 v = int_to_f64(i) * 0.001
        u64 p = h_q + i * 4
        unsafe { *(p as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_q, h_q, q_bytes, 1); if err != 0 { die("H2D q", err) }

    // K cache pattern: K[pos, kv_h, j] = pos*10000 + kv_h*1000 + j (as f32).
    // Lets us verify the kernel's kv_h derivation (h>>1) and K-slot
    // base addressing.
    i = 0
    u64 max_seq = 64; u64 nkv = 8; u64 hd = 128
    while i < max_seq * nkv * hd {
        u64 ipos = i / (nkv * hd)
        u64 ikv  = (i / hd) % nkv
        u64 ij   = i % hd
        f64 v = int_to_f64(ipos) * 10000.0 + int_to_f64(ikv) * 1000.0 + int_to_f64(ij)
        u64 p = h_kc + i * 4
        unsafe { *(p as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_kc, h_kc, kv_bytes, 1); if err != 0 { die("H2D kc", err) }

    // Zero out d_out so we can detect writes.
    u64 h_zero = alloc(q_bytes)
    i = 0
    while i < 16 * 128 { u64 p = h_zero + i * 4; unsafe { *(p as f32) = 0.0 }; i = i + 1 }
    err = hipMemcpy(d_out, h_zero, q_bytes, 1); if err != 0 { die("H2D zero", err) }

    // Build kernarg.
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_q }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_kc }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_vc }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = d_out }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = 1 }   // pos_plus_1 = 1
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }

    // Launch: grid = 16 (= nh), block = 32 (= 1 wave).
    print_str("launching grid=16 block=32...\n")
    u64 t0 = time_now()
    err = hipModuleLaunchKernel(fh, 16, 1, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("L", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }
    u64 t1 = time_now()
    err = hipMemcpy(h_out, d_out, q_bytes, 2); if err != 0 { die("D2H", err) }
    print_str("kernel_us="); u64 s = fmt_dec((t1 - t0) / 1000); print_str(s); dealloc(s); print_str("\n")

    // Verify per-head reduced score (milestone 2 phase 2d):
    //   out[head*128] should = (1/√128) * sum_{j=0..127}
    //       q[head*128 + j] * K[0, head>>1, j]
    //
    // Per-head sums grow large (head 15 ≈ 100k pre-scale), so we use
    // a relative-error threshold (1%).
    u64 fail = 0
    f64 inv_sqrt_dk = 1.0 / 11.31370849898476
    u64 head = 0
    while head < 16 {
        u64 kvh = head / 2
        f64 sum = 0.0
        u64 j = 0
        while j < 128 {
            f64 qv = int_to_f64(head * 128 + j) * 0.001
            f64 kv = int_to_f64(kvh) * 1000.0 + int_to_f64(j)
            sum = sum + qv * kv
            j = j + 1
        }
        f64 expected = sum * inv_sqrt_dk
        f32 expected_f = f64_to_f32(expected)
        f32 actual = 0.0f
        unsafe { *((h_out + head * 128 * 4) as f32) -> actual }
        f32 d = actual - expected_f
        if d < 0.0f { d = 0.0f - d }
        f32 abs_e = expected_f
        if abs_e < 0.0f { abs_e = 0.0f - abs_e }
        f32 thresh = abs_e * 0.01f
        if thresh < 0.001f { thresh = 0.001f }
        if d > thresh { fail = fail + 1 }
        head = head + 1
    }
    print_str("score fail count (out of 16): "); u64 sf = fmt_dec(fail); print_str(sf); dealloc(sf); print_str("\n")
    if fail == 0 {
        print_str("OK — Q · K[0] / √dk reduced + scaled per head.\n")
    } else {
        print_str("FAIL — heads 0..7 actual vs expected (f32 bits):\n")
        u64 jj = 0
        while jj < 8 {
            u32 ob = 0
            unsafe { *((h_out + jj * 128 * 4) as u32) -> ob }
            u64 ob64 = ob
            f64 sum2 = 0.0
            u64 kvh2 = jj / 2
            u64 j2 = 0
            while j2 < 128 {
                f64 qv = int_to_f64(jj * 128 + j2) * 0.001
                f64 kv = int_to_f64(kvh2) * 1000.0 + int_to_f64(j2)
                sum2 = sum2 + qv * kv
                j2 = j2 + 1
            }
            f32 ef = f64_to_f32(sum2 * inv_sqrt_dk)
            u64 eb = alloc(4); unsafe { *(eb as f32) = ef }
            u32 eb32 = 0; unsafe { *(eb as u32) -> eb32 }
            u64 eb64 = eb32
            print_str("  head["); u64 sj = fmt_dec(jj); print_str(sj); dealloc(sj)
            print_str("] act="); u64 sa = fmt_dec(ob64); print_str(sa); dealloc(sa)
            print_str(" exp="); u64 se = fmt_dec(eb64); print_str(se); dealloc(se)
            print_str("\n")
            dealloc(eb)
            jj = jj + 1
        }
    }
    exit(0)
}
