// std/hip_kfd.mlr — KFD-backed shim for the std/hip.mlr API surface.
//
// Selected by the compiler when --target=amdgpu-native is set:
// import_resolve() rewrites "../std/hip.mlr" → "../std/hip_kfd.mlr" so
// every hip* call in the launcher resolves to a concrete MLR function
// here instead of a @dynamic extern against libamdhip64. Net effect:
//
//   1. ldd of the produced binary contains only libc + ld-linux + vdso.
//   2. Existing launchers (hipMalloc / hipMemcpy / hipModuleLoadData /
//      hipModuleGetFunction / hipModuleLaunchKernel / hipDeviceSynchronize
//      / hipFree) keep working unchanged; the dispatch goes through
//      raw AMDKFD ioctls.
//
// What the shim does NOT cover (yet): hipGraph* (deferred until any
// launcher actually needs graph capture under amdgpu-native — none of
// the Stage 2c targets do).
//
// Semantics differences worth knowing:
//   * hipModuleLaunchKernel is SYNCHRONOUS (dispatch + busy-poll wait
//     before returning). HIP itself is async + you sync via
//     hipDeviceSynchronize; here both are conflated. Matches the
//     b5b-style "single queue, wait between every dispatch" pattern.
//   * hipDeviceSynchronize is a no-op for that reason.
//   * Kernarg unmarshalling assumes every argument is 8 bytes (uint64
//     or f64). Every MLRift @kernel emitter satisfies this — args_desc
//     entries declare size=8 in src/format_amdgpu.mlr.

import "kfd.mlr"
import "thread.mlr"

// --- Lazily-initialised global queue + kernarg ring + drain signal ---
//
// One queue serves all launches. Async pattern (matches HIP):
//   * hipModuleLaunchKernel: enqueue an AQL packet without waiting.
//   * hipDeviceSynchronize : wait for the queue to drain.
//
// Drain uses ONE shared completion signal initialised to 0. Every
// dispatched packet has its completion_signal field pointing to it;
// the GPU atomic-decrements by 1 when the kernel retires. CPU side
// keeps a "pending" counter (0 - launched, wraps in u64). Sync
// busy-polls until signal == pending (i.e. all launched kernels
// retired). Avoids the per-launch CPU reset+wait round-trip that
// dominated the old shim's runtime, and avoids the kernarg-ring race
// you'd get with rp/wp polling alone (CP advances rp on packet
// fetch, not retire).
//
// Kernarg ring: 1024 slots × 256 bytes = 256 KiB. 1024 >> AQL ring's
// 64 capacity so old kernels never see their kernarg slot overwritten
// even if back-pressure is loose — the AQL barrier=1 bit serialises
// dispatches so by the time we re-use slot N, all kernels at the same
// slot index from the previous lap have been launched, and with the
// drain signal we ensure they've also retired before sync.

static uint64 _HIPKFD_KARG_SLOTS    = 1024
static uint64 _HIPKFD_KARG_SLOT_SZ  = 512        // up from 256: clang-compiled
                                                  // COv5 kernels declare
                                                  // kernarg_size that includes
                                                  // ~256 B of hidden args
                                                  // (csr_build = 336, lif = 384)
static uint64 _HIPKFD_KARG_SLOT_MASK = 1023      // power-of-two — bitmask wrap

static uint64 _hipkfd_q              = 0
static uint64 _hipkfd_signal         = 0
static uint64 _hipkfd_signal_h       = 0     // host pointer to amd_signal_t
static uint64 _hipkfd_pending        = 0     // (0 - launched) in u64, wraps
static uint64 _hipkfd_kernarg_ring   = 0
static uint64 _hipkfd_kernarg_ring_h = 0
static uint64 _hipkfd_karg_slot      = 0     // round-robin index

// KFD event-driven completion (B-full in docs/SYNC_LAUNCH_GAP.md).
// Tested and rejected — see SYNC_LAUNCH_GAP.md "Events port: dead
// end" for why. Wrappers stay in kfd_raw.mlr as infra for any future
// work; this shim keeps the busy-poll signal path because:
//   * mailbox-wired path hangs: GPU can't write to a CPU-mmap'd
//     event page (no GPU VA mapping for it from CREATE_EVENT alone).
//   * WAIT_EVENTS-as-sleep without mailbox: ~3 ms per sync — 3.5×
//     SLOWER than busy-poll. Only useful for very long waits.
// Statics intentionally absent.

// Cached queue-descriptor fields (read once at lazy_init, never change).
// Avoids 6 loads per launch from the queue struct.
static uint64 _hipkfd_q_ring_host    = 0
static uint64 _hipkfd_q_ring_cap     = 0
static uint64 _hipkfd_q_wp_host      = 0
static uint64 _hipkfd_q_db_host      = 0
static uint64 _hipkfd_q_rp_host      = 0
static uint64 _hipkfd_q_signal_va    = 0     // = _hipkfd_signal, hoisted

// Optional device-side u64-copy kernel handle. Auto-detected the
// first time hipModuleLoadData sees a module containing the
// "_kfd_copy_u64" symbol. Used by hipMemcpy(D2H) to speed up
// reads from host-mapped VRAM, where CPU-side PCIe BAR1 reads run
// at ~1.3 GB/s. Falls back to plain memcpy when not registered.
static uint64 _hipkfd_copy_kernel_kd = 0
static uint64 _hipkfd_copy_kernel_ks = 0

// Reusable GTT staging buffer for the D2H fast path. Allocated lazily
// on first use, grows on demand. mmap-of-half-a-gig per call costs
// more than the BAR1 memcpy it replaces, so we keep one buffer alive
// for the lifetime of the process.
static uint64 _hipkfd_stage_va     = 0
static uint64 _hipkfd_stage_h      = 0
static uint64 _hipkfd_stage_bytes  = 0

// Lazy SDMA queue used by hipMemcpy(H2D). For each H2D the source
// host buffer is registered with the GPU as a USERPTR (kernel pins
// the pages and adds a GPU VM mapping that aliases them) and the SDMA
// engine reads from there directly into VRAM. Skips both the BAR1-WC
// CPU-write path and the GTT-WC staging-memcpy path — the only PCIe
// traffic is the SDMA's own DMA reads (~25 GB/s).
//
// Failure to create the queue (old kernels, no SDMA, perm issues)
// falls back to the parallel-thread BAR1 path.
static uint64 _hipkfd_sdma_q         = 0
static uint64 _hipkfd_sdma_init_done = 0       // 0 = not tried, 1 = ok, 2 = failed

// Parallel-memcpy thread pool for H2D writes through PCIe BAR1. WC
// buffer flushes serialise per-core, so a single thread tops out at
// ~2 GB/s on this RX 7800 XT setup. 4 cores split the buffer across
// 4 separate WC queues to the PCIe controller — empirically a 3–4×
// throughput win on noesis_60m's 7×480 MB H2D phase.
static uint64 _HIPKFD_H2D_THREADS  = 4
static uint64 _hipkfd_h2d_pool_init = 0

// Per-worker job descriptor (dst/src/size). Three parallel arrays so
// thread_pool_submit can pass them as a0/a1/a2.
static uint64 _hipkfd_h2d_dst_arr   = 0
static uint64 _hipkfd_h2d_src_arr   = 0
static uint64 _hipkfd_h2d_size_arr  = 0

// Worker entry point: plain memcpy of one chunk.
fn _hipkfd_h2d_worker(uint64 dst, uint64 src, uint64 size) {
    memcpy(dst, src, size)
}

fn _hipkfd_h2d_pool_ensure() {
    if _hipkfd_h2d_pool_init != 0 { return }
    thread_pool_init(_HIPKFD_H2D_THREADS)
    _hipkfd_h2d_dst_arr  = alloc(_HIPKFD_H2D_THREADS * 8)
    _hipkfd_h2d_src_arr  = alloc(_HIPKFD_H2D_THREADS * 8)
    _hipkfd_h2d_size_arr = alloc(_HIPKFD_H2D_THREADS * 8)
    _hipkfd_h2d_pool_init = 1
}

// Parallel memcpy: split [src, src+size) → [dst, dst+size) across
// _HIPKFD_H2D_THREADS workers. Chunk size is 64-byte aligned (WC
// flush granularity); the last worker absorbs the remainder.
fn _hipkfd_h2d_parallel(uint64 dst, uint64 src, uint64 size) {
    _hipkfd_h2d_pool_ensure()
    uint64 n_thr = _HIPKFD_H2D_THREADS
    uint64 chunk = size / n_thr
    chunk = (chunk / 64) * 64                      // align to cache line
    if chunk == 0 {
        memcpy(dst, src, size)
        return
    }
    uint64 worker_fn = fn_addr("_hipkfd_h2d_worker")
    uint64 i = 0
    uint64 off = 0
    while i < n_thr {
        uint64 this_size = chunk
        if i == (n_thr - 1) { this_size = size - off }   // last absorbs rem
        thread_pool_submit(i, worker_fn, dst + off, src + off, this_size)
        off = off + chunk
        i = i + 1
    }
    thread_pool_wait()
}

// Ensure the SDMA queue is ready. Returns 1 on success, 0 if the path
// isn't usable.
fn _hipkfd_sdma_ensure() -> uint64 {
    if _hipkfd_sdma_init_done == 2 { return 0 }
    if _hipkfd_sdma_init_done == 0 {
        _hipkfd_lazy_init()
        uint64 q = kfd_create_sdma_queue()
        if q == 0 {
            _hipkfd_sdma_init_done = 2
            return 0
        }
        _hipkfd_sdma_q = q
        _hipkfd_sdma_init_done = 1
    }
    return 1
}

// SDMA-backed H2D via USERPTR: pin the source host buffer in the GPU
// VM, kick the SDMA engine to read straight from there into VRAM.
// The userptr mapping stays alive until process exit (KFD reclaims
// at fd-close). Returns 1 on success, 0 if any step declines.
fn _hipkfd_h2d_sdma(uint64 dst_va, uint64 src, uint64 size) -> uint64 {
    if _hipkfd_sdma_ensure() == 0 { return 0 }
    // KFD's USERPTR alloc requires the source VA to be page-aligned
    // and the size to be a multiple of a page. Round size up; the
    // SDMA copy itself only transfers `size` bytes (the trailing
    // bytes in the rounded-up region are pinned but never read).
    uint64 page_mask = 4095
    if (src & page_mask) != 0 { return 0 }
    uint64 reg_size  = (size + page_mask) & 0xFFFFFFFFFFFFF000
    uint64 src_va = dev_register_userptr(src, reg_size)
    if src_va == 0 { return 0 }
    kfd_sdma_copy(_hipkfd_sdma_q, src_va, dst_va, size)
    return 1
}

fn _hipkfd_ensure_stage(uint64 nbytes) -> uint64 {
    if _hipkfd_stage_bytes >= nbytes { return 1 }
    if _hipkfd_stage_va != 0 {
        dev_free(_hipkfd_stage_va)
        _hipkfd_stage_va = 0
        _hipkfd_stage_h  = 0
        _hipkfd_stage_bytes = 0
    }
    uint64 va = dev_try_alloc_host_visible(nbytes)
    if va == 0 { return 0 }
    _hipkfd_stage_va    = va
    _hipkfd_stage_h     = dev_host_ptr(va)
    _hipkfd_stage_bytes = nbytes
    return 1
}

// DRM AMDGPU context allocated as part of the no-ROCm GPU power-state
// story (task #55). SET_STABLE_PSTATE/PEAK over DRM applies the hint
// to that context's DRM command-submissions only — KFD doorbell-driven
// compute queues are a separate scheduler tree. We allocate the ctx
// anyway: cheap, exercises the path for future kernel versions, and
// having an active AMDGPU context per-process nudges DPM heuristics
// on at least gfx12+.
static uint32 _hipkfd_drm_ctx_id   = 0
static uint64 _hipkfd_drm_ctx_done = 0

fn _hipkfd_drm_pin_clocks() {
    if _hipkfd_drm_ctx_done != 0 { return }
    uint64 ctx_slot = alloc(4)
    uint32 r = raw_drm_ctx_alloc(kfd_drm_fd(), ctx_slot)
    if r != 0 { _hipkfd_drm_ctx_done = 1; return }
    uint32 ctx_id = 0; unsafe { *(ctx_slot as uint32) -> ctx_id }
    _hipkfd_drm_ctx_id = ctx_id
    uint32 peak = AMDGPU_CTX_STABLE_PSTATE_PEAK
    raw_drm_ctx_set_stable_pstate(kfd_drm_fd(), ctx_id, peak)
    _hipkfd_drm_ctx_done = 1
}

// ─────────────────────────────────────────────────────────────────────
// Debug introspection (task #56).
//
// hipkfd_dump_queue(tag) prints a snapshot of AQL queue + signal +
// recent dispatch history to stderr. Called between hipModuleLaunch
// invocations to bisect "queue corrupts after N dispatches" symptoms.
//
// History ring records the last 8 dispatches (kd_va, kernarg_va,
// header_setup, slot index, wp at write time). Both user and boost
// dispatches feed into it.

static uint64 _HIPKFD_HIST_N      = 8
static uint64 _hipkfd_hist_ring   = 0       // alloc'd lazily, 5*8 bytes per entry
static uint64 _hipkfd_hist_idx    = 0       // next write slot (mod N)
static uint64 _hipkfd_hist_count  = 0       // total dispatches recorded

fn _hipkfd_hist_record(uint64 kd_va, uint64 karg_va, uint64 header_setup,
                       uint64 slot, uint64 wp_at_write, uint64 kind) {
    if _hipkfd_hist_ring == 0 {
        _hipkfd_hist_ring = alloc(_HIPKFD_HIST_N * 48)
    }
    uint64 i = _hipkfd_hist_idx
    uint64 base = _hipkfd_hist_ring + i * 48
    unsafe { *((base +  0) as uint64) = kd_va }
    unsafe { *((base +  8) as uint64) = karg_va }
    unsafe { *((base + 16) as uint64) = header_setup }
    unsafe { *((base + 24) as uint64) = slot }
    unsafe { *((base + 32) as uint64) = wp_at_write }
    unsafe { *((base + 40) as uint64) = kind }       // 0=user, 1=boost, 2=copy_d2h
    _hipkfd_hist_idx = (i + 1) - ((i + 1) / _HIPKFD_HIST_N) * _HIPKFD_HIST_N
    _hipkfd_hist_count = _hipkfd_hist_count + 1
}

// Format a u64 as decimal into buf, return length. Tiny self-contained
// formatter — std/fmt.mlr might not be linked in every binary.
fn _hipkfd_dec(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 t = val
    while t > 0 { n = n + 1; t = t / 10 }
    uint64 i = n; t = val
    while i > 0 {
        i = i - 1
        uint64 d = t - (t / 10) * 10
        uint64 p = buf + i
        uint8 c = d + 48; unsafe { *(p as uint8) = c }
        t = t / 10
    }
    return n
}

// Format u64 as hex (no 0x prefix), return length, fixed `digits` width.
fn _hipkfd_hex(uint64 val, uint64 buf, uint64 digits) -> uint64 {
    uint64 i = digits
    while i > 0 {
        i = i - 1
        uint64 d = val - (val / 16) * 16
        uint8 c
        if d < 10 { c = d + 48 } else { c = d + 87 }            // 'a'+(d-10)
        uint64 p = buf + i
        unsafe { *(p as uint8) = c }
        val = val / 16
    }
    return digits
}

fn _hipkfd_dbg_emit(uint64 buf, uint64 label, uint64 lab_len,
                    uint64 val, uint64 hex_digits) {
    uint64 j = 0
    while j < lab_len {
        uint64 sp = label + j; uint64 c = 0; unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + j; uint8 cb = c; unsafe { *(dp as uint8) = cb }
        j = j + 1
    }
    uint64 sep = buf + lab_len
    uint8 eq = 61; unsafe { *(sep as uint8) = eq }
    uint64 vbase = buf + lab_len + 1
    uint64 vlen
    if hex_digits > 0 {
        uint8 z = 48; unsafe { *(vbase as uint8) = z }
        uint8 x = 120; unsafe { *((vbase + 1) as uint8) = x }
        vlen = _hipkfd_hex(val, vbase + 2, hex_digits) + 2
    } else {
        vlen = _hipkfd_dec(val, vbase)
    }
    uint64 nl = vbase + vlen
    uint8 nlc = 10; unsafe { *(nl as uint8) = nlc }
    write(2, buf, lab_len + 1 + vlen + 1)
}

// Public: dump shim/queue state with a caller-supplied tag prefix.
// Tag isn't bounds-checked — pass a NUL-terminated string.
fn hipkfd_dump_queue(uint64 tag) {
    if _hipkfd_q == 0 {
        write(2, "[hipkfd] dump_queue: shim not initialised\n", 42)
        return
    }
    uint64 buf = alloc(256)
    write(2, "==== hipkfd_dump_queue [", 24)
    uint64 tlen = 0
    while 1 == 1 {
        uint64 cp = tag + tlen; uint64 c = 0
        unsafe { *(cp as uint8) -> c }
        if c == 0 { break }
        tlen = tlen + 1
    }
    write(2, tag, tlen)
    write(2, "] ====\n", 7)

    uint64 wp = 0; unsafe { *(_hipkfd_q_wp_host as uint64) -> wp }
    uint64 rp = 0; unsafe { *(_hipkfd_q_rp_host as uint64) -> rp }
    _hipkfd_dbg_emit(buf, "  queue.wp        ", 18, wp, 16)
    _hipkfd_dbg_emit(buf, "  queue.rp        ", 18, rp, 16)
    _hipkfd_dbg_emit(buf, "  queue.in_flight ", 18, wp - rp, 0)
    _hipkfd_dbg_emit(buf, "  queue.cap       ", 18, _hipkfd_q_ring_cap, 0)

    // Signal value vs expected pending.
    uint64 sig_addr = _hipkfd_signal_h + 0x08
    uint64 sv = 0; unsafe { *(sig_addr as uint64) -> sv }
    _hipkfd_dbg_emit(buf, "  signal.value    ", 18, sv, 16)
    _hipkfd_dbg_emit(buf, "  signal.pending  ", 18, _hipkfd_pending, 16)
    uint64 drained = 1
    if sv != _hipkfd_pending { drained = 0 }
    _hipkfd_dbg_emit(buf, "  signal.drained  ", 18, drained, 0)

    _hipkfd_dbg_emit(buf, "  hist.total      ", 18, _hipkfd_hist_count, 0)

    // Walk the most recent N dispatches (oldest -> newest).
    if _hipkfd_hist_ring != 0 {
        uint64 n = _hipkfd_hist_count
        if n > _HIPKFD_HIST_N { n = _HIPKFD_HIST_N }
        uint64 start = (_hipkfd_hist_idx + _HIPKFD_HIST_N - n) - (((_hipkfd_hist_idx + _HIPKFD_HIST_N - n)) / _HIPKFD_HIST_N) * _HIPKFD_HIST_N
        uint64 k = 0
        while k < n {
            uint64 idx = (start + k) - ((start + k) / _HIPKFD_HIST_N) * _HIPKFD_HIST_N
            uint64 base = _hipkfd_hist_ring + idx * 48
            uint64 kd  = 0; unsafe { *((base +  0) as uint64) -> kd }
            uint64 ka  = 0; unsafe { *((base +  8) as uint64) -> ka }
            uint64 hdr = 0; unsafe { *((base + 16) as uint64) -> hdr }
            uint64 sl  = 0; unsafe { *((base + 24) as uint64) -> sl }
            uint64 wpa = 0; unsafe { *((base + 32) as uint64) -> wpa }
            uint64 kind = 0; unsafe { *((base + 40) as uint64) -> kind }
            // Read back the header word actually in the ring at that
            // slot — this catches "we wrote it but did the CP see it?"
            uint64 ring_pkt = _hipkfd_q_ring_host + sl * 64
            uint32 hdr_now = 0
            unsafe { *(ring_pkt as uint32) -> hdr_now }

            write(2, "  --- dispatch[", 15)
            uint64 nl = _hipkfd_dec(k, buf); write(2, buf, nl)
            write(2, "]\n", 2)
            _hipkfd_dbg_emit(buf, "    .kind        ", 17, kind, 0)
            _hipkfd_dbg_emit(buf, "    .kd_va       ", 17, kd, 16)
            _hipkfd_dbg_emit(buf, "    .karg_va     ", 17, ka, 16)
            _hipkfd_dbg_emit(buf, "    .slot        ", 17, sl, 0)
            _hipkfd_dbg_emit(buf, "    .wp_at_write ", 17, wpa, 0)
            _hipkfd_dbg_emit(buf, "    .header_set  ", 17, hdr, 8)
            _hipkfd_dbg_emit(buf, "    .header_now  ", 17, hdr_now, 8)
            // Decode header: low byte is type, bit 8 is barrier,
            // bits[10:9] acquire, bits[12:11] release.
            uint64 htype = hdr & 0xFF
            uint64 hbarrier = (hdr >> 8) & 0x1
            uint64 hacquire = (hdr >> 9) & 0x3
            uint64 hrelease = (hdr >> 11) & 0x3
            uint64 hsetup   = (hdr >> 16) & 0x3
            _hipkfd_dbg_emit(buf, "    .h.type      ", 17, htype, 0)
            _hipkfd_dbg_emit(buf, "    .h.barrier   ", 17, hbarrier, 0)
            _hipkfd_dbg_emit(buf, "    .h.acquire   ", 17, hacquire, 0)
            _hipkfd_dbg_emit(buf, "    .h.release   ", 17, hrelease, 0)
            _hipkfd_dbg_emit(buf, "    .h.setup     ", 17, hsetup, 0)
            k = k + 1
        }
    }
    write(2, "==== end dump ====\n", 19)
}

// ─────────────────────────────────────────────────────────────────────
// GPU-clock keepalive (task #55).
//
// Mechanism: at lazy_init, allocate executable VRAM, write a 28-byte
// "boost" kernel (a 65k-iter VALU loop ending with s_endpgm) and a
// 64-byte HSA kernel descriptor pointing at it. After every user
// hipModuleLaunchKernel we dispatch the boost kernel WITH
// barrier=0/signal_va=0 so it runs in parallel with the user's kernel,
// keeping the AQL queue continuously non-empty. The CP-side activity
// is what DPM samples — sustained 1+ ms of dispatch keeps sclk at
// boost. Cost per user-launch: 12 extra packet stores + 1 fence,
// ~few hundred nanoseconds.
//
// Why not a separate thread: contention on the AQL ring write pointer
// would need a spinlock, and the existing single-threaded dispatch
// fast path is fragile to mutate. Inlining the boost behind every
// user launch is simpler and the cost is invisible alongside the
// user's own kernel runtime.

static uint64 _hipkfd_boost_va     = 0
static uint64 _hipkfd_boost_kd_va  = 0
static uint64 _hipkfd_boost_done   = 0

// Dedicated boost queue — runs the boost kernel continuously from a
// background thread, completely separate from the user's compute queue.
// Goal: GPU sees continuous queue activity and DPM holds sclk at peak
// for the lifetime of the process. With this, the user's sync-launch
// path runs at full boost clocks, no warmup, no dips.
static uint64 _hipkfd_boost_q          = 0
static uint64 _hipkfd_boost_q_ring_host = 0
static uint64 _hipkfd_boost_q_ring_cap  = 0
static uint64 _hipkfd_boost_q_wp_host   = 0
static uint64 _hipkfd_boost_q_db_host   = 0
static uint64 _hipkfd_boost_q_rp_host   = 0
static uint64 _hipkfd_boost_thread_done = 0

// SDMA mclk-keeper queue — DPM ramps mclk only with sustained memory
// traffic, and the compute boost queue's pure-VALU loop never touches
// memory. We keep a second SDMA queue continuously dispatching small
// VRAM↔VRAM copies so the memory subsystem stays warm. SDMA runs on
// the dedicated DMA engine and steals zero CU cycles from the user
// kernel.
//
// Buffers are 64 KiB VRAM-only — large enough that each copy moves
// real bandwidth (not just header overhead) but small enough that the
// queue can hold many packets without wasting GPU memory. wp is a
// byte-cursor (SDMA semantic), not a packet count.
static uint64 _hipkfd_sdma_boost_q      = 0
static uint64 _hipkfd_sdma_boost_ring_h = 0
static uint64 _hipkfd_sdma_boost_wp_h   = 0
static uint64 _hipkfd_sdma_boost_db_h   = 0
static uint64 _hipkfd_sdma_boost_rp_h   = 0
static uint64 _hipkfd_sdma_boost_src    = 0
static uint64 _hipkfd_sdma_boost_dst    = 0
static uint64 _HIPKFD_SDMA_BOOST_BYTES  = 65536       // 64 KiB per copy
static uint64 _HIPKFD_SDMA_BOOST_DEPTH  = 32          // packets in flight

// Boost kernel image — 65 536-iter VALU loop. ~75 us at boost clock.
// Tuned to be SHORTER than a typical user kernel: with barrier=1 on
// user packets (ordering required for LLM-style chained kernels), a
// boost in flight when the next user dispatches forces the user to
// wait for boost completion. Keeping boost <= user-kernel time means
// the next user launch finds the boost from the previous cycle
// already drained — no false serialization. The boost packet itself
// has barrier=0 so it dispatches concurrently with the *current*
// user kernel on free CUs, adding zero latency to the user round-
// trip while still keeping the queue non-empty for DPM.
//
// Iter count tuning: tried 0x40 (~1us per wave, 5000x less compute
// than 0x10000), DPM dropped to idle floor and we went back to
// 63 ms / launch (cold-clock baseline). DPM needs sustained shader
// work, not just dispatch events. 0x10000 is the empirical sweet
// spot: enough to keep DPM at the highest sclk state, while still
// finishing well before a typical user kernel.
fn _hipkfd_boost_emit_image(uint64 dst) {
    uint32 w0 = 0x7E000280; unsafe { *((dst +  0) as uint32) = w0 }
    uint32 w1 = 0x4A000081; unsafe { *((dst +  4) as uint32) = w1 }
    uint32 w2 = 0xD449006A; unsafe { *((dst +  8) as uint32) = w2 }
    uint32 w3 = 0x0001FF00; unsafe { *((dst + 12) as uint32) = w3 }
    uint32 w4 = 0x00010000; unsafe { *((dst + 16) as uint32) = w4 }   // limit = 0x10000
    uint32 w5 = 0xBFA4FFFB; unsafe { *((dst + 20) as uint32) = w5 }
    uint32 w6 = 0xBFB00000; unsafe { *((dst + 24) as uint32) = w6 }
}

// HSA kernel descriptor — same shape we use for native kernels. The
// kernel image lives 64 bytes after the KD start, so the kd's
// kernel_code_entry_byte_offset = 64. rsrc1/2/3 + properties match
// the noesis kernels (1 wave, no kernargs needed beyond what KD/CP
// auto-set). kernarg_size = 0 — the kernel doesn't dereference any.
fn _hipkfd_boost_emit_kd(uint64 kd_h) {
    // HSA kernel-descriptor layout (gfx11):
    //   0x00 u32  group_segment_fixed_size
    //   0x04 u32  private_segment_fixed_size
    //   0x08 u32  kernarg_size
    //   0x0C u32  reserved
    //   0x10 i64  kernel_code_entry_byte_offset
    //   0x18 u8[20] reserved
    //   0x2C u32  compute_pgm_rsrc3              ← was at 0x38 (wrong!)
    //   0x30 u32  compute_pgm_rsrc1
    //   0x34 u32  compute_pgm_rsrc2
    //   0x38 u16  kernel_code_properties         ← was at 0x3C (wrong!)
    //   0x3A u16  kernarg_preload (length+offset)
    //   0x3C u32  reserved
    uint64 i = 0
    while i < 64 { uint64 p = kd_h + i; unsafe { *(p as uint8) = 0 }; i = i + 1 }
    uint32 ks   = 0;          unsafe { *((kd_h + 0x08) as uint32) = ks }
    uint64 kce  = 256;        unsafe { *((kd_h + 0x10) as uint64) = kce }
    uint32 r3   = 0x00000010; unsafe { *((kd_h + 0x2C) as uint32) = r3 }
    uint32 r1   = 0xE0AF0000; unsafe { *((kd_h + 0x30) as uint32) = r1 }
    uint32 r2   = 0x0000009E; unsafe { *((kd_h + 0x34) as uint32) = r2 }
    uint16 props = 0x0408;    unsafe { *((kd_h + 0x38) as uint16) = props }
}

fn _hipkfd_boost_init() {
    if _hipkfd_boost_done != 0 { return }
    // GTT + PUBLIC + EXECUTABLE so the CPU can write the kernel image
    // and the CP can fetch instructions from it. gfx11 requires the
    // kernel-code entry to be 256-byte aligned (CP fetches in 256 B
    // bursts and ignores low bits when computing the wave's PC base).
    // KD is 64 B at offset 0; place the image at offset 256.
    uint64 va = dev_alloc_aql_ring(4096)
    _hipkfd_boost_kd_va = va
    _hipkfd_boost_va    = va + 256
    uint64 kd_h  = dev_host_ptr(va)
    uint64 img_h = kd_h + 256
    _hipkfd_boost_emit_image(img_h)
    _hipkfd_boost_emit_kd(kd_h)
    _hipkfd_boost_done = 1
}

// Generic boost dispatch on a caller-provided queue. Used by both the
// inline-on-user-queue path (kept as an opt-in fallback) and the
// dedicated boost-queue path driven by the keepalive thread.
fn _hipkfd_boost_dispatch_on(uint64 ring_host, uint64 ring_cap,
                              uint64 wp_host, uint64 db_host, uint64 rp_host) {
    if _hipkfd_boost_done == 0 { return }

    uint64 wp = 0; unsafe { *(wp_host as uint64) -> wp }
    uint64 rp = 0; unsafe { *(rp_host as uint64) -> rp }
    while (wp - rp) >= ring_cap {
        unsafe { *(rp_host as uint64) -> rp }
    }
    uint64 slot   = wp - (wp / ring_cap) * ring_cap
    uint64 packet = ring_host + slot * 64

    uint16 bx16 = 32; unsafe { *((packet + 0x04) as uint16) = bx16 }
    uint16 by16 = 1;  unsafe { *((packet + 0x06) as uint16) = by16 }
    uint16 bz16 = 1;  unsafe { *((packet + 0x08) as uint16) = bz16 }
    uint16 r0   = 0;  unsafe { *((packet + 0x0A) as uint16) = r0 }
    uint32 g_x  = 32; unsafe { *((packet + 0x0C) as uint32) = g_x }
    uint32 g_y  = 1;  unsafe { *((packet + 0x10) as uint32) = g_y }
    uint32 g_z  = 1;  unsafe { *((packet + 0x14) as uint32) = g_z }
    uint32 priv0 = 0; unsafe { *((packet + 0x18) as uint32) = priv0 }
    uint32 grp0  = 0; unsafe { *((packet + 0x1C) as uint32) = grp0 }
    unsafe { *((packet + 0x20) as uint64) = _hipkfd_boost_kd_va }
    uint64 zk = 0; unsafe { *((packet + 0x28) as uint64) = zk }
    uint64 r2 = 0; unsafe { *((packet + 0x30) as uint64) = r2 }
    uint64 sigz = 0; unsafe { *((packet + 0x38) as uint64) = sigz }

    _kfd_fence()
    uint32 header_setup = (1 << 16) | 0x1402   // type=2, barrier=0
    unsafe { *((packet + 0x00) as uint32) = header_setup }
    _kfd_fence()
    uint64 new_wp = wp + 1
    unsafe { *(wp_host as uint64) = new_wp }
    _kfd_fence()
    uint64 db_value = new_wp - 1
    unsafe { *(db_host as uint64) = db_value }
    _hipkfd_hist_record(_hipkfd_boost_kd_va, 0, header_setup, slot, wp, 1)
}

// Inline boost on the user's compute queue (legacy path).
fn _hipkfd_boost_dispatch() {
    _hipkfd_boost_dispatch_on(_hipkfd_q_ring_host, _hipkfd_q_ring_cap,
                              _hipkfd_q_wp_host,   _hipkfd_q_db_host, _hipkfd_q_rp_host)
}

fn _hipkfd_boost_queue_init() {
    if _hipkfd_boost_q != 0 { return }
    _hipkfd_boost_q = kfd_create_queue(KFD_WAIT_BUSY_POLL)
    uint64 q = _hipkfd_boost_q
    uint64 t1 = 0; unsafe { *((q + 0x18) as uint64) -> t1 }; _hipkfd_boost_q_ring_host = t1
    uint64 t2 = 0; unsafe { *((q + 0x10) as uint64) -> t2 }; _hipkfd_boost_q_ring_cap  = t2
    uint64 t3 = 0; unsafe { *((q + 0x40) as uint64) -> t3 }; _hipkfd_boost_q_wp_host   = t3
    uint64 t4 = 0; unsafe { *((q + 0x28) as uint64) -> t4 }; _hipkfd_boost_q_db_host   = t4
    uint64 t5 = 0; unsafe { *((q + 0x60) as uint64) -> t5 }; _hipkfd_boost_q_rp_host   = t5
    // Prime DPM with one boost wave; user-launch path tops up the
    // queue back to 1-deep on every dispatch.
    _hipkfd_boost_dispatch_on(_hipkfd_boost_q_ring_host,
                               _hipkfd_boost_q_ring_cap,
                               _hipkfd_boost_q_wp_host,
                               _hipkfd_boost_q_db_host,
                               _hipkfd_boost_q_rp_host)
}

fn _hipkfd_sdma_boost_init() {
    if _hipkfd_sdma_boost_q != 0 { return }
    uint64 q = kfd_create_sdma_queue()
    if q == 0 { return }                                // SDMA path not usable
    _hipkfd_sdma_boost_q = q
    uint64 t1 = 0; unsafe { *((q + 0x18) as uint64) -> t1 }; _hipkfd_sdma_boost_ring_h = t1
    uint64 t2 = 0; unsafe { *((q + 0x40) as uint64) -> t2 }; _hipkfd_sdma_boost_wp_h   = t2
    uint64 t3 = 0; unsafe { *((q + 0x28) as uint64) -> t3 }; _hipkfd_sdma_boost_db_h   = t3
    uint64 t4 = 0; unsafe { *((q + 0x60) as uint64) -> t4 }; _hipkfd_sdma_boost_rp_h   = t4
    // VRAM-only buffers (no host pointer needed). dev_try_alloc_vram
    // returns 0 on failure — fall back to skipping mclk-keeper.
    uint64 src = dev_try_alloc_vram(_HIPKFD_SDMA_BOOST_BYTES)
    uint64 dst = dev_try_alloc_vram(_HIPKFD_SDMA_BOOST_BYTES)
    if src == 0 { return }
    if dst == 0 { return }
    _hipkfd_sdma_boost_src = src
    _hipkfd_sdma_boost_dst = dst
}

// Top up the SDMA boost queue with VRAM↔VRAM copies. Each copy is one
// 7-dword (28-byte) PM4 packet; we cap in-flight at _HIPKFD_SDMA_BOOST_DEPTH.
// SDMA wp is a byte cursor mod ring size, not a packet count — the
// kfd_create_sdma_queue stores ring size in bytes at q+0x10.
fn _hipkfd_sdma_boost_topup() {
    if _hipkfd_sdma_boost_q == 0 { return }
    if _hipkfd_sdma_boost_src == 0 { return }
    uint64 cur_wp = 0; unsafe { *(_hipkfd_sdma_boost_wp_h as uint64) -> cur_wp }
    uint64 cur_rp = 0; unsafe { *(_hipkfd_sdma_boost_rp_h as uint64) -> cur_rp }
    uint64 in_flight_bytes = cur_wp - cur_rp
    uint64 pkt_bytes = 28
    uint64 in_flight_pkts = in_flight_bytes / pkt_bytes
    if in_flight_pkts >= _HIPKFD_SDMA_BOOST_DEPTH { return }
    uint64 wp = cur_wp
    uint64 i = in_flight_pkts
    while i < _HIPKFD_SDMA_BOOST_DEPTH {
        wp = _sdma_emit_copy_linear(_hipkfd_sdma_boost_ring_h, wp,
                                     _hipkfd_sdma_boost_src, _hipkfd_sdma_boost_dst,
                                     _HIPKFD_SDMA_BOOST_BYTES)
        i = i + 1
    }
    _kfd_fence()
    unsafe { *(_hipkfd_sdma_boost_wp_h as uint64) = wp }
    _kfd_fence()
    unsafe { *(_hipkfd_sdma_boost_db_h as uint64) = wp }
}

// Top up the boost queue from the user thread on every dispatch.
// Same-queue contention with the user-queue dispatch is zero — they
// have separate ring buffers, doorbells, wp/rp pages.
//
// Topup depth (4) is empirical: deeper topup → more boost waves
// running concurrently with the user kernel → more CU contention →
// user kernel takes longer to retire. Going from 16-deep to 4-deep
// drops the per-launch overhead by ~30 % at M=1024 with no DPM
// regression (DPM samples activity over a coarser window than
// individual packet retirements).
fn _hipkfd_boost_topup() {
    if _hipkfd_boost_q == 0 { return }
    uint64 cur_wp = 0; unsafe { *(_hipkfd_boost_q_wp_host as uint64) -> cur_wp }
    uint64 cur_rp = 0; unsafe { *(_hipkfd_boost_q_rp_host as uint64) -> cur_rp }
    if cur_wp - cur_rp >= 1 { return }
    _hipkfd_boost_dispatch_on(_hipkfd_boost_q_ring_host,
                               _hipkfd_boost_q_ring_cap,
                               _hipkfd_boost_q_wp_host,
                               _hipkfd_boost_q_db_host,
                               _hipkfd_boost_q_rp_host)
}

fn _hipkfd_lazy_init() {
    if _hipkfd_q != 0 { return }
    kfd_init()
    _hipkfd_drm_pin_clocks()
    _hipkfd_q              = kfd_create_queue(KFD_WAIT_BUSY_POLL)
    _hipkfd_signal         = kfd_signal_alloc()
    // kfd_signal_alloc inits value=1 (HSA "in flight" default).
    // For our subtract-on-retire counter we need value=0.
    _hipkfd_signal_h       = dev_host_ptr(_hipkfd_signal)
    uint64 zero = 0
    unsafe { *((_hipkfd_signal_h + 0x08) as uint64) = zero }
    _hipkfd_pending        = 0
    _hipkfd_kernarg_ring   = dev_alloc_host_visible(_HIPKFD_KARG_SLOTS * _HIPKFD_KARG_SLOT_SZ)
    _hipkfd_kernarg_ring_h = dev_host_ptr(_hipkfd_kernarg_ring)
    _hipkfd_karg_slot      = 0

    // Hoist queue-descriptor fields out of the hot path. These are
    // read on every launch in the original _kfd_dispatch_core; with
    // 4 dispatches × 2000 steps that's 48K SMEM loads we can replace
    // with 6 cached statics. (MLRift's `*(p) -> dst` deref-store form
    // doesn't accept a static as dst, so we go through locals.)
    uint64 q = _hipkfd_q
    uint64 t_rh = 0; unsafe { *((q + 0x18) as uint64) -> t_rh }; _hipkfd_q_ring_host = t_rh
    uint64 t_rc = 0; unsafe { *((q + 0x10) as uint64) -> t_rc }; _hipkfd_q_ring_cap  = t_rc
    uint64 t_wh = 0; unsafe { *((q + 0x40) as uint64) -> t_wh }; _hipkfd_q_wp_host   = t_wh
    uint64 t_dh = 0; unsafe { *((q + 0x28) as uint64) -> t_dh }; _hipkfd_q_db_host   = t_dh
    uint64 t_ph = 0; unsafe { *((q + 0x60) as uint64) -> t_ph }; _hipkfd_q_rp_host   = t_ph
    _hipkfd_q_signal_va = _hipkfd_signal

    // Build the GPU-clock keepalive boost kernel + dedicated boost queue,
    // and kick off the background thread that keeps it continuously
    // non-empty.  Must come after the user-queue statics are populated
    // since the boost path uses kfd_create_queue (one-time alloc per
    // queue).  Disable via MLRIFT_BOOST=0 if you want raw cold-clock
    // measurements.
    _hipkfd_boost_init()
    uint64 boost_env = getenv("MLRIFT_BOOST")
    uint64 boost_off = 0
    if boost_env != 0 {
        uint8 bc = 0; unsafe { *(boost_env as uint8) -> bc }
        if bc == 48 { boost_off = 1 }
    }
    if boost_off == 0 {
        _hipkfd_boost_queue_init()
        _hipkfd_sdma_boost_init()
    }
}

// Profiling-timestamp surface for launchers that want to measure
// per-launch GPU runtime independently of the host-side sync wall
// time. The values are gpu_clock_counter ticks; pair with
// hipkfd_clock_sample to convert to host-ns.
fn hipkfd_signal_start_ts() -> uint64 {
    if _hipkfd_signal == 0 { return 0 }
    return kfd_signal_start_ts(_hipkfd_signal)
}
fn hipkfd_signal_end_ts() -> uint64 {
    if _hipkfd_signal == 0 { return 0 }
    return kfd_signal_end_ts(_hipkfd_signal)
}

// hipkfd_clock_sample: anchor (gpu_ticks, sys_ns) at the current
// instant. Two calls seconds apart let the user back out gpu_freq
// (gfx11 reports gpu ticks at a fixed rate, typically 100 MHz on
// RDNA3 — verify by sampling).
fn hipkfd_clock_sample(uint64 out_gpu_ticks, uint64 out_sys_ns) {
    _hipkfd_lazy_init()
    uint64 cpu_slot  = alloc(8)
    uint64 freq_slot = alloc(8)
    raw_kfd_get_clock_counters(kfd_fd(), kfd_gpu_id(),
                                out_gpu_ticks, cpu_slot,
                                out_sys_ns,    freq_slot)
}

// --- Error handling ---
// HIP error strings are pointers into libamdhip64 .rodata. We don't
// have one; return a fixed string so callers that print the message
// still see something sensible.
fn hipGetErrorString(uint32 err) -> uint64 {
    return "<hip-via-kfd: unmapped error>"
}

// --- Device enumeration + selection ---
// kfd_init has already discovered the GPU; report 1 device for any
// query and accept hipSetDevice(0). Other indices fail.
fn hipGetDeviceCount(uint64 count_ptr) -> uint32 {
    _hipkfd_lazy_init()
    uint64 one = 1
    unsafe { *(count_ptr as uint64) = one }
    return 0
}

fn hipSetDevice(uint32 dev_id) -> uint32 {
    _hipkfd_lazy_init()
    if dev_id == 0 { return 0 }
    return 1
}

// --- Device memory ---
// HIP semantics: dev_ptr_ptr is a pointer to a uint64 slot the caller
// owns; on success we write the device VA there.
//
// Backed by dev_alloc_smart_hostvis: try host-visible VRAM first
// (HBM bandwidth for the device side, ReBar-mapped on host), then
// host-visible GTT. Always returns a buffer with a real host
// pointer, so hipMemcpy keeps working through dev_host_ptr.
//
// Performance impact for noesis_60m_gpu_launch (5 GiB working set):
// VRAM-side ~960 GB/s instead of ~32 GB/s GTT, expected to drop
// sim_us from 425s into the same ballpark as ROCm/HIP (~28s) when
// ReBar is enabled and the working set fits in VRAM. Allocations
// that exceed BAR / VRAM headroom transparently spill to GTT.
fn hipMalloc(uint64 dev_ptr_ptr, uint64 size) -> uint32 {
    _hipkfd_lazy_init()
    uint64 dptr = dev_alloc_smart_hostvis(size)
    if dptr == 0 { return 2 }                                // hipErrorOutOfMemory
    unsafe { *(dev_ptr_ptr as uint64) = dptr }
    return 0
}

fn hipFree(uint64 dev_ptr) -> uint32 {
    if dev_ptr == 0 { return 0 }
    dev_free(dev_ptr)
    return 0
}

// Run the registered _kfd_copy_u64 kernel: device-side u64 memcpy
// from `src_va` (typically host-mapped VRAM) into `dst_va` (typically
// GTT staging). nbytes must be 8-byte aligned. Returns 1 if the
// kernel ran, 0 if no copy kernel is registered.
fn _hipkfd_dev_copy(uint64 dst_va, uint64 src_va, uint64 nbytes) -> uint64 {
    if _hipkfd_copy_kernel_kd == 0 { return 0 }
    if (nbytes - (nbytes / 8) * 8) != 0 { return 0 }   // not 8-aligned
    _hipkfd_lazy_init()

    uint64 n_u64 = nbytes / 8

    // Pack a 24-byte kernarg blob (dst, src, n).
    uint64 slot_idx = _hipkfd_karg_slot
    uint64 slot_off = slot_idx * _HIPKFD_KARG_SLOT_SZ
    uint64 karg_va  = _hipkfd_kernarg_ring + slot_off
    uint64 karg_h   = _hipkfd_kernarg_ring_h + slot_off
    _hipkfd_karg_slot = slot_idx + 1
    if _hipkfd_karg_slot >= _HIPKFD_KARG_SLOTS { _hipkfd_karg_slot = 0 }
    unsafe { *((karg_h + 0x00) as uint64) = dst_va }
    unsafe { *((karg_h + 0x08) as uint64) = src_va }
    unsafe { *((karg_h + 0x10) as uint64) = n_u64 }

    // Block 256, grid = ceil(n_u64 / 256).
    uint64 block = 256
    uint64 grid = (n_u64 + 255) / 256

    // Same async-batch dispatch path used by hipModuleLaunchKernel.
    uint64 one = 1
    _hipkfd_pending = _hipkfd_pending - one
    _kfd_dispatch_core(_hipkfd_q, _hipkfd_copy_kernel_kd,
                        grid, 1, 1, block, 1, 1,
                        karg_va, _hipkfd_copy_kernel_ks,
                        _hipkfd_signal)
    return 1
}

// hipMemcpy kinds: 0 = H2H, 1 = H2D, 2 = D2H, 3 = D2D, 4 = Default.
fn hipMemcpy(uint64 dst, uint64 src, uint64 size, uint32 kind) -> uint32 {
    if kind == 1 {
        // H2D. CPU stores to KFD's BAR1-mapped VRAM go through write-
        // combined PCIe; per-core WC flushes are PCIe-latency bound at
        // ~2 GB/s. We split each H2D across 4 worker threads to drive
        // 4 separate WC queues to the PCIe controller in parallel —
        // empirically a 3-4× throughput win.
        //
        // We also have an SDMA-engine path (_hipkfd_h2d_sdma) ready for
        // future use: USERPTR-pin the source RAM, kick a PM4 SDMA
        // COPY_LINEAR, drain. On this RX 7800 XT the PCIe controller's
        // SDMA engine bench at ~the same rate as 4 cores' WC writes,
        // and USERPTR pin-time + per-packet drain eats the DMA savings,
        // so it lands ~150 ms slower on the noesis 7×480 MB H2D phase.
        // Kept opt-in: enable by setting MLRIFT_USE_SDMA=1.
        if size >= 0x100000 {                              // ≥1 MB worth doing
            uint64 sdma_env = getenv("MLRIFT_USE_SDMA")
            uint64 use_sdma = 0
            if sdma_env != 0 {
                uint8 c = 0; unsafe { *(sdma_env as uint8) -> c }
                if c != 48 { use_sdma = 1 }
            }
            if use_sdma > 0 {
                if _hipkfd_h2d_sdma(dst, src, size) == 1 { return 0 }
            }
            uint64 dst_h = dev_host_ptr(dst)
            _hipkfd_h2d_parallel(dst_h, src, size)
            return 0
        }
        dev_copy_h2d(src, dst, size)
    } else if kind == 2 {
        // D2H. If the source is host-mapped VRAM, the CPU-side memcpy
        // would read at PCIe BAR1 speed (~1.3 GB/s on gfx1100); for
        // anything bigger than a few MB that dominates total runtime.
        // Path through the registered _kfd_copy_u64 kernel into a
        // GTT staging buffer, then memcpy GTT->host.
        if _hipkfd_copy_kernel_kd != 0 {
            uint64 size_aligned = (size / 8) * 8
            if size_aligned == size {
                // Fast path: any non-GTT source. dev_alloc_kind == 1
                // (host-vis VRAM) is the case that benefits most;
                // kind 0 (VRAM-only without host pointer) would also
                // fall through here but dev_copy_d2h's dev_host_ptr
                // would have failed anyway.
                uint64 srckind = dev_alloc_kind(src)
                if srckind == 1 {
                    if _hipkfd_ensure_stage(size) == 1 {
                        if _hipkfd_dev_copy(_hipkfd_stage_va, src, size) == 1 {
                            hipDeviceSynchronize()
                            memcpy(dst, _hipkfd_stage_h, size)
                            return 0
                        }
                    }
                }
            }
        }
        dev_copy_d2h(src, dst, size)
    } else if kind == 3 {
        // D2D: both sides are device VAs; copy via host views.
        uint64 sh = dev_host_ptr(src)
        uint64 dh = dev_host_ptr(dst)
        memcpy(dh, sh, size)
    } else {
        // H2H (kind 0) or Default (kind 4): treat as plain host memcpy.
        memcpy(dst, src, size)
    }
    return 0
}

// --- Synchronisation ---
// hipModuleLaunchKernel is ASYNC; hipDeviceSynchronize drains via the
// shared signal counter (signal value == _hipkfd_pending iff all
// launched kernels have retired). _hipkfd_pending is the negative of
// the launch count in unsigned wrap-around — equivalent to "after
// every dispatched kernel atomic-decrements by 1, we expect this".
fn hipDeviceSynchronize() -> uint32 {
    if _hipkfd_q == 0 { return 0 }
    if _hipkfd_signal_h == 0 { return 0 }
    uint64 sig_addr = _hipkfd_signal_h + 0x08
    uint64 v = 0; unsafe { *(sig_addr as uint64) -> v }

    uint64 spin = 0
    while v != _hipkfd_pending {
        spin = spin + 1
        if spin > 30000000000 {
            kfd_die("hipDeviceSynchronize: timeout draining queue", spin)
        }
        unsafe { *(sig_addr as uint64) -> v }
    }
    return 0
}

// --- Module loading ---
// blob_ptr is host memory the user already loaded (typical pattern is
// file_open + file_size + file_read into an alloc'd buffer). We don't
// know the size from the HIP signature; kernel_load_from_blob only
// reads ELF e_phoff/e_phnum/etc., which lie at fixed offsets, so we
// pass 0 as a placeholder for the recorded size — it's only stored
// in the mod handle for diagnostics, not used by KFD itself.
fn hipModuleLoadData(uint64 mod_out, uint64 blob_ptr) -> uint32 {
    _hipkfd_lazy_init()
    uint64 mod = kernel_load_from_blob(blob_ptr, 0)
    unsafe { *(mod_out as uint64) = mod }

    // If this module ships a `_kfd_copy_u64` symbol, register it as
    // the HIP-shim's device-side copy kernel. The hipMemcpy(D2H)
    // fast path uses it when the source is host-mapped VRAM, where
    // CPU-side reads from PCIe BAR1 are ~20x slower than HBM reads.
    // Only the first module that defines the symbol wins; subsequent
    // loads keep using the original.
    if _hipkfd_copy_kernel_kd == 0 {
        uint64 ck = kernel_get_function(mod, "_kfd_copy_u64")
        if ck != 0 {
            _hipkfd_copy_kernel_kd = ck
            _hipkfd_copy_kernel_ks = kernel_kernarg_size(mod, ck)
        }
    }
    return 0
}

// hipModuleGetFunction returns a function handle. We need to remember
// kernarg_size for hipModuleLaunchKernel, so the handle is a small
// wrapper struct (32 bytes):
//   [0x00] kd_va               (u64)  — what kfd_dispatch wants
//   [0x08] kernarg_size        (u64)  — read from the kernel descriptor
//   [0x10] nargs               (u64)  — kernarg_size/8, precomputed
//   [0x18] group_segment_size  (u64)  — KD's static LDS bytes; the shim
//                                       needs this to populate AQL
fn hipModuleGetFunction(uint64 fn_out, uint64 mod, uint64 name_cstr) -> uint32 {
    uint64 kd_va = kernel_get_function(mod, name_cstr)
    if kd_va == 0 {
        // Symbol not in this module. Return hipErrorNotFound (500) so
        // launchers using the primary-then-fallback pattern can retry
        // against a different module rather than dying.
        return 500
    }
    uint64 ks    = kernel_kernarg_size(mod, kd_va)
    uint64 gss   = kernel_group_segment_size(mod, kd_va)
    uint64 wrap  = alloc(32)
    unsafe { *((wrap + 0x00) as uint64) = kd_va }
    unsafe { *((wrap + 0x08) as uint64) = ks }
    uint64 nargs = ks / 8
    unsafe { *((wrap + 0x10) as uint64) = nargs }
    unsafe { *((wrap + 0x18) as uint64) = gss }
    unsafe { *(fn_out as uint64) = wrap }
    return 0
}

// hipModuleLaunchKernel:
//   * fn_handle: wrapper from hipModuleGetFunction.
//   * grid_*  : workgroup count (HIP/CUDA convention; kfd_dispatch
//               multiplies by block_* internally for the AQL grid_size).
//   * shared_bytes / stream / extra: ignored.
//   * kernel_params: void** — array of pointers to per-arg 8-byte
//                    storage. Caller already populated each slot.
fn hipModuleLaunchKernel(
    uint64 fn_handle,
    uint32 grid_x, uint32 grid_y, uint32 grid_z,
    uint32 block_x, uint32 block_y, uint32 block_z,
    uint32 shared_bytes,
    uint64 stream,
    uint64 kernel_params,
    uint64 extra
) -> uint32 {
    // Hot path: noesis_60m_gpu_launch hits this 8000 times per run.
    // Everything that can be hoisted out has been.
    _hipkfd_lazy_init()                           // fast path: 1 load + branch
    uint64 kd_va = 0; unsafe { *((fn_handle + 0x00) as uint64) -> kd_va }
    uint64 ks    = 0; unsafe { *((fn_handle + 0x08) as uint64) -> ks }
    uint64 nargs = 0; unsafe { *((fn_handle + 0x10) as uint64) -> nargs }
    uint64 gss   = 0; unsafe { *((fn_handle + 0x18) as uint64) -> gss }
    if ks > _HIPKFD_KARG_SLOT_SZ {
        kfd_die("hipModuleLaunchKernel: kernarg_size > 256 (shim slot)", ks)
    }

    // Kernarg-ring slot (bitmask wrap; SLOT_MASK = SLOTS - 1, requires
    // SLOTS to be a power of two — 1024 is).
    uint64 slot_idx = _hipkfd_karg_slot
    uint64 slot_off = slot_idx * _HIPKFD_KARG_SLOT_SZ
    uint64 karg_va  = _hipkfd_kernarg_ring + slot_off
    uint64 karg_h   = _hipkfd_kernarg_ring_h + slot_off
    _hipkfd_karg_slot = (slot_idx + 1) & _HIPKFD_KARG_SLOT_MASK

    // Pre-zero the whole slot before unmarshal. clang-compiled COv5
    // kernels declare a kernarg_size that includes ~256 bytes of
    // hidden args (printf/hostcall/heap-base pointers etc.); the
    // launcher only fills the explicit prefix and the unmarshal loop
    // breaks at the first NULL slot, so without zeroing first the
    // hidden region carries stale data from a prior launch and the
    // kernel reads bogus dispatch geometry. Native-emitted kernels
    // (no hidden args) pay 16-32 8-byte writes per launch — far less
    // than the COv5 hidden-arg-corruption tax.
    uint64 zi = 0
    while zi < ks {
        uint64 zp = karg_h + zi
        uint64 zero = 0
        unsafe { *(zp as uint64) = zero }
        zi = zi + 8
    }

    // Unmarshal HIP ptr_table → contiguous KFD kernarg blob. nargs is
    // pre-computed in fn_handle so we avoid the ks/8 div per launch.
    // The loop breaks at the first NULL slot — `i` after exit is the
    // explicit-arg count, which is what we need to find the start of
    // the COv5 hidden-arg region below.
    uint64 i = 0
    while i < nargs {
        uint64 slot_ptr = 0
        unsafe { *((kernel_params + i * 8) as uint64) -> slot_ptr }
        if slot_ptr == 0 { break }
        uint64 v = 0
        unsafe { *(slot_ptr as uint64) -> v }
        unsafe { *((karg_h + i * 8) as uint64) = v }
        i = i + 1
    }
    uint64 explicit_args = i

    // Fill clang's COv5 hidden-arg region. Layout (verified against
    // amdhsa.kernels msgpack metadata for gfx1100, clang 19+):
    //   explicit_size + 0   u32 hidden_block_count_x   = grid_x
    //   explicit_size + 4   u32 hidden_block_count_y   = grid_y
    //   explicit_size + 8   u32 hidden_block_count_z   = grid_z
    //   explicit_size + 12  u16 hidden_group_size_x    = block_x
    //   explicit_size + 14  u16 hidden_group_size_y    = block_y
    //   explicit_size + 16  u16 hidden_group_size_z    = block_z
    //   explicit_size + 18  u16 hidden_remainder_x     = 0 (clean div)
    //   explicit_size + 20  u16 hidden_remainder_y     = 0
    //   explicit_size + 22  u16 hidden_remainder_z     = 0
    //   explicit_size + 40  u64 hidden_global_offset_x = 0
    //   explicit_size + 48  u64 hidden_global_offset_y = 0
    //   explicit_size + 56  u64 hidden_global_offset_z = 0
    //   explicit_size + 64  u16 hidden_grid_dims       = ndim (1/2/3)
    //
    // Offsets 24..39 are msgpack-reserved (printf_buffer / hostcall /
    // multigrid / heap_v1) — pre-zero leaves them as null pointers,
    // which is correct behaviour as long as the kernel doesn't use
    // printf or hostcall (none of our kernels do).
    //
    // Without this fill, group_size_x = 0 and `wg_id * group_size + tid`
    // collapses to `tid`; every block computes the same lane range so
    // outputs past block 0 are stale. That's both bugs we hit at once
    // (M=4096 wrong outputs + ~60 ms fixed-cost stall — the stall was
    // the GPU spinning on the "all-blocks-write-the-same-place" race).
    uint64 hidden_base = karg_h + explicit_args * 8
    uint32 gx32 = grid_x;  unsafe { *((hidden_base +  0) as uint32) = gx32 }
    uint32 gy32 = grid_y;  unsafe { *((hidden_base +  4) as uint32) = gy32 }
    uint32 gz32 = grid_z;  unsafe { *((hidden_base +  8) as uint32) = gz32 }
    uint16 hbx = block_x;  unsafe { *((hidden_base + 12) as uint16) = hbx }
    uint16 hby = block_y;  unsafe { *((hidden_base + 14) as uint16) = hby }
    uint16 hbz = block_z;  unsafe { *((hidden_base + 16) as uint16) = hbz }
    // hidden_grid_dims: 1 for x-only, 2 if y>1, 3 if z>1.
    uint16 ndim = 1
    if grid_y > 1 { ndim = 2 }
    if grid_z > 1 { ndim = 3 }
    if block_y > 1 { ndim = 2 }
    if block_z > 1 { ndim = 3 }
    unsafe { *((hidden_base + 64) as uint16) = ndim }
    // remainder_*, global_offset_* already zero from the slot pre-zero.

    // Async dispatch with shared completion signal.
    uint64 one = 1
    _hipkfd_pending = _hipkfd_pending - one

    // Inline _kfd_dispatch_core: avoid the function-call frame setup
    // (which on noesis_60m hits 8000 times). Body is identical to
    // std/kfd.mlr's _kfd_dispatch_core; queue-descriptor fields are
    // read from cached statics (lazy_init pulled them once from the
    // queue struct), so we skip 6 SMEM loads per launch.
    uint64 ring_host     = _hipkfd_q_ring_host
    uint64 ring_capacity = _hipkfd_q_ring_cap
    uint64 wp_host       = _hipkfd_q_wp_host
    uint64 db_host       = _hipkfd_q_db_host
    uint64 rp_host       = _hipkfd_q_rp_host

    uint64 wp = 0; unsafe { *(wp_host as uint64) -> wp }

    uint64 rp = 0
    unsafe { *(rp_host as uint64) -> rp }
    while (wp - rp) >= ring_capacity {
        unsafe { *(rp_host as uint64) -> rp }
    }

    uint64 slot = wp - (wp / ring_capacity) * ring_capacity
    uint64 packet = ring_host + slot * 64

    uint32 setup = 1
    if grid_y > 1 { setup = 2 }
    if grid_z > 1 { setup = 3 }

    uint16 bx16 = block_x; unsafe { *((packet + 0x04) as uint16) = bx16 }
    uint16 by16 = block_y; unsafe { *((packet + 0x06) as uint16) = by16 }
    uint16 bz16 = block_z; unsafe { *((packet + 0x08) as uint16) = bz16 }
    uint16 r0 = 0;         unsafe { *((packet + 0x0A) as uint16) = r0 }
    uint32 g_x = grid_x * block_x; unsafe { *((packet + 0x0C) as uint32) = g_x }
    uint32 g_y = grid_y * block_y; unsafe { *((packet + 0x10) as uint32) = g_y }
    uint32 g_z = grid_z * block_z; unsafe { *((packet + 0x14) as uint32) = g_z }
    uint32 priv0 = 0;    unsafe { *((packet + 0x18) as uint32) = priv0 }
    // AQL group_segment_size = KD static LDS + caller's dynamic shared.
    // KFD CP allocates LDS based on AQL, NOT KD; without this, kernels
    // declaring static LDS in KD silently get 0 bytes allocated and
    // ds_load returns 0 (LDS round-trip fails). HIP runtime sets this
    // bit; we have to as well or LDS-using kernels are dead on arrival.
    uint32 grp0  = gss + shared_bytes
    unsafe { *((packet + 0x1C) as uint32) = grp0  }
    unsafe { *((packet + 0x20) as uint64) = kd_va }
    unsafe { *((packet + 0x28) as uint64) = karg_va }
    uint64 r2 = 0;       unsafe { *((packet + 0x30) as uint64) = r2 }
    unsafe { *((packet + 0x38) as uint64) = _hipkfd_signal }

    _kfd_fence()

    uint32 header_setup = (setup << 16) | 0x1502
    unsafe { *((packet + 0x00) as uint32) = header_setup }

    _kfd_fence()

    uint64 new_wp = wp + 1
    unsafe { *(wp_host as uint64) = new_wp }
    _kfd_fence()
    uint64 db_value = new_wp - 1
    unsafe { *(db_host as uint64) = db_value }
    _hipkfd_hist_record(kd_va, karg_va, header_setup, slot, wp, 0)

    // GPU-clock keepalive: top up the dedicated boost queue if the
    // CP has drained it below the threshold. Boost queue is on its
    // own AQL ring / doorbell / wp / rp — zero contention with the
    // user queue. This runs from the user thread (no separate
    // keepalive thread needed); refilling 16-deep at most adds
    // ~16 packet writes (~few hundred ns).
    uint64 boost_env = getenv("MLRIFT_BOOST")
    uint64 boost_off = 0
    if boost_env != 0 {
        uint8 bc = 0; unsafe { *(boost_env as uint8) -> bc }
        if bc == 48 { boost_off = 1 }
    }
    if boost_off == 0 {
        _hipkfd_boost_topup()
        _hipkfd_sdma_boost_topup()
    }

    return 0
}
