// Step-A smoke: drives the fused attn_decode_f32 kernel through the
// gpu_attn_decode_to_dev launcher in std/inference_gpu.mlr.  Same
// shape + verifier as attn_decode_smoke but routed through the
// reusable wrapper that the qwen3 forward path will eventually call.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-attn-decode-f32=/tmp/attn_decode_f32.co dummy
//   MLRIFT_GPU_MATMUL=1 ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/attn_decode_launcher_smoke.mlr -o /tmp/attn_decode_launcher_smoke
// Run:
//   MLRIFT_GPU_MATMUL=1 /tmp/attn_decode_launcher_smoke

import "../../std/hip.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/time.mlr"
import "../../std/math_float.mlr"
import "../../std/inference_gpu.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn exit(uint64 code)

fn die(uint64 msg, uint64 code) {
    print_str(msg); print_str(" e="); u64 s = fmt_dec(code); print_str(s); dealloc(s); print_str("\n"); exit(1)
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    // Make sure inference_gpu's lazy init runs — that's what loads the CO.
    if gpu_matmul_enabled() == 0 {
        print_str("MLRIFT_GPU_MATMUL not set — exiting\n"); exit(1)
    }

    u64 q_bytes  = 16 * 128 * 4
    u64 kv_bytes = 64 * 8 * 128 * 4

    u64 d_q = 0; u64 d_kc = 0; u64 d_vc = 0; u64 d_out = 0
    u64 slot
    slot = alloc(8); err = hipMalloc(slot, q_bytes);  if err != 0 { die("mq",  err) }; unsafe { *(slot as u64) -> d_q }
    slot = alloc(8); err = hipMalloc(slot, kv_bytes); if err != 0 { die("mkc", err) }; unsafe { *(slot as u64) -> d_kc }
    slot = alloc(8); err = hipMalloc(slot, kv_bytes); if err != 0 { die("mvc", err) }; unsafe { *(slot as u64) -> d_vc }
    slot = alloc(8); err = hipMalloc(slot, q_bytes);  if err != 0 { die("mo",  err) }; unsafe { *(slot as u64) -> d_out }

    u64 pos_plus_1 = 4
    u64 max_seq = 64; u64 nkv = 8; u64 hd = 128

    // Q
    u64 h_q = alloc(q_bytes)
    u64 i = 0
    while i < 16 * 128 {
        f64 v = int_to_f64(i) * 0.001
        u64 p = h_q + i * 4
        unsafe { *(p as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_q, h_q, q_bytes, 1); if err != 0 { die("H2D q", err) }

    // K
    u64 h_kc = alloc(kv_bytes)
    i = 0
    while i < max_seq * nkv * hd {
        u64 ipos = i / (nkv * hd)
        u64 ikv  = (i / hd) % nkv
        u64 ij   = i % hd
        f64 v = int_to_f64(ipos) * 10000.0 + int_to_f64(ikv) * 1000.0 + int_to_f64(ij)
        u64 p = h_kc + i * 4
        unsafe { *(p as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_kc, h_kc, kv_bytes, 1); if err != 0 { die("H2D kc", err) }

    // V
    u64 h_vc = alloc(kv_bytes)
    i = 0
    while i < max_seq * nkv * hd {
        u64 ipos = i / (nkv * hd)
        u64 ikv  = (i / hd) % nkv
        u64 ij   = i % hd
        f64 v = (int_to_f64(ipos) + 1.0) * 0.01
              + int_to_f64(ikv) * 0.001
              + int_to_f64(ij) * 0.0001
        u64 p = h_vc + i * 4
        unsafe { *(p as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_vc, h_vc, kv_bytes, 1); if err != 0 { die("H2D vc", err) }

    // Drive through the launcher.
    u64 t0 = time_now()
    u64 rc = gpu_attn_decode_to_dev(d_q, d_kc, d_vc, d_out, pos_plus_1)
    if rc != 0 { die("launcher rc", rc) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }
    u64 t1 = time_now()

    u64 h_out = alloc(q_bytes)
    err = hipMemcpy(h_out, d_out, q_bytes, 2); if err != 0 { die("D2H", err) }
    print_str("launcher kernel_us="); u64 s = fmt_dec((t1 - t0) / 1000); print_str(s); dealloc(s); print_str("\n")

    // Verify (same as attn_decode_smoke.mlr).
    u64 fail = 0
    f64 inv_sqrt_dk = 1.0 / 11.31370849898476
    u64 head = 0
    while head < 16 {
        u64 kvh = head / 2
        u64 sb = alloc(pos_plus_1 * 8)
        f64 mx = -1.0e15
        u64 pos = 0
        while pos < pos_plus_1 {
            f64 sum = 0.0
            u64 j = 0
            while j < 128 {
                f64 qv = int_to_f64(head * 128 + j) * 0.001
                f64 kv = int_to_f64(pos) * 10000.0
                       + int_to_f64(kvh) * 1000.0
                       + int_to_f64(j)
                sum = sum + qv * kv
                j = j + 1
            }
            f64 sv = sum * inv_sqrt_dk
            unsafe { *((sb + pos * 8) as f64) = sv }
            if sv > mx { mx = sv }
            pos = pos + 1
        }
        f64 esum = 0.0
        pos = 0
        while pos < pos_plus_1 {
            f64 sv = 0.0
            unsafe { *((sb + pos * 8) as f64) -> sv }
            f64 ev = exp_f64(sv - mx)
            unsafe { *((sb + pos * 8) as f64) = ev }
            esum = esum + ev
            pos = pos + 1
        }
        pos = 0
        while pos < pos_plus_1 {
            f64 ev = 0.0
            unsafe { *((sb + pos * 8) as f64) -> ev }
            unsafe { *((sb + pos * 8) as f64) = ev / esum }
            pos = pos + 1
        }
        u64 j = 0
        while j < 128 {
            f64 acc = 0.0
            pos = 0
            while pos < pos_plus_1 {
                f64 wv = 0.0
                unsafe { *((sb + pos * 8) as f64) -> wv }
                f64 vv = (int_to_f64(pos) + 1.0) * 0.01
                       + int_to_f64(kvh) * 0.001
                       + int_to_f64(j) * 0.0001
                acc = acc + wv * vv
                pos = pos + 1
            }
            f32 expected_f = f64_to_f32(acc)
            f32 actual = 0.0f
            unsafe { *((h_out + (head * 128 + j) * 4) as f32) -> actual }
            f32 d = actual - expected_f
            if d < 0.0f { d = 0.0f - d }
            f32 abs_e = expected_f
            if abs_e < 0.0f { abs_e = 0.0f - abs_e }
            f32 thresh = abs_e * 0.01f
            if thresh < 0.00001f { thresh = 0.00001f }
            if d > thresh { fail = fail + 1 }
            j = j + 1
        }
        dealloc(sb)
        head = head + 1
    }
    print_str("attn (via launcher) fail count (out of 2048): "); u64 sf = fmt_dec(fail); print_str(sf); dealloc(sf); print_str("\n")
    if fail == 0 {
        print_str("OK — gpu_attn_decode_to_dev wrapper works.\n"); exit(0)
    } else {
        print_str("FAIL\n"); exit(1)
    }
}
