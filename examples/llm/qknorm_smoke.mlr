// Step-D smoke #1: validates gpu_qknorm_f32_to_dev (M-row × N=128
// fused RMSNorm) against the CPU qwen3_rmsnorm_f32_weights reference
// at Qwen3-0.6B head-dim shape.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-rmsnorm-f32-N=128:/tmp/rmsnorm_f32_128.co dummy
//   MLRIFT_GPU_MATMUL=1 ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/qknorm_smoke.mlr -o /tmp/qknorm_smoke
// Run:
//   MLRIFT_GPU_MATMUL=1 /tmp/qknorm_smoke

import "../../std/hip.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/math_float.mlr"
import "../../std/inference_gpu.mlr"
import "../../std/qwen3.mlr"

@dynamic extern fn exit(uint64 code)

fn die(uint64 msg, uint64 code) {
    print_str(msg); print_str(" e="); u64 s = fmt_dec(code); print_str(s); dealloc(s); print_str("\n"); exit(1)
}

fn rand_step(u64 state_ptr) -> f32 {
    u32 s = 0; unsafe { *(state_ptr as u32) -> s }
    s = s ^ (s << 13)
    s = s ^ (s >> 17)
    s = s ^ (s << 5)
    unsafe { *(state_ptr as u32) = s }
    u32 hi32 = s >> 8
    u64 hi = hi32
    f32 v = int_to_f32(hi) / 8388608.0f - 1.0f
    return v
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }
    if gpu_matmul_enabled() == 0 { print_str("MLRIFT_GPU_MATMUL not set\n"); exit(1) }

    u64 M = 16    // 16 Q heads
    u64 N = 128
    u64 bytes_in  = M * N * 4
    u64 bytes_g   = N * 4

    // Host buffers + ref output.
    u64 h_in   = alloc(bytes_in)
    u64 h_g    = alloc(bytes_g)
    u64 h_ref  = alloc(bytes_in)
    u64 h_gpu  = alloc(bytes_in)
    u64 seed_slot = alloc(4); unsafe { *(seed_slot as u32) = 0xC0FFEE99 }

    u64 i = 0
    while i < M * N {
        // Simple deterministic in [-1, 1): fmod-style.
        f64 vd = int_to_f64(i * 7 + 3) * 0.011 - 1.0
        while vd > 1.0 { vd = vd - 2.0 }
        while vd < -1.0 { vd = vd + 2.0 }
        unsafe { *((h_in + i * 4) as f32) = f64_to_f32(vd) }
        i = i + 1
    }
    i = 0
    while i < N {
        f64 vd = 1.0 + 0.05 * (int_to_f64(i) * 0.013 - 1.0)
        unsafe { *((h_g + i * 4) as f32) = f64_to_f32(vd) }
        i = i + 1
    }
    dealloc(seed_slot)

    // CPU reference: M independent rmsnorms with shared gamma.
    u64 h = 0
    while h < M {
        qwen3_rmsnorm_f32_weights(h_ref + h * N * 4, h_in + h * N * 4, h_g, N)
        h = h + 1
    }

    // GPU: H2D, dispatch, D2H.
    u64 d_in  = 0; u64 d_out = 0; u64 d_g = 0
    u64 slot
    slot = alloc(8); err = hipMalloc(slot, bytes_in); if err != 0 { die("min",  err) }; unsafe { *(slot as u64) -> d_in }
    slot = alloc(8); err = hipMalloc(slot, bytes_in); if err != 0 { die("mout", err) }; unsafe { *(slot as u64) -> d_out }
    slot = alloc(8); err = hipMalloc(slot, bytes_g);  if err != 0 { die("mg",   err) }; unsafe { *(slot as u64) -> d_g }
    err = hipMemcpy(d_in, h_in, bytes_in, 1); if err != 0 { die("H2D in", err) }
    err = hipMemcpy(d_g,  h_g,  bytes_g,  1); if err != 0 { die("H2D g",  err) }

    if gpu_qknorm_f32_to_dev(d_out, d_in, d_g, M) != 0 { die("launch", 0) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }
    err = hipMemcpy(h_gpu, d_out, bytes_in, 2); if err != 0 { die("D2H", err) }

    // Compare.
    u64 fail = 0
    f32 max_abs = 0.0f
    u64 k = 0
    while k < M * N {
        f32 cv = 0.0f; unsafe { *((h_ref + k * 4) as f32) -> cv }
        f32 gv = 0.0f; unsafe { *((h_gpu + k * 4) as f32) -> gv }
        f32 d = cv - gv; if d < 0.0f { d = 0.0f - d }
        if d > max_abs { max_abs = d }
        if d > 0.0001f { fail = fail + 1 }
        k = k + 1
    }
    print_str("qknorm fail count: "); u64 sf = fmt_dec(fail); print_str(sf); dealloc(sf)
    print_str(" / "); u64 stot = fmt_dec(M * N); print_str(stot); dealloc(stot); print_str("\n")
    u64 mb = alloc(4); unsafe { *(mb as f32) = max_abs }
    u32 mb_b = 0; unsafe { *(mb as u32) -> mb_b }
    u64 mb64 = mb_b
    print_str("max abs diff bits="); u64 smb = fmt_dec(mb64); print_str(smb); dealloc(smb); print_str("\n"); dealloc(mb)
    if fail == 0 {
        print_str("OK — gpu_qknorm_f32_to_dev matches CPU rmsnorm.\n"); exit(0)
    } else {
        // Sanity: print first input as f32 + bits.
        f32 in0 = 0.0f; unsafe { *((h_in + 0) as f32) -> in0 }
        u32 in0b = 0; unsafe { *((h_in + 0) as u32) -> in0b }
        u64 in0b64 = in0b
        print_str("h_in[0] bits="); u64 sib = fmt_dec(in0b64); print_str(sib); dealloc(sib); print_str("\n")
        print_str("FAIL — first 8 values (in / cpu / gpu f32 bits):\n")
        u64 jj = 0
        while jj < 8 {
            u32 ib = 0; unsafe { *((h_in  + jj * 4) as u32) -> ib }
            u32 cb = 0; unsafe { *((h_ref + jj * 4) as u32) -> cb }
            u32 gb = 0; unsafe { *((h_gpu + jj * 4) as u32) -> gb }
            u64 ib64 = ib; u64 cb64 = cb; u64 gb64 = gb
            print_str("  ["); u64 sj = fmt_dec(jj); print_str(sj); dealloc(sj)
            print_str("] in="); u64 si = fmt_dec(ib64); print_str(si); dealloc(si)
            print_str(" cpu="); u64 sc = fmt_dec(cb64); print_str(sc); dealloc(sc)
            print_str(" gpu="); u64 sg = fmt_dec(gb64); print_str(sg); dealloc(sg)
            print_str("\n")
            jj = jj + 1
        }
        exit(1)
    }
}
