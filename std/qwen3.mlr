// MLRift Standard Library — Qwen3 forward-pass primitives
//
// Layer 0 numerical verification target (Qwen3-0.6B, input token 14990 "hello",
// fp32 reference from transformers 5.6.2):
//   hidden_states after layer 0, first 5 values:
//     [-0.2150, 0.3201, 0.0887, -1.2590, -0.0759]
//
// Qwen3 architecture (config.json → this file's hard-coded constants for now):
//   hidden_size            = 1024
//   head_dim               = 128
//   num_attention_heads    = 16
//   num_key_value_heads    = 8
//   intermediate_size      = 3072
//   rms_norm_eps           = 1e-6
//   rope_theta             = 1_000_000
//   hidden_act             = silu (SwiGLU: gate * silu(gate) * up, then down_proj)
//   tie_word_embeddings    = true
//   QK-Norm                = per-head-dim RMSNorm applied to Q and K (shape
//                            [head_dim], no +1 bias shift)
//
// Weights are BF16 row-major (HuggingFace safetensors convention):
//   embed_tokens.weight: [vocab_size, hidden]
//   q_proj.weight:       [num_heads * head_dim, hidden]           = [2048, 1024]
//   k_proj.weight:       [num_kv_heads * head_dim, hidden]        = [1024, 1024]
//   v_proj.weight:       [num_kv_heads * head_dim, hidden]        = [1024, 1024]
//   o_proj.weight:       [hidden, num_heads * head_dim]           = [1024, 2048]
//   q_norm.weight:       [head_dim] = [128]
//   k_norm.weight:       [head_dim] = [128]
//   input_layernorm.weight / post_attention_layernorm.weight: [hidden]
//   gate_proj / up_proj: [intermediate_size, hidden]              = [3072, 1024]
//   down_proj:           [hidden, intermediate_size]              = [1024, 3072]

import "inference.mlr"
import "safetensors.mlr"
import "math_float.mlr"
import "thread.mlr"
import "fmt.mlr"
import "io.mlr"

// -----------------------------------------------------------------------------
// Qwen3-0.6B architectural constants. Phase 1 keeps these as compile-time
// globals; the eventual engine will read them from config.json instead.
// -----------------------------------------------------------------------------
static u64 QWEN3_HIDDEN         = 1024
static u64 QWEN3_HEAD_DIM       = 128
static u64 QWEN3_N_HEADS        = 16
static u64 QWEN3_N_KV_HEADS     = 8
static u64 QWEN3_Q_DIM          = 2048   // N_HEADS × HEAD_DIM
static u64 QWEN3_KV_DIM         = 1024   // N_KV_HEADS × HEAD_DIM
static u64 QWEN3_INTERMEDIATE   = 3072
static u64 QWEN3_ROPE_DIM       = 128    // head_dim (full RoPE across the head)

// rope_theta = 1e6 (big-number base for long-context positional encoding).
// Expressed as f64 because 1e6 is exact in float64 but not a compile-time
// integer-friendly constant to keep in the source as f32 / u64.

// -----------------------------------------------------------------------------
// RMSNorm without the (1 + w) shift used by Gemma. Standard Qwen/Llama form:
//   y = x * rsqrt(mean(x²) + eps) * w
// -----------------------------------------------------------------------------
fn qwen3_rmsnorm_bf16(u64 out_ptr, u64 in_ptr, u64 w_ptr, u64 dim) {
    // sum of squares in f32
    f32 sum_sq = 0.0f
    u64 i = 0
    while i < dim {
        f32 v = 0.0f
        unsafe { *((in_ptr + i * 4) as f32) -> v }
        sum_sq = sum_sq + v * v
        i = i + 1
    }
    f32 mean_sq = sum_sq / int_to_f32(dim)

    // eps = 1e-6f — same bit-pattern trick as std/inference.mlr
    uint64[1] eps_tmp
    u64 ep = eps_tmp
    u8 e0 = 0x61; u8 e1 = 0x18; u8 e2 = 0x86; u8 e3 = 0x35
    store8(ep + 0, e0); store8(ep + 1, e1); store8(ep + 2, e2); store8(ep + 3, e3)
    f32 eps = 0.0f
    unsafe { *(ep as f32) -> eps }

    f32 one  = 1.0f
    f32 rsq  = one / sqrt_f32(mean_sq + eps)

    i = 0
    while i < dim {
        f32 v = 0.0f
        unsafe { *((in_ptr + i * 4) as f32) -> v }
        f32 w = bf16_to_f32(w_ptr + i * 2)    // bf16 weight → f32
        f32 y = v * rsq * w
        unsafe { *((out_ptr + i * 4) as f32) = y }
        i = i + 1
    }
}

// Same RMSNorm but the weight is already in f32. Used when QK-Norm's
// 128-entry weight has been widened once into a scratch buffer.
fn qwen3_rmsnorm_f32_weights(u64 out_ptr, u64 in_ptr, u64 w_ptr, u64 dim) {
    f32 sum_sq = 0.0f
    u64 i = 0
    while i < dim {
        f32 v = 0.0f
        unsafe { *((in_ptr + i * 4) as f32) -> v }
        sum_sq = sum_sq + v * v
        i = i + 1
    }
    f32 mean_sq = sum_sq / int_to_f32(dim)

    uint64[1] eps_tmp
    u64 ep = eps_tmp
    u8 e0 = 0x61; u8 e1 = 0x18; u8 e2 = 0x86; u8 e3 = 0x35
    store8(ep + 0, e0); store8(ep + 1, e1); store8(ep + 2, e2); store8(ep + 3, e3)
    f32 eps = 0.0f
    unsafe { *(ep as f32) -> eps }

    f32 one = 1.0f
    f32 rsq = one / sqrt_f32(mean_sq + eps)

    i = 0
    while i < dim {
        f32 v = 0.0f
        unsafe { *((in_ptr + i * 4) as f32) -> v }
        f32 w = 0.0f
        unsafe { *((w_ptr + i * 4) as f32) -> w }
        f32 y = v * rsq * w
        unsafe { *((out_ptr + i * 4) as f32) = y }
        i = i + 1
    }
}

// Widen a BF16 weight row of `dim` elements into an f32 scratch buffer.
// Used once per QK-Norm weight per layer so the inner-loop normalise doesn't
// redecode the same 128 bytes for every head.
fn qwen3_bf16_row_to_f32(u64 out_ptr, u64 src_ptr, u64 dim) {
    u64 i = 0
    while i < dim {
        f32 v = bf16_to_f32(src_ptr + i * 2)
        unsafe { *((out_ptr + i * 4) as f32) = v }
        i = i + 1
    }
}


// -----------------------------------------------------------------------------
// RoPE (rotary positional embedding)
//
// Reference (transformers/models/qwen3/modeling_qwen3.py):
//   inv_freq[i] = 1 / (theta^(2i/rope_dim)),  i = 0..rope_dim/2-1
//   cos[p, i]   = cos(p * inv_freq[i])
//   sin[p, i]   = sin(p * inv_freq[i])
//   # rotate_half splits the last dim in half:
//   x1 = x[..., :rope_dim/2]
//   x2 = x[..., rope_dim/2:]
//   x_rot = cat([x1*cos - x2*sin,  x1*sin + x2*cos], dim=-1)
//
// For single-token Phase-1 verification, position=0 → cos=1, sin=0 and RoPE
// is the identity. We still emit the code path so Phase 2 (multi-token) uses
// the same helpers without rewriting.
// -----------------------------------------------------------------------------

// Compute cos/sin for a single position into two f32 buffers of
// length rope_dim/2. Caller keeps them stack-local.
fn qwen3_rope_compute(u64 cos_out, u64 sin_out, u64 position, u64 rope_dim, f64 theta_base) {
    u64 half = rope_dim / 2
    // Fast path: position 0 → cos = 1, sin = 0 for all frequencies.
    // Skips 64 log+exp calls per layer, which is the heaviest constant-cost
    // path in the forward pass at the single-token Phase-1 test point.
    if position == 0 {
        f32 one_f = 1.0f
        f32 zero_f = 0.0f
        u64 i = 0
        while i < half {
            unsafe { *((cos_out + i * 4) as f32) = one_f }
            unsafe { *((sin_out + i * 4) as f32) = zero_f }
            i = i + 1
        }
        return
    }
    u64 i = 0
    while i < half {
        f64 exponent = int_to_f64(2 * i) / int_to_f64(rope_dim)
        f64 denom = pow_f64(theta_base, exponent)
        f64 inv_freq = int_to_f64(1) / denom
        f64 angle = int_to_f64(position) * inv_freq
        f32 c = f64_to_f32(cos_f64(angle))
        f32 s = f64_to_f32(sin_f64(angle))
        unsafe { *((cos_out + i * 4) as f32) = c }
        unsafe { *((sin_out + i * 4) as f32) = s }
        i = i + 1
    }
}

// Apply RoPE in-place to a [n_heads, head_dim] f32 buffer. cos/sin are
// shared across heads (same position for every head).
fn qwen3_rope_apply(u64 x_ptr, u64 cos_ptr, u64 sin_ptr, u64 n_heads, u64 head_dim) {
    u64 half = head_dim / 2
    u64 h = 0
    while h < n_heads {
        u64 row = x_ptr + h * head_dim * 4
        u64 i = 0
        while i < half {
            f32 x1 = 0.0f
            f32 x2 = 0.0f
            unsafe { *((row + i * 4) as f32) -> x1 }
            unsafe { *((row + (i + half) * 4) as f32) -> x2 }
            f32 c = 0.0f
            f32 s = 0.0f
            unsafe { *((cos_ptr + i * 4) as f32) -> c }
            unsafe { *((sin_ptr + i * 4) as f32) -> s }
            f32 y1 = x1 * c - x2 * s
            f32 y2 = x1 * s + x2 * c
            unsafe { *((row + i * 4) as f32) = y1 }
            unsafe { *((row + (i + half) * 4) as f32) = y2 }
            i = i + 1
        }
        h = h + 1
    }
}

// -----------------------------------------------------------------------------
// Cached scaled-dot-product attention with grouped-query broadcast.
//
// For each query head h: scores[t] = (q[h] · K_cache[t, kvh]) * scale for
// t in [0, seq_len), softmax with max-subtraction (numerically stable),
// then out[h] = sum_t softmax[t] * V_cache[t, kvh].
//
// Cache layout (per layer, f32):
//   K_cache: [max_seq, n_kv_heads, head_dim] row-major
//   V_cache: same shape
// Offset to K_cache[t, kvh, 0] = (t * n_kv_heads + kvh) * head_dim * 4 bytes.
//
// The caller is expected to have written the current token's K and V into
// K_cache[pos] / V_cache[pos] already (post QK-norm + RoPE for K). Then call
// here with seq_len = pos + 1. Causal masking is implicit — we only attend
// over positions 0..seq_len-1, which are exactly the ones written so far.
//
// q_ptr: f32 [n_heads, head_dim]    (current token's Q, post QK-norm + RoPE)
// out:   f32 [n_heads, head_dim]
// GQA: kvh = (h * n_kv_heads) / n_heads.
// -----------------------------------------------------------------------------
fn qwen3_attn_cached(u64 out_ptr,
                     u64 q_ptr, u64 k_cache, u64 v_cache,
                     u64 seq_len,
                     u64 n_heads, u64 n_kv_heads, u64 head_dim) {
    f32 scale = 1.0f / sqrt_f32(int_to_f32(head_dim))
    u64 kv_row_bytes = n_kv_heads * head_dim * 4

    u64 h = 0
    while h < n_heads {
        u64 kvh = (h * n_kv_heads) / n_heads
        u64 q_row = q_ptr   + h * head_dim * 4
        u64 o_row = out_ptr + h * head_dim * 4

        // Pass 1: find max raw score across positions. Scores computed on the
        // fly (no scratch buffer — a tiny MLRift codegen bug was corrupting
        // a 2-entry f32[] scratch here).
        f32 max_score = 0.0f
        u64 first = 1
        u64 t = 0
        while t < seq_len {
            u64 k_row = k_cache + t * kv_row_bytes + kvh * head_dim * 4
            f32 s = 0.0f
            u64 d = 0
            while d < head_dim {
                f32 qv = 0.0f; unsafe { *((q_row + d * 4) as f32) -> qv }
                f32 kv = 0.0f; unsafe { *((k_row + d * 4) as f32) -> kv }
                s = s + qv * kv
                d = d + 1
            }
            s = s * scale
            if first == 1 {
                max_score = s
                first = 0
            } else {
                if s > max_score { max_score = s }
            }
            t = t + 1
        }

        // Zero output row. We accumulate e*V[t] into it in pass 2, then
        // divide by sum_exp at the end.
        f32 zero = 0.0f
        u64 d0 = 0
        while d0 < head_dim {
            unsafe { *((o_row + d0 * 4) as f32) = zero }
            d0 = d0 + 1
        }

        // Pass 2: recompute each score, e = exp(score - max), accumulate
        // e*V[t] into o_row, and accumulate sum_exp. Recomputing scores
        // costs one extra Q·K dot per position (tiny vs V accumulate).
        f32 sum_exp = 0.0f
        t = 0
        while t < seq_len {
            u64 k_row = k_cache + t * kv_row_bytes + kvh * head_dim * 4
            u64 v_row = v_cache + t * kv_row_bytes + kvh * head_dim * 4
            f32 s = 0.0f
            u64 d = 0
            while d < head_dim {
                f32 qv = 0.0f; unsafe { *((q_row + d * 4) as f32) -> qv }
                f32 kv = 0.0f; unsafe { *((k_row + d * 4) as f32) -> kv }
                s = s + qv * kv
                d = d + 1
            }
            s = s * scale
            f32 e = exp_f32_fast(s - max_score)
            sum_exp = sum_exp + e
            u64 d2 = 0
            while d2 < head_dim {
                f32 vv = 0.0f; unsafe { *((v_row + d2 * 4) as f32) -> vv }
                f32 ov = 0.0f; unsafe { *((o_row + d2 * 4) as f32) -> ov }
                unsafe { *((o_row + d2 * 4) as f32) = ov + e * vv }
                d2 = d2 + 1
            }
            t = t + 1
        }

        // Normalize: out /= sum_exp
        f32 inv_sum = 1.0f / sum_exp
        u64 dn = 0
        while dn < head_dim {
            f32 ov = 0.0f; unsafe { *((o_row + dn * 4) as f32) -> ov }
            unsafe { *((o_row + dn * 4) as f32) = ov * inv_sum }
            dn = dn + 1
        }

        h = h + 1
    }
}

// -----------------------------------------------------------------------------
// SwiGLU FFN
//   gate = gate_proj(x)            [intermediate]
//   up   = up_proj(x)              [intermediate]
//   h    = silu(gate) * up         [intermediate]
//   y    = down_proj(h)            [hidden]
// silu(x) = x / (1 + exp(-x)) = x * sigmoid(x)
// -----------------------------------------------------------------------------
fn qwen3_silu_mul(u64 out_ptr, u64 gate_ptr, u64 up_ptr, u64 dim) {
    u64 i = 0
    f32 one = 1.0f
    while i < dim {
        f32 g = 0.0f; unsafe { *((gate_ptr + i * 4) as f32) -> g }
        f32 u = 0.0f; unsafe { *((up_ptr   + i * 4) as f32) -> u }
        // sigmoid(g) = 1/(1+exp(-g))
        f32 sig = one / (one + exp_f32_fast(0.0f - g))
        f32 y = g * sig * u
        unsafe { *((out_ptr + i * 4) as f32) = y }
        i = i + 1
    }
}

// Reasonably-accurate single-precision exp. std/math_float.mlr's exp_f64
// has a bug: for negative arguments it skips the 2^k scaling (k is negative,
// f64_double_n doesn't handle that), returning the raw Taylor-reduced value.
// So exp(-50) comes out ~1.84 instead of ~1.9e-22 — catastrophic for SiLU on
// large positive gate activations where sigmoid(g) = 1/(1+exp(-g)) needs a
// correct exp of a large negative number. Work around by pushing negative
// arguments through the positive path via reciprocal.
fn exp_f32_fast(f32 x) -> f32 {
    f64 xd = f32_to_f64(x)
    f64 zero = int_to_f64(0)
    f64 one = int_to_f64(1)
    if xd < zero {
        f64 pos = zero - xd
        f64 yp  = exp_f64(pos)
        return f64_to_f32(one / yp)
    }
    f64 yd = exp_f64(xd)
    return f64_to_f32(yd)
}

// -----------------------------------------------------------------------------
// One full transformer layer (no KV cache, single token at position `pos`).
//
// Inputs:
//   x_in    — f32 [hidden]  residual stream at layer entry
//   weights — pointers to the 11 BF16 tensors this layer needs:
//             input_norm_w, q_proj_w, k_proj_w, v_proj_w, q_norm_w, k_norm_w,
//             o_proj_w, post_attn_norm_w, gate_proj_w, up_proj_w, down_proj_w
//   pos     — absolute position (0 for first token)
//
// Output:
//   x_out — f32 [hidden], hidden state after this layer (residual stream)
//
// Allocates scratch internally for readability; production path can bring
// scratches in from the caller to avoid per-layer allocs.
// -----------------------------------------------------------------------------
struct Qwen3LayerWeights {
    u64 input_norm_w
    u64 q_proj_w
    u64 k_proj_w
    u64 v_proj_w
    u64 q_norm_w
    u64 k_norm_w
    u64 o_proj_w
    u64 post_norm_w
    u64 gate_proj_w
    u64 up_proj_w
    u64 down_proj_w
}

// Dump file FD — caller sets via qwen3_set_dump_fd before calling forward_layer.
// 0 = no dumping.
static u64 qwen3_dump_fd = 0

fn qwen3_set_dump_fd(u64 fd) { qwen3_dump_fd = fd }

// Internal: emit a labelled "[label] v0 v1 v2 v3 v4\n" line to the dump fd.
fn qwen3_dump5(u64 label, u64 ptr) {
    if qwen3_dump_fd == 0 { return }
    u64 ll = str_len(label)
    file_write(qwen3_dump_fd, "[", 1)
    file_write(qwen3_dump_fd, label, ll)
    file_write(qwen3_dump_fd, "] ", 2)
    u64 i = 0
    while i < 5 {
        if i != 0 { file_write(qwen3_dump_fd, " ", 1) }
        f32 v = 0.0f
        unsafe { *((ptr + i * 4) as f32) -> v }
        u64 s = fmt_f32(v, 6)
        u64 sl = str_len(s)
        file_write(qwen3_dump_fd, s, sl)
        dealloc(s)
        i = i + 1
    }
    file_write(qwen3_dump_fd, "\n", 1)
}

fn qwen3_forward_layer(u64 x_out, u64 x_in,
                       Qwen3LayerWeights w,
                       u64 pos,
                       u64 k_cache_layer, u64 v_cache_layer,
                       u64 num_workers) {
    u64 hidden = QWEN3_HIDDEN
    u64 hd     = QWEN3_HEAD_DIM
    u64 nh     = QWEN3_N_HEADS
    u64 nkv    = QWEN3_N_KV_HEADS
    u64 q_dim  = QWEN3_Q_DIM
    u64 kv_dim = QWEN3_KV_DIM
    u64 ff     = QWEN3_INTERMEDIATE

    u64 kv_row_bytes = nkv * hd * 4
    u64 k_row = k_cache_layer + pos * kv_row_bytes
    u64 v_row = v_cache_layer + pos * kv_row_bytes

    // qwen3_dump5("x_in",   x_in)
    u64 resid = alloc(hidden * 4)
    memcpy(resid, x_in, hidden * 4)

    u64 x_norm = alloc(hidden * 4)
    qwen3_rmsnorm_bf16(x_norm, x_in, w.input_norm_w, hidden)
    // qwen3_dump5("x_norm", x_norm)

    // Q / K / V projections. K and V target the cache slot at `pos` directly;
    // downstream QK-norm and RoPE mutate the cache in place. V is stored raw
    // (no norm, no RoPE — Qwen3 only rotates Q and K).
    u64 q_buf = alloc(q_dim * 4)
    // Q / K / V projections — one matmul each. Not on the residual
    // stream, so the naive accumulator is plenty (Kahan-off). The
    // residual-stream ones (o_proj, down_proj) below keep Kahan on.
    matmul_bf16_weights_f32(q_buf, x_norm, w.q_proj_w, 1, q_dim,  hidden, num_workers, 0)
    matmul_bf16_weights_f32(k_row, x_norm, w.k_proj_w, 1, kv_dim, hidden, num_workers, 0)
    matmul_bf16_weights_f32(v_row, x_norm, w.v_proj_w, 1, kv_dim, hidden, num_workers, 0)
    // qwen3_dump5("q_raw", q_buf)
    // qwen3_dump5("q_raw_h1", q_buf + 128 * 4)
    // qwen3_dump5("k_raw", k_row)
    // qwen3_dump5("k_raw_64", k_row + 64 * 4)
    // qwen3_dump5("v_raw", v_row)

    u64 qk_w_f32 = alloc(hd * 4)
    qwen3_bf16_row_to_f32(qk_w_f32, w.q_norm_w, hd)
    u64 h = 0
    while h < nh {
        u64 q_slice = q_buf + h * hd * 4
        qwen3_rmsnorm_f32_weights(q_slice, q_slice, qk_w_f32, hd)
        h = h + 1
    }
    qwen3_bf16_row_to_f32(qk_w_f32, w.k_norm_w, hd)
    h = 0
    while h < nkv {
        u64 k_slice = k_row + h * hd * 4
        qwen3_rmsnorm_f32_weights(k_slice, k_slice, qk_w_f32, hd)
        h = h + 1
    }
    dealloc(qk_w_f32)
    // qwen3_dump5("q_norm", q_buf)
    // qwen3_dump5("q_norm_h0_64", q_buf + 64 * 4)
    // qwen3_dump5("q_norm_h1", q_buf + 128 * 4)
    // qwen3_dump5("k_norm", k_row)
    // qwen3_dump5("k_norm_h0_64", k_row + 64 * 4)

    u64 cos_buf = alloc((hd / 2) * 4)
    u64 sin_buf = alloc((hd / 2) * 4)
    f64 theta = 1000000.0
    qwen3_rope_compute(cos_buf, sin_buf, pos, hd, theta)
    qwen3_rope_apply(q_buf, cos_buf, sin_buf, nh,  hd)
    qwen3_rope_apply(k_row, cos_buf, sin_buf, nkv, hd)
    dealloc(cos_buf)
    dealloc(sin_buf)
    // qwen3_dump5("q_rope", q_buf)
    // qwen3_dump5("k_rope_cur", k_row)
    // qwen3_dump5("k_rope_pos0", k_cache_layer)

    // Cache-aware attention over positions 0..pos (inclusive). V_cache is
    // already populated at index `pos` by the matmul above.
    u64 attn_out = alloc(q_dim * 4)
    qwen3_attn_cached(attn_out, q_buf,
                      k_cache_layer, v_cache_layer,
                      pos + 1, nh, nkv, hd)
    // qwen3_dump5("attn",   attn_out)

    u64 o_buf = alloc(hidden * 4)
    // o_proj feeds the first residual add. Kahan was needed on the
    // scalar path to avoid argmax drift; the AVX2 naive kernel is
    // precise enough on Qwen3-0.6B (verified bit-identical tokens).
    matmul_bf16_weights_f32(o_buf, attn_out, w.o_proj_w, 1, hidden, q_dim, num_workers, 0)
    // qwen3_dump5("o_out",  o_buf)

    // Residual add: x = resid + o_buf
    u64 mid = alloc(hidden * 4)
    u64 i = 0
    while i < hidden {
        f32 a = 0.0f; unsafe { *((resid + i * 4) as f32) -> a }
        f32 b = 0.0f; unsafe { *((o_buf + i * 4) as f32) -> b }
        f32 y = a + b
        unsafe { *((mid + i * 4) as f32) = y }
        i = i + 1
    }

    // qwen3_dump5("mid",    mid)
    u64 mid_norm = alloc(hidden * 4)
    qwen3_rmsnorm_bf16(mid_norm, mid, w.post_norm_w, hidden)
    // qwen3_dump5("mid_norm", mid_norm)

    u64 gate_buf = alloc(ff * 4)
    u64 up_buf   = alloc(ff * 4)
    // gate_proj and up_proj feed silu(gate) * up, not a residual — Kahan off.
    matmul_bf16_weights_f32(gate_buf, mid_norm, w.gate_proj_w, 1, ff, hidden, num_workers, 0)
    // qwen3_dump5("gate",   gate_buf)
    matmul_bf16_weights_f32(up_buf,   mid_norm, w.up_proj_w,   1, ff, hidden, num_workers, 0)
    // qwen3_dump5("up",     up_buf)
    u64 ff_buf = alloc(ff * 4)
    qwen3_silu_mul(ff_buf, gate_buf, up_buf, ff)
    // qwen3_dump5("silu",   ff_buf)
    // down_proj via the shared MT matmul. The old hand-inlined single-thread
    // loop was kept while the IR-store-8-byte bug was still in the compiler;
    // that's fixed now, so the MT path works and parallelises the 3M-element
    // hotspot.
    u64 ff_out = alloc(hidden * 4)
    // down_proj feeds the second residual add. See note on o_proj above —
    // AVX2 naive preserves argmax on Qwen3-0.6B.
    matmul_bf16_weights_f32(ff_out, ff_buf, w.down_proj_w, 1, hidden, ff, num_workers, 0)
    // qwen3_dump5("ff_out", ff_out)

    // Second residual add: x_out = mid + ff_out
    i = 0
    while i < hidden {
        f32 a = 0.0f; unsafe { *((mid + i * 4) as f32) -> a }
        f32 b = 0.0f; unsafe { *((ff_out + i * 4) as f32) -> b }
        f32 y = a + b
        unsafe { *((x_out + i * 4) as f32) = y }
        i = i + 1
    }

    dealloc(resid); dealloc(x_norm)
    dealloc(q_buf)
    dealloc(attn_out); dealloc(o_buf)
    dealloc(mid); dealloc(mid_norm)
    dealloc(gate_buf); dealloc(up_buf); dealloc(ff_buf); dealloc(ff_out)
}
