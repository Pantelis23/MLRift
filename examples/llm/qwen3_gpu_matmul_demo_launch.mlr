// qwen3 GPU matmul demo — exercises std/inference_gpu.mlr's
// matmul_bf16_weights_f32_gpu against a real Qwen3-0.6B q_proj.weight
// pulled out of model.safetensors.  Compares device output against
// CPU reference for one M=1 decode-shape matmul.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-bf16-to-f32=/tmp/bf16_to_f32.co dummy
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-gemv-f32=/tmp/gemv_f32.co dummy
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-gemm-f32=/tmp/gemm_f32.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/qwen3_gpu_matmul_demo_launch.mlr -o /tmp/qwen3_gpu_matmul_demo_kfd
// Run:
//   MLRIFT_GPU_MATMUL=1 /tmp/qwen3_gpu_matmul_demo_kfd

import "../../std/hip.mlr"
import "../../std/inference_gpu.mlr"
import "../../std/safetensors.mlr"
import "../../std/inference.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/thread.mlr"
import "../../std/time.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn main() {
    u64 num_workers = 16
    thread_pool_init(num_workers)

    u32 err = hipSetDevice(0)
    if err != 0 { puts("setDev failed"); exit(1) }

    u64 enabled = gpu_matmul_enabled()
    if enabled == 0 {
        puts("gpu_matmul DISABLED — set MLRIFT_GPU_MATMUL=1 and ensure")
        puts("/tmp/{bf16_to_f32,gemv_f32}.co exist.  Falling back to CPU-only run.")
    } else {
        puts("gpu_matmul ENABLED")
    }

    u64 path = "/home/pantelis/Desktop/Projects/Work/MLRift-experimental/Qwen3-0.6B/model.safetensors"
    SafetensorFile st = safetensors_open(path)
    if st.file_size == 0 { puts("[demo] safetensors_open failed"); exit(1) }

    // Pull q_proj from layer 0.  Shape: [num_heads * head_dim, hidden] = [2048, 1024]
    SafetensorView wv = safetensors_get(st, "model.layers.0.self_attn.q_proj.weight")
    if wv.ptr == 0 { puts("[demo] q_proj not found"); exit(1) }
    u64 N = 2048
    u64 K = 1024
    if wv.len != N * K * 2 {
        puts("[demo] unexpected q_proj byte length")
        exit(1)
    }

    // Synthetic input vector x[K], deterministic.
    u64 x_bytes = K * 4
    u64 x = alloc(x_bytes)
    u64 i = 0
    while i < K {
        f64 v = (int_to_f64(i) * 0.0003) - 0.05
        f32 vf = f64_to_f32(v)
        u64 p = x + i * 4
        unsafe { *(p as f32) = vf }
        i = i + 1
    }

    u64 out_bytes = N * 4
    u64 out_cpu = alloc(out_bytes)
    u64 out_gpu = alloc(out_bytes)

    // === CPU reference ===
    u64 cpu_t0 = time_now()
    matmul_bf16_weights_f32_mt(out_cpu, x, wv.ptr, 1, N, K, num_workers)
    u64 cpu_t1 = time_now()
    u64 cpu_us = (cpu_t1 - cpu_t0) / 1000
    puts("CPU matmul:")
    print_str("  per_call_us: ")
    u64 sa = fmt_dec(cpu_us); print_str(sa); print_str("\n"); dealloc(sa)

    // === GPU dispatch ===
    if enabled == 1 {
        // First call (cold; includes one-shot dequant).
        u64 g_t0 = time_now()
        u64 rc = matmul_bf16_weights_f32_gpu(out_gpu, x, wv.ptr, 1, N, K)
        u64 g_t1 = time_now()
        u64 gpu_cold_us = (g_t1 - g_t0) / 1000
        if rc != 0 { puts("[demo] GPU dispatch returned 1 (fall-through)"); exit(1) }

        // Hot call (cached weight; per-call cost as in the bench).
        u64 h_t0 = time_now()
        u64 rc2 = matmul_bf16_weights_f32_gpu(out_gpu, x, wv.ptr, 1, N, K)
        u64 h_t1 = time_now()
        u64 gpu_hot_us = (h_t1 - h_t0) / 1000
        if rc2 != 0 { puts("[demo] GPU 2nd call fall-through"); exit(1) }

        puts("GPU matmul:")
        print_str("  cold_us (incl one-shot dequant): "); u64 sb = fmt_dec(gpu_cold_us); print_str(sb); print_str("\n"); dealloc(sb)
        print_str("  hot_us  (cached weight):         "); u64 sc = fmt_dec(gpu_hot_us);  print_str(sc); print_str("\n"); dealloc(sc)

        // Compare.  Bf16 quantisation is identical on both paths (CPU
        // also dequants from the same bf16 source), so the only diff
        // is f32 fma reordering across K=1024.
        u64 fail_001 = 0
        u64 fail_01  = 0
        u64 nan_cpu  = 0
        u64 nan_gpu  = 0
        f32 max_finite_abs = 0.0
        u64 j = 0
        while j < N {
            u64 cp = out_cpu + j * 4
            u64 gp = out_gpu + j * 4
            u32 cb = 0; u32 gb = 0
            unsafe { *(cp as u32) -> cb }
            unsafe { *(gp as u32) -> gb }
            // NaN check: exponent all-ones && mantissa nonzero.
            u32 c_exp = (cb >> 23) & 0xFF
            u32 g_exp = (gb >> 23) & 0xFF
            u32 c_man = cb & 0x7FFFFF
            u32 g_man = gb & 0x7FFFFF
            if c_exp == 0xFF && c_man != 0 { nan_cpu = nan_cpu + 1 }
            if g_exp == 0xFF && g_man != 0 { nan_gpu = nan_gpu + 1 }
            f32 cv = 0.0; f32 gv = 0.0
            unsafe { *(cp as f32) -> cv }
            unsafe { *(gp as f32) -> gv }
            f32 d = gv - cv
            if d < 0.0 { d = 0.0 - d }
            // d > thresh tests are false for NaN, so NaN cells don't pollute the counters.
            if d > 0.001 { fail_001 = fail_001 + 1 }
            if d > 0.01  { fail_01  = fail_01  + 1 }
            // track max FINITE abs diff (skip NaN/Inf)
            u64 dbuf = alloc(4); unsafe { *(dbuf as f32) = d }
            u32 dbits = 0; unsafe { *(dbuf as u32) -> dbits }
            u32 d_exp = (dbits >> 23) & 0xFF
            if d_exp != 0xFF {
                if d > max_finite_abs { max_finite_abs = d }
            }
            j = j + 1
        }
        u64 mfb = alloc(4); unsafe { *(mfb as f32) = max_finite_abs }
        u32 mfb_bits = 0; unsafe { *(mfb as u32) -> mfb_bits }
        u64 mfb_bits64 = mfb_bits
        print_str("Verify CPU vs GPU:\n")
        print_str("  cells:                "); u64 sd = fmt_dec(N);            print_str(sd); print_str("\n"); dealloc(sd)
        print_str("  fail_count (>0.001):  "); u64 sea = fmt_dec(fail_001);    print_str(sea); print_str("\n"); dealloc(sea)
        print_str("  fail_count (>0.01):   "); u64 seb = fmt_dec(fail_01);     print_str(seb); print_str("\n"); dealloc(seb)
        print_str("  nan_cells_cpu:        "); u64 sng = fmt_dec(nan_cpu);     print_str(sng); print_str("\n"); dealloc(sng)
        print_str("  nan_cells_gpu:        "); u64 snh = fmt_dec(nan_gpu);     print_str(snh); print_str("\n"); dealloc(snh)
        print_str("  max_finite_abs_bits:  "); u64 sf = fmt_dec(mfb_bits64);   print_str(sf); print_str("\n"); dealloc(sf)

        // Dump first 8 cells, both sides, in raw u32 bit pattern.
        print_str("  diag (first 8 cells, u32 bits):\n")
        u64 di = 0
        while di < 8 {
            u64 cp = out_cpu + di * 4
            u64 gp = out_gpu + di * 4
            u32 cb = 0; u32 gb = 0
            unsafe { *(cp as u32) -> cb }
            unsafe { *(gp as u32) -> gb }
            u64 cb64 = cb; u64 gb64 = gb
            print_str("    ["); u64 sx = fmt_dec(di); print_str(sx); dealloc(sx)
            print_str("] cpu="); u64 sy = fmt_dec(cb64); print_str(sy); dealloc(sy)
            print_str(" gpu=");  u64 sz = fmt_dec(gb64); print_str(sz); dealloc(sz)
            print_str("\n")
            di = di + 1
        }
    }

    safetensors_free(st)
    thread_pool_shutdown()
    exit(0)
}
