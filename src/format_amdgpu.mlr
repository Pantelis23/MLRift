@export
fn emit_amdgpu_softmax_causal_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_softmax_causal_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("softmax_causal_f32", 18,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 16,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1024)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_softmax_causal_f32_blob: cannot open output\n", 57)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

fn amdgpu_lower_llm_softmax_causal_f32(uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 args_desc = alloc(8 * 8)
    _emit_softmax_causal_f32_body(args_desc)
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }
    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 16,
                0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                1024)
    return 0
}

// Shape-parametric softmax_causal_f32. Same body as parametric softmax
// plus a 3-dword causal-mask injection right after the load: lanes
// where col j > row r set v10 = -inf so they contribute 0 to exp-sum
// and don't perturb the max.  N power of two in [32, 1024] = max
// seq_len for the attention-score row.
fn _emit_softmax_causal_f32_body_N(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 Np = _round_up_pow2(N)

    // ── Prologue + load ────────────────────────────────────────────
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)             // s_waitcnt
    asm_u32(0xBF09080F)             // s_cmp_ge_u32 s15, s8
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)             // s_cbranch_scc1 → .Lend (patched)
    asm_u32(0x960C0A0F)
    asm_u32(0x4A02000C)
    asm_u32(0x30080282)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02); asm_u32(0x00020804)
    asm_u32(0xD5207C03); asm_u32(0x01AA0605)
    asm_u32(0x7E1A0280)
    asm_u32(0xD7006A0C); asm_u32(0x00020806)
    asm_u32(0xD5207C0D); asm_u32(0x01AA1A07)
    // Load x. Non-pow2 N: gate to lane<N (default v10 = -inf, which is
    // also the identity for max-reduce AND would-be result of the
    // causal mask for padding lanes since j>=N > r is always true).
    if N != Np {
        _emit_gated_load_v10(12, 10, 0xFF800000)
    } else {
        asm_u32(0xDC520000); asm_u32(0x0A7C0002)
        asm_u32(0xBF8903F7)         // s_waitcnt vmcnt(0)
    }

    // ── Causal mask: if v0 (lane=col) > s15 (row), v10 = -inf ──────
    asm_u32(0xD449000E); asm_u32(0x0002000F)   // v_cmp_lt_u32_e64 s14, s15, v0
    asm_u32(0x7E1E02FF); asm_u32(0xFF800000)   // v_mov_b32 v15, -inf
    asm_u32(0xD501000A); asm_u32(0x003A1F0A)   // v_cndmask_b32_e64 v10, v10, v15, s14

    asm_u32(0x7E0A030A)             // v_mov_b32 v5, v10
    asm_u32(0x300C0082)
    asm_u32(0x7E120280)
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)

    // ── Phase A: max-reduce ────────────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x200A0F05, 12)

    // ── Mid: e = exp(x - max) ──────────────────────────────────────
    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0x0816110A)             // v_sub_f32 v11, v10, v8
    asm_u32(0xBE8C00FF); asm_u32(0x3FB8AA3B)   // log2(e)
    asm_u32(0x1016160C)             // v_mul_f32 v11, s12, v11
    asm_u32(0x7E164B0B)             // v_exp_f32 v11, v11
    asm_u32(0xBFBD0000)
    asm_u32(0x7E0A030B)             // v5 = v11
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)

    // ── Phase B: sum-reduce e ──────────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 12)

    // ── Finalize ───────────────────────────────────────────────────
    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0x7E105508)             // v_rcp_f32 v8, v8
    asm_u32(0x100A110B)             // v_mul_f32 v5, v11, v8
    if N != Np { _emit_store_gate(12, 10) }
    asm_u32(0xDC6A0000); asm_u32(0x007C050C)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Thread-coarsened softmax_causal body for N > 1024. Same approach as
// rmsnorm large-N: block fixed at 1024, K = ceil(N/1024) chunks per
// lane, three passes over the row (max-reduce, sum-of-exp, apply).
// Re-loads x in each pass (no caching).  Causal mask is computed
// per-chunk from v_pos = chunk_off + v0.
fn _emit_softmax_causal_f32_body_NL(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 K = (N + 1023) / 1024
    uint64 last_chunk_size = N - (K - 1) * 1024
    uint64 last_partial = 0
    if last_chunk_size != 1024 { last_partial = 1 }

    // ── Prologue ────────────────────────────────────────────────────
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF09080F)             // s_cmp_ge_u32 s15, s8 (m bound)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)             // s_cbranch_scc1 → .Lend (patched)
    asm_u32(0x960C0A0F)             // s_mul_i32 s12, s15, s10 (row * n)
    asm_u32(0x4A02000C)             // v_add_nc_u32 v1, s12, v0
    asm_u32(0x30080282)             // v_lshlrev_b32 v4, 2, v1
    _emit_vpair_build_from_sbase(2, 4, 4)    // v[2:3] = in_ptr + v4
    _emit_vpair_build_from_sbase(12, 6, 4)   // v[12:13] = out_ptr + v4
    asm_u32(0x300C0082)             // v_lshlrev_b32 v6, 2, v0
    asm_u32(0x7E120280)             // v_mov_b32 v9, 0
    // Initialise v5 = -inf for max-reduce.
    asm_u32(0x7E0A02FF); asm_u32(0xFF800000)

    // ── PASS 1: max-reduce with causal mask ────────────────────────
    uint64 c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        // v_pos = c*1024 + v0  in v18
        _emit_vpos_for_chunk(18, c * 1024)
        // Load x (gated for last partial; default = -inf so masked
        // padding lanes don't perturb the max).
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)   // s12 = limit
            _emit_gated_load_v10(12, 12, 0xFF800000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        // Causal mask via v_pos > s15.
        _emit_causal_mask_v10(12, 18)
        // v5 = max(v5, v10)  → v_max_f32 v5, v5, v10 = 0x200A1505
        asm_u32(0x200A1505)
        c = c + 1
    }

    // ── LDS max-reduce tree at 1024 ─────────────────────────────────
    asm_u32(0xD8340000); asm_u32(0x00000506)   // ds_store v6, v5
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x200A0F05, 12)

    // ── Broadcast max into v8, save to v19 (lives until PASS 3) ─────
    asm_u32(0xD8D80000); asm_u32(0x08000009)   // ds_load v8, v9
    asm_u32(0xBF89FC07)
    asm_u32(0x7E260308)             // v_mov_b32 v19, v8
    asm_u32(0xBFBD0000)             // s_barrier (release LDS)

    // ── Rebuild v[2:3] for PASS 2 ──────────────────────────────────
    _emit_vpair_build_from_sbase(2, 4, 4)

    // ── Initialise v5 = 0 for sum-of-exp reduce ────────────────────
    asm_u32(0x7E0A0280)             // v_mov_b32 v5, 0

    // ── PASS 2: sum-of-exp reduce ──────────────────────────────────
    c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        _emit_vpos_for_chunk(18, c * 1024)
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0xFF800000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        _emit_causal_mask_v10(12, 18)
        // diff = v10 - v19 (= x - max)  → v_sub_f32 v11, v10, v19
        asm_u32(0x0816270A)
        // s12 = log2(e); v11 *= s12
        asm_u32(0xBE8C00FF); asm_u32(0x3FB8AA3B)
        asm_u32(0x1016160C)             // v_mul_f32 v11, s12, v11
        // v11 = 2^v11 = exp(diff)
        asm_u32(0x7E164B0B)
        // v5 += v11  → v_add_f32 v5, v5, v11 = 0x060A1705
        asm_u32(0x060A1705)
        c = c + 1
    }

    // ── LDS sum-reduce tree at 1024 ────────────────────────────────
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 12)

    // ── Broadcast sum into v8, compute inv_sum = rcp(v8) ───────────
    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0x7E105508)             // v_rcp_f32 v8, v8

    // ── Rebuild v[2:3] and v[12:13] for PASS 3 ─────────────────────
    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)

    // ── PASS 3: apply (out = exp(diff) * inv_sum) ──────────────────
    c = 0
    while c < K {
        if c > 0 {
            _emit_vpair_add_imm(2, 4096)
            _emit_vpair_add_imm(12, 4096)
        }
        _emit_vpos_for_chunk(18, c * 1024)
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0xFF800000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        _emit_causal_mask_v10(12, 18)
        // Recompute e = exp((x - max)*log2e)
        asm_u32(0x0816270A)
        asm_u32(0xBE8C00FF); asm_u32(0x3FB8AA3B)
        asm_u32(0x1016160C)
        asm_u32(0x7E164B0B)
        // out = e * inv_sum  → v_mul_f32 v5, v11, v8
        asm_u32(0x100A110B)
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_store_gate(12, 12)
        }
        asm_u32(0xDC6A0000); asm_u32(0x007C050C)
        c = c + 1
    }

    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)             // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_softmax_causal_f32_N_blob(uint64 out_path, uint64 N) -> uint64 {
    if N < 32 || N > 8192 {
        write(2, "emit_amdgpu_softmax_causal_f32_N_blob: N must be in [32, 8192]\n", 64)
        return 1
    }
    uint64[8] args_desc
    uint64 lds_bytes = 0
    if N <= 1024 {
        _emit_softmax_causal_f32_body_N(args_desc, N)
        uint64 Np = _round_up_pow2(N)
        lds_bytes = Np * 4
    } else {
        _emit_softmax_causal_f32_body_NL(args_desc, N)
        lds_bytes = 4096
    }
    uint64 rsrc1 = 0xE0AF0001
    if N > 1024 { rsrc1 = 0xE0AF0002 }
    uint64 size = emit_amdgpu_code_object_lds("softmax_causal_f32", 18,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 20,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_softmax_causal_f32_N_blob: cannot open output\n", 59)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Debug variant of N3: identical KD/dispatch/bounds, but the kernel
// body just stores 1.0 (0x3F800000) to C[row, col]. If output cells
// fail to receive 1.0, the bug is in dispatch/store, not LDS.
@export
fn emit_amdgpu_gemm_f32_lds_debug_blob(uint64 out_path) -> uint64 {
    asm_init()
    // Kernarg load (only need c, n).
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xF4040300); asm_u32(0xF8000020)
    asm_u32(0xF4040380); asm_u32(0xF8000028)
    asm_u32(0xBF89FC07)
    // ty/tx extract.
    asm_u32(0xD6100001); asm_u32(0x02291500)
    asm_u32(0x360000FF); asm_u32(0x000003FF)
    // row, col.
    asm_u32(0x84108403)
    asm_u32(0x84118402)
    asm_u32(0x4A060210)
    asm_u32(0x4A080011)
    // Bounds.
    asm_u32(0xBE82007E)
    asm_u32(0x7C98060A)
    asm_u32(0x8B7E6A7E)
    asm_u32(0x7C98080C)
    asm_u32(0x8B7E6A7E)
    asm_u32(0xBFA50010)                        // s_cbranch_execz +16 → .Lend
    // Compute c address: c_ptr + (row*n + col) * 4
    asm_u32(0xD72C0008); asm_u32(0x00001903)   // v_mul_lo_u32 v8, v3, s12
    asm_u32(0x4A100908)                         // v_add_nc_u32 v8, v8, v4
    asm_u32(0x7E120280)                         // v_mov_b32 v9, 0
    asm_u32(0xD73C0008); asm_u32(0x00021082)   // v_lshlrev_b64 v[8:9], 2, v[8:9]
    asm_u32(0xD7006A08); asm_u32(0x00021008)   // v_add_co_u32 v8, vcc_lo, s8, v8
    asm_u32(0xD5207C09); asm_u32(0x01AA1209)   // v_add_co_ci_u32 v9, null, s9, v9, vcc_lo
    // Store 1.0 (0x3F800000) — load via v_mov_b32 v6, 0x3F800000 (e32 with literal).
    asm_u32(0x7E0C02FF); asm_u32(0x3F800000)   // v_mov_b32 v6, 0x3F800000
    asm_u32(0xDC6A0000); asm_u32(0x007C0608)   // global_store_b32 v[8:9], v6, off
    asm_u32(0xBC7C0000)                         // s_waitcnt_vscnt null, 0
    asm_u32(0xBFB00000)                         // s_endpgm

    uint64[12] args_desc
    uint64 a0  = args_desc + 0;   unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc + 8;   unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }

    // Same KD as N3 (debug must match exactly to isolate bug).
    uint64 size = emit_amdgpu_code_object_lds("gemm_f32_lds", 12,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 14,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1024)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { return 1 }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// AST→AMDGPU lowerer (M1d, extended by M1e).
//
// Two supported kernel shapes. Both require the body to be a
// single PtrStore of a u32 value:
//
//   M1d (1 arg):
//     @kernel fn write_sentinel(uint64 out) {
//         unsafe { *(out as uint32) = INT_LITERAL }
//     }
//
//   M1e (2 args):
//     @kernel fn write_value(uint64 out, uint32 value) {
//         unsafe { *(out as uint32) = value }
//     }
//
// Everything outside those shapes prints an error pointing at the
// offending kernel — the shape grows as the encoder and lowerer do.
//
// Return codes: 0 OK, 1 unsupported shape, 2 I/O failure,
// 3 no @kernel fn in module.
@export
fn emit_amdgpu_from_module(uint64 mod_node, uint64 source, uint64 out_path) -> uint64 {
    // Walk the module for every @kernel fn and lower each into the
    // kernel table. The M1f refactor made emit_amdgpu_multi_code_object
    // accept any number of entries, so all kernels in the .mlr file
    // land in one .co.
    kt_reset()
    uint32 c0 = ast_child(mod_node)
    uint64 wc = c0
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint64 lrc = amdgpu_lower_kernel_to_table(wc, source)
                // 0 = success, 1 = unsupported (hard error),
                // 2 = skip-this-kernel (soft, drop it from the .co
                //     and resolve from a fallback module at launch).
                if lrc == 1 { return lrc }
            }
        }
        uint32 nxt = ast_next(wc)
        wc = nxt
    }
    if kt_count == 0 { return 3 }

    uint64 size = emit_amdgpu_multi_code_object()
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { return 2 }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─────────────────────────────────────────────────────────────────────
// noesis_60m_gpu kernel lowerers
// ─────────────────────────────────────────────────────────────────────
//
// Each of these emits gfx1100 ISA matching one of the four @kernel
// bodies in examples/noesis_60m_gpu.mlr, with kernarg layout matching
// the launcher in examples/noesis_60m_gpu_launch.mlr. The launcher uses
// grid_x = (N+255)/256, block_x = 256, so each kernel computes a global
// thread index gid = wg_id_x * 256 + tid_in_wg before the bounds guard.
//
// The "block_dim = 256" assumption is hardcoded (rather than read from a
// hidden kernarg / dispatch packet) because the launcher always uses
// 256 and reading the dispatch packet here would require extra rsrc2
// bits we don't currently emit. See "Caveats" in /tmp/native_lowering_report.md.
//
// rsrc2 = 0x9E enables 15 user SGPRs; this puts wg_id_x at s15.

// ─── ISA helpers used by the noesis delivery_step lowering ──────────
//
// Encodings verified against llvm-mc in session 2's report; the
// derivations (word1/word2 field decomposition) come from the same
// VOP3/VOP3B/VOP2/VOPC layouts the existing helpers above already
// document. These thin wrappers are kept right next to the noesis
// emitters because the existing structural lowerers don't use them.

// v_mul_lo_u32 vdst, v_src0, v_src1  — VOP3B op 0x02C, low 32 bits of u32×u32.
//   word1 = 0xD72C0000 | (vdst & 0xFF)
//   word2 = ((0x100 | src1) << 9) | (0x100 | src0)
//   Verified: v_mul_lo_u32 v0, v1, v2 → 0xD72C0000 0x00020501.
fn asm_v_mul_lo_u32_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD72C0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_mul_lo_u32 vdst, v_src0, s_src1  — same op, src1 is an SGPR.
//   Verified: v_mul_lo_u32 v3, v0, s4 → 0xD72C0003 0x00000900.
fn asm_v_mul_lo_u32_vs(uint64 vdst, uint64 v_src0, uint64 s_src1) {
    uint64 word1 = 0xD72C0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = s_src1 & 0x1FF                 // SGPR raw
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_lshlrev_b64 v[dst:dst+1], <imm shift 0..63>, v[src:src+1]
//   word1 = 0xD73C0000 | (dst & 0xFF)
//   word2 = (0x100 | src) << 9 | (0x80 + shift)
//   Verified: v_lshlrev_b64 v[2:3], 3, v[0:1]   → 0xD73C0002 0x00020083.
//             v_lshlrev_b64 v[10:11], 3, v[8:9] → 0xD73C000A 0x00021083.
fn asm_v_lshlrev_b64_imm_vv(uint64 vdst_pair, uint64 shift_amount, uint64 v_src_pair) {
    uint64 word1 = 0xD73C0000 | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x80 + (shift_amount & 0x3F)         // inline const
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_u32 vdst, vcc_lo, s_src0, v_src1   (VOP3B op 0x100, writes vcc_lo)
//   word1 = 0xD7006A00 | (vdst & 0xFF)
//   word2 = ((0x100 | v_src1) << 9) | (s_src0 & 0xFF)
//   Verified: v_add_co_u32 v0, vcc_lo, s2, v4 → 0xD7006A00 0x00020802.
//             v_add_co_u32 v6, vcc_lo, s8, v4 → 0xD7006A06 0x00020808.
fn asm_v_add_co_u32_vcc_sv(uint64 vdst, uint64 s_src0, uint64 v_src1) {
    uint64 word1 = 0xD7006A00 | (vdst & 0xFF)
    uint64 src0_enc = s_src0 & 0x1FF                       // SGPR raw
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_ci_u32_e64 vdst, null, s_src0, v_src1, vcc_lo  (op 0x120)
//   Reads vcc_lo (carry-in) and writes a discarded carry-out (null).
//   word1 = 0xD5207C00 | (vdst & 0xFF)
//   word2 = (vcc_lo<<18) | ((0x100|v_src1) << 9) | (s_src0 & 0xFF)
//   Verified: v_add_co_ci_u32_e64 v1, null, s3, v5, vcc_lo → 0xD5207C01 0x01AA0A03.
fn asm_v_add_co_ci_u32_null_sv_vcc(uint64 vdst, uint64 s_src0, uint64 v_src1) {
    uint64 word1 = 0xD5207C00 | (vdst & 0xFF)
    uint64 src0_enc = s_src0 & 0x1FF                       // SGPR raw
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_u32 vdst, vcc_lo, v_src0, v_src1  — VGPR+VGPR variant.
//   word1 = 0xD7006A00 | (vdst & 0xFF)
//   word2 = ((0x100 | v_src1) << 9) | (0x100 | v_src0)
//   Verified: v_add_co_u32 v0, vcc_lo, v2, v4 → 0xD7006A00 0x00020902.
fn asm_v_add_co_u32_vcc_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD7006A00 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_ci_u32_e64 vdst, null, v_src0, v_src1, vcc_lo — VGPR+VGPR variant.
//   Verified: v_add_co_ci_u32_e64 v1, null, v3, v5, vcc_lo → 0xD5207C01 0x01AA0B03.
fn asm_v_add_co_ci_u32_null_vv_vcc(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD5207C00 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// ── Tier 1 primitives (verified via llvm-mc gfx1100) ─────────────────
//
// v_mul_hi_u32 vdst, v_src0, v_src1   (VOP3 op 0x12D)
//   word1 = 0xD72D0000 | vdst
//   word2 = ((0x100|v_src1) << 9) | (0x100|v_src0)
//   Verified: v_mul_hi_u32 v3, v0, v1 → 0xD72D0003 0x00020300.
fn asm_v_mul_hi_u32_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD72D0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_mul_hi_u32 vdst, v_src0, s_src1
//   Verified: v_mul_hi_u32 v3, v0, s4 → 0xD72D0003 0x00000900.
fn asm_v_mul_hi_u32_vs(uint64 vdst, uint64 v_src0, uint64 s_src1) {
    uint64 word1 = 0xD72D0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = s_src1 & 0x1FF
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_lshrrev_b64 v[dst:dst+1], <imm shift 0..63>, v[src:src+1]   (VOP3 op 0x13D)
//   word1 = 0xD73D0000 | (dst & 0xFF)
//   word2 = ((0x100|src_pair) << 9) | (0x80 + shift)
//   Verified: v_lshrrev_b64 v[2:3], 30, v[0:1] → 0xD73D0002 0x0002009E.
//             v_lshrrev_b64 v[2:3], 27, v[0:1] → 0xD73D0002 0x0002009B.
//             v_lshrrev_b64 v[2:3], 31, v[0:1] → 0xD73D0002 0x0002009F.
fn asm_v_lshrrev_b64_imm_vv(uint64 vdst_pair, uint64 shift_amount, uint64 v_src_pair) {
    uint64 word1 = 0xD73D0000 | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x80 + (shift_amount & 0x3F)
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

