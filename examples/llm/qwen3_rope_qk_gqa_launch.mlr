// Qwen3 GQA-aware RoPE pre-attention chain (#30 cont.).
//
// Real GQA shape: Q has [M, num_heads, head_dim], K has
// [M, num_kv_heads, head_dim] with num_kv_heads < num_heads.  Attention
// later broadcasts each KV-head across num_heads/num_kv_heads Q-heads
// (handled inside the Q@K^T matmul).  Before that broadcast, RoPE is
// applied independently to Q and K — the operation is per-head, so
// the kernel runs over different total row counts for Q vs K.
//
// This launcher proves the shape orchestration: same rope_d128.co
// loaded once, called twice with different `m` kernarg values:
//   call 1: m = M * num_heads     (Q rotation)
//   call 2: m = M * num_kv_heads  (K rotation)
//
// Targets a Llama-3-8B-style head config (32 query heads, 8 KV heads,
// group_size = 4) since group_size = pow2 — a separate slice will
// generalise to non-pow2 group_size for Qwen3 family.  head_dim = 128
// (Llama 3 / Qwen3 / Llama 4).
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-rope-f32-D=128:/tmp/rope_d128.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/qwen3_rope_qk_gqa_launch.mlr -o /tmp/qwen3_rope_qk_gqa_kfd
// Run:
//   M=4 /tmp/qwen3_rope_qk_gqa_kfd

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 { i = i - 1; uint64 d = tmp - (tmp / 10) * 10; uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }; tmp = tmp / 10 }
    return n
}
fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len { uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }; uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }; i = i + 1 }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}
fn die(uint64 msg, uint64 code) { puts(msg); print_label_val("e", 1, code); exit(1) }
fn parse_env_count(uint64 name) -> uint64 {
    uint64 s = getenv(name); if s == 0 { return 0 }
    uint64 v = 0; uint64 i = 0
    while 1 == 1 { uint64 cp = s + i; uint64 c = 0; unsafe { *(cp as uint8) -> c }; if c == 0 { break }; if c >= 48 && c <= 57 { v = v * 10 + (c - 48); i = i + 1; continue }; break }
    return v
}

fn fill_qk(uint64 buf, uint64 nrows, uint64 D, f64 base) {
    // Keep magnitudes small so a*cos - b*sin stays in f32's precision
    // band even at M=64 (q_rows reaches 2048).  Larger scale triggers
    // catastrophic-cancellation precision loss documented in rope_f32.
    uint64 r = 0
    while r < nrows {
        uint64 c = 0
        while c < D {
            f64 vd = (int_to_f64(r) * 0.0001 + int_to_f64(c) * 0.0001) + base
            uint64 p = buf + (r * D + c) * 4
            unsafe { *(p as f32) = f64_to_f32(vd) }
            c = c + 1
        }
        r = r + 1
    }
}

fn fill_cos_sin(uint64 cos, uint64 sin, uint64 nrows, uint64 Dh) {
    uint64 r = 0
    while r < nrows {
        uint64 c = 0
        while c < Dh {
            uint64 idx = r * Dh + c
            uint64 cm = idx % 256
            uint64 sm = (idx * 3 + 17) % 256
            f64 cv = (int_to_f64(cm) - 128.0) / 128.0
            f64 sv = (int_to_f64(sm) - 128.0) / 128.0
            uint64 cp = cos + idx * 4; unsafe { *(cp as f32) = f64_to_f32(cv) }
            uint64 sp = sin + idx * 4; unsafe { *(sp as f32) = f64_to_f32(sv) }
            c = c + 1
        }
        r = r + 1
    }
}

fn verify_rope_block(uint64 h_in, uint64 h_out, uint64 h_cos, uint64 h_sin,
                     uint64 nrows, uint64 D, uint64 Dh, f32 thresh) -> uint64 {
    uint64 fail = 0; uint64 r = 0
    while r < nrows {
        uint64 j = 0
        while j < Dh {
            uint64 cs_idx = r * Dh + j
            uint64 cp = h_cos + cs_idx * 4; f32 cosp = 0.0; unsafe { *(cp as f32) -> cosp }
            uint64 sp = h_sin + cs_idx * 4; f32 sinp = 0.0; unsafe { *(sp as f32) -> sinp }
            uint64 ap = h_in + (r * D + j) * 4; f32 a = 0.0; unsafe { *(ap as f32) -> a }
            uint64 bp = h_in + (r * D + j + Dh) * 4; f32 b = 0.0; unsafe { *(bp as f32) -> b }
            f64 ad = f32_to_f64(a); f64 bd = f32_to_f64(b)
            f64 cd = f32_to_f64(cosp); f64 sd = f32_to_f64(sinp)
            f32 rf = f64_to_f32(ad * cd - bd * sd)
            f32 rs = f64_to_f32(ad * sd + bd * cd)
            uint64 of = h_out + (r * D + j) * 4
            uint64 os = h_out + (r * D + j + Dh) * 4
            f32 df = 0.0; unsafe { *(of as f32) -> df }
            f32 ds = 0.0; unsafe { *(os as f32) -> ds }
            f32 d1 = rf - df; if d1 < 0.0 { d1 = 0.0 - d1 }
            f32 d2 = rs - ds; if d2 < 0.0 { d2 = 0.0 - d2 }
            f32 ar1 = rf; if ar1 < 0.0 { ar1 = 0.0 - ar1 }
            f32 ar2 = rs; if ar2 < 0.0 { ar2 = 0.0 - ar2 }
            f32 floor = 0.000001
            if ar1 < floor { ar1 = floor }; if ar2 < floor { ar2 = floor }
            f32 r1 = d1 / ar1; f32 r2 = d2 / ar2
            if r1 > thresh || r2 > thresh { fail = fail + 1 }
            j = j + 1
        }
        r = r + 1
    }
    return fail
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    uint64 M = 4
    uint64 me = parse_env_count("M"); if me != 0 { M = me }
    uint64 num_heads    = 32        // Llama 3 8B Q heads
    uint64 num_kv_heads =  8        // Llama 3 8B KV heads (group_size = 4)
    uint64 D            = 128       // head_dim
    uint64 Dh           = D / 2

    uint64 fd = file_open("/tmp/rope_d128.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("missing /tmp/rope_d128.co"); exit(1) }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "rope_f32"); if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    // Allocate device buffers.  Cos/sin use the maximum row count
    // needed by either call (M * num_heads, since num_heads ≥ num_kv_heads).
    // The kernel reads cos[row*Dh..(row+1)*Dh) where row is the global
    // row index — so K's smaller row count just samples a prefix.
    uint64 q_rows  = M * num_heads
    uint64 k_rows  = M * num_kv_heads
    uint64 q_bytes = q_rows * D * 4
    uint64 k_bytes = k_rows * D * 4
    uint64 cs_bytes = q_rows * Dh * 4

    uint64 d_q_in  = 0; uint64 d_q_out = 0
    uint64 d_k_in  = 0; uint64 d_k_out = 0
    uint64 d_cos   = 0; uint64 d_sin   = 0
    uint64 slot
    slot = alloc(8); err = hipMalloc(slot, q_bytes); if err != 0 { die("mQin", err) }; unsafe { *(slot as uint64) -> d_q_in }
    slot = alloc(8); err = hipMalloc(slot, q_bytes); if err != 0 { die("mQou", err) }; unsafe { *(slot as uint64) -> d_q_out }
    slot = alloc(8); err = hipMalloc(slot, k_bytes); if err != 0 { die("mKin", err) }; unsafe { *(slot as uint64) -> d_k_in }
    slot = alloc(8); err = hipMalloc(slot, k_bytes); if err != 0 { die("mKou", err) }; unsafe { *(slot as uint64) -> d_k_out }
    slot = alloc(8); err = hipMalloc(slot, cs_bytes); if err != 0 { die("mCos", err) }; unsafe { *(slot as uint64) -> d_cos }
    slot = alloc(8); err = hipMalloc(slot, cs_bytes); if err != 0 { die("mSin", err) }; unsafe { *(slot as uint64) -> d_sin }

    uint64 h_q_in  = alloc(q_bytes)
    uint64 h_k_in  = alloc(k_bytes)
    uint64 h_cos   = alloc(cs_bytes)
    uint64 h_sin   = alloc(cs_bytes)
    fill_qk(h_q_in, q_rows, D, 0.0)
    fill_qk(h_k_in, k_rows, D, 0.5)         // different base so Q/K differ
    fill_cos_sin(h_cos, h_sin, q_rows, Dh)  // sized for Q (covers K too)

    err = hipMemcpy(d_q_in, h_q_in, q_bytes,  1); if err != 0 { die("H2D Q",  err) }
    err = hipMemcpy(d_k_in, h_k_in, k_bytes,  1); if err != 0 { die("H2D K",  err) }
    err = hipMemcpy(d_cos,  h_cos,  cs_bytes, 1); if err != 0 { die("H2D cs", err) }
    err = hipMemcpy(d_sin,  h_sin,  cs_bytes, 1); if err != 0 { die("H2D sn", err) }

    // ─ Call 1: RoPE on Q with m = M * num_heads = 128 rows.
    uint64 k_qin   = alloc(8); unsafe { *(k_qin   as uint64) = d_q_in }
    uint64 k_qou   = alloc(8); unsafe { *(k_qou   as uint64) = d_q_out }
    uint64 k_co1   = alloc(8); unsafe { *(k_co1   as uint64) = d_cos }
    uint64 k_si1   = alloc(8); unsafe { *(k_si1   as uint64) = d_sin }
    uint64 k_mq    = alloc(8); unsafe { *(k_mq    as uint64) = q_rows }
    uint64 kp_q = alloc(5 * 8)
    unsafe { *(kp_q        as uint64) = k_qin }
    unsafe { *((kp_q +  8) as uint64) = k_qou }
    unsafe { *((kp_q + 16) as uint64) = k_co1 }
    unsafe { *((kp_q + 24) as uint64) = k_si1 }
    unsafe { *((kp_q + 32) as uint64) = k_mq }
    err = hipModuleLaunchKernel(fh, q_rows, 1, 1, Dh, 1, 1, 0, 0, kp_q, 0)
    if err != 0 { die("launch Q", err) }

    // ─ Call 2: RoPE on K with m = M * num_kv_heads = 32 rows.
    uint64 k_kin   = alloc(8); unsafe { *(k_kin   as uint64) = d_k_in }
    uint64 k_kou   = alloc(8); unsafe { *(k_kou   as uint64) = d_k_out }
    uint64 k_co2   = alloc(8); unsafe { *(k_co2   as uint64) = d_cos }
    uint64 k_si2   = alloc(8); unsafe { *(k_si2   as uint64) = d_sin }
    uint64 k_mk    = alloc(8); unsafe { *(k_mk    as uint64) = k_rows }
    uint64 kp_k = alloc(5 * 8)
    unsafe { *(kp_k        as uint64) = k_kin }
    unsafe { *((kp_k +  8) as uint64) = k_kou }
    unsafe { *((kp_k + 16) as uint64) = k_co2 }
    unsafe { *((kp_k + 24) as uint64) = k_si2 }
    unsafe { *((kp_k + 32) as uint64) = k_mk }
    err = hipModuleLaunchKernel(fh, k_rows, 1, 1, Dh, 1, 1, 0, 0, kp_k, 0)
    if err != 0 { die("launch K", err) }

    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    uint64 h_q_out = alloc(q_bytes)
    uint64 h_k_out = alloc(k_bytes)
    err = hipMemcpy(h_q_out, d_q_out, q_bytes, 2); if err != 0 { die("D2H Q", err) }
    err = hipMemcpy(h_k_out, d_k_out, k_bytes, 2); if err != 0 { die("D2H K", err) }

    f32 thresh = 0.001
    uint64 fail_q = verify_rope_block(h_q_in, h_q_out, h_cos, h_sin, q_rows, D, Dh, thresh)
    uint64 fail_k = verify_rope_block(h_k_in, h_k_out, h_cos, h_sin, k_rows, D, Dh, thresh)

    print_label_val("M",              1, M)
    print_label_val("num_heads",      9, num_heads)
    print_label_val("num_kv_heads",  12, num_kv_heads)
    print_label_val("Q_rows",         6, q_rows)
    print_label_val("K_rows",         6, k_rows)
    print_label_val("Q_pairs_failed",14, fail_q)
    print_label_val("K_pairs_failed",14, fail_k)

    hipFree(d_q_in); hipFree(d_q_out); hipFree(d_k_in); hipFree(d_k_out)
    hipFree(d_cos); hipFree(d_sin)
    exit(0)
}
