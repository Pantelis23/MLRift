// Nested if/else + early-exit while + break/continue. Exercises the
// branch-inversion and CMP+JCC fusion peepholes on interesting shapes.
fn abs_diff(uint64 a, uint64 b) -> uint64 {
    if a > b { return a - b }
    return b - a
}

fn main() {
    uint64 i = 0
    uint64 sum = 0
    while i < 20 {
        if i == 7 { i = i + 1; continue }
        if i >= 15 { break }
        if (i & 1) == 0 {
            sum = sum + i
        } else {
            sum = sum + i * 2
        }
        i = i + 1
    }
    println(sum)            // deterministic
    println(abs_diff(100, 37))
    println(abs_diff(37, 100))
    println(abs_diff(42, 42))

    // Short-circuit logical && and ||
    uint64 x = 5
    if x > 0 && x < 10 { println(1) } else { println(0) }
    if x < 0 || x == 5 { println(1) } else { println(0) }
    if x > 0 && x > 100 { println(1) } else { println(0) }
    exit(0)
}
