// MLRift Standard Library — Matmul primitives
//
// Single entry point for the hot path of every transformer: multi-thread
// out[1 × N] = x[1 × K] · Wᵀ where `W` is stored row-major [N × K] in
// BF16 (HuggingFace convention). Activations and output stay f32.
//
// Extracted out of std/inference.mlr so the matmul kernel can grow
// independent of the BF16 decode helpers (AVX2 paths land next). Also
// lifts three cross-cutting fixes out of per-call land:
//
//   * Persistent thread-pool contexts — one alloc at first use, reused
//     forever. The old per-call alloc(48) was ~1 800 mmap round-trips
//     per 20-token decode at Qwen3-0.6B scale and showed up as 30 %+
//     kernel time in /usr/bin/time -v.
//
//   * Persistent per-worker BF16-decode scratch — one 64-byte cache
//     line per worker, reused forever. Removes one alloc per worker
//     per matmul call.
//
//   * Kahan-on / Kahan-off flag — the residual-stream matmuls (o_proj,
//     down_proj) compound drift across 28 layers; the rest (Q, K, V,
//     gate, up, lm_head) are fine with a naive accumulator. Callers
//     opt in per-call.
//
// The BF16 decode is still the per-element `store8 + store8 + unsafe
// load` trick — an AVX2 vpmovzxwd+vpslld kernel is next, but it drops
// in behind this interface without touching callers.

import "thread.mlr"

// ---------------------------------------------------------------------------
// Per-worker ctx slot layout (64 bytes — one cache line, no false sharing):
//   [ 0] out_ptr         [ 8] x_ptr          [16] w_ptr
//   [24] M               [32] N              [40] K
//   [48] scratch_ptr     [56] reserved
// Workers read slots 0..40 (shared across workers in a given matmul
// call) and slots 48..55 (their own BF16 decode scratch). Slots 56..63
// are padding to keep 64-byte alignment.
// ---------------------------------------------------------------------------
static u64 mm_ctx_base    = 0
static u64 mm_max_workers = 0

fn mm_init(u64 num_workers) {
    if mm_ctx_base != 0 {
        if num_workers <= mm_max_workers { return }
        dealloc(mm_ctx_base)
    }
    // 64 bytes of ctx + 4 bytes of BF16 scratch per worker. We pack the
    // scratch pointer INTO the ctx (slot [48]) so the worker only needs
    // one pointer load to find everything it owns. Scratch itself sits
    // right after the ctx block.
    u64 ctx_sz  = num_workers * 64
    u64 scr_sz  = num_workers * 64       // 64-byte stride avoids false sharing
    u64 total   = ctx_sz + scr_sz
    mm_ctx_base = alloc(total)
    u64 scr_base = mm_ctx_base + ctx_sz

    // Zero-seed scratch slots (BF16 decode only writes bytes 2..3 of
    // each slot; bytes 0..1 must stay 0) and stash each worker's scratch
    // pointer in its ctx slot.
    u64 i = 0
    while i < num_workers {
        u64 ctx_i = mm_ctx_base + i * 64
        u64 scr_i = scr_base + i * 64
        u64 p48 = ctx_i + 48
        unsafe { *(p48 as u64) = scr_i }
        // Zero the 4 scratch bytes (the entire 64-byte cache line is
        // fresh from alloc(), but be explicit — cheap).
        u8 zero = 0
        store8(scr_i + 0, zero)
        store8(scr_i + 1, zero)
        store8(scr_i + 2, zero)
        store8(scr_i + 3, zero)
        i = i + 1
    }
    mm_max_workers = num_workers
}

fn mm_shutdown() {
    if mm_ctx_base != 0 {
        dealloc(mm_ctx_base)
        mm_ctx_base = 0
        mm_max_workers = 0
    }
}

// ---------------------------------------------------------------------------
// BF16-weight matmul workers — one with Kahan compensation, one naive.
// Same loop body except for how the running sum is updated.
// ---------------------------------------------------------------------------

fn mm_worker_bf16_f32_kahan(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    u64 scratch = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch }

    u64 m = 0
    while m < M {
        u64 n = start_n
        while n < end_n {
            f32 sum = 0.0f
            f32 c   = 0.0f
            u64 k = 0
            while k < K {
                f32 xv = 0.0f
                unsafe { *((x_ptr + (m * K + k) * 4) as f32) -> xv }
                u64 w_off = (n * K + k) * 2
                u8 b0u = load8(w_ptr + w_off)
                u8 b1u = load8(w_ptr + w_off + 1)
                store8(scratch + 2, b0u)
                store8(scratch + 3, b1u)
                f32 wv = 0.0f
                unsafe { *(scratch as f32) -> wv }
                f32 prod = xv * wv
                f32 y = prod - c
                f32 t = sum + y
                c = (t - sum) - y
                sum = t
                k = k + 1
            }
            unsafe { *((out_ptr + (m * N + n) * 4) as f32) = sum }
            n = n + 1
        }
        m = m + 1
    }
}

fn mm_worker_bf16_f32_naive(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    u64 scratch = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch }

    u64 m = 0
    while m < M {
        u64 n = start_n
        while n < end_n {
            f32 sum = 0.0f
            u64 k = 0
            while k < K {
                f32 xv = 0.0f
                unsafe { *((x_ptr + (m * K + k) * 4) as f32) -> xv }
                u64 w_off = (n * K + k) * 2
                u8 b0u = load8(w_ptr + w_off)
                u8 b1u = load8(w_ptr + w_off + 1)
                store8(scratch + 2, b0u)
                store8(scratch + 3, b1u)
                f32 wv = 0.0f
                unsafe { *(scratch as f32) -> wv }
                sum = sum + xv * wv
                k = k + 1
            }
            unsafe { *((out_ptr + (m * N + n) * 4) as f32) = sum }
            n = n + 1
        }
        m = m + 1
    }
}

// AVX2 BF16×F32 inner loop. Same output as mm_worker_bf16_f32_naive but
// the K loop runs 8 elements per iteration using an ymm accumulator.
//
// BF16-to-F32 decode in vector: load 8 bf16 into an xmm register,
// vpmovzxwd widens to 8×u32 in ymm, vpslld by 16 aligns the bf16 payload
// into the f32 high bits — reinterpretation then gives a valid f32 lane.
//
// K must be a multiple of 8. That's fine for Qwen3 (K ∈ {1024, 3072}).
// The entry dispatcher falls back to the scalar worker for non-multiples.
// Same as mm_worker_bf16_f32_avx2_naive but processes TWO output columns
// per outer iteration, each with its own 8-wide accumulator (ymm0,
// ymm3). The FMAs into the two accumulators are independent, so the
// CPU can keep both FMA ports busy instead of serializing on a single
// dependency chain. On Zen 4 with FMA latency 4 / throughput 2, this
// roughly doubles the effective GFLOP/s when it's the bottleneck.
//
// Requires an even (end_n - start_n); the dispatcher sends an odd tail
// column through the 1-wide worker.
fn mm_worker_bf16_f32_avx2_naive_2w(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }

    u64 m = 0
    while m < M {
        u64 x_row = x_ptr + m * K * 4
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n + 1 < end_n {
            u64 w_row1 = w_ptr + n * K * 2
            u64 w_row2 = w_row1 + K * 2
            u64 out_slot = o_row + n * 4
            asm {
                // vxorps ymm0, ymm0, ymm0       ; acc1 = 0
                "0xC5 0xFC 0x57 0xC0"
                // vxorps ymm3, ymm3, ymm3       ; acc2 = 0
                "0xC5 0xE4 0x57 0xDB"
                // xor rax, rax
                "0x48 0x31 0xC0"
                // .loop: cmp rax, rdx            ; (3)
                "0x48 0x39 0xD0"
                // jge +52 (past body to reduce)  ; rel8 = 0x34
                "0x7D 0x34"
                // vmovups ymm1, [rsi + rax*4]    ; (5) x shared
                "0xC5 0xFC 0x10 0x0C 0x86"
                // vmovdqu xmm2, [rdi + rax*2]    ; (5) col1 weights
                "0xC5 0xFA 0x6F 0x14 0x47"
                // vpmovzxwd ymm2, xmm2           ; (5)
                "0xC4 0xE2 0x7D 0x33 0xD2"
                // vpslld ymm2, ymm2, 16          ; (5)
                "0xC5 0xED 0x72 0xF2 0x10"
                // vfmadd231ps ymm0, ymm1, ymm2   ; (5) acc1 += x*w1
                "0xC4 0xE2 0x75 0xB8 0xC2"
                // vmovdqu xmm2, [r8 + rax*2]     ; (6) col2 weights (r8 base)
                "0xC4 0xC1 0x7A 0x6F 0x14 0x40"
                // vpmovzxwd ymm2, xmm2           ; (5)
                "0xC4 0xE2 0x7D 0x33 0xD2"
                // vpslld ymm2, ymm2, 16          ; (5)
                "0xC5 0xED 0x72 0xF2 0x10"
                // vfmadd231ps ymm3, ymm1, ymm2   ; (5) acc2 += x*w2
                "0xC4 0xE2 0x75 0xB8 0xDA"
                // add rax, 8                     ; (4)
                "0x48 0x83 0xC0 0x08"
                // jmp .loop                       ; rel8 = -57 = 0xC7
                "0xEB 0xC7"
                // .done: horizontal reduce ymm0 → xmm0[0]
                // vextractf128 xmm1, ymm0, 1     ; (6)
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                // vaddps xmm0, xmm0, xmm1        ; (4)
                "0xC5 0xF8 0x58 0xC1"
                // vhaddps xmm0, xmm0, xmm0       ; (4)
                "0xC5 0xFB 0x7C 0xC0"
                // vhaddps xmm0, xmm0, xmm0       ; (4)
                "0xC5 0xFB 0x7C 0xC0"
                // vmovss [rcx], xmm0             ; (4) store col1 scalar
                "0xC5 0xFA 0x11 0x01"
                // Reduce ymm3 → xmm3[0]
                // vextractf128 xmm1, ymm3, 1     ; (6)
                "0xC4 0xE3 0x7D 0x19 0xD9 0x01"
                // vaddps xmm3, xmm3, xmm1        ; (4)
                "0xC5 0xE0 0x58 0xD9"
                // vhaddps xmm3, xmm3, xmm3       ; (4)
                "0xC5 0xE3 0x7C 0xDB"
                // vhaddps xmm3, xmm3, xmm3       ; (4)
                "0xC5 0xE3 0x7C 0xDB"
                // vmovss [rcx+4], xmm3           ; (5) store col2 scalar
                "0xC5 0xFA 0x11 0x59 0x04"
                // vzeroupper                     ; (3)
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row1 -> rdi, w_row2 -> r8, K -> rdx, out_slot -> rcx) clobbers(rax)
            n = n + 2
        }
        // Odd tail column — reuse the 1-wide path inline so the caller
        // doesn't need to orchestrate it.
        if n < end_n {
            u64 w_row = w_ptr + n * K * 2
            u64 out_slot = o_row + n * 4
            asm {
                "0xC5 0xFC 0x57 0xC0"
                "0x48 0x31 0xC0"
                "0x48 0x39 0xD0"
                "0x7D 0x1F"
                "0xC5 0xFC 0x10 0x0C 0x86"
                "0xC5 0xFA 0x6F 0x14 0x47"
                "0xC4 0xE2 0x7D 0x33 0xD2"
                "0xC5 0xED 0x72 0xF2 0x10"
                "0xC4 0xE2 0x75 0xB8 0xC2"
                "0x48 0x83 0xC0 0x08"
                "0xEB 0xDC"
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                "0xC5 0xF8 0x58 0xC1"
                "0xC5 0xFB 0x7C 0xC0"
                "0xC5 0xFB 0x7C 0xC0"
                "0xC5 0xFA 0x11 0x01"
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row -> rdi, K -> rdx, out_slot -> rcx) clobbers(rax)
        }
        m = m + 1
    }
}

fn mm_worker_bf16_f32_avx2_naive(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }

    u64 m = 0
    while m < M {
        u64 x_row = x_ptr + m * K * 4
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n < end_n {
            u64 w_row = w_ptr + n * K * 2
            u64 out_slot = o_row + n * 4
            asm {
                // vxorps ymm0, ymm0, ymm0       ; accumulator = 0
                "0xC5 0xFC 0x57 0xC0"
                // xor rax, rax                   ; k = 0
                "0x48 0x31 0xC0"
                // .loop: cmp rax, rdx            ; 3 bytes
                "0x48 0x39 0xD0"
                // jge +31 (past loop body to reduce block)
                "0x7D 0x1F"
                // vmovups ymm1, [rsi + rax*4]    ; 8 f32 activations
                "0xC5 0xFC 0x10 0x0C 0x86"
                // vmovdqu xmm2, [rdi + rax*2]    ; 8 bf16 weights (16 bytes)
                "0xC5 0xFA 0x6F 0x14 0x47"
                // vpmovzxwd ymm2, xmm2           ; widen 8 u16 → 8 u32
                "0xC4 0xE2 0x7D 0x33 0xD2"
                // vpslld ymm2, ymm2, 16          ; bf16 bits → upper 16 of f32
                "0xC5 0xED 0x72 0xF2 0x10"
                // vfmadd231ps ymm0, ymm1, ymm2   ; acc += x * w
                "0xC4 0xE2 0x75 0xB8 0xC2"
                // add rax, 8
                "0x48 0x83 0xC0 0x08"
                // jmp .loop  (-36 = back to cmp)
                "0xEB 0xDC"
                // .done: horizontal reduce ymm0 → scalar
                // vextractf128 xmm1, ymm0, 1
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                // vaddps xmm0, xmm0, xmm1
                "0xC5 0xF8 0x58 0xC1"
                // vhaddps xmm0, xmm0, xmm0
                "0xC5 0xFB 0x7C 0xC0"
                // vhaddps xmm0, xmm0, xmm0       ; xmm0[0] = sum of all 8 lanes
                "0xC5 0xFB 0x7C 0xC0"
                // vmovss [rcx], xmm0             ; store scalar f32 output
                "0xC5 0xFA 0x11 0x01"
                // vzeroupper                     ; clean AVX→SSE transition
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row -> rdi, K -> rdx, out_slot -> rcx) clobbers(rax)
            n = n + 1
        }
        m = m + 1
    }
}

// ---------------------------------------------------------------------------
// Public entry: matmul with BF16 weights, F32 activations, Kahan on/off.
//
// out[M × N] = x[M × K] · wᵀ, `w` stored row-major [N × K] in BF16.
// Columns are sharded across the thread pool.
//
// `use_kahan != 0` picks the compensated variant for residual-stream
// hotspots; `= 0` gives the naive accumulator.
// ---------------------------------------------------------------------------
fn matmul_bf16_weights_f32(u64 out_ptr, u64 x_ptr, u64 w_ptr,
                           u64 M, u64 N, u64 K,
                           u64 num_workers, u64 use_kahan) {
    if mm_ctx_base == 0 || num_workers > mm_max_workers {
        mm_init(num_workers)
    }

    // Populate the 6 shared fields in every worker's ctx slot. That's
    // num_workers × 6 stores per call — still far cheaper than the old
    // per-call alloc(48), which was an mmap syscall with full heap-lock
    // contention.
    u64 w = 0
    while w < num_workers {
        u64 ctx_w = mm_ctx_base + w * 64
        unsafe { *(ctx_w as u64) = out_ptr }
        u64 p8 = ctx_w + 8
        unsafe { *(p8 as u64) = x_ptr }
        u64 p16 = ctx_w + 16
        unsafe { *(p16 as u64) = w_ptr }
        u64 p24 = ctx_w + 24
        unsafe { *(p24 as u64) = M }
        u64 p32 = ctx_w + 32
        unsafe { *(p32 as u64) = N }
        u64 p40 = ctx_w + 40
        unsafe { *(p40 as u64) = K }
        w = w + 1
    }

    u64 fn_ptr = 0
    if use_kahan != 0 {
        fn_ptr = fn_addr("mm_worker_bf16_f32_kahan")
    } else {
        // Naive path — use AVX2 2-wide when K is a multiple of 8. The
        // 2-wide kernel runs two independent accumulators per inner
        // iter, so both FMA ports stay busy even under the loop-carried
        // dep; single-accumulator version serializes on one port.
        if (K & 7) == 0 {
            fn_ptr = fn_addr("mm_worker_bf16_f32_avx2_naive_2w")
        } else {
            fn_ptr = fn_addr("mm_worker_bf16_f32_naive")
        }
    }

    // Submit jobs to workers 0..num_workers-2, and run the last slice
    // inline on the main thread. Saves one futex_wake syscall per matmul
    // (+the context-switch round trip); over ~1 680 matmul calls per
    // 20-token decode that's ~3–5 ms of real wall time in our bench.
    u64 chunk = N / num_workers
    w = 0
    while w + 1 < num_workers {
        u64 start_n = w * chunk
        u64 end_n   = start_n + chunk
        u64 ctx_w = mm_ctx_base + w * 64
        thread_pool_submit(w, fn_ptr, start_n, end_n, ctx_w)
        w = w + 1
    }
    // Last slice — main thread runs it directly. Handles the N-not-
    // divisible-by-num_workers tail naturally because end=N.
    u64 main_start = (num_workers - 1) * chunk
    u64 main_end   = N
    u64 main_ctx   = mm_ctx_base + (num_workers - 1) * 64
    if use_kahan != 0 {
        mm_worker_bf16_f32_kahan(main_start, main_end, main_ctx)
    } else {
        if (K & 7) == 0 {
            mm_worker_bf16_f32_avx2_naive_2w(main_start, main_end, main_ctx)
        } else {
            mm_worker_bf16_f32_naive(main_start, main_end, main_ctx)
        }
    }
    thread_pool_wait()
}
