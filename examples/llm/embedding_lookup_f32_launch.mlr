// embedding_lookup_f32: out[seq, d] = embed[token_ids[seq], d].
//
// Each workgroup handles one sequence position; one lane per dim. Block = D
// (embed_dim ≤ 1024 for the simple form), grid = SEQ.  Bit-exact gather —
// the verifier compares each output cell against a host indexing reference.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-embedding-lookup-f32=/tmp/embedding_lookup_f32.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/embedding_lookup_f32_launch.mlr -o /tmp/embedding_lookup_f32_kfd
// Run:
//   /tmp/embedding_lookup_f32_kfd

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 { i = i - 1; uint64 d = tmp - (tmp / 10) * 10; uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }; tmp = tmp / 10 }
    return n
}
fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len { uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }; uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }; i = i + 1 }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}
fn die(uint64 msg, uint64 code) { puts(msg); print_label_val("e", 1, code); exit(1) }

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    uint64 fd = file_open("/tmp/embedding_lookup_f32.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("missing /tmp/embedding_lookup_f32.co"); exit(1) }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "embedding_lookup_f32"); if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    // Qwen3-0.6B embedding shape: V=151,936 vocab, D=1024.  Use a smaller
    // V here to keep the demo fast; the kernel doesn't depend on V — it
    // just gathers based on whatever token_id the host wrote.
    uint64 V   = 8192
    uint64 D   = 1024
    uint64 SEQ = 256

    uint64 tok_bytes   = SEQ * 4              // uint32 per token
    uint64 embed_bytes = V * D * 4            // f32 [V, D]
    uint64 out_bytes   = SEQ * D * 4          // f32 [seq, D]

    uint64 d_tok = 0; uint64 d_embed = 0; uint64 d_out = 0
    uint64 slot
    slot = alloc(8); err = hipMalloc(slot, tok_bytes);   if err != 0 { die("mTok", err) };   unsafe { *(slot as uint64) -> d_tok }
    slot = alloc(8); err = hipMalloc(slot, embed_bytes); if err != 0 { die("mEmb", err) };   unsafe { *(slot as uint64) -> d_embed }
    slot = alloc(8); err = hipMalloc(slot, out_bytes);   if err != 0 { die("mOut", err) };   unsafe { *(slot as uint64) -> d_out }

    // Fill embed table: embed[v, d] = v * 0.001 + d * 0.0007 - 0.5
    // (deterministic; lets the verifier reconstruct without storing).
    uint64 h_embed = alloc(embed_bytes)
    uint64 v = 0
    while v < V {
        uint64 d = 0
        while d < D {
            f64 val = int_to_f64(v) * 0.001 + int_to_f64(d) * 0.0007 - 0.5
            uint64 p = h_embed + (v * D + d) * 4
            unsafe { *(p as f32) = f64_to_f32(val) }
            d = d + 1
        }
        v = v + 1
    }
    err = hipMemcpy(d_embed, h_embed, embed_bytes, 1); if err != 0 { die("H2D embed", err) }

    // Token IDs: pseudo-random in [0, V), deterministic via splitmix-ish.
    uint64 h_tok = alloc(tok_bytes)
    uint64 i = 0
    while i < SEQ {
        uint64 hash = (i + 1) * 2654435761
        uint64 tok_id = hash - (hash / V) * V         // hash mod V
        uint32 tid32 = tok_id
        uint64 p = h_tok + i * 4
        unsafe { *(p as uint32) = tid32 }
        i = i + 1
    }
    err = hipMemcpy(d_tok, h_tok, tok_bytes, 1); if err != 0 { die("H2D tok", err) }

    uint64 k_tok = alloc(8); unsafe { *(k_tok as uint64) = d_tok }
    uint64 k_emb = alloc(8); unsafe { *(k_emb as uint64) = d_embed }
    uint64 k_out = alloc(8); unsafe { *(k_out as uint64) = d_out }
    uint64 k_d   = alloc(8); unsafe { *(k_d   as uint64) = D }
    uint64 kp = alloc(4 * 8)
    unsafe { *(kp        as uint64) = k_tok }
    unsafe { *((kp +  8) as uint64) = k_emb }
    unsafe { *((kp + 16) as uint64) = k_out }
    unsafe { *((kp + 24) as uint64) = k_d }

    uint32 grid  = SEQ
    uint32 block = D
    err = hipModuleLaunchKernel(fh, grid, 1, 1, block, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    uint64 h_out = alloc(out_bytes)
    err = hipMemcpy(h_out, d_out, out_bytes, 2); if err != 0 { die("D2H", err) }

    // Bit-exact verify: for each (seq, d), out[seq, d] should equal
    // embed[token_ids[seq], d].
    uint64 mismatch = 0
    i = 0
    while i < SEQ {
        uint64 tp = h_tok + i * 4
        uint32 tid = 0; unsafe { *(tp as uint32) -> tid }
        uint64 tid64 = tid
        uint64 d = 0
        while d < D {
            uint64 ep = h_embed + (tid64 * D + d) * 4
            uint64 op = h_out   + (i     * D + d) * 4
            uint32 eb = 0; uint32 ob = 0
            unsafe { *(ep as uint32) -> eb }
            unsafe { *(op as uint32) -> ob }
            if eb != ob { mismatch = mismatch + 1 }
            d = d + 1
        }
        i = i + 1
    }

    print_label_val("V",        1, V)
    print_label_val("D",        1, D)
    print_label_val("SEQ",      3, SEQ)
    print_label_val("cells",    5, SEQ * D)
    print_label_val("mismatch", 8, mismatch)

    hipFree(d_tok); hipFree(d_embed); hipFree(d_out)
    exit(0)
}
