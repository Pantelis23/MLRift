// Smoke test for the batched gemv kernel.  Computes
//   out[batch, N] = w[N, K] @ x[batch, K]^T
// on the GPU via the new gemv_coop_f32_batched kernel, and against a
// CPU reference per-stream (dot product per (b, n)).  Verifies all
// streams' outputs are correct.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-gemv-coop-f32-batched=/tmp/gemv_coop_f32_batched.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/gemv_batched_smoke.mlr -o /tmp/gemv_batched_smoke
// Run:
//   /tmp/gemv_batched_smoke

import "../../std/hip.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/time.mlr"
import "../../std/math_float.mlr"
import "../../std/inference_gpu.mlr"

@dynamic extern fn exit(uint64 code)

fn die(uint64 msg, uint64 code) {
    print_str(msg); print_str(" e="); u64 s = fmt_dec(code); print_str(s); dealloc(s); print_str("\n"); exit(1)
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    // Load the batched kernel directly (smoke targets the kernel; the
    // gpu_matmul_to_dev_batched launcher lives in inference_gpu.mlr
    // and is exercised end-to-end via the qwen3 forward path once
    // slice 1.3.2's chain reshape lands).
    u64 fd = file_open("/tmp/gemv_coop_f32_batched.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { die("missing co", 0) }
    u64 sz = file_size(fd); u64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    u64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    u64 mod = 0; unsafe { *(mod_slot as u64) -> mod }
    u64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "gemv_coop_f32_batched"); if err != 0 { die("getFn", err) }
    u64 fh = 0; unsafe { *(fh_slot as u64) -> fh }
    print_str("gemv_coop_f32_batched loaded\n")

    u64 N = 1024       // output dim (must be ≥ 256 for kernel's K/256 chunk count)
    u64 K = 256        // inner dim (must be multiple of 256)
    u64 batch = 4
    u64 w_bytes   = N * K * 4
    u64 x_bytes   = batch * K * 4
    u64 out_bytes = batch * N * 4

    // Host buffers + reference.
    u64 h_w   = alloc(w_bytes)
    u64 h_x   = alloc(x_bytes)
    u64 h_ref = alloc(out_bytes)
    u64 h_gpu = alloc(out_bytes)

    u64 i = 0
    while i < N * K {
        f64 vd = int_to_f64(i * 11 + 7) * 0.0007 - 1.0
        while vd > 1.0 { vd = vd - 2.0 }
        while vd < -1.0 { vd = vd + 2.0 }
        unsafe { *((h_w + i * 4) as f32) = f64_to_f32(vd) }
        i = i + 1
    }
    i = 0
    while i < batch * K {
        f64 vd = int_to_f64(i * 13 + 19) * 0.001 - 1.0
        while vd > 1.0 { vd = vd - 2.0 }
        while vd < -1.0 { vd = vd + 2.0 }
        unsafe { *((h_x + i * 4) as f32) = f64_to_f32(vd) }
        i = i + 1
    }

    // CPU reference: per (b, n) compute dot product W[n, :] · X[b, :].
    u64 b = 0
    while b < batch {
        u64 x_row = h_x + b * K * 4
        u64 out_row = h_ref + b * N * 4
        u64 n = 0
        while n < N {
            u64 w_row = h_w + n * K * 4
            f32 acc = 0.0f
            u64 k = 0
            while k < K {
                f32 wv = 0.0f; unsafe { *((w_row + k * 4) as f32) -> wv }
                f32 xv = 0.0f; unsafe { *((x_row + k * 4) as f32) -> xv }
                acc = acc + wv * xv
                k = k + 1
            }
            unsafe { *((out_row + n * 4) as f32) = acc }
            n = n + 1
        }
        b = b + 1
    }
    print_str("CPU reference computed\n")

    // GPU: H2D, dispatch, D2H.
    u64 d_w = 0; u64 d_x = 0; u64 d_out = 0
    u64 slot
    slot = alloc(8); err = hipMalloc(slot, w_bytes);   if err != 0 { die("mw",  err) }; unsafe { *(slot as u64) -> d_w }
    slot = alloc(8); err = hipMalloc(slot, x_bytes);   if err != 0 { die("mx",  err) }; unsafe { *(slot as u64) -> d_x }
    slot = alloc(8); err = hipMalloc(slot, out_bytes); if err != 0 { die("mout",err) }; unsafe { *(slot as u64) -> d_out }
    err = hipMemcpy(d_w, h_w, w_bytes, 1); if err != 0 { die("H2D w", err) }
    err = hipMemcpy(d_x, h_x, x_bytes, 1); if err != 0 { die("H2D x", err) }

    // Build kernarg.  Layout: (a_ptr=W, b_ptr=x, c_ptr=out, m=N, k_dim=K).
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_w }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_x }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = N }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = K }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }

    u64 t0 = time_now()
    u32 cgrid = N
    u32 cgrid_y = batch
    err = hipModuleLaunchKernel(fh, cgrid, cgrid_y, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }
    u64 t1 = time_now()

    err = hipMemcpy(h_gpu, d_out, out_bytes, 2); if err != 0 { die("D2H", err) }
    print_str("kernel_us="); u64 ks = fmt_dec((t1 - t0) / 1000); print_str(ks); dealloc(ks); print_str("\n")

    // Compare.
    u64 fail = 0
    f32 max_abs = 0.0f
    u64 k = 0
    while k < batch * N {
        f32 cv = 0.0f; unsafe { *((h_ref + k * 4) as f32) -> cv }
        f32 gv = 0.0f; unsafe { *((h_gpu + k * 4) as f32) -> gv }
        f32 d = cv - gv; if d < 0.0f { d = 0.0f - d }
        if d > max_abs { max_abs = d }
        f32 ac = cv; if ac < 0.0f { ac = 0.0f - ac }
        f32 thresh = ac * 0.001f
        if thresh < 0.001f { thresh = 0.001f }
        if d > thresh { fail = fail + 1 }
        k = k + 1
    }
    u64 total = batch * N
    print_str("batched-gemv fail count: "); u64 sf = fmt_dec(fail); print_str(sf); dealloc(sf)
    print_str(" / "); u64 stot = fmt_dec(total); print_str(stot); dealloc(stot); print_str("\n")
    u64 mb = alloc(4); unsafe { *(mb as f32) = max_abs }
    u32 mb_b = 0; unsafe { *(mb as u32) -> mb_b }
    u64 mb64 = mb_b
    print_str("max abs diff bits="); u64 smb = fmt_dec(mb64); print_str(smb); dealloc(smb); print_str("\n"); dealloc(mb)
    if fail == 0 {
        print_str("OK — gemv_coop_f32_batched matches per-stream reference.\n"); exit(0)
    } else {
        print_str("FAIL\n"); exit(1)
    }
}
