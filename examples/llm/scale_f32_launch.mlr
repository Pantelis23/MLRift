// Launcher for scale_f32 (Phase 3a smoke test).
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/scale_f32.mlr        -o /tmp/scale_f32
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/scale_f32_launch.mlr -o /tmp/scale_f32_launch_kfd
// Run:
//   N=2048 FACTOR=0.5 /tmp/scale_f32_launch_kfd

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 {
        i = i - 1
        uint64 d = tmp - (tmp / 10) * 10
        uint64 p = buf + i; uint8 c = d + 48
        unsafe { *(p as uint8) = c }
        tmp = tmp / 10
    }
    return n
}

fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len {
        uint64 sp = label + i; uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + i; uint8 cb = c
        unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen
    uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}

fn die(uint64 msg, uint64 code) {
    puts(msg); print_label_val("hipError", 8, code); exit(1)
}

fn parse_env_count(uint64 name) -> uint64 {
    uint64 s = getenv(name)
    if s == 0 { return 0 }
    uint64 v = 0; uint64 i = 0
    while 1 == 1 {
        uint64 cp = s + i; uint64 c = 0
        unsafe { *(cp as uint8) -> c }
        if c == 0 { break }
        if c >= 48 && c <= 57 { v = v * 10 + (c - 48); i = i + 1; continue }
        break
    }
    return v
}

fn main() {
    uint32 err = hipSetDevice(0)
    if err != 0 { die("hipSetDevice", err) }

    uint64 N = 2048
    uint64 ne = parse_env_count("N"); if ne != 0 { N = ne }

    uint64 co_path = "/tmp/scale_f32.co"
    uint64 fd = file_open(co_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 {
        puts("missing /tmp/scale_f32.co — build:")
        puts("  mlrc --arch=x86_64 --target=amdgpu-native examples/llm/scale_f32.mlr -o /tmp/scale_f32")
        exit(1)
    }
    uint64 sz = file_size(fd)
    uint64 blob = alloc(sz)
    file_read(fd, blob, sz)
    file_close(fd)

    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }

    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "scale_f32")
    if err != 0 { die("getFn scale_f32", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    uint64 bytes = N * 4
    uint64 d_buf = 0
    uint64 slot = alloc(8); err = hipMalloc(slot, bytes)
    if err != 0 { die("hipMalloc", err) }
    unsafe { *(slot as uint64) -> d_buf }

    // Fill host buffer with deterministic values.
    uint64 h_in = alloc(bytes)
    uint64 i = 0
    while i < N {
        f64 vd = int_to_f64(i) * 0.001 + 1.0
        f32 v = f64_to_f32(vd)
        uint64 p = h_in + i * 4
        unsafe { *(p as f32) = v }
        i = i + 1
    }
    err = hipMemcpy(d_buf, h_in, bytes, 1)
    if err != 0 { die("H2D", err) }

    // factor = 0.5 (hardcoded for now; literal in kernel param 2).
    f64 fd_factor = 0.5
    f32 factor = f64_to_f32(fd_factor)
    uint32 factor_bits = 0
    uint64 fp = alloc(4); unsafe { *(fp as f32) = factor }
    unsafe { *(fp as uint32) -> factor_bits }

    uint64 k_buf = alloc(8); unsafe { *(k_buf as uint64) = d_buf }
    uint64 k_n   = alloc(8); uint64 nv = N; unsafe { *(k_n as uint64) = nv }
    uint64 k_f   = alloc(8); uint64 fb64 = factor_bits; unsafe { *(k_f as uint64) = fb64 }
    uint64 kp = alloc(3 * 8)
    unsafe { *(kp        as uint64) = k_buf }
    unsafe { *((kp +  8) as uint64) = k_n }
    unsafe { *((kp + 16) as uint64) = k_f }

    uint32 grid_x  = (N + 255) / 256
    uint32 block_x = 256

    err = hipModuleLaunchKernel(fh, grid_x, 1, 1, block_x, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    // D2H + verify
    uint64 h_out = alloc(bytes)
    err = hipMemcpy(h_out, d_buf, bytes, 2); if err != 0 { die("D2H", err) }

    uint64 fail_count = 0
    uint64 first_bad  = 0xFFFFFFFFFFFFFFFF
    i = 0
    while i < N {
        uint64 ip = h_in + i * 4; uint64 op = h_out + i * 4
        f32 in_v = 0.0; unsafe { *(ip as f32) -> in_v }
        f32 ot_v = 0.0; unsafe { *(op as f32) -> ot_v }
        f32 expect = in_v * factor
        f32 d = ot_v - expect
        if d < 0.0 { d = 0.0 - d }
        if d > 0.000001 {
            fail_count = fail_count + 1
            if first_bad == 0xFFFFFFFFFFFFFFFF { first_bad = i }
        }
        i = i + 1
    }

    print_label_val("N",          1, N)
    print_label_val("fail_count", 10, fail_count)
    print_label_val("first_bad",   9, first_bad)

    // Find first PASSING cell after some range to see if it's contiguous.
    if first_bad < 0xFFFFFFFFFFFFF000 {
        uint64 j = first_bad
        uint64 first_pass_after = 0xFFFFFFFFFFFFFFFF
        while j < N {
            uint64 ip = h_in + j * 4
            uint64 op = h_out + j * 4
            f32 in_v = 0.0; unsafe { *(ip as f32) -> in_v }
            f32 ot_v = 0.0; unsafe { *(op as f32) -> ot_v }
            f32 expect = in_v * factor
            f32 d = ot_v - expect
            if d < 0.0 { d = 0.0 - d }
            if d <= 0.000001 {
                if first_pass_after == 0xFFFFFFFFFFFFFFFF { first_pass_after = j; break }
            }
            j = j + 1
        }
        print_label_val("first_pass_after_bad", 20, first_pass_after)
    }

    hipFree(d_buf)
    exit(0)
}
