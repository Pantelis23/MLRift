                                               asm_text_buf, asm_text_len,
                                               16, 8, 16, 7,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 2,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_kv_broadcast_f32_blob: cannot open output\n", 55)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

@export
fn emit_amdgpu_residual_add_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_residual_add_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("residual_add_f32", 16,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 11,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_residual_add_f32_blob: cannot open output\n", 55)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

fn amdgpu_lower_llm_residual_add_f32(uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 args_desc = alloc(8 * 8)
    _emit_residual_add_f32_body(args_desc)
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }
    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 11,
                0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                0)
    return 0
}

// LLM Phase 2 — softmax_causal_f32: numerically-stable softmax with
// autoregressive causal mask. cells with col j > row r get masked to
// -inf before reductions, so they contribute 0 to exp-sum and don't
// perturb max. Same shape and kernarg layout as softmax_f32.
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] uint64 in_ptr   (M × 256 f32 attention scores)
