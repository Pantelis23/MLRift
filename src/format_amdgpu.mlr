// MLRift — AMDGPU code-object ELF emitter (Stage 1, milestone M1a).
//
// Produces a ROCm-loadable code object (raw amdgcn ELF, NOT a clang
// offload bundle) for a single handcrafted kernel. The target
// scenario for M1a is: write a no-op kernel (just `s_endpgm`),
// hand the blob to hipModuleLoadData, and confirm the loader
// accepts it plus hipModuleGetFunction resolves the kernel symbol.
//
// This is the scaffolding for Stage 1 as described in
// docs/GPU_ZERO_DEPENDENCY.md — it still keeps the existing
// --target=hip-amd (hipcc-driven) path intact. A new CLI flag
// `--target=amdgpu-native` drives this emitter instead.
//
// Layout mirrors what hipcc emits (stripped of the clang offload
// bundle wrapper), trimmed to the minimum the ROCm loader checks
// for code-object v4. References: /tmp/gpu_decay_amdgcn.co (from
// hipcc --genco, bundle-stripped) and the AMDGPU-ABI doc
// (https://llvm.org/docs/AMDGPUUsage.html#code-object-v4-metadata).
//
// File layout (matches hipcc's structural pattern):
//
//   0x000  ELF64 header
//   0x040  program headers (6 phdrs × 56 bytes)
//   0x1A0  .note                 (AMDGPU metadata, MsgPack)
//   ...    .dynsym               (3 entries: null, kernel, kernel.kd)
//   ...    .dynstr               (kernel name + ".kd" variant)
//   ...    .rodata               (64-byte kernel descriptor)
//   0x900  .text                 (page-aligned virtually)
//   ...    section headers
//   ...    .shstrtab
//
// Virtual addresses keep RX's page alignment modulo 0x1000:
// .text sits at vaddr = file_offset + 0x1000 so the RX PT_LOAD is
// a 0x1000-aligned page segment.

// ---------------------------------------------------------------------------
// Output buffer
// ---------------------------------------------------------------------------

static uint64 amd_buf = 0
static uint64 amd_len = 0
static uint64 amd_cap = 0

// Set to 1 by main.kr when `--target=amdgpu-native` is on the CLI.
// Gates the M1d emission path (see emit_amdgpu_from_module below).
static uint64 target_amdgpu_native = 0

// ---------------------------------------------------------------------------
// Kernel table (M1f)
//
// emit_amdgpu_code_object used to be a single-kernel path — everything
// from .dynsym to .rodata to .note hard-wired two symbols and one
// kernel body. M1f pluralises that: callers push entries into this
// table, then emit_amdgpu_multi_code_object walks them once to lay
// out every section.
//
// Entry layout (13 u64 fields × 8 bytes = 104 bytes/entry):
//   0: name_ptr      (host pointer to the kernel name string)
//   1: name_len
//   2: bytes_ptr     (host pointer to assembled kernel text)
//   3: bytes_len
//   4: args_desc     (host pointer to args descriptor, see amd_arg_*)
//   5: n_args
//   6: kernarg_size
//   7: sgpr_count
//   8: vgpr_count
//   9: rsrc1
//   10: rsrc2
//   11: rsrc3
//   12: props
//
// Plus per-kernel computed offsets filled in during emit (kept in
// parallel arrays because they're only relevant during the emit):
//   kt_kd_off[i]     — .rodata byte offset of kernel i's descriptor
//   kt_text_off[i]   — .text   byte offset of kernel i's first instr
//   kt_text_vaddr[i] — kd-to-entry delta lives in KD offset 0x10

static uint64 KT_STRIDE = 104
static uint64 KT_MAX    = 32
static uint64 kt_buf    = 0
static uint64 kt_count  = 0

// Per-kernel computed offsets, filled during emit_amdgpu_multi_code_object.
static uint64 kt_kd_off       = 0
static uint64 kt_text_off     = 0
static uint64 kt_text_vaddr   = 0

fn kt_reset() {
    if kt_buf == 0 {
        kt_buf        = alloc(KT_MAX * KT_STRIDE)
        kt_kd_off     = alloc(KT_MAX * 8)
        kt_text_off   = alloc(KT_MAX * 8)
        kt_text_vaddr = alloc(KT_MAX * 8)
    }
    kt_count = 0
}

fn kt_push(uint64 name_ptr, uint64 name_len,
           uint64 bytes_ptr, uint64 bytes_len,
           uint64 args_desc, uint64 n_args,
           uint64 kernarg_size,
           uint64 sgpr_count, uint64 vgpr_count,
           uint64 rsrc1, uint64 rsrc2, uint64 rsrc3, uint64 props) {
    if kt_count >= KT_MAX {
        write(2, "format_amdgpu: kernel table overflow\n", 37)
        exit(1)
    }
    uint64 base = kt_buf + kt_count * KT_STRIDE
    uint64 p0  = base +   0; unsafe { *(p0  as uint64) = name_ptr }
    uint64 p1  = base +   8; unsafe { *(p1  as uint64) = name_len }
    uint64 p2  = base +  16; unsafe { *(p2  as uint64) = bytes_ptr }
    uint64 p3  = base +  24; unsafe { *(p3  as uint64) = bytes_len }
    uint64 p4  = base +  32; unsafe { *(p4  as uint64) = args_desc }
    uint64 p5  = base +  40; unsafe { *(p5  as uint64) = n_args }
    uint64 p6  = base +  48; unsafe { *(p6  as uint64) = kernarg_size }
    uint64 p7  = base +  56; unsafe { *(p7  as uint64) = sgpr_count }
    uint64 p8  = base +  64; unsafe { *(p8  as uint64) = vgpr_count }
    uint64 p9  = base +  72; unsafe { *(p9  as uint64) = rsrc1 }
    uint64 p10 = base +  80; unsafe { *(p10 as uint64) = rsrc2 }
    uint64 p11 = base +  88; unsafe { *(p11 as uint64) = rsrc3 }
    uint64 p12 = base +  96; unsafe { *(p12 as uint64) = props }
    kt_count = kt_count + 1
}

fn kt_get(uint64 idx, uint64 field_idx) -> uint64 {
    uint64 p = kt_buf + idx * KT_STRIDE + field_idx * 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn kt_set_u64_arr(uint64 arr, uint64 idx, uint64 v) {
    uint64 p = arr + idx * 8
    unsafe { *(p as uint64) = v }
}

fn kt_get_u64_arr(uint64 arr, uint64 idx) -> uint64 {
    uint64 p = arr + idx * 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

@export
fn amd_buf_ptr() -> uint64 { return amd_buf }

@export
fn amd_buf_len() -> uint64 { return amd_len }

fn amd_init() {
    if amd_buf == 0 {
        amd_cap = 65536   // 64 KB is plenty for M1a/M1b
        amd_buf = alloc(amd_cap)
    }
    amd_len = 0
    // zero the buffer — we rely on zero-init for reserved fields
    uint64 i = 0
    while i < amd_cap {
        uint64 p = amd_buf + i
        uint8 z = 0
        unsafe { *(p as uint8) = z }
        i = i + 1
    }
}

fn amd_byte(uint64 v) {
    if amd_len >= amd_cap {
        write(2, "format_amdgpu: output buffer overflow\n", 38)
        exit(1)
    }
    uint64 p = amd_buf + amd_len
    uint8 b = v & 0xFF
    unsafe { *(p as uint8) = b }
    amd_len = amd_len + 1
}

fn amd_u16(uint64 v) {
    amd_byte(v & 0xFF)
    amd_byte((v >> 8) & 0xFF)
}

fn amd_u32(uint64 v) {
    amd_byte(v & 0xFF)
    amd_byte((v >> 8) & 0xFF)
    amd_byte((v >> 16) & 0xFF)
    amd_byte((v >> 24) & 0xFF)
}

fn amd_u64(uint64 v) {
    amd_u32(v & 0xFFFFFFFF)
    amd_u32((v >> 32) & 0xFFFFFFFF)
}

fn amd_bytes(uint64 src, uint64 n) {
    uint64 i = 0
    while i < n {
        uint64 sp = src + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        amd_byte(b)
        i = i + 1
    }
}

fn amd_pad_to(uint64 target) {
    while amd_len < target { amd_byte(0) }
}

fn amd_align_up(uint64 n, uint64 a) -> uint64 {
    uint64 m = a - 1
    return (n + m) & ~m
}

fn amd_align(uint64 a) { amd_pad_to(amd_align_up(amd_len, a)) }

// Write a u32 at a specific offset (for back-patching).
fn amd_patch_u32(uint64 off, uint64 v) {
    uint64 p0 = amd_buf + off
    uint8 b0 = v & 0xFF
    unsafe { *(p0 as uint8) = b0 }
    uint64 p1 = amd_buf + off + 1
    uint8 b1 = (v >> 8) & 0xFF
    unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = amd_buf + off + 2
    uint8 b2 = (v >> 16) & 0xFF
    unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = amd_buf + off + 3
    uint8 b3 = (v >> 24) & 0xFF
    unsafe { *(p3 as uint8) = b3 }
}

// ---------------------------------------------------------------------------
// MsgPack mini-encoder — just enough for the AMD metadata we produce
// ---------------------------------------------------------------------------
//
// The metadata is a small map: top-level has 3 keys (amdhsa.kernels,
// amdhsa.target, amdhsa.version), and each kernel is a map with
// 15-ish keys. All strings are ASCII, short enough for fixstr; two
// values in the kernel map can overflow 32 (kernarg_size, max flat
// workgroup size) so we need the uint16 tag too.
//
// MsgPack reference (packed specification):
//   positive fixint  0x00..0x7F
//   fixmap N         0x80 | (N & 0x0F)        (N < 16)
//   fixarray N       0x90 | (N & 0x0F)        (N < 16)
//   fixstr len       0xA0 | (len & 0x1F)      (len <= 31)
//   false            0xC2
//   true             0xC3
//   uint8            0xCC <u8>
//   uint16           0xCD <u16 BE>
//   uint32           0xCE <u32 BE>
//   str8             0xD9 <u8 len> <bytes>
//   map16            0xDE <u16 BE count>

fn mp_fixmap(uint64 n) {
    uint64 tag = 0x80 | (n & 0x0F)
    amd_byte(tag)
}

fn mp_fixarray(uint64 n) {
    if n < 16 {
        uint64 tag = 0x90 | (n & 0x0F)
        amd_byte(tag)
    } else {
        // array16 tag: 0xDC followed by u16 BE count. Needed once
        // kernels with more than 15 kernargs appeared (M1t-3's
        // lif_stp has 19 kernargs; lif_full will have 22).
        amd_byte(0xDC)
        amd_byte((n >> 8) & 0xFF)
        amd_byte(n & 0xFF)
    }
}

fn mp_map16(uint64 n) {
    amd_byte(0xDE)
    amd_byte((n >> 8) & 0xFF)
    amd_byte(n & 0xFF)
}

fn mp_str_bytes(uint64 ptr, uint64 len) {
    if len <= 31 {
        uint64 tag = 0xA0 | (len & 0x1F)
        amd_byte(tag)
    } else if len <= 255 {
        amd_byte(0xD9)
        amd_byte(len & 0xFF)
    } else {
        write(2, "format_amdgpu: mp_str length > 255 unsupported\n", 47)
        exit(1)
    }
    amd_bytes(ptr, len)
}

// mp_str_lit — convenience for compile-time constant strings.
fn mp_str_lit(uint64 s) { mp_str_bytes(s, str_len(s)) }

fn mp_uint(uint64 v) {
    if v < 0x80 {
        amd_byte(v)
    } else if v <= 0xFF {
        amd_byte(0xCC)
        amd_byte(v)
    } else if v <= 0xFFFF {
        amd_byte(0xCD)
        amd_byte((v >> 8) & 0xFF)
        amd_byte(v & 0xFF)
    } else if v <= 0xFFFFFFFF {
        amd_byte(0xCE)
        amd_byte((v >> 24) & 0xFF)
        amd_byte((v >> 16) & 0xFF)
        amd_byte((v >> 8)  & 0xFF)
        amd_byte(v & 0xFF)
    } else {
        write(2, "format_amdgpu: mp_uint > 2^32 unsupported\n", 42)
        exit(1)
    }
}

fn mp_true()  { amd_byte(0xC3) }
fn mp_false() { amd_byte(0xC2) }

// ---------------------------------------------------------------------------
// AMD kernel metadata (.note body)
// ---------------------------------------------------------------------------
//
// Emits the complete MsgPack blob that goes inside the NT_AMDGPU_METADATA
// note. Returns the byte length written. Shape:
//
//   { "amdhsa.kernels": [ {...} ],
//     "amdhsa.target":  "amdgcn-amd-amdhsa--gfx1100",
//     "amdhsa.version": [1, 2] }
//
// The inner kernel map lists the bare minimum fields ROCm's loader
// inspects for a zero-kernarg / zero-resource kernel. Future
// milestones (M1b onwards) will extend `.args`.

// Args descriptor layout:
//   [arg0_size, arg0_kind, arg1_size, arg1_kind, ...]
// Each entry is 16 bytes (two u64s). Kinds: 0 = global_buffer,
// 1 = by_value. The encoder treats an empty (n_args=0) descriptor
// as "no kernargs" — same as the M1a nop kernel.
static uint64 AMD_ARG_KIND_GLOBAL_BUFFER = 0
static uint64 AMD_ARG_KIND_BY_VALUE      = 1

fn amd_arg_size_at(uint64 desc, uint64 i) -> uint64 {
    uint64 p = desc + i * 16
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn amd_arg_kind_at(uint64 desc, uint64 i) -> uint64 {
    uint64 p = desc + i * 16 + 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

// Emit the MsgPack body for all kernels currently registered in
// the kernel table. Each kernel contributes one entry in the
// `amdhsa.kernels` fixarray; top-level keys (`amdhsa.target`,
// `amdhsa.version`) are singletons.
fn amd_emit_metadata_body() -> uint64 {
    uint64 start = amd_len

    // Top-level map with 3 entries.
    mp_fixmap(3)

    // "amdhsa.kernels" -> [ {...} × kt_count ]
    mp_str_lit("amdhsa.kernels")
    mp_fixarray(kt_count)

    uint64 ki = 0
    while ki < kt_count {
        uint64 kname_ptr    = kt_get(ki, 0)
        uint64 kname_len    = kt_get(ki, 1)
        uint64 args_desc    = kt_get(ki, 4)
        uint64 n_args       = kt_get(ki, 5)
        uint64 kernarg_sz   = kt_get(ki, 6)
        uint64 sgpr_count   = kt_get(ki, 7)
        uint64 vgpr_count   = kt_get(ki, 8)

        // 16-entry inner map: needs map16 not fixmap (caps at 15).
        mp_map16(16)

        // .args — per-arg fixmap, shape depends on kind. See
        // amd_emit_metadata_body's original comment for field layout.
        mp_str_lit(".args")
        mp_fixarray(n_args)
        uint64 aai  = 0
        uint64 aoff = 0
        while aai < n_args {
            uint64 sz   = amd_arg_size_at(args_desc, aai)
            uint64 kind = amd_arg_kind_at(args_desc, aai)
            // Each arg sits at its natural alignment within the
            // kernarg segment. The AMDGPU ABI aligns to the arg's
            // own size for primitives (e.g. f64 rounds to 8). Without
            // this the decay kernel's factor gets offset=12 and the
            // kernel reads the wrong 8 bytes.
            if sz > 1 {
                uint64 rem = aoff - (aoff / sz) * sz
                if rem != 0 { aoff = aoff + sz - rem }
            }
            if kind == AMD_ARG_KIND_GLOBAL_BUFFER {
                mp_fixmap(4)
                mp_str_lit(".address_space"); mp_str_lit("global")
                mp_str_lit(".offset");        mp_uint(aoff)
                mp_str_lit(".size");          mp_uint(sz)
                mp_str_lit(".value_kind");    mp_str_lit("global_buffer")
            } else {
                mp_fixmap(3)
                mp_str_lit(".offset");        mp_uint(aoff)
                mp_str_lit(".size");          mp_uint(sz)
                mp_str_lit(".value_kind");    mp_str_lit("by_value")
            }
            aoff = aoff + sz
            aai  = aai + 1
        }
        mp_str_lit(".group_segment_fixed_size");   mp_uint(0)
        mp_str_lit(".kernarg_segment_align");      mp_uint(8)
        mp_str_lit(".kernarg_segment_size");       mp_uint(kernarg_sz)
        mp_str_lit(".max_flat_workgroup_size");    mp_uint(1024)
        mp_str_lit(".name");                       mp_str_bytes(kname_ptr, kname_len)
        mp_str_lit(".private_segment_fixed_size"); mp_uint(0)
        mp_str_lit(".sgpr_count");                 mp_uint(sgpr_count)
        mp_str_lit(".sgpr_spill_count");           mp_uint(0)

        // .symbol = <name>.kd — built inline per kernel.
        uint8[256] ksym_buf
        uint64 ki_sb = 0
        while ki_sb < kname_len {
            uint64 src = kname_ptr + ki_sb
            uint64 b = 0
            unsafe { *(src as uint8) -> b }
            uint64 dst = ksym_buf + ki_sb
            uint8 b8 = b
            unsafe { *(dst as uint8) = b8 }
            ki_sb = ki_sb + 1
        }
        uint64 sp_dot = ksym_buf + kname_len
        uint8 dot = 46; unsafe { *(sp_dot as uint8) = dot }
        uint64 sp_k = ksym_buf + kname_len + 1
        uint8 k8 = 107; unsafe { *(sp_k as uint8) = k8 }
        uint64 sp_d = ksym_buf + kname_len + 2
        uint8 d8 = 100; unsafe { *(sp_d as uint8) = d8 }
        uint64 ksym_len = kname_len + 3
        mp_str_lit(".symbol");                     mp_str_bytes(ksym_buf, ksym_len)

        mp_str_lit(".uniform_work_group_size");    mp_uint(1)
        mp_str_lit(".uses_dynamic_stack");         mp_false()
        mp_str_lit(".vgpr_count");                 mp_uint(vgpr_count)
        mp_str_lit(".vgpr_spill_count");           mp_uint(0)
        mp_str_lit(".wavefront_size");             mp_uint(32)
        mp_str_lit(".workgroup_processor_mode");   mp_uint(1)

        ki = ki + 1
    }

    //   "amdhsa.target" -> "amdgcn-amd-amdhsa--gfx1100"
    mp_str_lit("amdhsa.target")
    mp_str_lit("amdgcn-amd-amdhsa--gfx1100")

    //   "amdhsa.version" -> [1, 2]
    mp_str_lit("amdhsa.version")
    mp_fixarray(2)
    mp_uint(1)
    mp_uint(2)

    return amd_len - start
}

// ---------------------------------------------------------------------------
// Kernel descriptor (64 bytes) — lives in .rodata, referenced by the
// symbol "<kernel>.kd". Layout from AMDGPU ABI v4 (same offsets as v5).
//
//   0x00 u32  group_segment_fixed_size
//   0x04 u32  private_segment_fixed_size
//   0x08 u32  kernarg_size
//   0x0C u8[4] reserved
//   0x10 i64  kernel_code_entry_byte_offset   (from KD start to .text entry)
//   0x18 u8[20] reserved
//   0x2C u32  compute_pgm_rsrc3
//   0x30 u32  compute_pgm_rsrc1
//   0x34 u32  compute_pgm_rsrc2
//   0x38 u16  kernel_code_properties
//   0x3A u8   kernarg_preload_length
//   0x3B u8   kernarg_preload_offset
//   0x3C u8[4] reserved

fn amd_emit_kernel_descriptor(uint64 kernarg_size, uint64 entry_offset,
                              uint64 rsrc1, uint64 rsrc2, uint64 rsrc3,
                              uint64 properties) {
    // 0x00
    amd_u32(0)                        // group_segment_fixed_size
    amd_u32(0)                        // private_segment_fixed_size
    amd_u32(kernarg_size)             // kernarg_size
    amd_u32(0)                        // reserved
    // 0x10
    amd_u64(entry_offset)             // signed offset to entry
    // 0x18
    amd_u64(0)
    amd_u64(0)
    amd_u32(0)                        // reserved block (20 bytes)
    // 0x2C
    amd_u32(rsrc3)                    // compute_pgm_rsrc3
    // 0x30
    amd_u32(rsrc1)                    // compute_pgm_rsrc1
    amd_u32(rsrc2)                    // compute_pgm_rsrc2
    // 0x38
    amd_u16(properties)
    amd_byte(0)                       // kernarg_preload_length
    amd_byte(0)                       // kernarg_preload_offset
    amd_u32(0)                        // reserved tail
}

// ---------------------------------------------------------------------------
// ELF emission
// ---------------------------------------------------------------------------
//
// We lay the file out in a single pass, using fixed offsets that
// mirror the hipcc-produced code object but trimmed for M1a. All
// offsets below are PICKED at layout time; there is no back-patch
// pass. The section / segment sizes follow from string/content
// lengths we compute up front.

static uint64 AMD_ELF_HEADER_SIZE   = 64
static uint64 AMD_PHDR_SIZE         = 56
static uint64 AMD_SHDR_SIZE         = 64
static uint64 AMD_SYMBOL_SIZE       = 24

// ELF constants
static uint64 ELF_ET_DYN            = 3
static uint64 ELF_EM_AMDGPU         = 224
static uint64 ELF_OSABI_AMDGPU_HSA  = 64
static uint64 ELF_AMDHSA_ABI_V4     = 4
static uint64 ELF_EF_AMDGPU_GFX1100 = 0x41

static uint64 ELF_PT_LOAD           = 1
static uint64 ELF_PT_DYNAMIC        = 2
static uint64 ELF_PT_NOTE           = 4
static uint64 ELF_PT_PHDR           = 6

static uint64 ELF_PF_X              = 1
static uint64 ELF_PF_W              = 2
static uint64 ELF_PF_R              = 4

static uint64 ELF_SHT_NULL          = 0
static uint64 ELF_SHT_PROGBITS      = 1
static uint64 ELF_SHT_SYMTAB        = 2
static uint64 ELF_SHT_STRTAB        = 3
static uint64 ELF_SHT_HASH          = 5
static uint64 ELF_SHT_DYNAMIC       = 6
static uint64 ELF_SHT_NOTE          = 7
static uint64 ELF_SHT_DYNSYM        = 11

// .dynamic DT_* tags
static uint64 DT_NULL               = 0
static uint64 DT_HASH               = 4
static uint64 DT_STRTAB             = 5
static uint64 DT_SYMTAB             = 6
static uint64 DT_STRSZ              = 10
static uint64 DT_SYMENT             = 11

static uint64 ELF_SHF_WRITE         = 1
static uint64 ELF_SHF_ALLOC         = 2
static uint64 ELF_SHF_EXECINSTR     = 4

// Symbol binding + type packed into st_info
static uint64 ELF_STB_LOCAL         = 0
static uint64 ELF_STB_GLOBAL        = 1
static uint64 ELF_STT_NOTYPE        = 0
static uint64 ELF_STT_OBJECT        = 1
static uint64 ELF_STT_FUNC          = 2
static uint64 ELF_STV_DEFAULT       = 0
static uint64 ELF_STV_PROTECTED     = 3

fn amd_st_info(uint64 bind, uint64 typ) -> uint64 {
    return ((bind & 0xF) << 4) | (typ & 0xF)
}

// Emit the NT_AMDGPU_METADATA note: name="AMDGPU\0\0" (8 bytes) +
// MsgPack body. Returns total note bytes written. Pulls kernel
// list from the kernel table.
fn amd_emit_note_section() -> uint64 {
    uint64 start = amd_len
    uint64 hdr_off = amd_len
    amd_u32(7)            // n_namesz = strlen("AMDGPU") + 1 = 7
    amd_u32(0)            // n_descsz — back-patched
    amd_u32(0x20)         // n_type = NT_AMDGPU_METADATA = 32
    // name: "AMDGPU\0" padded to 4 bytes → "AMDGPU\0\0"
    amd_byte(65)  // A
    amd_byte(77)  // M
    amd_byte(68)  // D
    amd_byte(71)  // G
    amd_byte(80)  // P
    amd_byte(85)  // U
    amd_byte(0)
    amd_byte(0)   // padding to 8-byte name area
    // Body
    uint64 body_len = amd_emit_metadata_body()
    amd_patch_u32(hdr_off + 4, body_len)
    amd_align(4)
    return amd_len - start
}

// ---------------------------------------------------------------------------
// gfx1100 instruction encoder (M1c subset)
//
// We only encode what write_sentinel needs: SOPP (s_endpgm,
// s_waitcnt), SMEM (s_load_b64), a single VOPD shape
// (v_dual_mov_b32 + v_dual_mov_b32 with a 32-bit literal), and
// one FLAT/GLOBAL form (global_store_b32 with SADDR). Enough to
// take the kernel from hand-pasted bytes to structured calls;
// broader coverage grows as Stage 1 proper lands.
//
// All encoders write 32-bit words little-endian into a dedicated
// kernel-text buffer (`asm_text_buf`) so the caller can pass the
// full text to emit_amdgpu_code_object without tangling it with
// the surrounding ELF layout.
// ---------------------------------------------------------------------------

static uint64 asm_text_buf = 0
static uint64 asm_text_len = 0
static uint64 asm_text_cap = 0

fn asm_init() {
    if asm_text_buf == 0 {
        asm_text_cap = 4096
        asm_text_buf = alloc(asm_text_cap)
    }
    asm_text_len = 0
}

fn asm_byte(uint64 v) {
    if asm_text_len >= asm_text_cap {
        write(2, "format_amdgpu: asm text overflow\n", 33)
        exit(1)
    }
    uint64 p = asm_text_buf + asm_text_len
    uint8 b = v & 0xFF
    unsafe { *(p as uint8) = b }
    asm_text_len = asm_text_len + 1
}

fn asm_u32(uint64 word) {
    asm_byte(word & 0xFF)
    asm_byte((word >> 8)  & 0xFF)
    asm_byte((word >> 16) & 0xFF)
    asm_byte((word >> 24) & 0xFF)
}

// ── SOPP format (single 32-bit word) ────────────────────────────────
// [31:23] = 0x17F   (SOPP prefix on gfx11)
// [22:16] = 7-bit opcode
// [15:0]  = simm16
//
// SOPP opcodes we care about:
//   0x30  s_endpgm
//   0x09  s_waitcnt
static uint64 GFX11_SOPP_PREFIX = 0x17F

fn asm_sopp(uint64 op, uint64 simm16) {
    uint64 word = (GFX11_SOPP_PREFIX << 23)
                  | ((op & 0x7F) << 16)
                  | (simm16 & 0xFFFF)
    asm_u32(word)
}

fn asm_s_endpgm() { asm_sopp(0x30, 0) }

// s_clause <count> — scheduling hint that the next (count+1)
// instructions form a group with no intervening memory ops. Clang
// emits this ahead of back-to-back s_load_* pairs to let the
// hardware batch their SMEM accesses. op = 0x05 on gfx11.
fn asm_s_clause(uint64 count) { asm_sopp(0x05, count & 0xFFFF) }

// s_waitcnt lgkmcnt(0) — wait for scalar/LDS memory, ignore vmcnt.
// simm16 encoding for gfx11 combined waitcnt:
//   [3:0]    vmcnt[3:0]
//   [7]      expcnt
//   [11:8]   lgkmcnt
//   [14:12]  vmcnt[6:4]
//   [15]     reserved (set by clang)
// The composed "lgkmcnt=0, others max" value is 0xFC07; clang emits
// exactly this ahead of reads from SMEM-loaded SGPRs.
fn asm_s_waitcnt_lgkmcnt_zero() { asm_sopp(0x09, 0xFC07) }

// s_waitcnt vmcnt(0) — wait for VMEM ops to drain. simm16 0x03F7
// = lgkmcnt max (0xF) << 8 | expcnt max << 7 | vmcnt_lo 0x7 and
// vmcnt_hi=0 (vmcnt total bits scattered across [3:0] and [14:12]
// on gfx11). We care about "vmcnt=0, others ignored", clang emits
// exactly 0x03F7 for that.
fn asm_s_waitcnt_vmcnt_zero() { asm_sopp(0x09, 0x03F7) }

// s_delay_alu <simm16> — SOPP op 0x07 (gfx11+). The simm16 encodes
// how far back the current instruction should wait for a VALU
// dependency. simm16 values this helper takes directly:
//   0x01 = instid0(VALU_DEP_1)
//   0x02 = instid0(VALU_DEP_2)
//   0x03 = instid0(VALU_DEP_3)
//   0x04 = instid0(VALU_DEP_4)
// Used to satisfy VGPR RAW hazards between a multi-cycle VALU (e.g.
// v_add_f64) and a consumer (e.g. an atomic that reads the result
// in its data quad). The CAS-loop in the M1p demo relies on this
// to guarantee v[6:7] is settled before the cmpswap reads the quad.
fn asm_s_delay_alu(uint64 simm16) { asm_sopp(0x07, simm16 & 0xFFFF) }

// s_waitcnt_vscnt null, 0 — gfx10/11 split the VMEM counter into
// vmcnt (reads + atomics-with-return) and vscnt (pure stores and
// no-return atomics). This helper drains vscnt to 0. After any
// write-heavy kernel or atomic sequence that may produce stores,
// emit this in addition to vmcnt(0) before s_endpgm to ensure the
// memory system is quiesced before the dispatch completes.
// Verified against llvm-mc: encoding [0x00,0x00,0x7c,0xbc]
// → word 0xBC7C0000 (SOPK-family, op 0x3E, sdst=null=0x7D, simm=0).
fn asm_s_waitcnt_vscnt_zero() { asm_u32(0xBC7C0000) }

// s_cbranch_execz <simm16> — SOPP op 0x25. Branches forward by
// simm16 dwords if EXEC == 0 (no lanes active). Used right after
// s_and_saveexec to skip the guarded body when no lane passed the
// predicate. Caller passes the dword count directly.
fn asm_s_cbranch_execz(uint64 simm16_dwords) { asm_sopp(0x25, simm16_dwords & 0xFFFF) }

// ── Scalar control flow (M1m — building blocks for the CSR kernel
// while loops that M1n will actually wire up). All three are SOPP;
// simm16 is a SIGNED dword offset added to PC+4 — negative values
// encode as the two's-complement 16-bit pattern for backward
// branches.

// s_branch <simm16>          — unconditional scalar branch.
//   Clang reference: s_branch 0x8 → 0xBFA00008  (op 0x20)
fn asm_s_branch(uint64 simm16_dwords) { asm_sopp(0x20, simm16_dwords & 0xFFFF) }

// s_cbranch_scc0 <simm16>    — branch if SCC == 0 (last SALU
// compare was false).  Op 0x21 on gfx11 (clang: 0xBFA10008).
fn asm_s_cbranch_scc0(uint64 simm16_dwords) { asm_sopp(0x21, simm16_dwords & 0xFFFF) }

// s_cbranch_vccz <simm16> — SOPP op 0x23. Branches if VCC == 0
// (all lanes' vcmp was false / equal).
fn asm_s_cbranch_vccz(uint64 simm16_dwords) { asm_sopp(0x23, simm16_dwords & 0xFFFF) }

// s_cbranch_vccnz <simm16> — SOPP op 0x24. Branches if VCC != 0
// (some lane's vcmp was true / mismatch). Used by the CAS retry
// loop: when cmpswap's returned prev differs from the expected pair,
// vcc_lo becomes nonzero and we branch back to the loop head.
fn asm_s_cbranch_vccnz(uint64 simm16_dwords) { asm_sopp(0x24, simm16_dwords & 0xFFFF) }

// s_cbranch_scc1 <simm16>    — branch if SCC == 1 (compare true).
// Op 0x22 on gfx11 (clang: 0xBFA20008).
fn asm_s_cbranch_scc1(uint64 simm16_dwords) { asm_sopp(0x22, simm16_dwords & 0xFFFF) }

// ── Scalar arithmetic / compare (M1m).

// s_add_u32 sdst, ssrc0, imm8  (SOP2 op 0x00).
//   SOP2 word = [31:30]=10 | [29:23]=op | [22:16]=sdst | [15:8]=ssrc1 | [7:0]=ssrc0.
//   For a small literal imm (0..64), ssrc1 encodes as 0x80+imm.
//   Clang reference: s_add_u32 s2, s2, 1 → 0x80028102.
fn asm_s_add_u32_imm(uint64 sdst, uint64 ssrc0_sgpr, uint64 imm) {
    uint64 ssrc1_enc = 0x80 + (imm & 0x3F)               // inline const
    uint64 word = (0x2 << 30)                             // SOP2 prefix
                  | (0x00 << 23)                          // op
                  | ((sdst & 0x7F) << 16)
                  | ((ssrc1_enc & 0xFF) << 8)
                  | (ssrc0_sgpr & 0xFF)
    asm_u32(word)
}

// s_cmp_lt_u32 ssrc0, ssrc1  (SOPC op 0x0A).
//   Sets SCC = (ssrc0 < ssrc1). Format:
//   [31:24] = 0xBF prefix | [23:16] = op | [15:8] = ssrc1 | [7:0] = ssrc0
//   Clang reference: s_cmp_lt_u32 s2, s3 → 0xBF0A0302.
fn asm_s_cmp_lt_u32(uint64 ssrc0, uint64 ssrc1) {
    uint64 word = (0xBF << 24)
                  | (0x0A << 16)
                  | ((ssrc1 & 0xFF) << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// s_cmp_eq_u32 ssrc0, ssrc1  (SOPC op 0x06).
//   Sets SCC = (ssrc0 == ssrc1). For "test register against small
//   constant" patterns (e.g. cell_type == 1), pass ssrc1 = 0x80 + K
//   for inline constant K. Verified: s_cmp_eq_u32 s14, 1 → 0xBF06810E.
fn asm_s_cmp_eq_u32(uint64 ssrc0, uint64 ssrc1) {
    uint64 word = (0xBF << 24)
                  | (0x06 << 16)
                  | ((ssrc1 & 0xFF) << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// s_mov_b32 sdst, 0  (SOP1 op 0x00 with inline-0 src).
//   Format: [31:23]=0x17D | [22:16]=sdst | [15:8]=op | [7:0]=ssrc0
//   Clang reference: s_mov_b32 s2, 0 → 0xBE820080.
fn asm_s_mov_b32_imm0(uint64 sdst) {
    uint64 word = (0x17D << 23)
                  | ((sdst & 0x7F) << 16)
                  | (0x00 << 8)
                  | 0x80                                  // inline constant 0
    asm_u32(word)
}

// Generalised s_mov_b32 sdst, ssrc0 — any SGPR/exec_lo (0x7E)/
// vcc_lo (0x6A) encoded in either slot. Used to save/restore
// EXEC around per-lane divergent loops.
//   s_mov_b32 s4, exec_lo → 0xBE84007E
//   s_mov_b32 exec_lo, s4 → 0xBEFE0004
fn asm_s_mov_b32(uint64 sdst, uint64 ssrc0) {
    uint64 word = (0x17D << 23)
                  | ((sdst & 0x7F) << 16)
                  | (0x00 << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// ── VALU divergent-loop primitives (M1n).
//
// v_cmp_lt_u32_e32 vcc_lo, v_src0, v_src1  — VOPC op 0x49.
//   Sets VCC[lane] = (src0 < src1) per active lane. Used to gate
//   each iteration of a while loop where the bound differs per
//   lane.
//   Clang reference: v_cmp_lt_u32_e32 vcc_lo, v0, v1 → 0x7C920300.
fn asm_v_cmp_lt_u32_vv(uint64 vsrc0, uint64 vsrc1) {
    uint64 src0_enc = 0x100 | (vsrc0 & 0xFF)
    uint64 word = (0x3E << 25)
                  | (0x49 << 17)
                  | ((vsrc1 & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_cmp_ne_u64_e32 vcc_lo, v[src0:+1], v[src1:+1]  — VOPC op 0x5D (64-bit).
//   Sets VCC[lane] = (u64(src0) != u64(src1)) per active lane. Both
//   operands are VGPR pairs. Used by the atomic-CAS retry loop: after
//   cmpswap, compare the returned "prev" against the "expected" pair;
//   if any lane saw a mismatch, vcc is nonzero and the loop retries.
//   Verified against llvm-mc: `v_cmp_ne_u64_e32 vcc_lo, v[0:1], v[4:5]`
//   → 0x7CBA0900.
fn asm_v_cmp_ne_u64_vv(uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 word = (0x3E << 25)
                  | (0x5D << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_cmp_lt_f64_e32 vcc_lo, 0, v[vsrc1_pair:+1]  — VOPC op 0x21.
//   Sets VCC[lane] = (0.0 < v[vsrc1:vsrc1+1]) per active lane. With
//   src0 pinned to inline-zero (0x80), this is the "rel > 0.0" guard
//   used by csr_i_deliver / csr_e_deliver. Verified against llvm-mc:
//   `v_cmp_lt_f64_e32 vcc_lo, 0, v[4:5]` → 0x7C420880.
fn asm_v_cmp_lt_f64_zero_v(uint64 vsrc1_pair) {
    uint64 word = (0x3E << 25)
                  | (0x21 << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | 0x80                       // src0 = inline 0.0
    asm_u32(word)
}

// v_cmp_ge_f64_e32 vcc_lo, v[src0:+1], v[src1:+1]  — VOPC op 0x26.
//   Sets VCC[lane] = (v[src0:+1] >= v[src1:+1]) per active lane. Used
//   by lif_spike to test v_new >= V_thresh for spike detection.
//   Verified: `v_cmp_ge_f64_e32 vcc_lo, v[0:1], v[22:23]` → 0x7C4C2D00.
fn asm_v_cmp_ge_f64_vv(uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 word = (0x3E << 25)
                  | (0x26 << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// s_and_b32 exec_lo, exec_lo, vcc_lo  — SOP2 op 0x0B.
//   Reduces EXEC to the intersection of current EXEC and VCC:
//   lanes where vcmp was false drop out of the active set.
//   Hard-wired to the exec_lo & vcc_lo operand shape since that's
//   the only one any of our loop patterns need.
//   Clang reference: → 0x8B7E6A7E.
fn asm_s_and_b32_exec_vcc_lo() {
    // (0x2<<30) SOP2 prefix | (0x16<<23) op (s_and_b32 on gfx11)
    // | (0x7E<<16) sdst=exec_lo | (0x6A<<8) ssrc1=vcc_lo
    // | 0x7E ssrc0=exec_lo
    uint64 word = (0x2 << 30)
                  | (0x16 << 23)
                  | (0x7E << 16)
                  | (0x6A << 8)
                  | 0x7E
    asm_u32(word)
}

// v_cmp_eq_u32_e32 vcc_lo, <inline imm>, v<vgpr>  — VOPC op 0x4A.
//   Sets VCC[lane] = (imm == u32(v[vgpr])) per active lane. src0 is
//   an inline literal (0..63 encoded as 0x80+K; mask is &0x3F). Used
//   for the ref == 0 guard in mt_lif_full.
//   Verified: `v_cmp_eq_u32_e32 vcc_lo, 0, v12` → 0x7C941880.
fn asm_v_cmp_eq_u32_imm_vgpr(uint64 imm, uint64 vgpr) {
    uint64 src0_enc = 0x80 + (imm & 0x3F)
    uint64 word = (0x3E << 25)
                  | (0x4A << 17)
                  | ((vgpr & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// s_xor_b32 exec_lo, exec_lo, s<ssrc1>  — SOP2 op s_xor_b32 (gfx11).
//   Flips EXEC by XORing with a saved SGPR. Used to transition from
//   the "then" EXEC mask to the "else" mask (complementary lanes)
//   inside an if/else guarded by s_and_saveexec_b32.
//   Verified via llvm-mc: `s_xor_b32 exec_lo, exec_lo, s46` encodes
//   as bytes [0x7e,0x2e,0x7e,0x8d] → word 0x8D7E2E7E. That puts the
//   gfx11 op field at 0x1A (not 0x18).
fn asm_s_xor_b32_exec_sgpr(uint64 ssrc1) {
    uint64 word = (0x2 << 30)
                  | (0x1A << 23)
                  | (0x7E << 16)
                  | ((ssrc1 & 0xFF) << 8)
                  | 0x7E
    asm_u32(word)
}

// v_add_nc_u32_e32 vdst, vsrc0, vsrc1  — VOP2 op 0x25, no-carry
// 32-bit vector integer add.
//   Clang reference: v_add_nc_u32_e32 v2, v0, v2 → 0x4A040500.
fn asm_v_add_nc_u32_vv(uint64 vdst, uint64 vsrc0, uint64 vsrc1) {
    uint64 src0_enc = 0x100 | (vsrc0 & 0xFF)
    uint64 word = (0x25 << 25)
                  | ((vdst & 0xFF) << 17)
                  | ((vsrc1 & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_add_nc_u32_e32 vdst, imm, vsrc1 — same op but with an inline
// constant (0..64 encode as 0x80+K) in the src0 slot.
//   Clang reference: v_add_nc_u32_e32 v0, 1, v0 → 0x4A000081.
fn asm_v_add_nc_u32_imm(uint64 vdst, uint64 imm, uint64 vsrc1) {
    uint64 src0_enc = 0x80 + (imm & 0x3F)
    uint64 word = (0x25 << 25)
                  | ((vdst & 0xFF) << 17)
                  | ((vsrc1 & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// s_cbranch_execnz <simm16>  — SOPP op 0x26. Branches if EXEC != 0
// (at least one lane still active). Used to loop back while any
// lane still has work.
fn asm_s_cbranch_execnz(uint64 simm16_dwords) { asm_sopp(0x26, simm16_dwords & 0xFFFF) }

// ── SMEM format (64-bit instruction) ───────────────────────────────
// Word 1 (gfx11):
//   [31:26] = 0x3D   (SMEM prefix)
//   [25:18] = 8-bit opcode
//   [17]     reserved
//   [14]     DLC
//   [13]     GLC
//   [12:7]   sdata_pair (6-bit) — SGPR-pair index (halved): to load
//             into s[2N:2N+1], pass N. asm_s_load_b64(0, 0) loads into
//             s[0:1]; asm_s_load_b64(1, 0) into s[2:3]; etc.
//   [6:0]    sbase_pair (7-bit) — SGPR-pair index, ALSO halved (NOT
//             a raw SGPR index). To read from s[2:3], pass sbase=1;
//             from s[4:5], pass sbase=2. This asymmetry with FLAT/
//             GLOBAL saddr (which is raw) was verified against
//             llvm-mc — an earlier comment here claimed the opposite
//             because the single caller only ever used sbase=0,
//             masking the issue.
// Word 2 (offset):
//   [31:25]  soffset (7-bit SGPR index; 0x7D = SGPR_NULL)
//   [24:0]   25-bit signed immediate offset
//
// For "s[sdata:sdata+1], s[sbase:sbase+1], null" with zero offset:
//   clang emits 0xF8000000 as the offset word. That's soffset bits
//   [31:25] = 0x7C — the gfx11 "no SGPR offset" sentinel, not the
//   SGPR_NULL (0x7D) reg index. Leave as opaque for now; exposing
//   it properly comes when we grow the encoder.
static uint64 GFX11_SMEM_PREFIX = 0x3D

// s_load_b64 s[sdata:sdata+1], s[sbase:sbase+1], null  (op 0x01)
fn asm_s_load_b64(uint64 sdata, uint64 sbase_pair) {
    uint64 word1 = (GFX11_SMEM_PREFIX << 26)
                   | (0x01 << 18)
                   | ((sdata & 0x3F) << 7)
                   | (sbase_pair & 0x7F)
    asm_u32(word1)
    asm_u32(0xF8000000)
}

// s_load_b64 pair s[sdata_pair:+1], s[sbase_pair:+1], <imm_offset>
// (SMEM op 0x01 with a non-zero imm offset). Lets us pull a second
// 8-byte kernarg past the base pointer — e.g. kernarg[16..23].
fn asm_s_load_b64_off(uint64 sdata_pair, uint64 sbase_pair, uint64 imm_offset) {
    uint64 word1 = (GFX11_SMEM_PREFIX << 26)
                   | (0x01 << 18)
                   | ((sdata_pair & 0x3F) << 7)
                   | (sbase_pair & 0x7F)
    asm_u32(word1)
    uint64 word2 = (0x7C << 25) | (imm_offset & 0x1FFFFFF)
    asm_u32(word2)
}

// s_load_b32 s<SGPR>, s[sbase_pair:+1], <imm_offset>  (SMEM op 0x00)
//
// Gotcha: the SMEM sdata field is pair-index-encoded even for b32
// loads (the destination must be an even SGPR for hardware
// alignment reasons), so a load into s2 needs sdata_pair=1 — not 2.
// The 6-bit field lives at [12:7] of word 1. This mirrors how the
// b64 loader already takes "pair index"; asm_s_load_b64(0,0)
// coincidentally works because 0/2==0, but sdata_pair=N here means
// the destination SGPR is 2N.
fn asm_s_load_b32(uint64 sdata_pair, uint64 sbase_pair, uint64 imm_offset) {
    uint64 word1 = (GFX11_SMEM_PREFIX << 26)
                   | (0x00 << 18)
                   | ((sdata_pair & 0x3F) << 7)
                   | (sbase_pair & 0x7F)
    asm_u32(word1)
    uint64 word2 = (0x7C << 25) | (imm_offset & 0x1FFFFFF)
    asm_u32(word2)
}

// ── VOP1: single-source vector op in 32 bits. Layout (gfx11):
//   [31:25] = 0x3F  (VOP1 prefix)
//   [24:17] = vdst  (8-bit VGPR destination)
//   [16:9]  = op    (8-bit opcode)
//   [8:0]   = src0  (9-bit: SGPR=raw, VGPR=0x100|N, inline=0x80..0xC0 for 0..64)
// Verified against llvm-mc: `v_mov_b32 v6, 7` → 0x7E0C0287.
fn asm_v_mov_b32(uint64 vdst_vgpr, uint64 src0) {
    uint64 word = (0x3F << 25)
                  | ((vdst_vgpr & 0xFF) << 17)
                  | (0x01 << 9)
                  | (src0 & 0x1FF)
    asm_u32(word)
}

// v_mov_b32 vdst, <inline imm 0..64>  — the common case.
// inline_u 0→0x80, 1→0x81, …, 64→0xC0. For negatives use 0xC1..0xD0 directly
// via asm_v_mov_b32.
fn asm_v_mov_b32_inline_u(uint64 vdst_vgpr, uint64 inline_u) {
    asm_v_mov_b32(vdst_vgpr, 0x80 + inline_u)
}

// ── VOPD: dual-issue VOP1/VOP2 pair in one 64-bit instruction (gfx11+).
// Full encoding is intricate; we only need the specific form
//   v_dual_mov_b32 v0, 0 :: v_dual_mov_b32 v1, <literal32>
// which clang emits for the sentinel kernel. Words are:
//   0xCA100080   — VOPD + op pair (mov, mov), v_dst_x=v0, v_dst_y=v1,
//                  src_x=inline-zero, src_y=VGPR encoding 0xFF (literal)
//   0x000000FF   — per-slot operand word; 0xFF in the slot-y source
//                  means "literal follows"
//   <literal32>  — the 32-bit immediate for dst_y
fn asm_v_dual_mov_b32_mov_b32_lit(uint64 vdst_x, uint64 vdst_y, uint64 lit32) {
    // Reference encoding depends on vdst_x=0, vdst_y=1; if the
    // caller uses other dsts we'd need to splice them into word 1's
    // [14:9] / [23:17] fields. Today the one caller passes (0,1).
    if vdst_x != 0 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_x=0\n", 57)
        exit(1)
    }
    if vdst_y != 1 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_y=1\n", 57)
        exit(1)
    }
    asm_u32(0xCA100080)
    asm_u32(0x000000FF)
    asm_u32(lit32)
}

// VOPD sibling of the _lit variant above: src_y comes from an
// already-populated SGPR instead of a 32-bit literal word. Word-1
// is unchanged (same opcode pair + vdst encoding); word-2 holds
// the slot-Y src0 directly — SGPR indices encode in the low 9
// bits. Save 4 bytes and one instruction-cache cycle relative to
// the literal form.
fn asm_v_dual_mov_b32_mov_b32_sgpr(uint64 vdst_x, uint64 vdst_y, uint64 src_y_sgpr) {
    if vdst_x != 0 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_x=0\n", 57)
        exit(1)
    }
    if vdst_y != 1 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_y=1\n", 57)
        exit(1)
    }
    asm_u32(0xCA100080)
    asm_u32(src_y_sgpr & 0x1FF)
}

// VOPD v_dual_mov with BOTH slots sourced from SGPRs. For splat-f64:
//   v_dual_mov_b32 v0, s_lo :: v_dual_mov_b32 v1, s_hi
// moves an SGPR pair into a VGPR pair in one issue. Still hard-wired
// to the canonical (vdst_x=0, vdst_y=1) layout — VOPD's implicit
// "vdst_y = vdst_x XOR 1" pairing means (0,1) is the natural slot
// for data placed in v[0:1].
// Verified against llvm-mc: `v_dual_mov_b32 v0, s4 :: v_dual_mov_b32 v1, s5`
//   → 0xCA100004 0x00000005.
fn asm_v_dual_mov_b32_sx_sy(uint64 vdst_x, uint64 vdst_y,
                            uint64 src_x_sgpr, uint64 src_y_sgpr) {
    if vdst_x != 0 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32_sx_sy only supports vdst_x=0\n", 63)
        exit(1)
    }
    if vdst_y != 1 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32_sx_sy only supports vdst_y=1\n", 63)
        exit(1)
    }
    // Same word-1 constant skeleton as the lit/sgpr variants, with
    // the slot-x src occupying the low 9 bits.
    uint64 word1 = 0xCA100000 | (src_x_sgpr & 0x1FF)
    asm_u32(word1)
    asm_u32(src_y_sgpr & 0x1FF)
}

// ── VOP2 — two-operand VGPR math in 32 bits. Layout (gfx11):
//   [31]     = 0   (VOP2 marker — zero bit distinguishes from VOP3/VOPC)
//   [30:25]  = op (6 bits)
//   [24:17]  = vdst (8 bits, VGPR)
//   [16:9]   = vsrc1 (8 bits, VGPR)
//   [8:0]    = src0 (9 bits, general — SGPR / VGPR / inline / literal)
//
// Inline-constant src0 encodings used here:
//   128..192  = 0..64  (for 0 <= K <= 64, encoding is 128 + K)
//
// For `v_lshlrev_b32 vdst, K, vsrc`, semantics = vdst = vsrc << K.
// src0 holds the shift amount (inline const), vsrc1 the value.
fn asm_v_lshlrev_b32_imm(uint64 vdst_vgpr, uint64 shift_amount, uint64 src_vgpr) {
    // VOP2 op 0x18 = v_lshlrev_b32 on gfx11. (First draft used 0x30,
    // which would set bit 30 of the word and break the VOP2-family
    // marker convention; confirmed against clang's v_lshlrev_b32
    // output.)
    uint64 src0_enc = 128 + (shift_amount & 0x3F)
    uint64 word = (0x18 << 25)
                  | ((vdst_vgpr & 0xFF) << 17)
                  | ((src_vgpr  & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// ── VOPC — vector compare producing a lane mask into VCC. Layout
// (gfx11):
//   [31:25] = 0b0111110   (VOPC prefix, 0x3E)
//   [24:17] = 8-bit op
//   [16:9]  = vsrc1 (8 bits, VGPR)
//   [8:0]   = src0 (9 bits)
//
// v_cmp_gt_u32_e32 vcc_lo, src0, vsrc1  ≡  VCC = (src0 > vsrc1).
// Op 0x4C on gfx11. With src0 = SGPR, vsrc1 = VGPR, this gives the
// "sgpr > vgpr" lane mask we need for `if v0 < n` bounds checks —
// clang emits "gt" (not "lt") to put the SGPR on the left.
fn asm_v_cmp_gt_u32_sgpr_vgpr(uint64 sgpr_src0, uint64 vgpr_src1) {
    uint64 word = (0x3E << 25)
                  | (0x4C << 17)
                  | ((vgpr_src1 & 0xFF) << 9)
                  | (sgpr_src0 & 0x1FF)      // SGPRs encode directly as src0
    asm_u32(word)
}

// ── SOP1 — single-source scalar op. Layout (gfx11):
//   [31:23] = 0b101111101 (0x17D prefix — one bit higher than SOPP)
//   [22:16] = 7-bit ssrc0   (here we use 0x6A = VCC_LO)
//   [15:8]  = 8-bit op
//   [7:0]   = sdst (7 bits) + 1 bit reserved
//
// s_and_saveexec_b32 sdst, ssrc0 — op 0x20 on gfx11. Saves current
// EXEC into sdst, sets EXEC = EXEC & ssrc0 (the vcc_lo mask from
// the preceding vcmp), returning original EXEC in sdst for the
// `end-if` restore point.
fn asm_s_and_saveexec_b32_vcc_lo(uint64 sdst_sgpr) {
    // Reference: s_and_saveexec_b32 s2, vcc_lo = 0xBE82206A
    //   [31:23] = 101111101 = 0x17D
    //   [22:16] = 0000010   = s2 (sdst, low 7 bits)
    //   [15:8]  = 00100000  = 0x20 (op = s_and_saveexec_b32)
    //   [7:0]   = 01101010  = 0x6A (ssrc0 = VCC_LO)
    uint64 word = (0x17D << 23)
                  | ((sdst_sgpr & 0x7F) << 16)
                  | (0x20 << 8)
                  | 0x6A                          // VCC_LO
    asm_u32(word)
}

// ── FLAT/GLOBAL (gfx11) — 64-bit instruction.
// Word 1: opcode + flags. For global_store_b32 with SADDR variant
// clang emits 0xDC6A0000 (opcode field encodes the SEG=global + the
// specific b32-store op).
// Word 2 fields:
//   [31:24] = reserved / scratch_offset (we hold at 0)
//   [23:16] = saddr (SGPR pair index for the base pointer)
//   [15:8]  = vdata (VGPR holding the value to store)
//   [7:0]   = vaddr (VGPR holding byte offset from saddr)
//
// For v0/v1/s[0:1] the reference is 0x00000100 — saddr=0, vdata=1,
// vaddr=0.
fn asm_global_store_b32(uint64 v_addr, uint64 v_data, uint64 saddr_pair) {
    asm_u32(0xDC6A0000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((v_data     & 0xFF) << 8)
                   | (v_addr      & 0xFF)
    asm_u32(word2)
}

// global_load_b64 v[vdst_pair:+1], v_addr, s[saddr_pair:+1]   (op 0x15)
// Loads 8 bytes from (s[saddr]+v_addr) into the VGPR pair
// starting at vdst_pair.
fn asm_global_load_b64(uint64 vdst_pair, uint64 v_addr, uint64 saddr_pair) {
    asm_u32(0xDC560000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdst_pair & 0xFF) << 24)
                   | ((v_addr    & 0xFF) << 0)
    // Reference for v[0:1]/v2/s[2:3]: 0x00020002
    //   [31:24]=vdst=0x00, [23:16]=saddr=0x02, [15:8]=vdata=0x00,
    //   [7:0]=vaddr=0x02. So vdst encoded at [31:24].
    asm_u32(word2)
}

// global_load_b64 ... glc  — bit 14 of word1 forces a bypass of L0
// so the load reads through L2. Needed when reading a location that
// an atomic just wrote on this same wave: a plain load would hit
// stale L0 and the CAS-loop's "assumed" would not match the actual
// post-atomic memory value. Verified via llvm-mc: word1 = 0xDC564000.
fn asm_global_load_b64_glc(uint64 vdst_pair, uint64 v_addr, uint64 saddr_pair) {
    asm_u32(0xDC564000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdst_pair & 0xFF) << 24)
                   | ((v_addr    & 0xFF) << 0)
    asm_u32(word2)
}

// buffer_gl0_inv — invalidate the L0 cache. No operands; emits
// a 64-bit instruction (word1=0xE0AC0000, word2=0). Used after
// an atomic-with-return so that subsequent plain global_loads
// from the same address do not return the pre-atomic value from
// a stale L0 cache line.
fn asm_buffer_gl0_inv() {
    asm_u32(0xE0AC0000)
    asm_u32(0x00000000)
}

// global_store_b64 v_addr, v[vdata_pair:+1], s[saddr_pair:+1]  (op 0x1B)
// Stores the VGPR pair starting at vdata_pair to (s[saddr]+v_addr).
// Verified against llvm-mc:
//   v0, v[6:7], s[0:1] → word2 0x00000600   (vdata at [15:8])
//   v0, v[0:1], s[0:1] → word2 0x00000000
//   v2, v[0:1], s[2:3] → word2 0x00020002
// NOTE: the store layout is asymmetric with loads. For loads, vdst
// is at [31:24]; for stores, vdata is at [15:8]. Older callers all
// happened to store v[0:1] (vdata=0), which masked this asymmetry.
fn asm_global_store_b64(uint64 v_addr, uint64 vdata_pair, uint64 saddr_pair) {
    asm_u32(0xDC6E0000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdata_pair & 0xFF) << 8)
                   | (v_addr & 0xFF)
    asm_u32(word2)
}

// global_atomic_cmpswap_b64 v[vdst_pair:+1], v_addr, v[vdata_quad:+3], s[saddr_pair:+1] glc
// 8-byte atomic compare-and-swap on (s[saddr_pair]+v_addr).
// VGPR quad layout per AMD ISA (cross-checked against clang's HIP lowering
// of atomicCAS(addr, cmp, val)):
//   v[vdata_quad:+1]   = NEW value  (what to write if cmp matches)
//   v[vdata_quad+2:+3] = COMPARE value (what memory must currently hold)
// With GLC=1, v[vdst_pair:+1] receives the old memory value.
//
// IMPORTANT (gfx11): when operands for cmp/new are produced by VALU
// instructions (e.g. v_add_f64 to compute new = current + delta), the
// atomic is only reliable when vdst_pair overlaps vdata_quad's low half
// (i.e. vdst_pair == vdata_quad). Non-overlapping layouts seem to work
// for simple hand-written tests where the data_quad is set via inline
// constants (M1o) but silently fail to swap when the data_quad VGPRs
// were written by multi-cycle VALU ops just before the atomic (M1p).
// hipcc always emits the overlapping form.
//
// Verified against llvm-mc:
//   v[0:1], v2, v[4:7], s[0:1] glc → 0xDD0A4000 0x00000402
//   v[8:9], v2, v[4:7], s[2:3] glc → 0xDD0A4000 0x08000402
//   v[0:1], v10,v[4:7], s[0:1] glc → 0xDD0A4000 0x0000040A
fn asm_global_atomic_cmpswap_b64_glc(uint64 vdst_pair, uint64 v_addr,
                                      uint64 vdata_quad, uint64 saddr_pair) {
    asm_u32(0xDD0A4000)
    uint64 word2 = ((vdst_pair  & 0xFF) << 24)
                   | ((saddr_pair & 0x7F) << 16)
                   | ((vdata_quad & 0xFF) << 8)
                   | (v_addr      & 0xFF)
    asm_u32(word2)
}

// global_atomic_add_u64 v[vaddr:+1], v[vdata:+1], off  — GLOBAL op 0x0E,
//   no-return form. Adds u64(vdata_pair) to *((uint64*)&mem[vaddr_pair])
//   atomically. Used for bumping the LTD event counter in mt_csr_e_delayed.
//   Verified: `global_atomic_add_u64 v[0:1], v[2:3], off` → 0xDD0E0000, 0x007C0200.
fn asm_global_atomic_add_u64_offvaddr(uint64 vaddr_pair, uint64 vdata_pair) {
    // word1 fixed: GLOBAL prefix + op 0x0E + vdst=0 (no return).
    asm_u32(0xDD0E0000)
    uint64 word2 = ((vaddr_pair & 0xFF) << 0)
                   | ((vdata_pair & 0xFF) << 8)
                   | (0x7C << 16)                       // saddr = OFF/NULL
    asm_u32(word2 & 0xFFFFFFFF)
}

// ── VOP3 — 64-bit three-source vector op. Layout (gfx11, non-VOP3P):
//   Word 1:
//     [31:26] = 0x35  (VOP3 prefix)
//     [25:16] = 10-bit op
//     [15]    = clamp
//     [14:11] = opsel (or similar)
//     [7:0]   = vdst (8 bits)
//   Word 2:
//     [31:29] = neg[2,1,0]  (source-negation flags, lane-high)
//     [28:21] doesn't matter here
//     (This is a narrow helper, not a general VOP3 encoder.)
//
// v_fma_f64 vdst_pair, -s[0:1], v[0:1], v[0:1]  — op 0x014 on gfx11.
// Used for the decay idiom  v - v * factor  == fma(-factor, v, v).
// Reference bytes: 0xD6140000 0x24020000.
// v_mad_u32_u24 vdst, s_src0, s_src1, v_src2   (VOP3 op 0x0B)
// vdst = src0 * src1 + src2, interpreting src0/src1 as u24. On
// gfx1100 this is the compact way to compute a 32-bit fused
// multiply-add across an SGPR pair and a VGPR — which is exactly
// what the grid-tid formula needs (gid = wg_id_x * bdim + tid).
// Verified against llvm-mc: op=0x0B, word1=0xD60B0001 for
// `v_mad_u32_u24 v1, s3, s2, v0`.
fn asm_v_mad_u32_u24(uint64 vdst_vgpr,
                     uint64 src0_sgpr, uint64 src1_sgpr,
                     uint64 src2_vgpr) {
    uint64 word1 = (0x6B << 25) | (0x00B << 16) | (vdst_vgpr & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = src0_sgpr & 0x1FF                // SGPR raw
    uint64 src1_enc = src1_sgpr & 0x1FF                // SGPR raw
    uint64 src2_enc = 0x100 | (src2_vgpr & 0xFF)       // VGPR 0x100+N
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_add_f64 vdst_pair, s_pair, -v_pair  (VOP3 op 0x127, neg[1]=1)
//
// Used by the relax idiom: `diff = target - v` is lowered as
// `add_f64(target_sgpr_pair, -v_src_pair)`. Encoding verified
// against clang for `v_add_f64 v[4:5], s[0:1], -v[2:3]`
// = 0xD7270004 0x40020400.
fn asm_v_add_f64_s_negv(uint64 vdst_pair, uint64 s_src_pair,
                         uint64 v_src_pair) {
    uint64 word1 = (0x6B << 25) | (0x127 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = s_src_pair & 0x1FF                // SGPR raw
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)       // VGPR 0x100+N
    uint64 neg = 0x2                                     // neg[1] = 1 → -src1
    uint64 word2 = (neg << 29)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_add_f64 vdst_pair, v_src0_pair, v_src1_pair  (VOP3 op 0x127, no neg)
//
// The pure VGPR+VGPR form. Used by the f64-atomic-add CAS loop body
// to compute new = current + delta, where both operands are already
// sitting in VGPR pairs (current from a global_load, delta from a
// pair of SGPR-sourced v_mov_b32s).
// Verified against llvm-mc: `v_add_f64 v[4:5], v[0:1], v[2:3]`
// → 0xD7270004 0x00020500.
fn asm_v_add_f64_vv(uint64 vdst_pair, uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x127 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_mul_f64 vdst_pair, v_src0_pair, v_src1_pair  (VOP3 op 0x128).
//   Companion to v_add_f64_vv. csr_i_deliver computes effective =
//   w * release, both VGPR pairs, storing into another pair.
//   Verified: v_mul_f64 v[0:1], v[2:3], v[4:5] → 0xD7280000 0x00020902.
fn asm_v_mul_f64_vv(uint64 vdst_pair, uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x128 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_sub_f64 vdst_pair, v_src0_pair, v_src1_pair  (= v_add_f64 with neg[1]=1).
//   Implemented as `v_add_f64 vdst, src0, -src1` on gfx11 (no dedicated
//   subtract op). Used by the LIF integrate body for V_rest - V and
//   drive - s_inh * J_I. Verified: v_add_f64 v[2:3], v[2:3], -v[6:7]
//   → 0xD7270002 0x40020D02 (neg bit at word2[30]).
fn asm_v_sub_f64_vv(uint64 vdst_pair, uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x127 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 neg = 0x2                                // neg[1] = 1 → src1 negated
    uint64 word2 = (neg << 29)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_max_f64 vdst, v[src0:+1], v[src1:+1]  — VOP3A op 0x2A.
//   Sets v[vdst:vdst+1] = max(v[src0:src0+1], v[src1:src1+1]) as f64.
//   Same shape as asm_v_mul_f64_vv, different op. Used by the STDP
//   LTD weight clamp in mt_csr_e_delayed.
//   Verified: `v_max_f64 v[0:1], v[2:3], v[4:5]` → 0xD72A0000, 0x00020902.
fn asm_v_max_f64_vv(uint64 vdst_pair, uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 word1 = (0xD7 << 24) | (0x2A << 16) | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (vsrc1_pair & 0xFF)
    uint64 word2 = (src1_enc << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2 & 0xFFFFFFFF)
}

// v_min_f64 vdst, v[src0:+1], v[src1:+1]  — VOP3A op 0x29.
//   Sets v[vdst:vdst+1] = min(v[src0:src0+1], v[src1:src1+1]) as f64.
//   Verified: `v_min_f64 v[0:1], v[2:3], v[4:5]` → 0xD7290000, 0x00020902.
fn asm_v_min_f64_vv(uint64 vdst_pair, uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 word1 = (0xD7 << 24) | (0x29 << 16) | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (vsrc1_pair & 0xFF)
    uint64 word2 = (src1_enc << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2 & 0xFFFFFFFF)
}

// v_fma_f64 vdst_pair, s_pair, v_src1_pair, v_src2_pair  (no neg)
//
// Companion to asm_v_fma_f64_neg_s_v_v — same op (0x014) but with
// neg=0 and src0 from an SGPR pair rather than a negated one.
// Used by relax: `nv = factor * diff + v` lowers as fma(factor_s,
// diff_v, v_v). Verified against clang for
// `v_fma_f64 v[2:3], s[2:3], v[4:5], v[2:3]` = 0xD6140002 0x040A0802.
fn asm_v_fma_f64_s_v_v(uint64 vdst_pair, uint64 s_src0_pair,
                        uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = s_src0_pair & 0x1FF               // SGPR raw
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

fn asm_v_fma_f64_neg_s_v_v(uint64 vdst_pair, uint64 neg_sgpr_pair,
                           uint64 v_src1_pair, uint64 v_src2_pair) {
    // Word 1: prefix + op + vdst.  gfx11 VOP3 prefix is 7 bits at
    // [31:25] = 0x6B (= bit 25 set in the 0x35-at-[31:26] framing);
    // op occupies [24:16] (9 bits).
    uint64 word1 = (0x6B << 25)
                   | (0x014 << 16)
                   | (vdst_pair & 0xFF)
    asm_u32(word1)
    // Word 2 layout reverse-engineered from ref 0x24020000:
    //   [31:29] = neg (3 bits) = 001  ->  negate src0 only
    //   [28:24] = reserved / 0
    //   [22:18] = src2[9:0] low / vgpr pair: reference has 0x02 here
    //              → src2 = v[0:1] pair, but encoding uses the low 9
    //              bits packed. The reference src2 VGPR pair starts at
    //              v0 (encoding 0x100), and clang compresses it into
    //              the word as 0x02 at [22:18]? Actually bits [28:18]
    //              = 11 bits = src2 = 0x...
    //   [17:9]  = src1
    //   [8:0]   = src0
    //
    // Rather than fully derive the field layout we splice in the
    // reverse-engineered value directly for the "neg sgpr, vgpr,
    // vgpr" operand shape that the decay idiom needs. Generalising
    // across VOP3 operand shapes lands alongside the next f64
    // lowerable expression.
    uint64 src0_enc = neg_sgpr_pair & 0x1FF               // SGPR pair: encoding = pair_idx * 2
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)        // VGPR = 0x100 + idx
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 neg = 0x1                                       // neg[0]=1 → -src0
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// ---------------------------------------------------------------------------
// Top-level emitter
// ---------------------------------------------------------------------------

// Back-compat single-kernel emit: push one entry and emit. Used by
// emit_amdgpu_nop_blob, emit_amdgpu_sentinel_blob, and any other
// single-shot caller.
@export
fn emit_amdgpu_code_object(uint64 kname_ptr, uint64 kname_len,
                            uint64 kernel_bytes, uint64 kernel_size,
                            uint64 kernarg_size, uint64 kernarg_align,
                            uint64 sgpr_count, uint64 vgpr_count,
                            uint64 rsrc1, uint64 rsrc2, uint64 rsrc3,
                            uint64 properties,
                            uint64 args_desc, uint64 n_args) -> uint64 {
    kt_reset()
    kt_push(kname_ptr, kname_len, kernel_bytes, kernel_size,
            args_desc, n_args, kernarg_size,
            sgpr_count, vgpr_count,
            rsrc1, rsrc2, rsrc3, properties)
    return emit_amdgpu_multi_code_object()
}

// Emit an amdgcn ELF containing every kernel currently in the
// kernel table (populated via kt_push). Returns the final file size
// in bytes; callers retrieve the buffer via amd_buf_ptr() +
// amd_buf_len(). The single-kernel entry point above is just a
// thin wrapper around this.
@export
fn emit_amdgpu_multi_code_object() -> uint64 {
    amd_init()

    if kt_count == 0 {
        write(2, "format_amdgpu: no kernels in table\n", 35)
        exit(1)
    }

    uint64 n_phdrs = 5

    // ELF header
    amd_byte(0x7F); amd_byte(0x45); amd_byte(0x4C); amd_byte(0x46) // \x7fELF
    amd_byte(2)                       // ELFCLASS64
    amd_byte(1)                       // ELFDATA2LSB
    amd_byte(1)                       // EV_CURRENT
    amd_byte(ELF_OSABI_AMDGPU_HSA)
    amd_byte(ELF_AMDHSA_ABI_V4)
    amd_byte(0); amd_byte(0); amd_byte(0); amd_byte(0)
    amd_byte(0); amd_byte(0); amd_byte(0)
    amd_u16(ELF_ET_DYN)               // e_type
    amd_u16(ELF_EM_AMDGPU)            // e_machine
    amd_u32(1)                        // e_version
    amd_u64(0)                        // e_entry (unused for code objects)
    amd_u64(AMD_ELF_HEADER_SIZE)      // e_phoff (right after header)
    uint64 shoff_patch = amd_len
    amd_u64(0)                        // e_shoff — patched later
    amd_u32(ELF_EF_AMDGPU_GFX1100)    // e_flags
    amd_u16(AMD_ELF_HEADER_SIZE)      // e_ehsize
    amd_u16(AMD_PHDR_SIZE)            // e_phentsize
    amd_u16(n_phdrs)                  // e_phnum
    amd_u16(AMD_SHDR_SIZE)            // e_shentsize
    uint64 shnum_patch = amd_len
    amd_u16(0)                        // e_shnum — patched later
    uint64 shstrndx_patch = amd_len
    amd_u16(0)                        // e_shstrndx — patched later

    // PHDR placeholders (we'll emit actual phdrs after we compute
    // the layout). Reserve `n_phdrs * AMD_PHDR_SIZE` zeroed bytes.
    uint64 phdr_off = amd_len
    uint64 phdr_area = n_phdrs * AMD_PHDR_SIZE
    uint64 pi = 0
    while pi < phdr_area { amd_byte(0); pi = pi + 1 }

    // ---- Phase 2: emit the R-segment payload.

    // Pad to 16 bytes for cleanliness.
    amd_align(16)

    uint64 r_seg_start = 0                  // R segment starts at file 0 (covers header+phdrs+everything below)
    uint64 r_vaddr = 0

    // .note — emit all kernels' metadata in one note.
    uint64 note_off = amd_len
    uint64 note_size = amd_emit_note_section()
    amd_align(8)

    // .hash — single-bucket SysV hash covering 1 + 2 * kt_count
    // dynsym entries. With one bucket every name lookup walks the
    // chain in insertion order: bucket[0] points at the highest
    // sym index, then chain[] walks back down to sym 1 (sym 0 is
    // STN_UNDEF and terminates). This is O(N) per lookup — fine at
    // the current scale; a proper gnu-hash variant lands when we
    // start emitting .co files with dozens of kernels.
    uint64 hash_off = amd_len
    uint64 n_syms_total = 1 + kt_count * 2      // NULL + {FUNC, OBJECT} per kernel
    amd_u32(1)                                  // nbuckets
    amd_u32(n_syms_total)                       // nchain
    amd_u32(n_syms_total - 1)                   // buckets[0] = last sym idx
    amd_u32(0)                                  // chain[0] — STN_UNDEF
    uint64 hi = 1
    while hi < n_syms_total {
        if hi == 1 {
            amd_u32(0)                          // chain[1] terminates
        } else {
            amd_u32(hi - 1)                     // chain[i] -> i-1
        }
        hi = hi + 1
    }
    uint64 hash_size = amd_len - hash_off
    amd_align(8)

    // .dynsym — NULL + {FUNC, OBJECT} per kernel. st_value / st_shndx
    // are back-patched once we know the .text and .rodata vaddrs.
    // Elf64_Sym: st_name(u32) st_info(u8) st_other(u8) st_shndx(u16)
    //            st_value(u64) st_size(u64) — 24 bytes.
    uint64 dynsym_off = amd_len
    amd_u32(0); amd_byte(0); amd_byte(0); amd_u16(0)
    amd_u64(0); amd_u64(0)
    uint64 dynstr_running = 1                   // skip leading \0
    uint64 dki = 0
    while dki < kt_count {
        uint64 kname_len_k = kt_get(dki, 1)
        uint64 kernel_sz_k = kt_get(dki, 3)
        // FUNC sym — name at dynstr_running, value/shndx patched.
        amd_u32(dynstr_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_FUNC))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(0)                              // st_shndx patched
        amd_u64(0)                              // st_value patched
        amd_u64(kernel_sz_k)
        dynstr_running = dynstr_running + kname_len_k + 1
        // OBJECT sym for "<name>.kd" — +3 chars ("." "k" "d").
        amd_u32(dynstr_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_OBJECT))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(0)                              // st_shndx patched
        amd_u64(0)                              // st_value patched
        amd_u64(64)
        dynstr_running = dynstr_running + kname_len_k + 3 + 1
        dki = dki + 1
    }
    uint64 dynsym_size = amd_len - dynsym_off

    // .dynstr: \0 + for each kernel: kname\0 + kname.kd\0
    uint64 dynstr_off = amd_len
    amd_byte(0)
    uint64 dsi = 0
    while dsi < kt_count {
        uint64 kname_ptr_k = kt_get(dsi, 0)
        uint64 kname_len_k = kt_get(dsi, 1)
        amd_bytes(kname_ptr_k, kname_len_k); amd_byte(0)
        amd_bytes(kname_ptr_k, kname_len_k)
        amd_byte(46); amd_byte(107); amd_byte(100); amd_byte(0)
        dsi = dsi + 1
    }
    uint64 dynstr_size = amd_len - dynstr_off

    // .rodata — one 64-byte kernel descriptor per kernel. The entry
    // byte offset inside each KD is back-patched once we've laid
    // out .text (different per-kernel delta).
    amd_align(64)
    uint64 rodata_off = amd_len
    uint64 rdi = 0
    while rdi < kt_count {
        uint64 kd_off_this = amd_len
        kt_set_u64_arr(kt_kd_off, rdi, kd_off_this)
        uint64 kernarg_sz = kt_get(rdi, 6)
        uint64 k_rsrc1    = kt_get(rdi, 9)
        uint64 k_rsrc2    = kt_get(rdi, 10)
        uint64 k_rsrc3    = kt_get(rdi, 11)
        uint64 k_props    = kt_get(rdi, 12)
        amd_emit_kernel_descriptor(kernarg_sz, 0, k_rsrc1, k_rsrc2, k_rsrc3, k_props)
        rdi = rdi + 1
    }
    amd_align(8)

    // .dynamic — minimum tags ROCm's loader follows to locate the
    // symbol table. We don't write a DT_GNU_HASH; DT_HASH alone is
    // enough for the SysV lookup path.
    uint64 dynamic_off = amd_len
    uint64 dyn_count = 6
    amd_u64(DT_HASH);   amd_u64(hash_off)
    amd_u64(DT_STRTAB); amd_u64(dynstr_off)
    amd_u64(DT_SYMTAB); amd_u64(dynsym_off)
    amd_u64(DT_STRSZ);  amd_u64(dynstr_size)
    amd_u64(DT_SYMENT); amd_u64(AMD_SYMBOL_SIZE)
    amd_u64(DT_NULL);   amd_u64(0)
    uint64 dynamic_size = amd_len - dynamic_off

    // End of R-segment payload.
    uint64 r_seg_end = amd_len

    // ---- .text must be page-aligned (0x1000) VIRTUALLY. We keep
    // file_offset ≡ vaddr (mod 0x1000) and give .text its own page.
    // File: pad to next 0x1000 boundary starting from 0x1000.
    // hipcc puts .text at file 0x900 / vaddr 0x1900. We'll do the
    // same modular offset: file 0x?00 / vaddr 0x1?00 where ? is the
    // same low-nibble. Simplest is file-align to 0x100 once we're
    // above 0x800, then vaddr = file_off + 0x1000.
    amd_align(256)
    uint64 text_file_off = amd_len
    uint64 text_vaddr_base = text_file_off + 0x1000

    // Emit each kernel's bytes back-to-back. 256-align kernels 2..N
    // (the ABI wants each kernel entry to start on a cache line);
    // kernel 0 already inherits the section's 256-alignment. We
    // deliberately compute text_size BEFORE any trailing pad so
    // the single-kernel N=1 case matches the pre-M1f byte layout
    // exactly (phdr filesz and .text sh_size cover only real
    // instruction bytes, not file padding).
    uint64 txi = 0
    while txi < kt_count {
        if txi > 0 { amd_align(256) }
        uint64 k_bytes = kt_get(txi, 2)
        uint64 k_bsize = kt_get(txi, 3)
        uint64 k_vaddr = amd_len - text_file_off + text_vaddr_base
        kt_set_u64_arr(kt_text_vaddr, txi, k_vaddr)
        amd_bytes(k_bytes, k_bsize)
        txi = txi + 1
    }
    uint64 text_size = amd_len - text_file_off
    amd_align(16)

    // Back-patch each KD's entry_byte_offset (i64 at KD+0x10) with
    // its own kernel's text vaddr delta.
    uint64 pki = 0
    while pki < kt_count {
        uint64 kd_off_k = kt_get_u64_arr(kt_kd_off, pki)
        uint64 text_va  = kt_get_u64_arr(kt_text_vaddr, pki)
        uint64 delta    = text_va - kd_off_k
        uint64 patch_at = kd_off_k + 0x10
        uint64 ei = 0
        while ei < 8 {
            uint64 ep = amd_buf + patch_at + ei
            uint8 eb = (delta >> (ei * 8)) & 0xFF
            unsafe { *(ep as uint8) = eb }
            ei = ei + 1
        }
        pki = pki + 1
    }

    // ---- Phase 2b: emit .symtab + .strtab at the tail of the file.
    // ROCm's ELF loader walks the section table looking up string
    // tables for every strtab-linked section; a code object without
    // a non-dynamic .strtab trips its "null sections(STRTAB)" check
    // even though runtime symbol resolution only reads .dynsym. Keep
    // these unallocated (outside any LOAD segment) — they exist
    // purely for the loader's sanity check.
    amd_align(8)
    uint64 strtab_off = amd_len
    amd_byte(0)
    uint64 sti = 0
    while sti < kt_count {
        uint64 knm_ptr = kt_get(sti, 0)
        uint64 knm_len = kt_get(sti, 1)
        amd_bytes(knm_ptr, knm_len); amd_byte(0)
        amd_bytes(knm_ptr, knm_len)
        amd_byte(46); amd_byte(107); amd_byte(100); amd_byte(0)
        sti = sti + 1
    }
    uint64 strtab_size = amd_len - strtab_off

    amd_align(8)
    uint64 symtab_off = amd_len
    amd_u32(0); amd_byte(0); amd_byte(0); amd_u16(0)
    amd_u64(0); amd_u64(0)
    uint64 strtab_running = 1
    uint64 syi = 0
    while syi < kt_count {
        uint64 kn_len_s = kt_get(syi, 1)
        uint64 kn_sz_s  = kt_get(syi, 3)
        uint64 k_vaddr_s = kt_get_u64_arr(kt_text_vaddr, syi)
        uint64 kd_off_s  = kt_get_u64_arr(kt_kd_off, syi)
        // FUNC sym
        amd_u32(strtab_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_FUNC))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(6)                       // .text section index
        amd_u64(k_vaddr_s)
        amd_u64(kn_sz_s)
        strtab_running = strtab_running + kn_len_s + 1
        // OBJECT sym
        amd_u32(strtab_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_OBJECT))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(5)                       // .rodata section index
        amd_u64(kd_off_s)
        amd_u64(64)
        strtab_running = strtab_running + kn_len_s + 3 + 1
        syi = syi + 1
    }
    uint64 symtab_size = amd_len - symtab_off

    // ---- Phase 3: section headers.
    // Sections (in this order — index must match):
    //   0: NULL
    //   1: .note
    //   2: .hash
    //   3: .dynsym
    //   4: .dynstr
    //   5: .rodata
    //   6: .text
    //   7: .dynamic
    //   8: .symtab
    //   9: .strtab
    //  10: .shstrtab

    // Build .shstrtab contents. We collect names and their offsets as
    // we write. Each section's sh_name is the offset within .shstrtab.
    amd_align(8)
    uint64 shstrtab_off = amd_len
    amd_byte(0)
    uint64 sh_name_note     = amd_len - shstrtab_off
    uint64 s_note   = ".note";    amd_bytes(s_note,   5);  amd_byte(0)
    uint64 sh_name_hash     = amd_len - shstrtab_off
    uint64 s_hash   = ".hash";    amd_bytes(s_hash,   5);  amd_byte(0)
    uint64 sh_name_dynsym   = amd_len - shstrtab_off
    uint64 s_dynsym = ".dynsym";  amd_bytes(s_dynsym, 7);  amd_byte(0)
    uint64 sh_name_dynstr   = amd_len - shstrtab_off
    uint64 s_dynstr = ".dynstr";  amd_bytes(s_dynstr, 7);  amd_byte(0)
    uint64 sh_name_rodata   = amd_len - shstrtab_off
    uint64 s_rodata = ".rodata";  amd_bytes(s_rodata, 7);  amd_byte(0)
    uint64 sh_name_text     = amd_len - shstrtab_off
    uint64 s_text   = ".text";    amd_bytes(s_text,   5);  amd_byte(0)
    uint64 sh_name_dynamic  = amd_len - shstrtab_off
    uint64 s_dyn    = ".dynamic"; amd_bytes(s_dyn,    8);  amd_byte(0)
    uint64 sh_name_symtab   = amd_len - shstrtab_off
    uint64 s_symtab = ".symtab"; amd_bytes(s_symtab, 7);  amd_byte(0)
    uint64 sh_name_strtab   = amd_len - shstrtab_off
    uint64 s_strtab = ".strtab"; amd_bytes(s_strtab, 7);  amd_byte(0)
    uint64 sh_name_shstr    = amd_len - shstrtab_off
    uint64 s_shstr  = ".shstrtab"; amd_bytes(s_shstr, 9);  amd_byte(0)
    uint64 shstrtab_size = amd_len - shstrtab_off

    // Section header table.
    amd_align(8)
    uint64 shoff = amd_len
    // [0] NULL
    uint64 si = 0
    while si < AMD_SHDR_SIZE { amd_byte(0); si = si + 1 }
    // [1] .note
    amd_u32(sh_name_note)
    amd_u32(ELF_SHT_NOTE)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(note_off)
    amd_u64(note_off)
    amd_u64(note_size)
    amd_u32(0); amd_u32(0)
    amd_u64(4); amd_u64(0)
    // [2] .hash
    amd_u32(sh_name_hash)
    amd_u32(ELF_SHT_HASH)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(hash_off)
    amd_u64(hash_off)
    amd_u64(hash_size)
    amd_u32(3)                      // sh_link = .dynsym (index 3)
    amd_u32(0)
    amd_u64(4); amd_u64(4)
    // [3] .dynsym
    amd_u32(sh_name_dynsym)
    amd_u32(ELF_SHT_DYNSYM)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(dynsym_off)
    amd_u64(dynsym_off)
    amd_u64(dynsym_size)
    amd_u32(4)                      // sh_link = .dynstr (index 4)
    amd_u32(1)                      // sh_info — first non-local sym index
    amd_u64(8)
    amd_u64(AMD_SYMBOL_SIZE)
    // [4] .dynstr
    amd_u32(sh_name_dynstr)
    amd_u32(ELF_SHT_STRTAB)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(dynstr_off)
    amd_u64(dynstr_off)
    amd_u64(dynstr_size)
    amd_u32(0); amd_u32(0)
    amd_u64(1); amd_u64(0)
    // [5] .rodata — size is 64 per kernel descriptor.
    amd_u32(sh_name_rodata)
    amd_u32(ELF_SHT_PROGBITS)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(rodata_off)
    amd_u64(rodata_off)
    amd_u64(64 * kt_count)
    amd_u32(0); amd_u32(0)
    amd_u64(64); amd_u64(0)
    // [6] .text — sh_addr at the first kernel's vaddr.
    amd_u32(sh_name_text)
    amd_u32(ELF_SHT_PROGBITS)
    amd_u64(ELF_SHF_ALLOC | ELF_SHF_EXECINSTR)
    amd_u64(text_vaddr_base)
    amd_u64(text_file_off)
    amd_u64(text_size)
    amd_u32(0); amd_u32(0)
    amd_u64(256); amd_u64(0)
    // [7] .dynamic
    amd_u32(sh_name_dynamic)
    amd_u32(ELF_SHT_DYNAMIC)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(dynamic_off)
    amd_u64(dynamic_off)
    amd_u64(dynamic_size)
    amd_u32(4)                      // sh_link = .dynstr
    amd_u32(0)
    amd_u64(8); amd_u64(16)
    // [8] .symtab — non-allocated, keeps the loader's sanity check happy.
    amd_u32(sh_name_symtab)
    amd_u32(ELF_SHT_SYMTAB)
    amd_u64(0)
    amd_u64(0)
    amd_u64(symtab_off)
    amd_u64(symtab_size)
    amd_u32(9)                      // sh_link = .strtab (index 9)
    amd_u32(1)                      // sh_info — first non-local
    amd_u64(8)
    amd_u64(AMD_SYMBOL_SIZE)
    // [9] .strtab
    amd_u32(sh_name_strtab)
    amd_u32(ELF_SHT_STRTAB)
    amd_u64(0)
    amd_u64(0)
    amd_u64(strtab_off)
    amd_u64(strtab_size)
    amd_u32(0); amd_u32(0)
    amd_u64(1); amd_u64(0)
    // [10] .shstrtab
    amd_u32(sh_name_shstr)
    amd_u32(ELF_SHT_STRTAB)
    amd_u64(0)
    amd_u64(0)
    amd_u64(shstrtab_off)
    amd_u64(shstrtab_size)
    amd_u32(0); amd_u32(0)
    amd_u64(1); amd_u64(0)

    uint64 shnum = 11

    // Patch e_shoff, e_shnum, e_shstrndx.
    uint64 sp0 = amd_buf + shoff_patch
    uint64 wi = 0
    while wi < 8 {
        uint64 bp = amd_buf + shoff_patch + wi
        uint8 bb = (shoff >> (wi * 8)) & 0xFF
        unsafe { *(bp as uint8) = bb }
        wi = wi + 1
    }
    uint64 snp0 = amd_buf + shnum_patch
    uint8 sn0 = shnum & 0xFF
    unsafe { *(snp0 as uint8) = sn0 }
    uint64 snp1 = amd_buf + shnum_patch + 1
    uint8 sn1 = (shnum >> 8) & 0xFF
    unsafe { *(snp1 as uint8) = sn1 }
    uint64 ssp0 = amd_buf + shstrndx_patch
    uint64 shstrndx = 10
    uint8 ss0 = shstrndx & 0xFF
    unsafe { *(ssp0 as uint8) = ss0 }
    uint64 ssp1 = amd_buf + shstrndx_patch + 1
    uint8 ss1 = (shstrndx >> 8) & 0xFF
    unsafe { *(ssp1 as uint8) = ss1 }

    // Patch every .dynsym entry's st_shndx + st_value now that
    // .text / .rodata vaddrs are known. Entry layout: 24 bytes
    // each, st_shndx at +6, st_value at +8. Entry k's FUNC sym is
    // at dynsym_off + (1 + 2k) * 24; its OBJECT sym at +1.
    uint64 patch_k = 0
    while patch_k < kt_count {
        uint64 func_off = dynsym_off + (1 + patch_k * 2) * 24
        uint64 obj_off  = dynsym_off + (1 + patch_k * 2 + 1) * 24
        uint64 tv       = kt_get_u64_arr(kt_text_vaddr, patch_k)
        uint64 kdv      = kt_get_u64_arr(kt_kd_off, patch_k)

        // FUNC — .text shndx = 6, value = text vaddr
        uint64 pfs = amd_buf + func_off + 6
        uint8 fs0 = 6; unsafe { *(pfs as uint8) = fs0 }
        uint64 pfs1 = amd_buf + func_off + 7
        uint8 fs1 = 0; unsafe { *(pfs1 as uint8) = fs1 }
        uint64 fvi = 0
        while fvi < 8 {
            uint64 vp = amd_buf + func_off + 8 + fvi
            uint8 vb = (tv >> (fvi * 8)) & 0xFF
            unsafe { *(vp as uint8) = vb }
            fvi = fvi + 1
        }

        // OBJECT — .rodata shndx = 5, value = KD file offset == vaddr
        uint64 pos = amd_buf + obj_off + 6
        uint8 os0 = 5; unsafe { *(pos as uint8) = os0 }
        uint64 pos1 = amd_buf + obj_off + 7
        uint8 os1 = 0; unsafe { *(pos1 as uint8) = os1 }
        uint64 ovi = 0
        while ovi < 8 {
            uint64 vp = amd_buf + obj_off + 8 + ovi
            uint8 vb = (kdv >> (ovi * 8)) & 0xFF
            unsafe { *(vp as uint8) = vb }
            ovi = ovi + 1
        }
        patch_k = patch_k + 1
    }

    // ---- Phase 4: emit the real phdrs at the reserved location.
    // Segment layout:
    //   PHDR_self : covers the phdrs themselves
    //   LOAD R    : file 0 -> r_seg_end, vaddr 0
    //   LOAD RX   : file text_file_off -> text_end, vaddr text_vaddr
    //   NOTE      : .note area

    uint64 r_filesz  = r_seg_end                // end of R-covered payload
    uint64 r_memsz   = r_filesz
    uint64 rx_filesz = (text_file_off + text_size) - text_file_off
    uint64 rx_memsz  = rx_filesz

    uint64 ph = phdr_off
    // [0] PHDR
    amd_patch_u32(ph,      ELF_PT_PHDR)
    amd_patch_u32(ph +  4, ELF_PF_R)
    uint64 wj = 0
    while wj < 8 {
        uint64 bp = amd_buf + ph + 8 + wj
        uint8 bb = (AMD_ELF_HEADER_SIZE >> (wj * 8)) & 0xFF
        unsafe { *(bp as uint8) = bb }
        wj = wj + 1
    }
    // p_vaddr, p_paddr
    uint64 wk = 0
    while wk < 8 {
        uint64 bp1 = amd_buf + ph + 16 + wk
        uint64 bp2 = amd_buf + ph + 24 + wk
        uint8 bb = (AMD_ELF_HEADER_SIZE >> (wk * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wk = wk + 1
    }
    // filesz, memsz
    uint64 wl = 0
    while wl < 8 {
        uint64 bp3 = amd_buf + ph + 32 + wl
        uint64 bp4 = amd_buf + ph + 40 + wl
        uint8 bb = (phdr_area >> (wl * 8)) & 0xFF
        unsafe { *(bp3 as uint8) = bb }
        unsafe { *(bp4 as uint8) = bb }
        wl = wl + 1
    }
    amd_patch_u32(ph + 48, 8)         // align

    // [1] LOAD R
    uint64 ph1 = phdr_off + AMD_PHDR_SIZE
    amd_patch_u32(ph1,      ELF_PT_LOAD)
    amd_patch_u32(ph1 +  4, ELF_PF_R)
    // offset=0, vaddr=0, paddr=0
    uint64 wa = 0
    while wa < 24 {
        uint64 bp = amd_buf + ph1 + 8 + wa
        uint8 bb = 0
        unsafe { *(bp as uint8) = bb }
        wa = wa + 1
    }
    uint64 wb = 0
    while wb < 8 {
        uint64 bp3 = amd_buf + ph1 + 32 + wb
        uint64 bp4 = amd_buf + ph1 + 40 + wb
        uint8 bb = (r_filesz >> (wb * 8)) & 0xFF
        unsafe { *(bp3 as uint8) = bb }
        unsafe { *(bp4 as uint8) = bb }
        wb = wb + 1
    }
    amd_patch_u32(ph1 + 48, 0x1000)

    // [2] LOAD RX
    uint64 ph2 = phdr_off + 2 * AMD_PHDR_SIZE
    amd_patch_u32(ph2,      ELF_PT_LOAD)
    amd_patch_u32(ph2 +  4, ELF_PF_R | ELF_PF_X)
    uint64 wc = 0
    while wc < 8 {
        uint64 bp = amd_buf + ph2 + 8 + wc
        uint8 bb = (text_file_off >> (wc * 8)) & 0xFF
        unsafe { *(bp as uint8) = bb }
        wc = wc + 1
    }
    uint64 wd = 0
    while wd < 8 {
        uint64 bp1 = amd_buf + ph2 + 16 + wd
        uint64 bp2 = amd_buf + ph2 + 24 + wd
        uint8 bb = (text_vaddr_base >> (wd * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wd = wd + 1
    }
    uint64 we = 0
    while we < 8 {
        uint64 bp3 = amd_buf + ph2 + 32 + we
        uint64 bp4 = amd_buf + ph2 + 40 + we
        uint8 bb = (rx_filesz >> (we * 8)) & 0xFF
        unsafe { *(bp3 as uint8) = bb }
        unsafe { *(bp4 as uint8) = bb }
        we = we + 1
    }
    amd_patch_u32(ph2 + 48, 0x1000)

    // [3] NOTE
    uint64 ph3 = phdr_off + 3 * AMD_PHDR_SIZE
    amd_patch_u32(ph3,      ELF_PT_NOTE)
    amd_patch_u32(ph3 +  4, ELF_PF_R)
    uint64 wf = 0
    while wf < 8 {
        uint64 bp1 = amd_buf + ph3 + 8  + wf     // offset
        uint64 bp2 = amd_buf + ph3 + 16 + wf     // vaddr
        uint64 bp3 = amd_buf + ph3 + 24 + wf     // paddr
        uint8 bb = (note_off >> (wf * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        unsafe { *(bp3 as uint8) = bb }
        wf = wf + 1
    }
    uint64 wg = 0
    while wg < 8 {
        uint64 bp1 = amd_buf + ph3 + 32 + wg
        uint64 bp2 = amd_buf + ph3 + 40 + wg
        uint8 bb = (note_size >> (wg * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wg = wg + 1
    }
    amd_patch_u32(ph3 + 48, 4)

    // [4] PT_DYNAMIC — points at .dynamic so loaders pick up the
    // DT_HASH/DT_SYMTAB/DT_STRTAB tags. Addr space is same as the R
    // segment (vaddr == file offset).
    uint64 ph4 = phdr_off + 4 * AMD_PHDR_SIZE
    amd_patch_u32(ph4,      ELF_PT_DYNAMIC)
    amd_patch_u32(ph4 +  4, ELF_PF_R)
    uint64 wm = 0
    while wm < 8 {
        uint64 bp1 = amd_buf + ph4 + 8  + wm
        uint64 bp2 = amd_buf + ph4 + 16 + wm
        uint64 bp3 = amd_buf + ph4 + 24 + wm
        uint8 bb = (dynamic_off >> (wm * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        unsafe { *(bp3 as uint8) = bb }
        wm = wm + 1
    }
    uint64 wn = 0
    while wn < 8 {
        uint64 bp1 = amd_buf + ph4 + 32 + wn
        uint64 bp2 = amd_buf + ph4 + 40 + wn
        uint8 bb = (dynamic_size >> (wn * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wn = wn + 1
    }
    amd_patch_u32(ph4 + 48, 8)

    return amd_len
}

// ---------------------------------------------------------------------------
// High-level driver: emit a no-op kernel code object (M1a).
//
// One kernel named "nop_kernel" whose body is a single s_endpgm
// (0xBF810000 in little-endian: 00 00 81 BF). Used to verify the
// code-object format is accepted by hipModuleLoadData before any
// instruction encoder lands in Stage 1 proper.

@export
fn emit_amdgpu_nop_blob(uint64 out_path) -> uint64 {
    uint64 kname = "nop_kernel"
    uint64 klen  = 10

    // s_endpgm — SOPP encoding bf810000, little-endian.
    uint8[4] kcode
    uint64 kp0 = kcode + 0; uint8 b0 = 0x00; unsafe { *(kp0 as uint8) = b0 }
    uint64 kp1 = kcode + 1; uint8 b1 = 0x00; unsafe { *(kp1 as uint8) = b1 }
    uint64 kp2 = kcode + 2; uint8 b2 = 0x81; unsafe { *(kp2 as uint8) = b2 }
    uint64 kp3 = kcode + 3; uint8 b3 = 0xBF; unsafe { *(kp3 as uint8) = b3 }

    // Resource values: copied verbatim from hipcc's decay_step
    // reference object. They encode a wavefront-size-32 kernel with
    // sensible float modes. We don't need any of this to be tight
    // for s_endpgm, and overreporting resources is harmless.
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000020
    uint64 props = 0x0408          // KERNARG_SEGMENT_PTR | WAVEFRONT_SIZE32

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           kcode, 4,
                                           0,       // kernarg_size
                                           8,       // kernarg_align
                                           0,       // sgpr_count
                                           0,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           0, 0)    // args_desc, n_args

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_nop_blob: cannot open output\n", 41)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1b: single-kernel blob that writes a 0xDEADBEEF sentinel through a
// global pointer arg. The kernel body is hand-assembled — 5
// instructions — lifted from `clang --target=amdgcn -mcpu=gfx1100 -O3`
// output. An in-tree AMDGPU assembler is the next milestone; for M1b
// we only prove that the code-object wrapper correctly describes the
// kernarg ABI and that the launcher's arg passing wires up, with the
// payload instructions supplied as a pre-assembled blob.
//
// Kernel source (reference):
//   extern "C" __global__ void write_sentinel(unsigned int *out) {
//       *out = 0xDEADBEEFu;
//   }
//
// Encoding (gfx1100, 36 bytes total — each 32-bit instruction is
// stored little-endian; llvm-objdump prints the reassembled word,
// the actual byte stream is the LE decomposition of each word):
//
//   00 00 04 F4   00 00 00 F8     s_load_b64 s[0:1], s[0:1], null
//                                   (words 0xF4040000, 0xF8000000)
//   80 00 10 CA   FF 00 00 00     v_dual_mov_b32 v0, 0 :: v_dual_mov_b32 v1, 0xdeadbeef
//                                   (words 0xCA100080, 0x000000FF)
//   EF BE AD DE                    literal 0xDEADBEEF
//   07 FC 89 BF                    s_waitcnt lgkmcnt(0)          (0xBF89FC07)
//   00 00 6A DC   00 01 00 00     global_store_b32 v0, v1, s[0:1]
//                                   (words 0xDC6A0000, 0x00000100)
//   00 00 B0 BF                    s_endpgm                      (0xBFB00000)
@export
fn emit_amdgpu_sentinel_blob(uint64 out_path) -> uint64 {
    uint64 kname = "write_sentinel"
    uint64 klen  = 14

    // Build the kernel body through the structured encoders. After
    // M1c this replaces M1b's 36-byte hand-pasted blob; callers
    // elsewhere can now generate kernels opcode-by-opcode rather
    // than copy-pasting clang output.
    //
    // Source-level semantics: out[0] = 0xDEADBEEF.
    //
    //   s_load_b64  s[0:1], s[0:1], null         ; kernarg -> device ptr
    //   v_dual_mov_b32 v0, 0                     ; byte offset
    //       :: v_dual_mov_b32 v1, 0xdeadbeef     ; store value
    //   s_waitcnt   lgkmcnt(0)
    //   global_store_b32  v0, v1, s[0:1]
    //   s_endpgm
    asm_init()
    asm_s_load_b64(0, 0)                              // s[0:1] <- [s[0:1]]
    asm_v_dual_mov_b32_mov_b32_lit(0, 1, 0xDEADBEEF)  // v0 = 0, v1 = sentinel
    asm_s_waitcnt_lgkmcnt_zero()
    asm_global_store_b32(0, 1, 0)                     // *s[0:1] = v1
    asm_s_endpgm()

    // Resource values from clang's gfx1100 -O3 output for this kernel.
    // rsrc3 = 0x10 (differs from M1a's 0x20 — hipcc's decay uses 0x20
    // but the LLVM standalone path defaults to 0x10; ROCm accepts
    // either).
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408    // KERNARG_SEGMENT_PTR | WAVEFRONT_SIZE32

    // One arg: 8-byte global_buffer.
    uint64[2] args_desc
    uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
    uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           8,       // kernarg_size (one 8-byte ptr)
                                           8,       // kernarg_align
                                           2,       // sgpr_count
                                           2,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 1)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_sentinel_blob: cannot open output\n", 46)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1n per-lane loop demo: hand-crafted kernel that exercises the
// VALU divergent while-loop primitives (v_cmp, s_and_b32 on EXEC,
// s_cbranch_execz, s_branch, EXEC save/restore). Each lane runs a
// different number of iterations based on its tid.
//
// Kernel (one workgroup, multiple threads):
//     gid = tid_x()
//     if gid < n:
//         acc = 0; i = 0
//         while i < gid:
//             acc += i
//             i += 1
//         out[gid] = acc          // = gid*(gid-1)/2 (Gauss)
//
// 18-instruction lowering:
//
//   s_load_b32 s2, s[0:1], 0x8                ; n
//   s_load_b64 s[4:5], s[0:1], null           ; out ptr
//   s_waitcnt lgkmcnt(0)
//   v_cmp_gt_u32 vcc_lo, s2, v0               ; (n > gid)
//   s_and_saveexec_b32 s2, vcc_lo
//   s_cbranch_execz tail                      ; all lanes out
//   v_mov_b32 v1, 0                            ; i = 0
//   v_mov_b32 v2, 0                            ; acc = 0
//   s_mov_b32 s3, exec_lo                      ; save outer EXEC
// loop_head:
//   v_cmp_lt_u32_e32 vcc_lo, v1, v0           ; (i < gid) per lane
//   s_and_b32 exec_lo, exec_lo, vcc_lo         ; drop done lanes
//   s_cbranch_execz loop_exit                  ; if all done, break
//   v_add_nc_u32 v2, v1, v2                   ; acc += i
//   v_add_nc_u32 v1, 1, v1                    ; i += 1
//   s_branch loop_head                         ; back
// loop_exit:
//   s_mov_b32 exec_lo, s3                      ; restore outer EXEC
//   v_lshlrev_b32 v0, 2, v0                    ; v0 = gid*4 (byte off)
//   global_store_b32 v0, v2, s[4:5]
// tail:
//   s_endpgm
@export
fn emit_amdgpu_per_lane_loop_blob(uint64 out_path) -> uint64 {
    uint64 kname = "per_lane_loop"
    uint64 klen  = 13

    asm_init()
    asm_s_load_b32(1, 0, 0x8)                   // s2 = n
    asm_s_load_b64(2, 0)                        // s[4:5] = out
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_cmp_gt_u32_sgpr_vgpr(2, 0)            // vcc = (s2 > v0)
    asm_s_and_saveexec_b32_vcc_lo(2)            // save + restrict
    // cbranch_execz skip distance: if all lanes out, jump over the
    // guarded body + loop to s_endpgm. Dwords from cbranch to
    // s_endpgm:
    //   v_mov, v_mov, s_mov, v_cmp, s_and, cbranch, v_add, v_add,
    //   s_branch, s_mov, v_lshl, global_store (2), = 14 dwords.
    asm_s_cbranch_execz(14)
    // v_mov_b32 v1, 0 → 0x7E020280
    asm_u32(0x7E020280)
    // v_mov_b32 v2, 0 → 0x7E040280
    asm_u32(0x7E040280)
    asm_s_mov_b32(3, 0x7E)                      // s3 = exec_lo

    // loop_head starts here — capture dword offset (relative to .text start)
    // so we can compute the backward branch.
    uint64 loop_head_off = asm_text_len / 4      // in dwords

    asm_v_cmp_lt_u32_vv(1, 0)                   // vcc = (v1 < v0)
    asm_s_and_b32_exec_vcc_lo()
    // cbranch_execz to loop_exit: 3 dwords ahead (v_add, v_add, s_branch)
    // then loop_exit is the 4th dword.
    asm_s_cbranch_execz(3)
    asm_v_add_nc_u32_vv(2, 1, 2)                // v2 += v1
    asm_v_add_nc_u32_imm(1, 1, 1)               // v1 += 1
    // s_branch backward to loop_head. After s_branch, PC advances to
    // (current dword + 1). Target = loop_head_off. simm16 = target - (current+1).
    uint64 s_branch_at_dword = asm_text_len / 4
    uint64 delta = loop_head_off - (s_branch_at_dword + 1)
    asm_s_branch(delta & 0xFFFF)

    // loop_exit:
    asm_s_mov_b32(0x7E, 3)                      // exec_lo = s3
    // v_lshlrev_b32 v0, 2, v0 → use existing helper
    asm_v_lshlrev_b32_imm(0, 2, 0)
    asm_global_store_b32(0, 2, 4)               // *(s[4:5] + v0) = v2  (saddr raw SGPR=4)

    // tail:
    asm_s_endpgm()

    uint64[4] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 4 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           12,
                                           8,
                                           6,           // sgpr s0..s5
                                           3,           // vgpr v0..v2
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 2)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_per_lane_loop_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1o atomic-CAS demo: hand-crafted kernel that exercises the
// global_atomic_cmpswap_b64 encoder. Single-kernarg (u64 *out).
// Launched with block_x=1 so only lane 0 is active, no contention.
//
//   *out = atomicCAS((uint64_t*)out, 0, 7)
//   after kernel: *out == 7  (memory held 0, compare matches, swap succeeds)
//
// Assembly (12 dwords, 48 bytes). Note the AMD data-quad ordering:
// v[4:5] holds the NEW value (to be written on match), v[6:7] holds
// the COMPARE value — mirrors HIP's `atomicCAS(addr, cmp, val)` which
// clang lowers with val in the low pair and cmp in the high pair.
//
//   s_load_b64 s[0:1], s[0:1], null                          ; kernarg ptr
//   s_waitcnt lgkmcnt(0)
//   v_mov_b32 v2, 0                                          ; v_addr (byte offset)
//   v_mov_b32 v4, 7                                          ; new_lo = 7
//   v_mov_b32 v5, 0                                          ; new_hi
//   v_mov_b32 v6, 0                                          ; cmp_lo
//   v_mov_b32 v7, 0                                          ; cmp_hi
//   global_atomic_cmpswap_b64 v[0:1], v2, v[4:7], s[0:1] glc ; atomic swap
//   s_waitcnt vmcnt(0)
//   s_waitcnt_vscnt null, 0
//   s_endpgm
@export
fn emit_amdgpu_atomic_demo_blob(uint64 out_path) -> uint64 {
    uint64 kname = "atomic_cas_demo"
    uint64 klen  = 15

    asm_init()
    asm_s_load_b64(0, 0)                                   // s[0:1] <- [s[0:1]]
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32_inline_u(2, 0)                           // v2 = 0  (byte offset)
    asm_v_mov_b32_inline_u(4, 7)                           // v4 = new_lo = 7
    asm_v_mov_b32_inline_u(5, 0)                           // v5 = new_hi
    asm_v_mov_b32_inline_u(6, 0)                           // v6 = cmp_lo
    asm_v_mov_b32_inline_u(7, 0)                           // v7 = cmp_hi
    asm_global_atomic_cmpswap_b64_glc(0, 2, 4, 0)          // v[0:1] = atomicCAS(*s[0:1], v[6:7]=0, v[4:5]=7)
    asm_s_waitcnt_vmcnt_zero()                             // drain return-value path
    asm_s_waitcnt_vscnt_zero()                             // drain the store path (gfx10+)
    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    uint64[2] args_desc
    uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
    uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           8,       // kernarg_size (one 8-byte ptr)
                                           8,       // kernarg_align
                                           2,       // sgpr_count  (s0, s1)
                                           8,       // vgpr_count  (v0..v7)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 1)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_atomic_demo_blob: cannot open output\n", 49)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1p f64-atomic-add demo: the CAS-loop idiom composed from the M1o
// atomic_cmpswap_b64 encoder + f64 arithmetic. Single-thread kernel
// that atomically adds `delta` to *out (f64). This is the primitive
// the CSR scatter kernels need — every E/I synapse delivery does
// exactly this step (atomic += conductance into the post-synaptic
// neuron's state).
//
// Kernargs (16 bytes, 8-byte aligned):
//   [0..7]   = out ptr  (u64)
//   [8..15]  = delta    (f64)
//
// VGPR map (matches hipcc — vdst MUST overlap data_quad low half
// for gfx11 atomic-with-return reliability when the data comes from
// VALU ops):
//   v[0:1]  = data_quad[0:1] = NEW pre-CAS, PREV post-CAS (= vdst)
//   v[2:3]  = data_quad[2:3] = COMPARE / assumed
//   v[4:5]  = delta, copied from s[2:3]
//   v6      = v_addr byte offset (= 0)
//
// Assembly (~18 dwords):
//   s_load_b64 s[2:3], s[0:1], 0x8       ; delta (load BEFORE overwriting s[0:1])
//   s_load_b64 s[0:1], s[0:1], null      ; out ptr
//   s_waitcnt  lgkmcnt(0)
//   v_mov_b32  v6, 0                     ; v_addr offset
//   global_load_b64 v[2:3], v6, s[0:1]   ; assumed = *out
//   s_waitcnt  vmcnt(0)
//   v_mov_b32  v4, s2                    ; delta_lo
//   v_mov_b32  v5, s3                    ; delta_hi
// loop_head:
//   v_add_f64  v[0:1], v[2:3], v[4:5]    ; new = assumed + delta
//   s_delay_alu instid0(VALU_DEP_1)      ; let v_add_f64 settle
//   global_atomic_cmpswap_b64 v[0:1], v6, v[0:3], s[0:1] glc  ; v[0:1] = prev after CAS
//   s_waitcnt  vmcnt(0); s_waitcnt_vscnt null, 0
//   v_cmp_ne_u64_e32 vcc_lo, v[2:3], v[0:1]   ; vcc=1 if CAS lost race
//   v_mov_b32  v2, v0                    ; assumed := prev
//   v_mov_b32  v3, v1
//   s_cbranch_vccnz loop_head
//   s_endpgm
@export
fn emit_amdgpu_f64_atomic_add_blob(uint64 out_path) -> uint64 {
    uint64 kname = "f64_atomic_add_demo"
    uint64 klen  = 19

    // VGPR layout (mirrors hipcc exactly — vdst must overlap
    // data_quad low half for atomic-with-return per AMD ISA):
    //   v[0:1] = NEW pre-CAS, PREV post-CAS (data_quad[0:1] / vdst)
    //   v[2:3] = CMP / assumed             (data_quad[2:3])
    //   v[4:5] = delta                      (from s[2:3] via v_mov)
    //   v6     = v_addr byte offset (= 0)
    asm_init()
    asm_s_load_b64_off(1, 0, 0x8)                    // s[2:3] <- kernarg[8..15] = delta bits
    asm_s_load_b64(0, 0)                             // s[0:1] <- kernarg[0..7]  = out ptr
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32_inline_u(6, 0)                     // v6 = 0 (v_addr offset)
    asm_global_load_b64(2, 6, 0)                     // v[2:3] = *s[0:1] (expected/cmp)
    asm_s_waitcnt_vmcnt_zero()
    asm_v_mov_b32(4, 2)                              // v4 = s2   (delta_lo)
    asm_v_mov_b32(5, 3)                              // v5 = s3   (delta_hi)

    // loop_head:
    uint64 loop_head_off = asm_text_len / 4

    asm_v_add_f64_vv(0, 2, 4)                        // v[0:1] = v[2:3] + v[4:5]  (new)
    asm_s_delay_alu(0x01)                            // let v_add_f64 settle
    asm_global_atomic_cmpswap_b64_glc(0, 6, 0, 0)    // v[0:1] = CAS(*s[0:1]+v6, cmp=v[2:3], new=v[0:1]); vdst overlaps
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)                        // vcc = (v[2:3] != v[0:1] = prev)
    asm_v_mov_b32(2, 0x100 | 0)                      // v2 = v0  (assumed <- prev for next iter)
    asm_v_mov_b32(3, 0x100 | 1)                      // v3 = v1

    // Backward branch to loop_head.
    uint64 cbranch_off = asm_text_len / 4
    uint64 delta = loop_head_off - (cbranch_off + 1)
    asm_s_cbranch_vccnz(delta & 0xFFFF)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // Two kernargs: out ptr (8 B, GLOBAL_BUFFER) + delta (8 B, BY_VALUE).
    uint64[4] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           16,      // kernarg_size (ptr + f64)
                                           8,       // kernarg_align
                                           4,       // sgpr_count (s0..s3)
                                           7,       // vgpr_count (v0..v6)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 2)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_f64_atomic_add_blob: cannot open output\n", 52)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1q (post-M1q' hazard fix) full CSR scatter demo: multi-synapse
// while loop + CSR-indirected (tgt, w) loads + f64 atomic-add into
// s_out[tgt]. Uses the clang-matching pattern discovered during the
// M1q' investigation:
//   * Scalar precomputation of rpi_tgt+syn*8 and rpi_w+syn*8 in SGPR
//     pairs (s_lshl_b64 + s_add_u32 + s_addc_u32).
//   * VMEM loads of tgt/w with saddr=<precomputed pair> and a
//     constant-zero v_addr VGPR (v8=0).
//   * 64-bit scatter address computed as a VGPR pair (v[6:7]) via
//     v_lshlrev_b64 + v_add_co_u32 + v_add_co_ci_u32_e64.
//   * Assumed-load and global_atomic_cmpswap use saddr=OFF (0x7C)
//     with a full 64-bit v_addr pair. The mixed saddr+32b-v_addr
//     mode my earlier attempts used failed under two specific
//     conditions that this pattern avoids: (a) VMEM-loaded VGPR
//     used as v_lshlrev source, and (b) chained atomic ops to the
//     same saddr-anchored address.
//
// Kernargs (32 bytes):
//   [0..7]   = rpi_ptr_ptr  (u64* — CSR row pointers)
//   [8..15]  = rpi_tgt_ptr  (u64* — target-neuron column indices)
//   [16..23] = rpi_w_ptr    (f64* — synapse weights)
//   [24..31] = s_out_ptr    (f64* — scatter destination)
@export
fn emit_amdgpu_csr_scatter_demo_blob(uint64 out_path) -> uint64 {
    uint64 kname = "csr_scatter_demo"
    uint64 klen  = 16

    asm_init()

    // --- Prologue: 4 pointer kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3] = rpi_ptr_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5] = rpi_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7] = rpi_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9] = s_out_ptr
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Second-level SMEM: [start, end] = rpi_ptr[0..1] ---
    asm_s_load_b64_off(5, 1, 0x00)                  // s[10:11] = start
    asm_s_load_b64_off(6, 1, 0x08)                  // s[12:13] = end
    asm_s_waitcnt_lgkmcnt_zero()

    // Constant zero VGPR used as v_addr for saddr-only VMEM loads.
    asm_v_mov_b32_inline_u(8, 0)

    // --- loop_head (SALU-driven while loop over synapses) ---
    uint64 loop_head_off = asm_text_len / 4
    asm_s_cmp_lt_u32(10, 12)                        // scc = (syn < end)
    uint64 scc_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // (placeholder, patched below)

    // Scalar precompute: s[14:15] = syn * 8
    asm_u32(0x848E830A)                             // s_lshl_b64 s[14:15], s[10:11], 3

    // s[16:17] = rpi_tgt_ptr + syn*8  (64-bit add)
    asm_u32(0x80100E04)                             // s_add_u32  s16, s4, s14
    asm_u32(0x82110F05)                             // s_addc_u32 s17, s5, s15

    // s[18:19] = rpi_w_ptr + syn*8
    asm_u32(0x80120E06)                             // s_add_u32  s18, s6, s14
    asm_u32(0x82130F07)                             // s_addc_u32 s19, s7, s15

    // Clang-matching layout: tgt goes into v[0:1], gets shifted in
    // place, then the scatter addr is built into v[6:7]. vmcnt(1) to
    // wait for ONLY the tgt load, like clang does.
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[16:17]
    asm_u32(0x00100008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[18:19]
    asm_u32(0x04120008)
    // s_waitcnt vmcnt(1) → word 0xBF8907F7 per clang. 0x07F7 = vmcnt=1
    // with other counters max.
    asm_u32(0xBF8907F7)

    // Shift tgt in place as 64-bit pair (byte offset for scatter).
    asm_u32(0xD73C0000)                             // v_lshlrev_b64 v[0:1], 3, v[0:1]
    asm_u32(0x00020083)

    // Compound s_delay_alu matching clang between v_lshlrev_b64 and
    // v_add_co_u32: VALU_DEP_1 | instskip(NEXT) | instid1(VALU_DEP_1)
    // = simm 0x0091 (SOPP op 0x07).
    asm_u32(0xBF870091)

    // Scatter address v[6:7] = s[8:9] + v[0:1] with carry.
    asm_u32(0xD7006A06)                             // v_add_co_u32 v6, vcc_lo, s8, v0
    asm_u32(0x00020008)
    asm_u32(0xD5207C07)                             // v_add_co_ci_u32_e64 v7, null, s9, v1, vcc_lo
    asm_u32(0x01AA0209)

    // Prime CAS "assumed" — saddr=OFF, v[6:7] is the 64-bit v_addr.
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v[6:7], off
    asm_u32(0x027C0006)
    asm_s_waitcnt_vmcnt_zero()

    // --- CAS retry loop for f64 atomic-add ---
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 4)                       // v[0:1] = assumed + w
    asm_s_delay_alu(0x01)

    asm_u32(0xDD0A4000)                             // global_atomic_cmpswap_b64 v[0:1], v[6:7], v[0:3], off glc
    asm_u32(0x007C0006)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()

    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_vccnz(cas_delta & 0xFFFF)

    // Bump syn and loop back.
    asm_s_add_u32_imm(10, 10, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_head_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // loop_exit: back-patch the scc0 cbranch.
    uint64 loop_exit_off = asm_text_len / 4
    uint64 scc_skip = loop_exit_off - (scc_patch_off + 1)
    uint64 patch_byte = asm_text_buf + scc_patch_off * 4
    uint32 new_word = 0xBFA10000 | (scc_skip & 0xFFFF)
    unsafe { *(patch_byte as uint32) = new_word }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // Four GLOBAL_BUFFER pointer kernargs.
    uint64[8] args_desc
    uint64 a0 = args_desc + 0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16; unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24; unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32; unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40; unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48; unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56; unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           32,      // kernarg_size (4 × 8 bytes)
                                           8,       // kernarg_align
                                           20,      // sgpr_count (s0..s19)
                                           16,      // vgpr_count (v0..v15)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 4)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_csr_scatter_demo_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1r csr_i_deliver: the first full scientific shape — the inhibitory
// CSR delivery kernel. Extends M1q's scatter with:
//   * Two nested guards over scalar state (cell_type == 1, release > 0)
//     implemented with SALU compares + scc/vccz branches so the body
//     is skipped when the guards fail (single-thread scope).
//   * f64 multiply of w * rel to produce the effective conductance
//     before the atomic-add.
// Single-thread semantics mirror the inner body of csr_i_deliver in
// examples/gpu_csr_i.mlr; a future milestone wires this into the AST
// lowerer + multi-thread EXEC-narrowing.
//
// Kernargs (56 bytes):
//   [0..7]   rpi_ptr_ptr    (u64*)
//   [8..15]  rpi_tgt_ptr    (u64*)
//   [16..23] rpi_w_ptr      (f64*)
//   [24..31] cell_type_ptr  (u64*)
//   [32..39] release_ptr    (f64*)
//   [40..47] s_inh_ptr      (f64*, scatter destination)
//   [48..55] n              (u64 by-value; unused in single-thread)
@export
fn emit_amdgpu_csr_i_deliver_blob(uint64 out_path) -> uint64 {
    uint64 kname = "csr_i_deliver"
    uint64 klen  = 13

    asm_init()

    // --- Prologue: 6 pointer kernargs (+ n kernarg skipped) ---
    asm_s_load_b64(1, 0)                            // s[2:3]   = rpi_ptr_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   = rpi_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   = rpi_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   = cell_type_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] = release_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] = s_inh_ptr
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Guard 1: ct == 1 ---
    asm_s_load_b64_off(7, 4, 0x00)                  // s[14:15] = *cell_type_ptr
    asm_s_waitcnt_lgkmcnt_zero()
    asm_s_cmp_eq_u32(14, 0x81)                      // scc = (s14 == 1)
    uint64 ct_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → loop_exit

    // --- Guard 2: rel > 0.0 ---
    asm_s_load_b64_off(8, 5, 0x00)                  // s[16:17] = rel bits
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32(4, 16)                            // v4 = s16 (rel_lo)
    asm_v_mov_b32(5, 17)                            // v5 = s17 (rel_hi)
    asm_s_delay_alu(0x02)
    asm_v_cmp_lt_f64_zero_v(4)                      // vcc = (0.0 < rel)
    uint64 rel_patch_off = asm_text_len / 4
    asm_sopp(0x23, 0)                               // s_cbranch_vccz placeholder → loop_exit

    // --- Load start, end via SMEM (sbase=1 = s[2:3] = rpi_ptr_ptr) ---
    asm_s_load_b64_off(9, 1, 0x00)                  // s[18:19] = start
    asm_s_load_b64_off(10, 1, 0x08)                 // s[20:21] = end
    asm_s_waitcnt_lgkmcnt_zero()

    // v8 = 0 constant for saddr-only VMEM loads.
    asm_v_mov_b32_inline_u(8, 0)

    // --- Outer loop: for syn in [start, end) ---
    uint64 loop_head_off = asm_text_len / 4
    asm_s_cmp_lt_u32(18, 20)                        // scc = (syn < end)
    uint64 loop_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → loop_exit

    // Scalar precompute of rpi_tgt+syn*8 and rpi_w+syn*8.
    asm_u32(0x84968312)                             // s_lshl_b64 s[22:23], s[18:19], 3
    asm_u32(0x80181604)                             // s_add_u32  s24, s4, s22
    asm_u32(0x82191705)                             // s_addc_u32 s25, s5, s23
    asm_u32(0x801A1606)                             // s_add_u32  s26, s6, s22
    asm_u32(0x821B1707)                             // s_addc_u32 s27, s7, s23

    // VMEM: v[0:1] = rpi_tgt[syn], v[6:7] = rpi_w[syn]
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[24:25]
    asm_u32(0x00180008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[26:27]
    asm_u32(0x061A0008)
    asm_u32(0xBF8907F7)                             // s_waitcnt vmcnt(1) — wait for tgt only

    // Shift tgt*8 in place (clang-matching layout).
    asm_u32(0xD73C0000)                             // v_lshlrev_b64 v[0:1], 3, v[0:1]
    asm_u32(0x00020083)
    asm_u32(0xBF870091)                             // s_delay_alu VALU_DEP_1 | instskip(NEXT) | instid1(VALU_DEP_1)

    // Scatter addr v[10:11] = s_inh + tgt*8.
    asm_u32(0xD7006A0A)                             // v_add_co_u32 v10, vcc_lo, s12, v0
    asm_u32(0x0002000C)
    asm_u32(0xD5207C0B)                             // v_add_co_ci_u32_e64 v11, null, s13, v1, vcc_lo
    asm_u32(0x01AA020D)

    // Wait for w load, then compute effective = w * rel.
    asm_s_waitcnt_vmcnt_zero()
    asm_v_mul_f64_vv(12, 6, 4)                      // v[12:13] = w * rel
    asm_s_delay_alu(0x01)

    // Prime CAS assumed = *s_inh[tgt] via saddr=OFF load.
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v[10:11], off
    asm_u32(0x027C000A)
    asm_s_waitcnt_vmcnt_zero()

    // --- CAS retry loop for the atomic add ---
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 12)                      // v[0:1] = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000)                             // global_atomic_cmpswap_b64 v[0:1], v[10:11], v[0:3], off glc
    asm_u32(0x007C000A)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_vccnz(cas_delta & 0xFFFF)

    // Bump syn and branch back.
    asm_s_add_u32_imm(18, 18, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_head_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // --- loop_exit: patch the three forward-skip placeholders ---
    uint64 loop_exit_off = asm_text_len / 4

    uint64 ct_skip = loop_exit_off - (ct_patch_off + 1)
    uint64 pb0 = asm_text_buf + ct_patch_off * 4
    uint32 w_ct = 0xBFA10000 | (ct_skip & 0xFFFF)
    unsafe { *(pb0 as uint32) = w_ct }

    uint64 rel_skip = loop_exit_off - (rel_patch_off + 1)
    uint64 pb1 = asm_text_buf + rel_patch_off * 4
    uint32 w_rel = 0xBFA30000 | (rel_skip & 0xFFFF)
    unsafe { *(pb1 as uint32) = w_rel }

    uint64 loop_skip = loop_exit_off - (loop_patch_off + 1)
    uint64 pb2 = asm_text_buf + loop_patch_off * 4
    uint32 w_loop = 0xBFA10000 | (loop_skip & 0xFFFF)
    unsafe { *(pb2 as uint32) = w_loop }

    asm_s_endpgm()

    // rsrc values matching clang for this kernel shape (7 kernargs,
    // ~14 VGPRs): rsrc1 bit 0 set (VGPR granules = 1 → allows up to
    // ~36 VGPRs wave32) and rsrc3 = 0x30 (gfx11 forward-progress bits).
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 7 kernargs: 6 GLOBAL_BUFFER + 1 BY_VALUE.
    uint64[14] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a10 = args_desc + 80; unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88; unsafe { *(a11 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a12 = args_desc + 96; unsafe { *(a12 as uint64) = 8 }
    uint64 a13 = args_desc + 104;unsafe { *(a13 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           56,      // kernarg_size (7 × 8 bytes)
                                           8,       // kernarg_align
                                           28,      // sgpr_count (s0..s27)
                                           16,      // vgpr_count (v0..v15)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 7)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_csr_i_deliver_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1s csr_e_deliver: the full excitatory CSR delivery kernel, adding
// STDP LTD on top of M1r's csr_i_deliver shape.
//
// Semantics (single-thread, src = 0):
//   for each synapse syn in [rpe_ptr[0], rpe_ptr[1]):
//     tgt  = rpe_tgt[syn]
//     w    = rpe_w[syn]
//     atomicAdd(&s_exc[tgt], w * release)
//     if rpe_is_ee[syn] != 0:
//       w_new = clamp(w + A_minus * x_post[tgt], 0.0, w_max)
//       rpe_w[syn] = w_new                     (non-atomic — one
//                                               thread per source)
//       atomicAdd_u64(ltd_events, 1)
//
// Kernargs (11 args, 88 bytes):
//   [0..7]   rpe_ptr_ptr    (u64*)
//   [8..15]  rpe_tgt_ptr    (u64*)
//   [16..23] rpe_w_ptr      (f64*)
//   [24..31] rpe_is_ee_ptr  (u64*)
//   [32..39] x_post_ptr     (f64*)
//   [40..47] release_ptr    (f64*)
//   [48..55] s_exc_ptr      (f64*)
//   [56..63] ltd_events_ptr (u64*)
//   [64..71] n              (u64 by-value, unused single-thread)
//   [72..79] A_minus        (f64 by-value)
//   [80..87] w_max          (f64 by-value)
@export
fn emit_amdgpu_csr_e_deliver_blob(uint64 out_path) -> uint64 {
    uint64 kname = "csr_e_deliver"
    uint64 klen  = 13

    asm_init()

    // --- Prologue: 8 pointer kernargs + 2 f64 by-value (skip n) ---
    asm_s_load_b64(1, 0)                            // s[2:3]   = rpe_ptr_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   = rpe_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   = rpe_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   = rpe_is_ee_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] = x_post_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] = release_ptr (transient)
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] = s_exc_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] = ltd_events_ptr
    asm_s_load_b64_off(9, 0, 0x48)                  // s[18:19] = A_minus bits (skip n at 0x40)
    asm_s_load_b64_off(10, 0, 0x50)                 // s[20:21] = w_max bits
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Guard: rel > 0.0 ---
    asm_s_load_b64_off(11, 6, 0x00)                 // s[22:23] = *release_ptr (sbase=6 = s[12:13])
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32(4, 22)                            // v4 = rel_lo
    asm_v_mov_b32(5, 23)                            // v5 = rel_hi
    asm_s_delay_alu(0x02)
    asm_v_cmp_lt_f64_zero_v(4)                      // vcc = (0.0 < rel)
    uint64 rel_patch_off = asm_text_len / 4
    asm_sopp(0x23, 0)                               // s_cbranch_vccz placeholder → loop_exit

    // --- Load start/end via rpe_ptr_ptr (sbase=1 = s[2:3]) ---
    asm_s_load_b64_off(12, 1, 0x00)                 // s[24:25] = start
    asm_s_load_b64_off(13, 1, 0x08)                 // s[26:27] = end
    asm_s_waitcnt_lgkmcnt_zero()

    // Move A_minus and w_max into VGPR pairs (v[16:17], v[18:19]).
    asm_v_mov_b32(16, 18)                           // v16 = s18
    asm_v_mov_b32(17, 19)                           // v17 = s19
    asm_v_mov_b32(18, 20)                           // v18 = s20
    asm_v_mov_b32(19, 21)                           // v19 = s21

    // Constants in VGPRs: v8 = 0 (v_addr zero), v[26:27] = (1, 0) for
    // ltd_events atomic increment.
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32_inline_u(26, 1)
    asm_v_mov_b32_inline_u(27, 0)
    asm_s_delay_alu(0x04)                           // settle v_mov burst

    // --- Outer loop: syn = start .. end ---
    uint64 loop_head_off = asm_text_len / 4
    asm_s_cmp_lt_u32(24, 26)                        // scc = (syn < end)
    uint64 loop_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → loop_exit

    // Scalar per-iter address compute.
    asm_u32(0x849C8318)                             // s_lshl_b64 s[28:29], s[24:25], 3
    asm_u32(0x801E1C04)                             // s_add_u32  s30, s4, s28  (rpe_tgt+syn*8 lo)
    asm_u32(0x821F1D05)                             // s_addc_u32 s31, s5, s29
    asm_u32(0x80201C06)                             // s_add_u32  s32, s6, s28  (rpe_w+syn*8 lo)
    asm_u32(0x82211D07)                             // s_addc_u32 s33, s7, s29
    asm_u32(0x80221C08)                             // s_add_u32  s34, s8, s28  (rpe_is_ee+syn*8 lo)
    asm_u32(0x82231D09)                             // s_addc_u32 s35, s9, s29

    // VMEM: load tgt into v[0:1], w into v[6:7].
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[30:31]
    asm_u32(0x001E0008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[32:33]
    asm_u32(0x06200008)
    asm_u32(0xBF8907F7)                             // s_waitcnt vmcnt(1) — wait for tgt

    // Shift tgt*8 in place, delay for settlement.
    asm_u32(0xD73C0000)                             // v_lshlrev_b64 v[0:1], 3, v[0:1]
    asm_u32(0x00020083)
    asm_u32(0xBF870091)                             // s_delay_alu compound

    // Scatter addr v[10:11] = s_exc + tgt*8.
    asm_u32(0xD7006A0A)                             // v_add_co_u32 v10, vcc_lo, s14, v0
    asm_u32(0x0002000E)
    asm_u32(0xD5207C0B)                             // v_add_co_ci_u32_e64 v11, null, s15, v1, vcc_lo
    asm_u32(0x01AA020F)

    // x_post addr v[22:23] = x_post + tgt*8.
    asm_u32(0xD7006A16)                             // v_add_co_u32 v22, vcc_lo, s10, v0
    asm_u32(0x0002000A)
    asm_u32(0xD5207C17)                             // v_add_co_ci_u32_e64 v23, null, s11, v1, vcc_lo
    asm_u32(0x01AA020B)

    asm_s_waitcnt_vmcnt_zero()                      // wait for w

    // effective = w * rel → v[12:13]
    asm_v_mul_f64_vv(12, 6, 4)
    asm_s_delay_alu(0x01)

    // Prime CAS assumed = *s_exc[tgt].
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v[10:11], off
    asm_u32(0x027C000A)
    asm_s_waitcnt_vmcnt_zero()

    // CAS retry loop.
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 12)                      // new = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000)                             // global_atomic_cmpswap_b64 v[0:1], v[10:11], v[0:3], off glc
    asm_u32(0x007C000A)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_vccnz(cas_delta & 0xFFFF)

    // --- STDP guard: is_ee[syn] != 0 (SMEM) ---
    asm_u32(0xF4040911)                             // s_load_b64 s[36:37], s[34:35], null
    asm_u32(0xF8000000)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(0xBF108024)                             // s_cmp_eq_u64 s[36:37], 0
    uint64 stdp_patch_off = asm_text_len / 4
    asm_s_cbranch_scc1(0)                           // scc=1 (is_ee==0) → skip

    // Load x_post[tgt] via precomputed v[22:23] (saddr=OFF).
    asm_u32(0xDC560000)                             // global_load_b64 v[14:15], v[22:23], off
    asm_u32(0x0E7C0016)
    asm_s_waitcnt_vmcnt_zero()

    // w_new = fma(A_minus, x_post, w) → v[20:21]
    asm_u32(0xD6140014)                             // v_fma_f64 v[20:21], v[16:17], v[14:15], v[6:7]
    asm_u32(0x041A1D10)
    asm_s_delay_alu(0x01)

    // Clamp: w_new = max(w_new, 0.0)
    asm_u32(0xD72A0014)                             // v_max_f64 v[20:21], v[20:21], 0
    asm_u32(0x00010114)
    asm_s_delay_alu(0x01)

    // Clamp: w_new = min(w_new, w_max)
    asm_u32(0xD7290014)                             // v_min_f64 v[20:21], v[20:21], v[18:19]
    asm_u32(0x00022514)
    asm_s_delay_alu(0x01)

    // Non-atomic store w_new → rpe_w[syn]  (saddr-mode via s[32:33])
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[20:21], s[32:33]
    asm_u32(0x00201408)
    asm_s_waitcnt_vscnt_zero()

    // Atomic ++ ltd_events
    asm_u32(0xDD0E0000)                             // global_atomic_add_u64 v0, v[26:27], s[16:17]
    asm_u32(0x00101A00)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()

    // --- skip_stdp: patch the stdp forward branch to here ---
    uint64 skip_stdp_off = asm_text_len / 4
    uint64 stdp_skip = skip_stdp_off - (stdp_patch_off + 1)
    uint64 pb_s = asm_text_buf + stdp_patch_off * 4
    uint32 w_stdp = 0xBFA20000 | (stdp_skip & 0xFFFF)   // s_cbranch_scc1
    unsafe { *(pb_s as uint32) = w_stdp }

    // syn++ and branch back to loop_head.
    asm_s_add_u32_imm(24, 24, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_head_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // --- loop_exit: patch the rel-guard + outer-loop placeholders ---
    uint64 loop_exit_off = asm_text_len / 4

    uint64 rel_skip = loop_exit_off - (rel_patch_off + 1)
    uint64 pb_r = asm_text_buf + rel_patch_off * 4
    uint32 w_rel = 0xBFA30000 | (rel_skip & 0xFFFF)
    unsafe { *(pb_r as uint32) = w_rel }

    uint64 loop_skip = loop_exit_off - (loop_patch_off + 1)
    uint64 pb_l = asm_text_buf + loop_patch_off * 4
    uint32 w_loop = 0xBFA10000 | (loop_skip & 0xFFFF)
    unsafe { *(pb_l as uint32) = w_loop }

    asm_s_endpgm()

    // VGPR granules = 3 (gfx11 wave32 granule = 8 → up to 32 VGPRs).
    // Kernel uses v0..v27 = 28 VGPRs, so granules=3 gives headroom.
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 11 kernargs: 8 GLOBAL_BUFFER + 3 BY_VALUE (n, A_minus, w_max).
    uint64[22] args_desc
    uint64 i = 0
    while i < 8 {
        uint64 ap = args_desc + i * 16;      unsafe { *(ap as uint64) = 8 }
        uint64 ak = args_desc + i * 16 + 8;  unsafe { *(ak as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        i = i + 1
    }
    // by-value args
    uint64 a16 = args_desc + 128; unsafe { *(a16 as uint64) = 8 }
    uint64 a17 = args_desc + 136; unsafe { *(a17 as uint64) = AMD_ARG_KIND_BY_VALUE }   // n
    uint64 a18 = args_desc + 144; unsafe { *(a18 as uint64) = 8 }
    uint64 a19 = args_desc + 152; unsafe { *(a19 as uint64) = AMD_ARG_KIND_BY_VALUE }   // A_minus
    uint64 a20 = args_desc + 160; unsafe { *(a20 as uint64) = 8 }
    uint64 a21 = args_desc + 168; unsafe { *(a21 as uint64) = AMD_ARG_KIND_BY_VALUE }   // w_max

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           88,      // kernarg_size (11 × 8)
                                           8,       // kernarg_align
                                           40,      // sgpr_count (s0..s37 + pad)
                                           28,      // vgpr_count (v0..v27)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 11)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_csr_e_deliver_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t (first sub-milestone) lif_integrate: the core LIF neuron
// update — refractory decrement OR membrane integration. Single-
// thread, one neuron. Full lif_full (spike detection + STP + ring
// buffer writes) stays deferred; this demo proves the f64 math chain
// and the nested conditional path.
//
// Semantics (for neuron i=0, single-thread):
//   if ref[0] > 0:
//       ref[0] -= 1
//       V[0]  = V_reset
//   else:
//       drive  = RI[0] + s_exc[0] * J_E - s_inh[0] * J_I
//       dv     = dt_over_tau * (V_rest - V[0] + drive)
//       V[0]  += dv
//
// Kernargs (80 bytes, 10 × 8):
//   [0..7]   V_ptr          (f64*)
//   [8..15]  ref_ptr        (u64*)
//   [16..23] RI_ptr         (f64*)
//   [24..31] s_exc_ptr      (f64*)
//   [32..39] s_inh_ptr      (f64*)
//   [40..47] dt_over_tau    (f64 by-value, precomputed = dt / tau_m)
//   [48..55] V_rest         (f64 by-value)
//   [56..63] J_E            (f64 by-value)
//   [64..71] J_I            (f64 by-value)
//   [72..79] V_reset        (f64 by-value)
@export
fn emit_amdgpu_lif_integrate_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_integrate"
    uint64 klen  = 13

    asm_init()

    // --- Prologue: 5 pointers + 5 f64 by-value kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3]   = V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   = ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   = RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   = s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] = s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] = dt_over_tau bits
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] = V_rest bits
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] = J_E bits
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] = J_I bits
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] = V_reset bits
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Load ref[0] via SMEM (deref ref_ptr = s[4:5]) ---
    asm_s_load_b64_off(11, 2, 0x00)                 // s[22:23] = ref[0] (sbase=2 = s[4:5])
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: if ref[0] == 0 → integrate (scc=1 → fall through)
    //                   > 0 → refractory (scc=0 → branch).
    asm_s_cmp_eq_u32(22, 0x80)                      // scc = (s22 == 0)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → refractory_body

    // --- Integrate path ---
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0 (v_addr for saddr loads)

    // VMEM loads:
    //   v[0:1] = V[0]        (saddr = s[2:3], raw SGPR 2)
    //   v[2:3] = RI[0]       (saddr = s[6:7], raw SGPR 6)
    //   v[4:5] = s_exc[0]    (saddr = s[8:9], raw SGPR 8)
    //   v[6:7] = s_inh[0]    (saddr = s[10:11], raw SGPR 10)
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[2:3]
    asm_u32(0x00020008)
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v8, s[6:7]
    asm_u32(0x02060008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[8:9]
    asm_u32(0x04080008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[10:11]
    asm_u32(0x060A0008)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs into VGPR pairs.
    asm_v_mov_b32(10, 12)                           // v10 = s12 (dt_over_tau lo)
    asm_v_mov_b32(11, 13)                           // v11 = s13
    asm_v_mov_b32(12, 14)                           // v12 = s14 (V_rest lo)
    asm_v_mov_b32(13, 15)                           // v13 = s15
    asm_v_mov_b32(14, 16)                           // v14 = s16 (J_E lo)
    asm_v_mov_b32(15, 17)                           // v15 = s17
    asm_v_mov_b32(16, 18)                           // v16 = s18 (J_I lo)
    asm_v_mov_b32(17, 19)                           // v17 = s19
    asm_s_delay_alu(0x04)                           // settle 4 VALU back

    // Arithmetic chain (re-using VGPRs per notes above):
    //   v[4:5] = s_exc * J_E
    //   v[6:7] = s_inh * J_I
    //   v[2:3] = RI + s_exc*J_E
    //   v[2:3] = v[2:3] - s_inh*J_I        (= drive)
    //   v[4:5] = V_rest - V
    //   v[2:3] = v[4:5] + v[2:3]           (= V_rest - V + drive)
    //   v[4:5] = dt_over_tau * v[2:3]      (= dv)
    //   v[0:1] = V + dv                    (= v_new)
    asm_v_mul_f64_vv(4, 4, 14)                      // v[4:5] = s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // v[6:7] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // v[2:3] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // v[2:3] = v[2:3] - s_inh*J_I (drive)
    asm_v_sub_f64_vv(4, 12, 0)                      // v[4:5] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // v[2:3] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // v[4:5] = dt_over_tau * v[2:3] (dv)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v[0:1] = V + dv (v_new)
    asm_s_delay_alu(0x01)

    // Store v[0:1] = v_new to V[0].
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[0:1], s[2:3]
    asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()

    // Branch to end.
    uint64 skip_refr_off = asm_text_len / 4
    asm_s_branch(0)                                 // placeholder → end

    // --- Refractory path: patch above scc0 to land here ---
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    // refractory body:
    //   s22 = s22 - 1       (ref_new)
    //   *ref[0] = s[22:23]
    //   *V[0]   = V_reset (s[20:21])
    asm_u32(0x80968116)                             // s_sub_u32 s22, s22, 1
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0
    asm_v_mov_b32(18, 22)                           // v18 = s22 (ref_new lo)
    asm_v_mov_b32(19, 23)                           // v19 = s23
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)                             // saddr=4, vdata=18, v_addr=8
    asm_s_waitcnt_vscnt_zero()

    // *V[0] = V_reset.
    asm_v_mov_b32(18, 20)                           // v18 = s20 (V_reset lo)
    asm_v_mov_b32(19, 21)                           // v19 = s21
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)                             // saddr=2, vdata=18, v_addr=8
    asm_s_waitcnt_vscnt_zero()

    // --- end: patch the integrate skip-to-end ---
    uint64 end_off = asm_text_len / 4
    uint64 end_skip = end_off - (skip_refr_off + 1)
    uint64 pb_se = asm_text_buf + skip_refr_off * 4
    uint32 w_se = 0xBFA00000 | (end_skip & 0xFFFF)  // SOPP op 0x20 = s_branch
    unsafe { *(pb_se as uint32) = w_se }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0003                       // VGPR granules=3 (32 VGPRs)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 10 kernargs: 5 GLOBAL_BUFFER + 5 BY_VALUE.
    uint64[20] args_desc
    uint64 ai = 0
    while ai < 5 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 10 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           80,      // kernarg_size (10 × 8)
                                           8,       // kernarg_align
                                           24,      // sgpr_count (s0..s23)
                                           24,      // vgpr_count (v0..v23)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 10)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_integrate_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t-2 lif_spike: LIF integrate + spike detection. Extends M1t-1
// with a threshold compare: if v_new >= V_thresh the neuron fires —
// V resets, ref becomes ref_steps, spike counter increments.
// Otherwise V just absorbs v_new.
//
// Kernargs (13 args, 104 bytes):
//   [0..7]   V_ptr        (f64*)
//   [8..15]  ref_ptr      (u64*)
//   [16..23] RI_ptr       (f64*)
//   [24..31] s_exc_ptr    (f64*)
//   [32..39] s_inh_ptr    (f64*)
//   [40..47] spike_ptr    (u64*)    — NEW
//   [48..55] dt_over_tau  (f64)
//   [56..63] V_rest       (f64)
//   [64..71] J_E          (f64)
//   [72..79] J_I          (f64)
//   [80..87] V_reset      (f64)
//   [88..95] V_thresh     (f64)     — NEW
//   [96..103] ref_steps   (u64)     — NEW
@export
fn emit_amdgpu_lif_spike_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_spike"
    uint64 klen  = 9

    asm_init()

    // --- Prologue: 6 pointers + 7 by-value kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] dt_over_tau
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] V_rest
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] J_E
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] J_I
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] V_reset
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] V_thresh
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] ref_steps
    asm_s_waitcnt_lgkmcnt_zero()

    // Load ref[0] (SMEM deref of s[4:5]).
    asm_s_load_b64_off(14, 2, 0x00)                 // s[28:29] = ref[0]
    // Load spike[0] (SMEM deref of s[12:13]).
    asm_s_load_b64_off(15, 6, 0x00)                 // s[30:31] = spike[0] (sbase=6 = s[12:13])
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: ref[0] == 0 → integrate; > 0 → refractory.
    asm_s_cmp_eq_u32(28, 0x80)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → refractory

    // ---- Integrate path ----
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0

    // VMEM loads via saddr-only (raw SGPR index for saddr).
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[2:3]
    asm_u32(0x00020008)
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v8, s[6:7]
    asm_u32(0x02060008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[8:9]
    asm_u32(0x04080008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[10:11]
    asm_u32(0x060A0008)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernarg SGPRs to VGPR pairs for arithmetic.
    asm_v_mov_b32(10, 14)                           // v10 = s14 (dt_over_tau lo)
    asm_v_mov_b32(11, 15)
    asm_v_mov_b32(12, 16)                           // v12 = s16 (V_rest lo)
    asm_v_mov_b32(13, 17)
    asm_v_mov_b32(14, 18)                           // v14 = s18 (J_E lo)
    asm_v_mov_b32(15, 19)
    asm_v_mov_b32(16, 20)                           // v16 = s20 (J_I lo)
    asm_v_mov_b32(17, 21)
    asm_v_mov_b32(20, 24)                           // v20 = s24 (V_thresh lo)
    asm_v_mov_b32(21, 25)
    asm_s_delay_alu(0x04)

    // Arithmetic chain (same as M1t-1): v_new → v[0:1].
    asm_v_mul_f64_vv(4, 4, 14)                      // v[4:5] = s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // v[6:7] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // v[2:3] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // v[2:3] = drive
    asm_v_sub_f64_vv(4, 12, 0)                      // v[4:5] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // v[2:3] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // v[4:5] = dv
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v[0:1] = v_new
    asm_s_delay_alu(0x01)

    // Spike detect: vcc = (v_new >= V_thresh).
    asm_v_cmp_ge_f64_vv(0, 20)
    uint64 spike_patch_off = asm_text_len / 4
    asm_s_cbranch_vccnz(0)                          // placeholder → spike body

    // No-spike: V[0] = v_new.
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[0:1], s[2:3]
    asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()
    uint64 after_no_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // placeholder → end

    // ---- Spike body ----
    uint64 spike_off = asm_text_len / 4
    // Patch spike cbranch forward.
    uint64 sp_skip = spike_off - (spike_patch_off + 1)
    uint64 pb_sp = asm_text_buf + spike_patch_off * 4
    uint32 w_sp = 0xBFA40000 | (sp_skip & 0xFFFF)   // SOPP op 0x24 = s_cbranch_vccnz
    unsafe { *(pb_sp as uint32) = w_sp }

    // V = V_reset (move s[22:23] to v[18:19], store via s[2:3]).
    asm_v_mov_b32(18, 22)                           // v18 = s22 (V_reset lo)
    asm_v_mov_b32(19, 23)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ref = ref_steps (move s[26:27] to v[18:19], store via s[4:5]).
    asm_v_mov_b32(18, 26)                           // v18 = s26 (ref_steps lo)
    asm_v_mov_b32(19, 27)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // spike[0] += 1 (scalar: s[30:31] + 1 with carry, then store via s[12:13]).
    asm_u32(0x801E811E)                             // s_add_u32 s30, s30, 1 (inline 1 = 0x81)
    asm_u32(0x821F801F)                             // s_addc_u32 s31, s31, 0
    asm_v_mov_b32(18, 30)                           // v18 = s30 (new spike lo)
    asm_v_mov_b32(19, 31)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[12:13]
    asm_u32(0x000C1208)                             // saddr=12, vdata=18, v_addr=8
    asm_s_waitcnt_vscnt_zero()

    // Branch to end.
    uint64 after_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // placeholder → end

    // ---- Refractory body ----
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    asm_u32(0x809C811C)                             // s_sub_u32 s28, s28, 1
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32(18, 28)                           // v18 = s28 (ref_new lo)
    asm_v_mov_b32(19, 29)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // V = V_reset.
    asm_v_mov_b32(18, 22)                           // v18 = s22 (V_reset lo)
    asm_v_mov_b32(19, 23)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ---- end: patch the two forward branches ----
    uint64 end_off = asm_text_len / 4

    uint64 ns_skip = end_off - (after_no_spike_off + 1)
    uint64 pb_ns = asm_text_buf + after_no_spike_off * 4
    uint32 w_ns = 0xBFA00000 | (ns_skip & 0xFFFF)   // s_branch
    unsafe { *(pb_ns as uint32) = w_ns }

    uint64 as_skip = end_off - (after_spike_off + 1)
    uint64 pb_as = asm_text_buf + after_spike_off * 4
    uint32 w_as = 0xBFA00000 | (as_skip & 0xFFFF)
    unsafe { *(pb_as as uint32) = w_as }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 13 kernargs: 6 GLOBAL_BUFFER + 7 BY_VALUE.
    uint64[26] args_desc
    uint64 ai = 0
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 13 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           104,     // kernarg_size (13 × 8)
                                           8,       // kernarg_align
                                           32,      // sgpr_count (s0..s31)
                                           24,      // vgpr_count (v0..v23)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 13)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_spike_blob: cannot open output\n", 47)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t-3 lif_stp: lif_spike + post-spike trace bumps (x_pre += 1.0,
// x_post += 1.0) + STP update:
//     rel       = u_stp * x_stp
//     release  := rel
//     x_stp    := x_stp - rel
//     u_stp    := u_stp + U_baseline * (1.0 - u_stp)
//
// Kernargs (19 args, 152 bytes). Appends x_pre_ptr, x_post_ptr,
// u_stp_ptr, x_stp_ptr, release_ptr, U_baseline to M1t-2's layout.
@export
fn emit_amdgpu_lif_stp_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_stp"
    uint64 klen  = 7

    asm_init()

    // --- Prologue: load all 19 kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] x_pre_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] u_stp_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] x_stp_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] release_ptr
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] dt_over_tau
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] V_rest
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] J_E
    asm_s_load_b64_off(15, 0, 0x70)                 // s[30:31] J_I
    asm_s_load_b64_off(16, 0, 0x78)                 // s[32:33] V_reset
    asm_s_load_b64_off(17, 0, 0x80)                 // s[34:35] V_thresh
    asm_s_load_b64_off(18, 0, 0x88)                 // s[36:37] ref_steps
    asm_s_load_b64_off(19, 0, 0x90)                 // s[38:39] U_baseline
    asm_s_waitcnt_lgkmcnt_zero()

    // Load ref[0] (deref ref_ptr, sbase=2).
    asm_s_load_b64_off(20, 2, 0x00)                 // s[40:41] = ref[0]
    // Load spike[0] (deref spike_ptr, sbase=6).
    asm_s_load_b64_off(21, 6, 0x00)                 // s[42:43] = spike[0]
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: ref[0] == 0 → integrate; > 0 → refractory.
    asm_s_cmp_eq_u32(40, 0x80)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → refractory

    // ---- Integrate path ----
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0

    // VMEM loads
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[2:3]
    asm_u32(0x00020008)
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v8, s[6:7]
    asm_u32(0x02060008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[8:9]
    asm_u32(0x04080008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[10:11]
    asm_u32(0x060A0008)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs to VGPR pairs.
    asm_v_mov_b32(10, 24)                           // v10 = s24 (dt_over_tau lo)
    asm_v_mov_b32(11, 25)
    asm_v_mov_b32(12, 26)                           // v12 = s26 (V_rest lo)
    asm_v_mov_b32(13, 27)
    asm_v_mov_b32(14, 28)                           // v14 = s28 (J_E lo)
    asm_v_mov_b32(15, 29)
    asm_v_mov_b32(16, 30)                           // v16 = s30 (J_I lo)
    asm_v_mov_b32(17, 31)
    asm_v_mov_b32(20, 34)                           // v20 = s34 (V_thresh lo)
    asm_v_mov_b32(21, 35)
    asm_v_mov_b32(30, 38)                           // v30 = s38 (U_baseline lo)
    asm_v_mov_b32(31, 39)
    asm_s_delay_alu(0x04)

    // v_new arithmetic chain (same pattern as M1t-1/2).
    asm_v_mul_f64_vv(4, 4, 14)                      // v[4:5] = s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // v[6:7] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // v[2:3] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // v[2:3] = drive
    asm_v_sub_f64_vv(4, 12, 0)                      // v[4:5] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // v[2:3] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // v[4:5] = dv
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v[0:1] = v_new
    asm_s_delay_alu(0x01)

    // Spike detect.
    asm_v_cmp_ge_f64_vv(0, 20)
    uint64 spike_patch_off = asm_text_len / 4
    asm_s_cbranch_vccnz(0)                          // placeholder → spike body

    // --- No-spike: store v_new to V[0] ---
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[0:1], s[2:3]
    asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()
    uint64 after_no_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // → end

    // ---- Spike body ----
    uint64 spike_off = asm_text_len / 4
    uint64 sp_skip = spike_off - (spike_patch_off + 1)
    uint64 pb_sp = asm_text_buf + spike_patch_off * 4
    uint32 w_sp = 0xBFA40000 | (sp_skip & 0xFFFF)
    unsafe { *(pb_sp as uint32) = w_sp }

    // V = V_reset (s[32:33] → v[18:19], store via s[2:3]).
    asm_v_mov_b32(18, 32)
    asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ref = ref_steps (s[36:37] → v[18:19], store via s[4:5]).
    asm_v_mov_b32(18, 36)
    asm_v_mov_b32(19, 37)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // spike[0] += 1.
    asm_u32(0x802A812A)                             // s_add_u32 s42, s42, 1
    asm_u32(0x822B802B)                             // s_addc_u32 s43, s43, 0
    asm_v_mov_b32(18, 42)
    asm_v_mov_b32(19, 43)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[12:13]
    asm_u32(0x000C1208)
    asm_s_waitcnt_vscnt_zero()

    // x_pre[0] += 1.0.
    asm_u32(0xDC560000)                             // global_load_b64 v[22:23], v8, s[14:15]
    asm_u32(0x160E0008)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016)                             // v_add_f64 v[22:23], v[22:23], 1.0 (src1=0xF2)
    asm_u32(0x0001E516)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[22:23], s[14:15]
    asm_u32(0x000E1608)
    asm_s_waitcnt_vscnt_zero()

    // x_post[0] += 1.0.
    asm_u32(0xDC560000)                             // global_load_b64 v[22:23], v8, s[16:17]
    asm_u32(0x16100008)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016)                             // v_add_f64 v[22:23], v[22:23], 1.0
    asm_u32(0x0001E516)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[22:23], s[16:17]
    asm_u32(0x00101608)
    asm_s_waitcnt_vscnt_zero()

    // STP: load u_stp[0] → v[24:25], x_stp[0] → v[26:27].
    asm_u32(0xDC560000)                             // global_load_b64 v[24:25], v8, s[18:19]
    asm_u32(0x18120008)
    asm_u32(0xDC560000)                             // global_load_b64 v[26:27], v8, s[20:21]
    asm_u32(0x1A140008)
    asm_s_waitcnt_vmcnt_zero()

    // rel = u * x → v[28:29].
    asm_v_mul_f64_vv(28, 24, 26)
    asm_s_delay_alu(0x01)

    // release[0] = rel (store v[28:29] to s[22:23]).
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[28:29], s[22:23]
    asm_u32(0x00161C08)
    asm_s_waitcnt_vscnt_zero()

    // x_new = x - rel.
    asm_v_sub_f64_vv(26, 26, 28)                    // v[26:27] = v[26:27] - v[28:29]
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[26:27], s[20:21]
    asm_u32(0x00141A08)
    asm_s_waitcnt_vscnt_zero()

    // u_new = u + U_baseline * (1 - u)
    //   tmp = 1.0 - u
    //   prod = U_baseline * tmp
    //   u_new = u + prod
    asm_u32(0xD727001C)                             // v_add_f64 v[28:29], 1.0, -v[24:25]
    asm_u32(0x400230F2)
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(28, 30, 28)                    // v[28:29] = U_baseline * tmp
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(24, 24, 28)                    // v[24:25] = u + prod
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[24:25], s[18:19]
    asm_u32(0x00121808)
    asm_s_waitcnt_vscnt_zero()

    uint64 after_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // → end

    // ---- Refractory body ----
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    asm_u32(0x80A88128)                             // s_sub_u32 s40, s40, 1 (ref--)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32(18, 40)
    asm_v_mov_b32(19, 41)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    asm_v_mov_b32(18, 32)                           // V_reset lo
    asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ---- end: patch forward branches ----
    uint64 end_off = asm_text_len / 4

    uint64 ns_skip = end_off - (after_no_spike_off + 1)
    uint64 pb_ns = asm_text_buf + after_no_spike_off * 4
    uint32 w_ns = 0xBFA00000 | (ns_skip & 0xFFFF)
    unsafe { *(pb_ns as uint32) = w_ns }

    uint64 as_skip = end_off - (after_spike_off + 1)
    uint64 pb_as = asm_text_buf + after_spike_off * 4
    uint32 w_as = 0xBFA00000 | (as_skip & 0xFFFF)
    unsafe { *(pb_as as uint32) = w_as }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0004                       // granules=4 → 40 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 19 kernargs: 11 GLOBAL_BUFFER + 8 BY_VALUE.
    uint64[38] args_desc
    uint64 ai = 0
    while ai < 11 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 19 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           152,     // kernarg_size
                                           8,       // kernarg_align
                                           48,      // sgpr_count
                                           32,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 19)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_stp_blob: cannot open output\n", 45)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t-4 lif_full (Stage-1 exit kernel): lif_stp + ring-buffer scatter
// for E-cells. After the STP update, if cell_type[i] == 0, the release
// value is stored into buf_delay[w_base + i] — the pending-delivery
// entry for the next-timestep synaptic fan-out. This is the kernel
// the 200k-neuron simulation actually dispatches each step.
//
// Kernargs (22 args, 176 bytes). Appends cell_type_ptr, buf_delay_ptr,
// w_base to M1t-3's layout.
@export
fn emit_amdgpu_lif_full_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_full"
    uint64 klen  = 8

    asm_init()

    // --- Prologue: load all 22 kernargs ---
    // 11 pointer kernargs from lif_stp + 2 new pointers + 8 + 1 new by-val.
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] x_pre_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] u_stp_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] x_stp_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] release_ptr
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] dt_over_tau
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] V_rest
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] J_E
    asm_s_load_b64_off(15, 0, 0x70)                 // s[30:31] J_I
    asm_s_load_b64_off(16, 0, 0x78)                 // s[32:33] V_reset
    asm_s_load_b64_off(17, 0, 0x80)                 // s[34:35] V_thresh
    asm_s_load_b64_off(18, 0, 0x88)                 // s[36:37] ref_steps
    asm_s_load_b64_off(19, 0, 0x90)                 // s[38:39] U_baseline
    asm_s_load_b64_off(22, 0, 0x98)                 // s[44:45] cell_type_ptr (NEW)
    asm_s_load_b64_off(23, 0, 0xA0)                 // s[46:47] buf_delay_ptr (NEW)
    asm_s_load_b64_off(24, 0, 0xA8)                 // s[48:49] w_base (NEW)
    asm_s_waitcnt_lgkmcnt_zero()

    // Load ref[0] and spike[0] into scratch (sbase pair-halved).
    asm_s_load_b64_off(20, 2, 0x00)                 // s[40:41] = ref[0]
    asm_s_load_b64_off(21, 6, 0x00)                 // s[42:43] = spike[0]
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: ref == 0 → integrate; > 0 → refractory.
    asm_s_cmp_eq_u32(40, 0x80)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)

    // ---- Integrate path ----
    asm_v_mov_b32_inline_u(8, 0)

    // VMEM loads of V, RI, s_exc, s_inh.
    asm_u32(0xDC560000); asm_u32(0x00020008)        // V → v[0:1]
    asm_u32(0xDC560000); asm_u32(0x02060008)        // RI → v[2:3]
    asm_u32(0xDC560000); asm_u32(0x04080008)        // s_exc → v[4:5]
    asm_u32(0xDC560000); asm_u32(0x060A0008)        // s_inh → v[6:7]
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs to VGPR pairs.
    asm_v_mov_b32(10, 24); asm_v_mov_b32(11, 25)    // v[10:11] = dt_over_tau
    asm_v_mov_b32(12, 26); asm_v_mov_b32(13, 27)    // v[12:13] = V_rest
    asm_v_mov_b32(14, 28); asm_v_mov_b32(15, 29)    // v[14:15] = J_E
    asm_v_mov_b32(16, 30); asm_v_mov_b32(17, 31)    // v[16:17] = J_I
    asm_v_mov_b32(20, 34); asm_v_mov_b32(21, 35)    // v[20:21] = V_thresh
    asm_v_mov_b32(30, 38); asm_v_mov_b32(31, 39)    // v[30:31] = U_baseline
    asm_s_delay_alu(0x04)

    // v_new arithmetic chain.
    asm_v_mul_f64_vv(4, 4, 14)                      // s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // drive
    asm_v_sub_f64_vv(4, 12, 0)                      // V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // dv
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v_new
    asm_s_delay_alu(0x01)

    // Spike detect.
    asm_v_cmp_ge_f64_vv(0, 20)
    uint64 spike_patch_off = asm_text_len / 4
    asm_s_cbranch_vccnz(0)

    // No-spike: store v_new to V.
    asm_u32(0xDC6E0000); asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()
    uint64 after_no_spike_off = asm_text_len / 4
    asm_s_branch(0)

    // ---- Spike body ----
    uint64 spike_off = asm_text_len / 4
    uint64 sp_skip = spike_off - (spike_patch_off + 1)
    uint64 pb_sp = asm_text_buf + spike_patch_off * 4
    uint32 w_sp = 0xBFA40000 | (sp_skip & 0xFFFF)
    unsafe { *(pb_sp as uint32) = w_sp }

    // V = V_reset.
    asm_v_mov_b32(18, 32); asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ref = ref_steps.
    asm_v_mov_b32(18, 36); asm_v_mov_b32(19, 37)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // spike++.
    asm_u32(0x802A812A)                             // s_add_u32 s42, s42, 1
    asm_u32(0x822B802B)                             // s_addc_u32 s43, s43, 0
    asm_v_mov_b32(18, 42); asm_v_mov_b32(19, 43)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x000C1208)
    asm_s_waitcnt_vscnt_zero()

    // x_pre += 1.0.
    asm_u32(0xDC560000); asm_u32(0x160E0008)        // load x_pre → v[22:23]
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016); asm_u32(0x0001E516)        // v_add_f64 v[22:23], v[22:23], 1.0
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x000E1608)
    asm_s_waitcnt_vscnt_zero()

    // x_post += 1.0.
    asm_u32(0xDC560000); asm_u32(0x16100008)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016); asm_u32(0x0001E516)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00101608)
    asm_s_waitcnt_vscnt_zero()

    // STP: load u, x; rel = u*x; store release; x_new = x - rel; u_new = u + U*(1-u).
    asm_u32(0xDC560000); asm_u32(0x18120008)        // u → v[24:25]
    asm_u32(0xDC560000); asm_u32(0x1A140008)        // x → v[26:27]
    asm_s_waitcnt_vmcnt_zero()

    asm_v_mul_f64_vv(28, 24, 26)                    // v[28:29] = rel = u*x
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00161C08)        // release[0] = rel
    asm_s_waitcnt_vscnt_zero()

    asm_v_sub_f64_vv(26, 26, 28)                    // x_new = x - rel
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00141A08)        // x_stp[0] = x_new
    asm_s_waitcnt_vscnt_zero()

    // u_new = u + U_baseline * (1 - u)
    asm_u32(0xD727001C); asm_u32(0x400230F2)        // v[28:29] = 1.0 - u
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(28, 30, 28)                    // U_base * (1-u)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(24, 24, 28)                    // u_new
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00121808)        // u_stp[0] = u_new
    asm_s_waitcnt_vscnt_zero()

    // --- Ring buffer: if cell_type[0] == 0, write rel to buf_delay[w_base+0] ---
    // Reload rel into v[28:29] (it was overwritten by u_new intermediate).
    asm_u32(0xDC560000); asm_u32(0x1C160008)        // global_load_b64 v[28:29], v8, s[22:23]  (re-read release[0])
    asm_s_waitcnt_vmcnt_zero()

    // SMEM load cell_type[0] (sbase=22 → s[44:45]).
    asm_u32(0xF4040C96); asm_u32(0xF8000000)        // s_load_b64 s[50:51], s[44:45], null
    asm_s_waitcnt_lgkmcnt_zero()

    asm_u32(0xBF068032)                             // s_cmp_eq_u32 s50, 0
    uint64 ring_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // skip ring if ct != 0

    // scatter addr: buf_delay + w_base*8.
    asm_u32(0x84B48330)                             // s_lshl_b64 s[52:53], s[48:49], 3
    asm_u32(0x8036342E)                             // s_add_u32  s54, s46, s52
    asm_u32(0x8237352F)                             // s_addc_u32 s55, s47, s53

    // Store v[28:29] (rel) at s[54:55].
    asm_u32(0xDC6E0000); asm_u32(0x00361C08)        // global_store_b64 v8, v[28:29], s[54:55]
    asm_s_waitcnt_vscnt_zero()

    // skip_ring patch.
    uint64 skip_ring_off = asm_text_len / 4
    uint64 ring_skip = skip_ring_off - (ring_patch_off + 1)
    uint64 pb_ring = asm_text_buf + ring_patch_off * 4
    uint32 w_ring = 0xBFA10000 | (ring_skip & 0xFFFF)
    unsafe { *(pb_ring as uint32) = w_ring }

    uint64 after_spike_off = asm_text_len / 4
    asm_s_branch(0)

    // ---- Refractory body ----
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    asm_u32(0x80A88128)                             // s_sub_u32 s40, s40, 1
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32(18, 40); asm_v_mov_b32(19, 41)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    asm_v_mov_b32(18, 32); asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ---- end: patch forward branches ----
    uint64 end_off = asm_text_len / 4

    uint64 ns_skip = end_off - (after_no_spike_off + 1)
    uint64 pb_ns = asm_text_buf + after_no_spike_off * 4
    uint32 w_ns = 0xBFA00000 | (ns_skip & 0xFFFF)
    unsafe { *(pb_ns as uint32) = w_ns }

    uint64 as_skip = end_off - (after_spike_off + 1)
    uint64 pb_as = asm_text_buf + after_spike_off * 4
    uint32 w_as = 0xBFA00000 | (as_skip & 0xFFFF)
    unsafe { *(pb_as as uint32) = w_as }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0004
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 22 kernargs: 13 GLOBAL_BUFFER + 9 BY_VALUE.
    uint64[44] args_desc
    uint64 ai = 0
    while ai < 13 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 22 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           176,     // kernarg_size (22 × 8)
                                           8,       // kernarg_align
                                           56,      // sgpr_count
                                           32,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 22)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_full_blob: cannot open output\n", 46)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1u-1 mt_lif_integrate: multi-thread LIF integrate. Each lane
// processes neuron i = tid. The integrate math (v_new = v + dt_over_tau
// * (V_rest - v + drive)) is the same as M1t-1, but now operating on
// VGPR pairs whose values were VMEM-loaded from arrays indexed by tid*8.
// No refractory branch, no spike detect — this is just the arithmetic-
// at-scale smoke test before the full mt_lif_full port.
//
// Launch convention: block_x = N, grid_x = 1. Hardware sets EXEC so
// that only lanes 0..N-1 run, so we skip the explicit tid<n guard.
//
// Kernargs (8 args, 64 bytes):
//   [0..7]   V_ptr
//   [8..15]  RI_ptr
//   [16..23] s_exc_ptr
//   [24..31] s_inh_ptr
//   [32..39] dt_over_tau (f64)
//   [40..47] V_rest      (f64)
//   [48..55] J_E         (f64)
//   [56..63] J_I         (f64)
@export
fn emit_amdgpu_mt_lif_integrate_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_lif_integrate"
    uint64 klen  = 16

    asm_init()

    // Kernarg loads.
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   RI_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   s_exc_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_inh_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] dt_over_tau
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] V_rest
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] J_E
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] J_I
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset: v2 = tid * 8 (v0 already holds tid_x).
    asm_v_lshlrev_b32_imm(2, 3, 0)                  // v2 = v0 << 3
    asm_s_delay_alu(0x01)

    // VMEM loads per-lane (saddr = s[X:X+1], v_addr = v2).
    // Encodings: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    asm_u32(0xDC560000); asm_u32(0x04020002)        // V    → v[4:5]   (saddr=2)
    asm_u32(0xDC560000); asm_u32(0x06040002)        // RI   → v[6:7]   (saddr=4)
    asm_u32(0xDC560000); asm_u32(0x08060002)        // s_exc→ v[8:9]   (saddr=6)
    asm_u32(0xDC560000); asm_u32(0x0A080002)        // s_inh→ v[10:11] (saddr=8)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs SGPR→VGPR pairs.
    asm_v_mov_b32(12, 10); asm_v_mov_b32(13, 11)    // v[12:13] dt_over_tau
    asm_v_mov_b32(14, 12); asm_v_mov_b32(15, 13)    // v[14:15] V_rest
    asm_v_mov_b32(16, 14); asm_v_mov_b32(17, 15)    // v[16:17] J_E
    asm_v_mov_b32(18, 16); asm_v_mov_b32(19, 17)    // v[18:19] J_I
    asm_s_delay_alu(0x04)

    // Arithmetic chain (same as M1t-1 but with shifted VGPR layout):
    //   v[8:9]  = s_exc * J_E
    //   v[10:11]= s_inh * J_I
    //   v[6:7]  = RI + s_exc*J_E
    //   v[6:7] -= s_inh*J_I           (= drive)
    //   v[8:9]  = V_rest - V
    //   v[6:7]  = v[8:9] + v[6:7]      (= V_rest - V + drive)
    //   v[8:9]  = dt_over_tau * v[6:7] (= dv)
    //   v[4:5]  += dv                  (= v_new)
    asm_v_mul_f64_vv(8, 8, 16)                      // s_exc * J_E
    asm_v_mul_f64_vv(10, 10, 18)                    // s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(6, 6, 8)                       // RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(6, 6, 10)                      // drive
    asm_v_sub_f64_vv(8, 14, 4)                      // V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(6, 8, 6)                       // V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(8, 12, 6)                      // dv = dt_over_tau * (...)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(4, 4, 8)                       // v_new = V + dv
    asm_s_delay_alu(0x01)

    // Store v_new to V[tid]  (saddr=s[2:3], v_addr=v2, vdata=v4).
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0002                       // VGPR granules=2 → 24 VGPRs (we use v0..v19)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 8 kernargs: 4 GLOBAL_BUFFER + 4 BY_VALUE.
    uint64[16] args_desc
    uint64 ai = 0
    while ai < 4 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 8 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           64,      // kernarg_size
                                           8,       // kernarg_align
                                           20,      // sgpr_count
                                           20,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 8)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_lif_integrate_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1u-2 mt_lif_full: multi-thread LIF + spike + traces + STP + ring-
// buffer scatter. Each lane processes neuron i = tid. Branches from
// single-thread lif_full (ref==0, V>=Vth, ct==0) become per-lane
// EXEC-mask branches: v_cmp → s_and_saveexec → body → s_xor exec,sN
// → else-body → s_mov exec,sN.
//
// Launch convention: block_x = N, grid_x = 1. Kernargs identical to
// lif_full (22 entries, 176 bytes), but pointer args now reference
// N-entry arrays instead of single slots. Ring buffer `buf_delay`
// is 2D: delay_slots × N, indexed buf_delay[w_base*N + tid].
//
// THIS IS THE SCAFFOLD STAGE. Prologue + state loads + S→V broadcasts
// only; the arithmetic, EXEC-mask branches, and stores land in
// subsequent commits.
@export
fn emit_amdgpu_mt_lif_full_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_lif_full"
    uint64 klen  = 11

    asm_init()

    // --- Prologue: load all 22 kernargs (same layout as ST lif_full) ---
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] x_pre_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] u_stp_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] x_stp_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] release_ptr
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] dt_over_tau
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] V_rest
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] J_E
    asm_s_load_b64_off(15, 0, 0x70)                 // s[30:31] J_I
    asm_s_load_b64_off(16, 0, 0x78)                 // s[32:33] V_reset
    asm_s_load_b64_off(17, 0, 0x80)                 // s[34:35] V_thresh
    asm_s_load_b64_off(18, 0, 0x88)                 // s[36:37] ref_steps
    asm_s_load_b64_off(19, 0, 0x90)                 // s[38:39] U_baseline
    asm_s_load_b64_off(20, 0, 0x98)                 // s[40:41] cell_type_ptr
    asm_s_load_b64_off(21, 0, 0xA0)                 // s[42:43] buf_delay_ptr
    asm_s_load_b64_off(22, 0, 0xA8)                 // s[44:45] w_base
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset: v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // --- Per-lane VMEM loads (saddr = raw SGPR index of pair low half) ---
    // Encoding: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    asm_u32(0xDC560000); asm_u32(0x04020002)        // V        → v[4:5]   saddr=s2
    asm_u32(0xDC560000); asm_u32(0x0C040002)        // ref      → v[12:13] saddr=s4
    asm_u32(0xDC560000); asm_u32(0x06060002)        // RI       → v[6:7]   saddr=s6
    asm_u32(0xDC560000); asm_u32(0x08080002)        // s_exc    → v[8:9]   saddr=s8
    asm_u32(0xDC560000); asm_u32(0x0A0A0002)        // s_inh    → v[10:11] saddr=s10
    asm_u32(0xDC560000); asm_u32(0x0E0C0002)        // spike    → v[14:15] saddr=s12
    asm_u32(0xDC560000); asm_u32(0x100E0002)        // x_pre    → v[16:17] saddr=s14
    asm_u32(0xDC560000); asm_u32(0x12100002)        // x_post   → v[18:19] saddr=s16
    asm_u32(0xDC560000); asm_u32(0x14120002)        // u_stp    → v[20:21] saddr=s18
    asm_u32(0xDC560000); asm_u32(0x16140002)        // x_stp    → v[22:23] saddr=s20
    asm_u32(0xDC560000); asm_u32(0x18280002)        // cell_type→ v[24:25] saddr=s40
    asm_s_waitcnt_vmcnt_zero()

    // SGPR→VGPR broadcast of all f64 by-value constants.
    asm_v_mov_b32(44, 24); asm_v_mov_b32(45, 25)    // v[44:45] dt_over_tau
    asm_v_mov_b32(32, 26); asm_v_mov_b32(33, 27)    // v[32:33] V_rest
    asm_v_mov_b32(34, 28); asm_v_mov_b32(35, 29)    // v[34:35] J_E
    asm_v_mov_b32(36, 30); asm_v_mov_b32(37, 31)    // v[36:37] J_I
    asm_v_mov_b32(38, 32); asm_v_mov_b32(39, 33)    // v[38:39] V_reset
    asm_v_mov_b32(40, 34); asm_v_mov_b32(41, 35)    // v[40:41] V_thresh
    asm_v_mov_b32(42, 38); asm_v_mov_b32(43, 39)    // v[42:43] U_baseline
    asm_s_delay_alu(0x04)

    // --- Outer branch: if ref == 0 { integrate + spike } else { refractory } ---
    asm_v_cmp_eq_u32_imm_vgpr(0, 12)                // vcc_lo = (v12 == 0)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= (ref==0)

    // --- Integrate arithmetic: v_new = V + dt_over_tau * (V_rest - V + drive) ---
    // drive    = RI + s_exc*J_E - s_inh*J_I
    // Uses v[26:27], v[28:29], v[30:31] as reusable f64 scratch.
    asm_v_mul_f64_vv(28, 8, 34)                     // v[28:29] = s_exc * J_E
    asm_v_mul_f64_vv(30, 10, 36)                    // v[30:31] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(26, 6, 28)                     // v[26:27] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(26, 26, 30)                    // v[26:27] = drive
    asm_v_sub_f64_vv(28, 32, 4)                     // v[28:29] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(26, 28, 26)                    // v[26:27] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(28, 44, 26)                    // v[28:29] = dv = dt_over_tau * (...)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(26, 4, 28)                     // v[26:27] = v_new (live for spike branch in Task 4)
    asm_s_delay_alu(0x01)

    // --- Spike branch (per-lane EXEC-mask predication) ---
    // if v_new >= V_thresh { spike_body } else { V = v_new }
    asm_v_cmp_ge_f64_vv(26, 40)                     // vcc_lo = (v_new >= V_thresh) per lane
    asm_s_and_saveexec_b32_vcc_lo(47)               // s47 = outer EXEC, EXEC &= vcc_lo

    // ---- spike-body (EXEC = spiking lanes) ----
    // Store V = V_reset to V_ptr[tid].
    asm_u32(0xDC6E0000); asm_u32(0x00022602)        // global_store_b64 v2, v[38:39], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Store ref = ref_steps (low 32 bits) to ref_ptr[tid]. ref_steps
    // arrives via s[36:37]; v[46] gets the low word, v[47] gets 0.
    asm_v_mov_b32(46, 36)
    asm_v_mov_b32_inline_u(47, 0)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00042E02)        // global_store_b64 v2, v[46:47], s[4:5]
    asm_s_waitcnt_vscnt_zero()

    // spike++ — increment low 32 bits of v[14:15].
    // v_add_nc_u32_e64 v14, v14, 1  (verified via llvm-mc gfx1100):
    //   encoding bytes [0x0e,0x00,0x25,0xd5,0x0e,0x03,0x01,0x00]
    //   → word1=0xD525000E, word2=0x0001030E (src0=v14, src1=inline 1).
    asm_u32(0xD525000E); asm_u32(0x0001030E)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x000C0E02)        // global_store_b64 v2, v[14:15], s[12:13]
    asm_s_waitcnt_vscnt_zero()

    // x_pre += 1.0 (VOP3 v_add_f64). Verified via llvm-mc:
    //   v_add_f64 v[16:17], v[16:17], 1.0 → 0xD7270010, 0x0001E510.
    asm_u32(0xD7270010); asm_u32(0x0001E510)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x000E1002)        // global_store_b64 v2, v[16:17], s[14:15]
    asm_s_waitcnt_vscnt_zero()

    // x_post += 1.0 (same shape, vdst=18). Verified via llvm-mc:
    //   v_add_f64 v[18:19], v[18:19], 1.0 → 0xD7270012, 0x0001E512.
    asm_u32(0xD7270012); asm_u32(0x0001E512)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00101202)        // global_store_b64 v2, v[18:19], s[16:17]
    asm_s_waitcnt_vscnt_zero()

    // --- STP update ---
    // rel = u * x → v[28:29] (scratch).
    asm_v_mul_f64_vv(28, 20, 22)                    // v[28:29] = u * x = rel
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00161C02)        // store rel to release_ptr[tid] via s[22:23]
    asm_s_waitcnt_vscnt_zero()

    // x_new = x - rel (overwrites v[22:23] in place).
    asm_v_sub_f64_vv(22, 22, 28)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00141602)        // store x_new to x_stp_ptr[tid] via s[20:21]
    asm_s_waitcnt_vscnt_zero()

    // u_new = u + U_baseline * (1 - u).
    //   Step 1: v[30:31] = 1.0 + (-u) via v_add_f64 with src0=inline 1.0, src1=-v[20:21].
    //   Verified via llvm-mc: v_add_f64 v[30:31], 1.0, -v[20:21] → 0xD727001E, 0x400228F2.
    asm_u32(0xD727001E); asm_u32(0x400228F2)
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(30, 42, 30)                    // v[30:31] = U_base * (1 - u)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(20, 20, 30)                    // v[20:21] = u_new = u + U_base*(1-u)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00121402)        // store u_new to u_stp_ptr[tid] via s[18:19]
    asm_s_waitcnt_vscnt_zero()

    // --- Nested ring-buffer scatter: if cell_type[tid] == 0, write rel to buf_delay[w_base*N + tid] ---
    // Compute scalar base = s[42:43] + (w_base << 7)   (N*8 = 128 = 1<<7 for N=16).
    // All three verified via llvm-mc:
    //   s_lshl_b64 s[52:53], s[44:45], 7 → 0x84B4872C
    //   s_add_u32  s54, s42, s52          → 0x8036342A
    //   s_addc_u32 s55, s43, s53          → 0x8237352B
    // Ring-base pointer arithmetic (scalar, executed once per wave):
    //   s[52:53] = w_base << 7  (N*8 = 128 for N=16)
    //   s[54:55] = buf_delay_ptr + s[52:53]  (full 64-bit base ptr)
    asm_u32(0x84B4872C)                             // s_lshl_b64 s[52:53], s[44:45], 7
    asm_u32(0x8036342A)                             // s_add_u32  s54, s42, s52
    asm_u32(0x8237352B)                             // s_addc_u32 s55, s43, s53

    // Reload rel from release_ptr[tid] into v[28:29] (it was overwritten by u-chain).
    asm_u32(0xDC560000); asm_u32(0x1C160002)        // global_load_b64 v[28:29], v2, s[22:23]
    asm_s_waitcnt_vmcnt_zero()

    // Predicate on cell_type == 0.
    asm_v_cmp_eq_u32_imm_vgpr(0, 24)                // vcc_lo = (v24 == 0)
    asm_s_and_saveexec_b32_vcc_lo(48)               // s48 = spike-EXEC, EXEC &= (ct==0)

    // Scatter: buf_delay_base (s[54:55]) + tid*8 (v2) ← v[28:29] (rel).
    asm_u32(0xDC6E0000); asm_u32(0x00361C02)        // global_store_b64 v2, v[28:29], s[54:55]
    asm_s_waitcnt_vscnt_zero()

    // Restore EXEC to spike-path (drop ct-predicate).
    asm_s_mov_b32(0x7E, 48)

    // ---- no-spike body (complementary lanes within outer EXEC) ----
    asm_s_xor_b32_exec_sgpr(47)                     // EXEC = old_EXEC ^ s47 = non-spiking lanes

    // Store v_new to V_ptr[tid] for lanes that did NOT spike.
    asm_u32(0xDC6E0000); asm_u32(0x00021A02)        // global_store_b64 v2, v[26:27], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Restore outer EXEC.
    asm_s_mov_b32(0x7E, 47)

    // ---- refractory-path lanes ----
    asm_s_xor_b32_exec_sgpr(46)                     // EXEC = outer ^ (ref==0) = refractory lanes

    // Decrement ref per-lane: v12 -= 1 (v_sub_nc_u32_e64 v12, v12, 1).
    // llvm-mc verified: word1 = 0xD526000C, word2 = 0x0001030C.
    asm_u32(0xD526000C); asm_u32(0x0001030C)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00040C02)        // global_store_b64 v2, v[12:13], s[4:5]
    asm_s_waitcnt_vscnt_zero()

    // V = V_reset (same encoding as the spike-path reset).
    asm_u32(0xDC6E0000); asm_u32(0x00022602)        // global_store_b64 v2, v[38:39], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Restore kernel-initial EXEC mask.
    asm_s_mov_b32(0x7E, 46)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0005                       // VGPR granule=5: (5+1)*8 = 48 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 22 kernargs: 13 GLOBAL_BUFFER + 9 BY_VALUE.
    uint64[44] args_desc
    uint64 ai = 0
    while ai < 13 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 22 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           176,     // kernarg_size
                                           8,       // kernarg_align
                                           56,      // sgpr_count
                                           48,      // vgpr_count (granule 5)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 22)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_lif_full_blob: cannot open output\n", 49)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B3 mt_csr_i_deliver: multi-thread inhibitory CSR delivery. Per-synapse
// dispatch — each lane handles one edge. Branches from the single-thread
// s_cmp + inner row loop become: coalesced VMEM loads of per-edge state
// + predicate-gated EXEC mask + f64 CAS-retry atomic add.
//
// Launch convention: block_x = total_edges, grid_x = 1.
//
// Kernargs (9 entries, 72 bytes):
//   [0x00] rpi_tgt_ptr        (u64*)
//   [0x08] rpi_w_ptr          (f64*)
//   [0x10] edge_to_src_ptr    (u64*)  — built host-side
//   [0x18] cell_type_ptr      (u64*)
//   [0x20] release_ptr        (f64*)
//   [0x28] s_inh_ptr          (f64*)
//   [0x30] n_pre              (u64 by-value, reserved)
//   [0x38] total_edges        (u64 by-value, reserved)
//   [0x40] _reserved          (u64)
//
// THIS IS THE SCAFFOLD STAGE. Predicates + atomic scatter land in the
// next commit.
@export
fn emit_amdgpu_mt_csr_i_deliver_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_csr_i_deliver"
    uint64 klen  = 16

    asm_init()

    // --- Prologue: 9 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   rpi_tgt_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   rpi_w_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   edge_to_src_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   cell_type_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] release_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] s_inh_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] n_pre (unused)
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] total_edges (unused)
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset: v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // --- Per-lane VMEM loads (saddr = raw SGPR index of pair low half) ---
    // Encoding: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    // Outputs: v[4:5]=rpi_tgt, v[6:7]=rpi_w, v[8:9]=edge_to_src
    asm_u32(0xDC560000); asm_u32(0x04020002)        // rpi_tgt      → v[4:5]   saddr=s2
    asm_u32(0xDC560000); asm_u32(0x06040002)        // rpi_w        → v[6:7]   saddr=s4
    asm_u32(0xDC560000); asm_u32(0x08060002)        // edge_to_src  → v[8:9]   saddr=s6
    asm_s_waitcnt_vmcnt_zero()

    // --- Compute per-lane src*8 offset → v[10:11] (src is in v[8:9]) ---
    // Plan had 0x00021183 for word2; llvm-mc says 0x00021083. Using
    // llvm-mc's value (src1=v[8:9] encodes as 0x108 → bits 17:9 of word2).
    asm_u32(0xD73C000A); asm_u32(0x00021083)        // v_lshlrev_b64 v[10:11], 3, v[8:9]
    asm_s_delay_alu(0x01)

    // --- cell_type address: v[12:13] = s[8:9] + v[10:11] ---
    // Plan had 0x0002140A for this word2; llvm-mc says 0x00021408 (src0=s8=0x08).
    // Plan duplicated the s10 constant here; corrected to s8.
    asm_u32(0xD7006A0C); asm_u32(0x00021408)        // v_add_co_u32 v12, vcc_lo, s8, v10
    // Plan had 0x01AA160B for word2; llvm-mc says 0x01AA1609 (src0=s9=0x09, not 0x0B).
    asm_u32(0xD5207C0D); asm_u32(0x01AA1609)        // v_add_co_ci_u32_e64 v13, null, s9, v11, vcc_lo
    asm_s_delay_alu(0x01)

    // --- Load cell_type[src] → v[16:17] via saddr=OFF + 64-bit v_addr ---
    asm_u32(0xDC560000); asm_u32(0x107C000C)        // global_load_b64 v[16:17], v[12:13], off
    asm_s_waitcnt_vmcnt_zero()

    // --- Outer predicate: cell_type[src] == 1 ---
    asm_v_cmp_eq_u32_imm_vgpr(1, 16)                // vcc_lo = (v16 == 1)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= ct==1

    // --- Recompute release address (v[12:13] is scratch) ---
    asm_u32(0xD7006A0C); asm_u32(0x0002140A)        // v_add_co_u32 v12, vcc_lo, s10, v10
    asm_u32(0xD5207C0D); asm_u32(0x01AA160B)        // v_add_co_ci_u32_e64 v13, null, s11, v11, vcc_lo
    asm_s_delay_alu(0x01)
    asm_u32(0xDC560000); asm_u32(0x127C000C)        // global_load_b64 v[18:19], v[12:13], off
    asm_s_waitcnt_vmcnt_zero()

    // --- Inner predicate: release[src] > 0.0 ---
    asm_v_cmp_lt_f64_zero_v(18)                     // vcc_lo = (0.0 < v[18:19])
    asm_s_and_saveexec_b32_vcc_lo(47)               // s47 = post-ct EXEC, EXEC &= rel>0

    // --- Scatter address: v[20:21] = s[12:13] + tgt*8 (tgt in v[4:5]) ---
    asm_u32(0xD73C0014); asm_u32(0x00020883)        // v_lshlrev_b64 v[20:21], 3, v[4:5]
    asm_s_delay_alu(0x01)
    asm_u32(0xD7006A14); asm_u32(0x0002280C)        // v_add_co_u32 v20, vcc_lo, s12, v20
    asm_u32(0xD5207C15); asm_u32(0x01AA2A0D)        // v_add_co_ci_u32_e64 v21, null, s13, v21, vcc_lo
    asm_s_delay_alu(0x01)

    // --- effective = w * rel → v[22:23] (v[6:7]=w, v[18:19]=rel) ---
    asm_v_mul_f64_vv(22, 6, 18)
    asm_s_delay_alu(0x01)

    // --- Prime CAS assumed = *s_inh[tgt] via saddr=OFF load ---
    asm_u32(0xDC560000); asm_u32(0x027C0014)        // global_load_b64 v[2:3], v[20:21], off
    asm_s_waitcnt_vmcnt_zero()

    // --- CAS retry loop for atomic f64 add ---
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 22)                      // v[0:1] = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000); asm_u32(0x007C0014)        // global_atomic_cmpswap_b64 v[0:1], v[20:21], v[0:3], off glc
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)                     // v2 = returned_prev_lo (copy of v0)
    asm_v_mov_b32(3, 0x100 | 1)                     // v3 = returned_prev_hi (copy of v1)
    // Narrow EXEC to lanes that still need to retry. Without this, lanes
    // that already succeeded keep re-participating in the loop body,
    // which for atomic-add is not idempotent — successful lanes keep
    // adding `effective` on top of other lanes' writes, so no lane ever
    // sees a stable "assumed" value and the loop never terminates.
    asm_s_and_b32_exec_vcc_lo()                     // exec_lo &= vcc_lo
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_execnz(cas_delta & 0xFFFF)

    // --- Restore EXEC masks ---
    asm_s_mov_b32(0x7E, 47)                         // exec_lo = s47 (drop rel>0)
    asm_s_mov_b32(0x7E, 46)                         // exec_lo = s46 (drop ct==1)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0002                       // VGPR granule=2 → 24 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 9 kernargs: 6 GLOBAL_BUFFER + 3 BY_VALUE.
    uint64[18] args_desc
    uint64 ai = 0
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 9 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           72,      // kernarg_size (9 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count (s2..s19 kernargs, s46/s47 EXEC saves)
                                           24,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 9)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_csr_i_deliver_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B3 mt_csr_e_delayed: multi-thread excitatory CSR delivery with
// delay-line read, STDP LTD, and fused buf_delay clear.
//
// Launch convention: block_x = total_edges, grid_x = 1.
//
// Kernargs (14 entries, 112 bytes):
//   [0x00] rpe_tgt_ptr         (u64*)
//   [0x08] rpe_w_ptr           (f64*)
//   [0x10] rpe_is_ee_ptr       (u64*)
//   [0x18] edge_to_src_e_ptr   (u64*)
//   [0x20] is_first_edge_e_ptr (u64*)
//   [0x28] buf_delay_ptr       (f64*)
//   [0x30] row_base            (u64 by-value)
//   [0x38] x_post_ptr          (f64*)
//   [0x40] s_exc_ptr           (f64*)
//   [0x48] ltd_events_ptr      (u64*)
//   [0x50] n_pre               (u64 by-value)
//   [0x58] A_minus             (f64 by-value)
//   [0x60] w_max               (f64 by-value)
//   [0x68] _reserved           (u64)
//
// THIS IS THE SCAFFOLD STAGE. Outer predicate + atomic scatter land
// in the next commit; STDP LTD + first-edge clear land after that.
@export
fn emit_amdgpu_mt_csr_e_delayed_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_csr_e_delayed"
    uint64 klen  = 16

    asm_init()

    // --- Prologue: 14 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   rpe_tgt_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   rpe_w_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   rpe_is_ee_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   edge_to_src_e_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] is_first_edge_e_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] buf_delay_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] row_base
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] s_exc_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] ltd_events_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] n_pre (unused)
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] A_minus
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] w_max
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset v2 = tid*8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // --- Per-lane VMEM loads (saddr = raw SGPR index of pair low half) ---
    // Encoding: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    // Outputs: v[4:5]=rpe_tgt, v[6:7]=rpe_w, v[12:13]=rpe_is_ee, v[8:9]=edge_to_src, v[14:15]=is_first
    asm_u32(0xDC560000); asm_u32(0x04020002)        // rpe_tgt         → v[4:5]   saddr=s2
    asm_u32(0xDC560000); asm_u32(0x06040002)        // rpe_w           → v[6:7]   saddr=s4
    asm_u32(0xDC560000); asm_u32(0x0C060002)        // rpe_is_ee       → v[12:13] saddr=s6
    asm_u32(0xDC560000); asm_u32(0x08080002)        // edge_to_src_e   → v[8:9]   saddr=s8
    asm_u32(0xDC560000); asm_u32(0x0E0A0002)        // is_first_edge_e → v[14:15] saddr=s10
    asm_s_waitcnt_vmcnt_zero()

    // --- SGPR→VGPR broadcast of f64 by-value constants ---
    asm_v_mov_b32(30, 24); asm_v_mov_b32(31, 25)    // v[30:31] A_minus
    asm_v_mov_b32(32, 26); asm_v_mov_b32(33, 27)    // v[32:33] w_max
    asm_s_delay_alu(0x02)

    // --- Gather: rel = buf_delay[row_base + src] ---
    // Scalar precompute: s[30:31] = buf_delay_ptr + row_base * 8
    asm_u32(0x849E830E)                             // s_lshl_b64 s[30:31], s[14:15], 3
    asm_u32(0x801E1E0C)                             // s_add_u32  s30, s12, s30
    asm_u32(0x821F1F0D)                             // s_addc_u32 s31, s13, s31
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane offset: v[16:17] = src * 8 (v[8:9] holds src, shift by 3)
    asm_u32(0xD73C0010); asm_u32(0x00021083)        // v_lshlrev_b64 v[16:17], 3, v[8:9]
    asm_s_delay_alu(0x01)

    // Build per-lane vaddr: v[18:19] = s[30:31] + v[16:17]
    asm_u32(0xD7006A12); asm_u32(0x0002201E)        // v_add_co_u32 v18, vcc_lo, s30, v16
    asm_u32(0xD5207C13); asm_u32(0x01AA221F)        // v_add_co_ci_u32_e64 v19, null, s31, v17, vcc_lo
    asm_s_delay_alu(0x01)

    // Load rel → v[20:21]
    asm_u32(0xDC560000); asm_u32(0x147C0012)        // global_load_b64 v[20:21], v[18:19], off
    asm_s_waitcnt_vmcnt_zero()

    // --- Outer predicate: rel > 0.0 ---
    asm_v_cmp_lt_f64_zero_v(20)                     // vcc_lo = (0.0 < v[20:21])
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = initial EXEC, EXEC &= rel>0

    // --- Scatter address: v[24:25] = s_exc_ptr + tgt*8 (tgt in v[4:5]) ---
    asm_u32(0xD73C0016); asm_u32(0x00020883)        // v_lshlrev_b64 v[22:23], 3, v[4:5]
    asm_s_delay_alu(0x01)
    asm_u32(0xD7006A18); asm_u32(0x00022C12)        // v_add_co_u32 v24, vcc_lo, s18, v22
    asm_u32(0xD5207C19); asm_u32(0x01AA2E13)        // v_add_co_ci_u32_e64 v25, null, s19, v23, vcc_lo
    asm_s_delay_alu(0x01)

    // --- effective = w * rel → v[26:27] (v[6:7]=w, v[20:21]=rel) ---
    asm_v_mul_f64_vv(26, 6, 20)
    asm_s_delay_alu(0x01)

    // Save v2 (per-lane tid*8 byte offset) to v44 BEFORE the prime CAS
    // load — that load clobbers v[2:3] with s_exc[tgt]'s current value.
    // The CAS retry later re-clobbers v2 each iteration. Post-CAS, v2
    // is restored from v44 so STDP LTD + first-edge-clear VMEM stores
    // address their lane's rpe_w / buf_delay slot correctly.
    asm_v_mov_b32(44, 0x100 | 2)                    // v44 = v2 (tid*8)
    asm_s_delay_alu(0x01)

    // --- Prime CAS assumed = *s_exc[tgt] ---
    asm_u32(0xDC560000); asm_u32(0x027C0018)        // global_load_b64 v[2:3], v[24:25], off
    asm_s_waitcnt_vmcnt_zero()

    // Save the rel>0 EXEC mask to s49; the CAS loop narrows EXEC as
    // lanes succeed, leaving EXEC=0 at loop exit. Subsequent STDP LTD
    // and first-edge-clear blocks need EXEC = rel>0 mask to run.
    asm_s_mov_b32(49, 0x7E)                         // s49 = exec_lo

    // --- CAS retry loop for atomic f64 add ---
    uint64 cas_head_e_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 26)                      // v[0:1] = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000); asm_u32(0x007C0018)        // global_atomic_cmpswap_b64 v[0:1], v[24:25], v[0:3], off glc
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    // Narrow EXEC to retrying lanes (see mt_csr_i_deliver for rationale).
    asm_s_and_b32_exec_vcc_lo()
    uint64 cas_branch_e_off = asm_text_len / 4
    uint64 cas_delta_e = cas_head_e_off - (cas_branch_e_off + 1)
    asm_s_cbranch_execnz(cas_delta_e & 0xFFFF)

    // Restore EXEC FIRST (CAS narrowed it to 0), so the v2 restore below
    // actually runs on the rel>0 lanes. If we moved v2 before this,
    // the VALU would execute on zero lanes and do nothing.
    asm_s_mov_b32(0x7E, 49)                         // exec_lo = s49

    // Restore v2 (tid*8 byte offset) from v44 for the STDP + first-edge
    // VMEM stores — the CAS retry clobbered v2 via v_mov v2, v0.
    asm_v_mov_b32(2, 0x100 | 44)                    // v2 = v44
    asm_s_delay_alu(0x01)

    // Precompute rpe_w store addr v[46:47] = s[4:5] + v44 (= rpe_w_ptr + tid*8).
    // Use v44 directly (instead of v2 via restore) so no VALU-VGPR
    // restore hazard can bite. v44 was saved from v2 pre-CAS under
    // rel>0 EXEC and the CAS loop doesn't touch v44.
    asm_u32(0xD7006A2E); asm_u32(0x00025804)        // v_add_co_u32 v46, vcc_lo, s4, v44
    asm_u32(0xD5207C2F); asm_u32(0x01AA2E05)        // v_add_co_ci_u32_e64 v47, null, s5, v23, vcc_lo
    asm_s_delay_alu(0x01)

    // --- Nested: if rpe_is_ee[edge] == 1 { STDP LTD } ---
    asm_v_cmp_eq_u32_imm_vgpr(1, 12)                // vcc_lo = (is_ee == 1)
    asm_s_and_saveexec_b32_vcc_lo(47)               // s47 = outer mask, EXEC &= (is_ee == 1)

    // --- Load x_post[tgt] via saddr=OFF + 64-bit v_addr ---
    // Build x_post addr: v[28:29] = s[16:17] + v[22:23] (v[22:23]=tgt*8 from Task-5 scatter calc)
    asm_u32(0xD7006A1C); asm_u32(0x00022C10)        // v_add_co_u32 v28, vcc_lo, s16, v22
    asm_u32(0xD5207C1D); asm_u32(0x01AA2E11)        // v_add_co_ci_u32_e64 v29, null, s17, v23, vcc_lo
    asm_s_delay_alu(0x01)
    asm_u32(0xDC560000); asm_u32(0x227C001C)        // global_load_b64 v[34:35], v[28:29], off
    asm_s_waitcnt_vmcnt_zero()

    // --- w_new = clamp(w + A_minus * x_post[tgt], 0.0, w_max) ---
    // v[36:37] = A_minus * x_post[tgt]  (A_minus in v[30:31], x_post in v[34:35])
    asm_v_mul_f64_vv(36, 30, 34)
    asm_s_delay_alu(0x01)
    // v[36:37] = w + A_minus*x_post   (v[6:7] = w)
    asm_v_add_f64_vv(36, 6, 36)
    asm_s_delay_alu(0x01)
    // Build zero pair in v[38:39] for the max clamp.
    asm_v_mov_b32_inline_u(38, 0)
    asm_v_mov_b32_inline_u(39, 0)
    asm_s_delay_alu(0x02)
    // v[36:37] = max(v[36:37], 0.0)
    asm_v_max_f64_vv(36, 36, 38)
    asm_s_delay_alu(0x01)
    // v[36:37] = min(v[36:37], w_max)   (w_max in v[32:33])
    asm_v_min_f64_vv(36, 36, 32)
    asm_s_delay_alu(0x01)

    // --- Store w_new back to rpe_w[edge] via saddr=s[4:5], v_addr=v2 ---
    // Encoding: 0xDC6E0000, (vdst_ignored<<24 | saddr<<16 | vdata<<8 | vaddr) = 0x00042402
    // v[46:47] was precomputed before the is_ee saveexec so the addr
    // pair is fresh for ALL rel>0 lanes, not just is_ee ones. Store
    // uses saddr=OFF + full 64-bit v_addr to avoid the gfx11 H1 hazard.
    asm_u32(0xDC6E0000); asm_u32(0x007C242E)        // global_store_b64 v[46:47], v[36:37], off
    asm_s_waitcnt_vscnt_zero()

    // --- atomic_add_u64(ltd_events, 1) ---
    // All lanes target the same address (ltd_events_ptr), build per-lane copies.
    // Addr pair v[40:41] = s[20:21].
    asm_v_mov_b32(40, 20)
    asm_v_mov_b32(41, 21)
    asm_s_delay_alu(0x02)
    // Data pair v[42:43] = 1_u64.
    asm_v_mov_b32_inline_u(42, 1)
    asm_v_mov_b32_inline_u(43, 0)
    asm_s_delay_alu(0x02)
    asm_global_atomic_add_u64_offvaddr(40, 42)
    asm_s_waitcnt_vscnt_zero()

    // --- Restore is_ee mask ---
    asm_s_mov_b32(0x7E, 47)

    // --- Nested: if is_first_edge[edge] == 1 { buf_delay[row_base+src] = 0 } ---
    asm_v_cmp_eq_u32_imm_vgpr(1, 14)                // vcc_lo = (v14 == 1)
    asm_s_and_saveexec_b32_vcc_lo(48)               // s48 = outer mask, EXEC &= is_first==1

    // v[18:19] still holds buf_delay addr from Task 5 outer gather; v[38:39] holds 0.0.
    // global_store_b64 v[18:19] vaddr pair, v[38:39] data pair, saddr=OFF.
    // Encoding: 0xDC6E0000, (saddr=0x7C<<16 | vdata=0x26<<8 | vaddr=0x12) = 0x007C2612
    asm_u32(0xDC6E0000); asm_u32(0x007C2612)
    asm_s_waitcnt_vscnt_zero()

    asm_s_mov_b32(0x7E, 48)

    // --- Restore outer EXEC ---
    asm_s_mov_b32(0x7E, 46)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0005                       // VGPR granule=5 → 48 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    uint64[28] args_desc
    uint64 ai = 0
    // 10 pointer args: rpe_tgt, rpe_w, rpe_is_ee, edge_to_src_e, is_first_edge_e
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    // row_base (by-value) at index 6
    uint64 rb_p0 = args_desc + ai * 16;     unsafe { *(rb_p0 as uint64) = 8 }
    uint64 rb_p1 = args_desc + ai * 16 + 8; unsafe { *(rb_p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
    ai = ai + 1
    // x_post_ptr, s_exc_ptr, ltd_events_ptr at indices 7, 8, 9
    while ai < 10 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    // n_pre, A_minus, w_max, _reserved (4 by-values) at indices 10-13
    while ai < 14 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           112,     // kernarg_size (14 × 8)
                                           8,       // kernarg_align
                                           50,      // sgpr_count (s0..s29 kernargs, s[30:31] scratch, s46/47/48 EXEC saves)
                                           48,      // vgpr_count (granule 5)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 14)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_csr_e_delayed_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B4 decay_step: per-lane exponential decay. buf[tid] -= buf[tid] * factor.
// Semantics matches examples/gpu_stage13_full.mlr:39-49.
//
// Launch: block_x = N, grid_x = 1. Guard via tid < n.
//
// Kernargs (4 entries, 32 bytes):
//   [0x00] buf_ptr    (f64*)
//   [0x08] n          (u64 by-value)
//   [0x10] factor     (f64 by-value)
//   [0x18] _reserved  (u64)
@export
fn emit_amdgpu_decay_step_blob(uint64 out_path) -> uint64 {
    uint64 kname = "decay_step"
    uint64 klen  = 10

    asm_init()

    // --- Prologue: 4 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   buf_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   n
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   factor
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // tid < n guard. `asm_v_cmp_gt_u32_sgpr_vgpr(s, v)` sets vcc = (s > v).
    // Passing (s=4, v=0) gives vcc = (s4 > v0) = (n > tid) = (tid < n).
    asm_v_cmp_gt_u32_sgpr_vgpr(4, 0)                // vcc_lo = (s4 > v0)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= (tid < n)

    // Per-lane byte offset: v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // Load buf[tid] → v[4:5] (saddr=s2 low-half index for s[2:3]=buf_ptr, v_addr=v2).
    asm_u32(0xDC560000); asm_u32(0x04020002)        // global_load_b64 v[4:5], v2, s[2:3]
    asm_s_waitcnt_vmcnt_zero()

    // SGPR→VGPR broadcast of factor (s[6:7] → v[6:7]).
    asm_v_mov_b32(6, 6); asm_v_mov_b32(7, 7)        // v[6:7] = factor
    asm_s_delay_alu(0x02)

    // v[8:9] = buf * factor
    asm_v_mul_f64_vv(8, 4, 6)
    asm_s_delay_alu(0x01)
    // v[4:5] = buf - buf*factor
    asm_v_sub_f64_vv(4, 4, 8)
    asm_s_delay_alu(0x01)

    // Store v[4:5] back to buf[tid].
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Restore outer EXEC (drop tid<n mask).
    asm_s_mov_b32(0x7E, 46)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0001                       // VGPR granule=1 → 16 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 4 kernargs: 1 GLOBAL_BUFFER + 3 BY_VALUE.
    uint64[8] args_desc
    uint64 p_a0_size = args_desc + 0;   unsafe { *(p_a0_size as uint64) = 8 }
    uint64 p_a0_kind = args_desc + 8;   unsafe { *(p_a0_kind as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 p_a1_size = args_desc + 16;  unsafe { *(p_a1_size as uint64) = 8 }
    uint64 p_a1_kind = args_desc + 24;  unsafe { *(p_a1_kind as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p_a2_size = args_desc + 32;  unsafe { *(p_a2_size as uint64) = 8 }
    uint64 p_a2_kind = args_desc + 40;  unsafe { *(p_a2_kind as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p_a3_size = args_desc + 48;  unsafe { *(p_a3_size as uint64) = 8 }
    uint64 p_a3_kind = args_desc + 56;  unsafe { *(p_a3_kind as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           32,      // kernarg_size (4 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count (kernargs + EXEC save at s46)
                                           16,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 4)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_decay_step_blob: cannot open output\n", 48)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B4 relax_step: per-lane relaxation toward a target.
//   buf[tid] = buf[tid] + (target - buf[tid]) * factor
// Semantics matches examples/gpu_stage13_full.mlr:52-62.
//
// Launch: block_x = N, grid_x = 1. Guard via tid < n.
//
// Kernargs (5 entries, 40 bytes):
//   [0x00] buf_ptr   (f64*)
//   [0x08] n         (u64 by-value)
//   [0x10] target    (f64 by-value)
//   [0x18] factor    (f64 by-value)
//   [0x20] _reserved (u64)
@export
fn emit_amdgpu_relax_step_blob(uint64 out_path) -> uint64 {
    uint64 kname = "relax_step"
    uint64 klen  = 10

    asm_init()

    // --- Prologue: 5 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   buf_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   n
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   target
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   factor
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // tid < n guard.
    asm_v_cmp_gt_u32_sgpr_vgpr(4, 0)                // vcc_lo = (s4 > v0)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= (tid < n)

    // v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // Load buf[tid] → v[4:5].
    asm_u32(0xDC560000); asm_u32(0x04020002)        // global_load_b64 v[4:5], v2, s[2:3]
    asm_s_waitcnt_vmcnt_zero()

    // Broadcast target → v[6:7], factor → v[8:9].
    asm_v_mov_b32(6, 6); asm_v_mov_b32(7, 7)        // v[6:7] = target
    asm_v_mov_b32(8, 8); asm_v_mov_b32(9, 9)        // v[8:9] = factor
    asm_s_delay_alu(0x04)

    // v[10:11] = target - buf
    asm_v_sub_f64_vv(10, 6, 4)
    asm_s_delay_alu(0x01)
    // v[10:11] = (target - buf) * factor
    asm_v_mul_f64_vv(10, 10, 8)
    asm_s_delay_alu(0x01)
    // v[4:5] = buf + (target - buf) * factor
    asm_v_add_f64_vv(4, 4, 10)
    asm_s_delay_alu(0x01)

    // Store v[4:5] back to buf[tid].
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    asm_s_mov_b32(0x7E, 46)
    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0001                       // granule 1 → 16 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 5 kernargs: 1 GLOBAL_BUFFER + 4 BY_VALUE.
    uint64[10] args_desc
    uint64 p0s = args_desc + 0;   unsafe { *(p0s as uint64) = 8 }
    uint64 p0k = args_desc + 8;   unsafe { *(p0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 p1s = args_desc + 16;  unsafe { *(p1s as uint64) = 8 }
    uint64 p1k = args_desc + 24;  unsafe { *(p1k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p2s = args_desc + 32;  unsafe { *(p2s as uint64) = 8 }
    uint64 p2k = args_desc + 40;  unsafe { *(p2k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p3s = args_desc + 48;  unsafe { *(p3s as uint64) = 8 }
    uint64 p3k = args_desc + 56;  unsafe { *(p3k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p4s = args_desc + 64;  unsafe { *(p4s as uint64) = 8 }
    uint64 p4k = args_desc + 72;  unsafe { *(p4k as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           40,      // kernarg_size (5 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count
                                           16,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 5)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_relax_step_blob: cannot open output\n", 48)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B4 fill_step: per-lane constant fill. buf[tid] = value.
// Semantics matches examples/gpu_stage13_full.mlr:65-72.
//
// Launch: block_x = N, grid_x = 1. Guard via tid < n.
//
// Kernargs (3 entries, 24 bytes):
//   [0x00] buf_ptr  (f64*)
//   [0x08] n        (u64 by-value)
//   [0x10] value    (f64 by-value)
@export
fn emit_amdgpu_fill_step_blob(uint64 out_path) -> uint64 {
    uint64 kname = "fill_step"
    uint64 klen  = 9

    asm_init()

    asm_s_load_b64(1, 0)                            // s[2:3] buf_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5] n
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7] value
    asm_s_waitcnt_lgkmcnt_zero()

    // tid < n guard.
    asm_v_cmp_gt_u32_sgpr_vgpr(4, 0)                // vcc_lo = (s4 > v0)
    asm_s_and_saveexec_b32_vcc_lo(46)

    // v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // Broadcast value → v[4:5].
    asm_v_mov_b32(4, 6); asm_v_mov_b32(5, 7)
    asm_s_delay_alu(0x02)

    // Store.
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    asm_s_mov_b32(0x7E, 46)
    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000                       // granule 0 → 8 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    uint64[6] args_desc
    uint64 p0s = args_desc + 0;   unsafe { *(p0s as uint64) = 8 }
    uint64 p0k = args_desc + 8;   unsafe { *(p0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 p1s = args_desc + 16;  unsafe { *(p1s as uint64) = 8 }
    uint64 p1k = args_desc + 24;  unsafe { *(p1k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p2s = args_desc + 32;  unsafe { *(p2s as uint64) = 8 }
    uint64 p2k = args_desc + 40;  unsafe { *(p2k as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           24,      // kernarg_size (3 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count
                                           8,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 3)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_fill_step_blob: cannot open output\n", 47)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1m loop-demo: hand-crafted kernel that exercises the SALU while-
// loop primitives (s_add_u32, s_cmp_lt_u32, s_cbranch_scc0,
// s_branch backward) before any AST-lowerer shape wires them in.
//
// Kernel (one thread, writes to out[0]):
//     acc = 0
//     i = 0
//     while i < count:   // count comes from kernarg
//         acc += i
//         i += 1
//     out[0] = acc       // = count*(count-1)/2
//
// Instruction sequence (15 instructions, SALU scalar loop — single
// thread, no VALU predication needed):
//
//   s_load_b32 s2, s[0:1], 0x8         ; s2 = count
//   s_load_b64 s[4:5], s[0:1], null    ; s[4:5] = out ptr
//   s_mov_b32 s6, 0                    ; s6 = i
//   s_mov_b32 s7, 0                    ; s7 = acc
//   s_waitcnt lgkmcnt(0)
// loop_top:
//   s_cmp_lt_u32 s6, s2                ; SCC = (i < count)
//   s_cbranch_scc0 loop_end            ; exit if !lt
//   s_add_u32 s7, s7, s6               ; acc += i    (2-reg form)
//   s_add_u32 s6, s6, 1                ; i += 1
//   s_branch loop_top                  ; back to compare
// loop_end:
//   v_mov_b32 v0, 0                    ; byte offset
//   v_mov_b32 v1, s7                   ; acc → VGPR for store
//   global_store_b32 v0, v1, s[4:5]
//   s_endpgm
@export
fn emit_amdgpu_loop_demo_blob(uint64 out_path) -> uint64 {
    uint64 kname = "loop_demo"
    uint64 klen  = 9

    asm_init()
    asm_s_load_b32(1, 0, 0x8)                      // s2 = count (sdata_pair=1 → s2)
    asm_s_load_b64(2, 0)                           // s[4:5] = out ptr
    asm_s_mov_b32_imm0(6)                          // s6 = 0 (i)
    asm_s_mov_b32_imm0(7)                          // s7 = 0 (acc)
    asm_s_waitcnt_lgkmcnt_zero()

    // loop_top @ offset 5 dwords from text start:
    uint64 loop_top_dword = 5
    asm_s_cmp_lt_u32(6, 2)                         // SCC = (s6 < s2)
    // s_cbranch_scc0 to loop_end: 3 instructions ahead
    //   (s_cbranch itself) + s_add + s_add + s_branch = 4 dwords after
    //   the cbranch → simm16 = 3 (skips 3 dwords to land on
    //   v_mov_b32 at loop_end).
    asm_s_cbranch_scc0(3)
    // s_add_u32 s7, s7, s6 — need a 2-sgpr SOP2 form. Existing
    // asm_s_add_u32_imm only handles imm src1. Emit manually:
    //   SOP2 s_add_u32: [31:23]=0x100, [22:16]=sdst, [15:8]=ssrc1, [7:0]=ssrc0
    uint64 add_word = (0x2 << 30) | (0x00 << 23) | ((7 & 0x7F) << 16) | ((6 & 0xFF) << 8) | (7 & 0xFF)
    asm_u32(add_word)
    asm_s_add_u32_imm(6, 6, 1)                     // s6 += 1
    // s_branch back to loop_top. Current dword offset = 5 + 4 = 9
    // (after cmp, cbranch, add, add). s_branch itself is at dword 9.
    // Target = loop_top_dword = 5. simm16 = target - (current+1) = 5-10 = -5.
    // Encode as two's-complement 16-bit: 0xFFFB.
    asm_s_branch(0xFFFB)

    // loop_end @ dword 10:
    // v_mov_b32 v0, 0  (VOP1 op 0x01, prefix 0x3F at [31:25], vdst at
    // [16:9], src0 at [8:0])
    //   Reference llvm-mc: v_mov_b32 v0, 0 → encoding 7E000280
    //   0x7E000280 = (0x3F<<25) | (0x01<<17) | (0<<9) | 0x80
    asm_u32(0x7E000280)
    // v_mov_b32 v1, s7 (VOP1 op 0x01, vdst=1, src0=SGPR 7 = 0x007)
    //   llvm-mc: 7E020207
    uint64 v_mov_word = (0x3F << 25) | (0x01 << 17) | ((1 & 0xFF) << 9) | (7 & 0x1FF)
    asm_u32(v_mov_word)
    asm_global_store_b32(0, 1, 4)                  // *(s[4:5]) = v1  (saddr=4, raw SGPR index)
    asm_s_endpgm()

    uint64[2] args_desc
    uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
    uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    // Second arg would be u32 count but for simplicity we reuse the
    // pointer-only desc: the caller still passes 8 bytes for the ptr.
    // For M1m demo we only need one declared arg and count comes
    // from the next 4 bytes of the kernarg segment — declare it
    // inline-by-hand instead. Use a larger args_desc.
    uint64[4] args_desc2
    uint64 a0 = args_desc2 + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc2 + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc2 + 16;  unsafe { *(a2 as uint64) = 4 }
    uint64 a3 = args_desc2 + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           12,      // kernarg_size (ptr + u32)
                                           8,
                                           8,       // sgpr_count (s0..s7 used)
                                           2,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc2, 2)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_loop_demo_blob: cannot open output\n", 47)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// AST→AMDGPU lowerer (M1d, extended by M1e).
//
// Two supported kernel shapes. Both require the body to be a
// single PtrStore of a u32 value:
//
//   M1d (1 arg):
//     @kernel fn write_sentinel(uint64 out) {
//         unsafe { *(out as uint32) = INT_LITERAL }
//     }
//
//   M1e (2 args):
//     @kernel fn write_value(uint64 out, uint32 value) {
//         unsafe { *(out as uint32) = value }
//     }
//
// Everything outside those shapes prints an error pointing at the
// offending kernel — the shape grows as the encoder and lowerer do.
//
// Return codes: 0 OK, 1 unsupported shape, 2 I/O failure,
// 3 no @kernel fn in module.
@export
fn emit_amdgpu_from_module(uint64 mod_node, uint64 source, uint64 out_path) -> uint64 {
    // Walk the module for every @kernel fn and lower each into the
    // kernel table. The M1f refactor made emit_amdgpu_multi_code_object
    // accept any number of entries, so all kernels in the .mlr file
    // land in one .co.
    kt_reset()
    uint32 c0 = ast_child(mod_node)
    uint64 wc = c0
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint64 lrc = amdgpu_lower_kernel_to_table(wc, source)
                // 0 = success, 1 = unsupported (hard error),
                // 2 = skip-this-kernel (soft, drop it from the .co
                //     and resolve from a fallback module at launch).
                if lrc == 1 { return lrc }
            }
        }
        uint32 nxt = ast_next(wc)
        wc = nxt
    }
    if kt_count == 0 { return 3 }

    uint64 size = emit_amdgpu_multi_code_object()
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { return 2 }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─────────────────────────────────────────────────────────────────────
// noesis_60m_gpu kernel lowerers
// ─────────────────────────────────────────────────────────────────────
//
// Each of these emits gfx1100 ISA matching one of the four @kernel
// bodies in examples/noesis_60m_gpu.mlr, with kernarg layout matching
// the launcher in examples/noesis_60m_gpu_launch.mlr. The launcher uses
// grid_x = (N+255)/256, block_x = 256, so each kernel computes a global
// thread index gid = wg_id_x * 256 + tid_in_wg before the bounds guard.
//
// The "block_dim = 256" assumption is hardcoded (rather than read from a
// hidden kernarg / dispatch packet) because the launcher always uses
// 256 and reading the dispatch packet here would require extra rsrc2
// bits we don't currently emit. See "Caveats" in /tmp/native_lowering_report.md.
//
// rsrc2 = 0x9E enables 15 user SGPRs; this puts wg_id_x at s15.

// ─── ISA helpers used by the noesis delivery_step lowering ──────────
//
// Encodings verified against llvm-mc in session 2's report; the
// derivations (word1/word2 field decomposition) come from the same
// VOP3/VOP3B/VOP2/VOPC layouts the existing helpers above already
// document. These thin wrappers are kept right next to the noesis
// emitters because the existing structural lowerers don't use them.

// v_mul_lo_u32 vdst, v_src0, v_src1  — VOP3B op 0x02C, low 32 bits of u32×u32.
//   word1 = 0xD72C0000 | (vdst & 0xFF)
//   word2 = ((0x100 | src1) << 9) | (0x100 | src0)
//   Verified: v_mul_lo_u32 v0, v1, v2 → 0xD72C0000 0x00020501.
fn asm_v_mul_lo_u32_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD72C0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_mul_lo_u32 vdst, v_src0, s_src1  — same op, src1 is an SGPR.
//   Verified: v_mul_lo_u32 v3, v0, s4 → 0xD72C0003 0x00000900.
fn asm_v_mul_lo_u32_vs(uint64 vdst, uint64 v_src0, uint64 s_src1) {
    uint64 word1 = 0xD72C0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = s_src1 & 0x1FF                 // SGPR raw
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_lshlrev_b64 v[dst:dst+1], <imm shift 0..63>, v[src:src+1]
//   word1 = 0xD73C0000 | (dst & 0xFF)
//   word2 = (0x100 | src) << 9 | (0x80 + shift)
//   Verified: v_lshlrev_b64 v[2:3], 3, v[0:1]   → 0xD73C0002 0x00020083.
//             v_lshlrev_b64 v[10:11], 3, v[8:9] → 0xD73C000A 0x00021083.
fn asm_v_lshlrev_b64_imm_vv(uint64 vdst_pair, uint64 shift_amount, uint64 v_src_pair) {
    uint64 word1 = 0xD73C0000 | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x80 + (shift_amount & 0x3F)         // inline const
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_u32 vdst, vcc_lo, s_src0, v_src1   (VOP3B op 0x100, writes vcc_lo)
//   word1 = 0xD7006A00 | (vdst & 0xFF)
//   word2 = ((0x100 | v_src1) << 9) | (s_src0 & 0xFF)
//   Verified: v_add_co_u32 v0, vcc_lo, s2, v4 → 0xD7006A00 0x00020802.
//             v_add_co_u32 v6, vcc_lo, s8, v4 → 0xD7006A06 0x00020808.
fn asm_v_add_co_u32_vcc_sv(uint64 vdst, uint64 s_src0, uint64 v_src1) {
    uint64 word1 = 0xD7006A00 | (vdst & 0xFF)
    uint64 src0_enc = s_src0 & 0x1FF                       // SGPR raw
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_ci_u32_e64 vdst, null, s_src0, v_src1, vcc_lo  (op 0x120)
//   Reads vcc_lo (carry-in) and writes a discarded carry-out (null).
//   word1 = 0xD5207C00 | (vdst & 0xFF)
//   word2 = (vcc_lo<<18) | ((0x100|v_src1) << 9) | (s_src0 & 0xFF)
//   Verified: v_add_co_ci_u32_e64 v1, null, s3, v5, vcc_lo → 0xD5207C01 0x01AA0A03.
fn asm_v_add_co_ci_u32_null_sv_vcc(uint64 vdst, uint64 s_src0, uint64 v_src1) {
    uint64 word1 = 0xD5207C00 | (vdst & 0xFF)
    uint64 src0_enc = s_src0 & 0x1FF                       // SGPR raw
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_u32 vdst, vcc_lo, v_src0, v_src1  — VGPR+VGPR variant.
//   word1 = 0xD7006A00 | (vdst & 0xFF)
//   word2 = ((0x100 | v_src1) << 9) | (0x100 | v_src0)
//   Verified: v_add_co_u32 v0, vcc_lo, v2, v4 → 0xD7006A00 0x00020902.
fn asm_v_add_co_u32_vcc_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD7006A00 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_add_co_ci_u32_e64 vdst, null, v_src0, v_src1, vcc_lo — VGPR+VGPR variant.
//   Verified: v_add_co_ci_u32_e64 v1, null, v3, v5, vcc_lo → 0xD5207C01 0x01AA0B03.
fn asm_v_add_co_ci_u32_null_vv_vcc(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD5207C00 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_cndmask_b32_e64 vdst, v_src0, v_src1, vcc_lo  — VOP3 op 0x101.
//   gfx11 rejects an SGPR-pair pair as src0/src1 (verified in session 2).
//   This helper is for the post-mov VGPR-only operand form.
//   Verified: v_cndmask_b32_e64 v0, v2, v4, vcc_lo → 0xD5010000 0x01AA0902.
fn asm_v_cndmask_b32_e64_vv_vcc(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD5010000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// global_load_u8 v_dst, v[v_addr_pair:+1], off  — GLOBAL op 0x10, size=1,
//   zero-extends to 32 bits. Saddr = OFF (0x7C); v_addr is a 64-bit pair.
//   Verified: global_load_u8 v3, v[2:3], off → 0xDC420000 0x037C0002.
fn asm_global_load_u8_offvaddr(uint64 vdst, uint64 v_addr_pair) {
    asm_u32(0xDC420000)
    uint64 word2 = ((vdst & 0xFF) << 24)
                   | (0x7C << 16)                          // saddr = OFF
                   | (v_addr_pair & 0xFF)
    asm_u32(word2)
}

// global_load_b64 v[vdst:vdst+1], v[vaddr_pair:vaddr_pair+1], off
//   off-saddr form with full 64-bit v_addr (vs the saddr_pair form in
//   asm_global_load_b64 above which uses a 32-bit v_addr). Used by the
//   CAS retry loop — the per-lane atomic target address is a 64-bit
//   pair built by v_add_co_u32 + v_add_co_ci_u32, not a (sgpr_pair +
//   u32_offset) split.
//   Verified: global_load_b64 v[2:3], v[20:21], off → 0xDC560000 0x027C0014.
fn asm_global_load_b64_offvaddr(uint64 vdst_pair, uint64 vaddr_pair) {
    asm_u32(0xDC560000)
    uint64 word2 = ((vdst_pair & 0xFF) << 24)
                   | (0x7C << 16)                          // saddr = OFF
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// global_atomic_cmpswap_b64 v[vdst:vdst+1], v[vaddr:+1], v[vdata_quad:+3], off glc
//   Off-saddr form (vs the asm_global_atomic_cmpswap_b64_glc above
//   which takes saddr_pair). v_addr is a full 64-bit pair.
//   Verified: v[0:1], v[8:9], v[2:5], off glc → 0xDD0A4000 0x007C0208.
fn asm_global_atomic_cmpswap_b64_offvaddr(uint64 vdst_pair, uint64 vaddr_pair, uint64 vdata_quad) {
    asm_u32(0xDD0A4000)
    uint64 word2 = ((vdst_pair  & 0xFF) << 24)
                   | (0x7C << 16)                          // saddr = OFF
                   | ((vdata_quad & 0xFF) << 8)
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// v_cmp_ne_u32_e32 vcc_lo, 0, v_src — VOPC op 0x4D.
//   Sets VCC[lane] = (0 != u32(v[src])). The "fired != 0" predicate
//   in delivery_step. Verified: vcc_lo, 0, v0 → 0x7C9A0080.
fn asm_v_cmp_ne_u32_imm0_vgpr(uint64 vgpr) {
    uint64 src0_enc = 0x80                                  // inline 0
    uint64 word = (0x3E << 25)
                  | (0x4D << 17)
                  | ((vgpr & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// ─── ISA helpers used by the noesis lif_step lowering ──────────────
// All encodings verified against llvm-mc -triple=amdgcn -mcpu=gfx1100.

// v_cmp_lt_u64_e32 vcc_lo, 0, v[src1:+1]  — VOPC op 0x59.
//   vcc_lo = (0 < v[src1]) per active lane. With src1=ref pair, this
//   is the "ref > 0" guard at the head of lif_step's main branch.
//   Verified: `v_cmp_lt_u64_e32 vcc_lo, 0, v[2:3]` → 0x7CB20480.
fn asm_v_cmp_lt_u64_imm0_vgpr_pair(uint64 vsrc1_pair) {
    uint64 src0_enc = 0x80                                   // inline 0
    uint64 word = (0x3E << 25)
                  | (0x59 << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// global_store_b8 v[v_addr_pair:+1], v_data, off  — GLOBAL op 0x18,
//   off-saddr form (saddr = OFF/0x7C). Stores the low byte of v_data
//   to the byte at v[v_addr_pair]. Used by lif_step to write
//   fired[i] = 0 / 1 (u8). Verified:
//     global_store_b8 v[2:3], v0, off → 0xDC620000 0x00007C02.
fn asm_global_store_b8_offvaddr(uint64 vaddr_pair, uint64 vdata) {
    asm_u32(0xDC620000)
    uint64 word2 = (0x7C << 16)                              // saddr = OFF
                   | ((vdata     & 0xFF) << 8)
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// global_store_b8 v_addr_u32, v_data, s[saddr:+1]  — GLOBAL op 0x18.
//   With sbase form (saddr is a raw SGPR pair), v_addr is a single
//   VGPR with a 32-bit byte offset. Used by lif_step's "fired[i]=0"
//   write at function entry (cheap since the byte offset is just gid).
//   Encoding for `global_store_b8 v0, v0, s[14:15]`: word1=0xDC620000,
//   word2 = (saddr_pair_raw_lo<<16) | (vdata<<8) | vaddr  with
//   saddr=14 → 0x000E0000 (NOT pair-halved like SMEM; saddr is a raw
//   SGPR index, same as the existing global_load_b64's saddr_pair arg).
fn asm_global_store_b8_saddr(uint64 vaddr, uint64 vdata, uint64 saddr_pair) {
    asm_u32(0xDC620000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdata     & 0xFF) << 8)
                   | (vaddr      & 0xFF)
    asm_u32(word2)
}

// v_rcp_f64 v[vdst:+1], v[vsrc:+1]  — VOP1 op 0x2F (gfx11 b3 → 0x18 e32 form).
//   Initial reciprocal estimate (~14 bits of accuracy) for f64 division.
//   Verified: `v_rcp_f64_e32 v[12:13], v[10:11]` → 0x7E185F0A.
fn asm_v_rcp_f64(uint64 vdst_pair, uint64 vsrc_pair) {
    uint64 src0_enc = 0x100 | (vsrc_pair & 0xFF)             // VGPR
    uint64 word = (0x3F << 25)                                // VOP1 prefix
                  | ((vdst_pair & 0xFF) << 17)
                  | (0x2F << 9)                               // op
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_div_scale_f64 v[vdst:+1], <sdst>, v[s0:+1], v[s1:+1], v[s2:+1]
//   VOP3B op 0x0FD. Scales operands of f64 division to avoid
//   underflow / overflow. sdst gets a scale flag (0x7C=null to discard,
//   0x6A=vcc_lo to feed v_div_fmas_f64's implicit shift control).
//   Verified:
//     v[4:5], null, v[2:3], v[2:3], v[0:1] → 0xD6FD7C04 0x04020502.
//     v[8:9], vcc_lo, v[0:1], v[2:3], v[0:1] → 0xD6FD6A08 0x04020500.
//   word1 = 0xD6FD0000 | (sdst << 8) | vdst.
//   word2 = (src2_enc<<18) | (src1_enc<<9) | src0_enc, no neg/abs.
fn asm_v_div_scale_f64(uint64 vdst_pair, uint64 sdst,
                       uint64 vsrc0_pair, uint64 vsrc1_pair, uint64 vsrc2_pair) {
    uint64 word1 = 0xD6FD0000 | ((sdst & 0xFF) << 8) | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (vsrc1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (vsrc2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_fma_f64 v[vdst:+1], -v[s0:+1], v[s1:+1], 1.0  — VOP3 op 0x014, neg src0.
//   Computes vdst = -src0 * src1 + 1.0  (f64 inline literal 1.0 = 0xF2).
//   Verified: `v_fma_f64 v[16:17], -v[10:11], v[12:13], 1.0`
//             → 0xD6140010 0x23CA190A.
fn asm_v_fma_f64_neg_v_v_lit1(uint64 vdst_pair, uint64 v_src0_pair,
                               uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0xF2                                    // inline 1.0
    uint64 neg = 0x1                                          // neg[0] = 1 → -src0
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_fma_f64 v[vdst:+1], v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x014, no neg.
//   All-VGPR three-source FMA. Verified:
//     v_fma_f64 v[12:13], v[16:17], v[12:13], v[12:13] → 0xD614000C 0x04321910.
//     v_fma_f64 v[16:17], v[10:11], v[12:13], v[14:15] → 0xD6140010 0x041A190A.
fn asm_v_fma_f64_v_v_v(uint64 vdst_pair, uint64 v_src0_pair,
                       uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_fma_f64 v[vdst:+1], -v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x014, neg src0.
//   All-VGPR three-source FMA, src0 negated.
//   Verified: `v_fma_f64 v[18:19], -v[16:17], v[12:13], v[14:15]`
//             → 0xD6140012 0x243A1910.
fn asm_v_fma_f64_negv_v_v(uint64 vdst_pair, uint64 v_src0_pair,
                          uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 neg = 0x1                                          // neg[0] = 1
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_div_fmas_f64 v[vdst:+1], v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x038.
//   FMA with implicit shift control from VCC; used in IEEE-correct f64
//   division to compute the rounded quotient.
//   Verified: v_div_fmas_f64 v[16:17], v[12:13], v[10:11], v[14:15]
//             → 0xD6380010 0x043A150C.
fn asm_v_div_fmas_f64(uint64 vdst_pair, uint64 v_src0_pair,
                      uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x038 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_div_fmas_f64 v[vdst:+1], -v[s0:+1], v[s1:+1], v[s2:+1] — neg src0 form.
//   Verified: v_div_fmas_f64 v[16:17], -v[12:13], v[10:11], v[14:15]
//             → 0xD6380010 0x243A150C.
fn asm_v_div_fmas_f64_neg(uint64 vdst_pair, uint64 v_src0_pair,
                          uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x038 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 neg = 0x1                                          // neg[0] = 1
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_div_fixup_f64 v[vdst:+1], v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x028.
//   Final IEEE rounding fixup for f64 division. src0 = quotient,
//   src1 = denominator, src2 = numerator.
//   Verified: v_div_fixup_f64 v[18:19], v[16:17], v[2:3], v[0:1]
//             → 0xD6280012 0x04020510.
fn asm_v_div_fixup_f64(uint64 vdst_pair, uint64 v_src0_pair,
                       uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x028 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// f64 division helper: v[r:r+1] = v[n:n+1] / v[d:d+1], using IEEE-correct
// gfx11 sequence (10 instructions). Scratch VGPR pairs s0=scaled_d,
// s1=scaled_n, t=reciprocal, u=correction term. Caller must reserve
// 8 contiguous VGPRs for {s0,s1,t,u} (each is a pair) — we accept them
// as 4 pair indices.
//
// Sequence (per AMD ISA + LLVM AMDGPU codegen):
//   scaled_d = div_scale_f64(d, d, n)         ; vcc gets scale flag
//   t        = rcp_f64(scaled_d)              ; ~14 bits
//   u        = -scaled_d * t + 1              ; e0
//   t        = u * t + t                      ; r += e0*r
//   u        = -scaled_d * t + 1              ; e1
//   t        = u * t + t                      ; r += e1*r (~52 bits)
//   scaled_n = div_scale_f64(n, d, n)
//   u        = div_fmas_f64(t, scaled_d, 0)   ; rounded q*d (no, actually...)
//   ...
// LLVM-correct sequence (cross-checked against AMDGPU backend codegen):
//   scaled_d = div_scale_f64(vcc, d, d, n)     ; vdst pair, vcc gets flag
//   rcp      = v_rcp_f64(scaled_d)
//   u0       = v_fma_f64(-scaled_d, rcp, 1.0)
//   t1       = v_fma_f64(u0, rcp, rcp)
//   u1       = v_fma_f64(-scaled_d, t1, 1.0)
//   t2       = v_fma_f64(u1, t1, t1)
//   scaled_n = div_scale_f64(vcc, n, d, n)
//   q1       = v_div_fmas_f64(t2, scaled_n, 0)   ; can't use 0 directly
// On gfx11, the canonical LLVM sequence is:
//   scaled_d = div_scale_f64(vcc, d, d, n)
//   rcp      = v_rcp_f64(scaled_d)
//   u0       = v_fma_f64(-scaled_d, rcp, 1.0)
//   rcp1     = v_fma_f64(u0, rcp, rcp)
//   u1       = v_fma_f64(-scaled_d, rcp1, 1.0)
//   rcp2     = v_fma_f64(u1, rcp1, rcp1)
//   scaled_n = div_scale_f64(vcc, n, d, n)        ; reset vcc to numerator scale
//   q        = v_mul_f64(scaled_n, rcp2)          ; OR div_fmas_f64 trick
//   r        = v_fma_f64(-scaled_d, q, scaled_n)  ; residual
//   q1       = v_div_fmas_f64(r, rcp2, q)         ; corrected q with shift
//   result   = v_div_fixup_f64(q1, d, n)
//
// Total: 11 VOP3 instructions. Caller passes:
//   v_n_pair, v_d_pair, v_r_pair  (numerator, denominator, result; can alias)
//   sd_pair = scaled_d scratch; sn_pair = scaled_n scratch;
//   t_pair = reciprocal scratch; u_pair = correction scratch.
// Result lands in v_r_pair.
fn asm_lif_div_f64(uint64 v_n, uint64 v_d, uint64 v_r,
                   uint64 sd, uint64 sn, uint64 t, uint64 u) {
    asm_v_div_scale_f64(sd, 0x7C, v_d, v_d, v_n)       // sd = scaled_d, sdst=null
    asm_v_rcp_f64(t, sd)                               // t = 1/scaled_d (rough)
    asm_v_fma_f64_neg_v_v_lit1(u, sd, t)               // u = -sd*t + 1
    asm_v_fma_f64_v_v_v(t, u, t, t)                    // t = u*t + t
    asm_v_fma_f64_neg_v_v_lit1(u, sd, t)               // u = -sd*t + 1
    asm_v_fma_f64_v_v_v(t, u, t, t)                    // t ≈ 1/sd accurate
    asm_v_div_scale_f64(sn, 0x6A, v_n, v_d, v_n)       // sn = scaled_n, sdst=vcc_lo
    asm_v_mul_f64_vv(u, sn, t)                         // u = sn * t (rough q)
    asm_v_fma_f64_negv_v_v(v_r, sd, u, sn)             // r_scratch = -sd*u + sn
    asm_v_div_fmas_f64(u, v_r, t, u)                   // u = r*t + u  (corrected)
    asm_v_div_fixup_f64(v_r, u, v_d, v_n)              // result = fixup(u, d, n)
}

// gid = wg_id_x * 256 + tid_in_wg, written into v1.
//   v_mov_b32 v1, s15            ; v1 = wg_id_x
//   v_lshlrev_b32 v1, 8, v1      ; v1 = wg_id_x << 8
//   v_add_nc_u32 v1, v1, v0      ; v1 = gid (tid_in_wg < 256 always)
fn asm_noesis_compute_gid_v1() {
    asm_v_mov_b32(1, 15)                            // v1 = s15
    asm_v_lshlrev_b32_imm(1, 8, 1)                  // v1 <<= 8
    asm_v_add_nc_u32_vv(1, 1, 0)                    // v1 += v0
    asm_s_delay_alu(0x01)
}

// noesis decay_step lowering.
//
//   @kernel fn decay_step(uint64 buf, uint64 n, f64 factor) {
//       uint64 i = tid_x()
//       if i < n {
//           uint64 p = buf + i * 8
//           f64 v; *(p as f64) -> v
//           v = v - v * factor
//           *(p as f64) = v
//       }
//   }
//
// Kernarg layout (matches launcher kp_decay):
//   [0x00] buf    (u64*) — GLOBAL_BUFFER size 8
//   [0x08] n      (u64 by-value, low 32 bits used) — size 4 + 4 pad
//   [0x10] factor (f64 by-value)                   — size 8
//   total = 24 bytes
fn amdgpu_lower_noesis_decay(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()
    asm_noesis_compute_gid_v1()                     // v1 = gid

    // Load n (low 32 bits) into s2 — sdata_pair=1 → s2.
    asm_s_load_b32(1, 0, 0x8)
    asm_s_waitcnt_lgkmcnt_zero()

    // gid < n: vcc_lo = (s2 > v1).
    asm_v_cmp_gt_u32_sgpr_vgpr(2, 1)
    asm_s_and_saveexec_b32_vcc_lo(2)
    asm_s_cbranch_execz(13)                         // skip 13 dwords to s_endpgm

    // Load buf into s[2:3], factor into s[4:5].
    asm_s_load_b64(1, 0)                            // s[2:3] = buf
    asm_s_load_b64_off(2, 0, 0x10)                  // s[4:5] = factor
    asm_v_lshlrev_b32_imm(2, 3, 1)                  // v2 = gid * 8
    asm_s_waitcnt_lgkmcnt_zero()

    // Load buf[gid] into v[4:5] (saddr = raw SGPR index of pair low half = 2).
    asm_global_load_b64(4, 2, 2)                    // v[4:5] = buf[gid]
    asm_s_waitcnt_vmcnt_zero()

    // v[4:5] = v - v*factor = -factor*v + v
    //   asm_v_fma_f64_neg_s_v_v(vdst=4, neg_sgpr_pair=4, vsrc1=4, vsrc2=4)
    //   → v_fma_f64 v[4:5], -s[4:5], v[4:5], v[4:5]
    asm_v_fma_f64_neg_s_v_v(4, 4, 4, 4)
    asm_global_store_b64(2, 4, 2)                   // buf[gid] = v[4:5]
    asm_s_endpgm()

    // 3 args; matches launcher's 24-byte buffer with HIP runtime
    // size-driven packing (4-byte n + 4-byte pad + 8-byte factor).
    uint64 args_desc = alloc(3 * 16)
    uint64 a0s = args_desc + 0;   unsafe { *(a0s as uint64) = 8 }
    uint64 a0k = args_desc + 8;   unsafe { *(a0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a1s = args_desc + 16;  unsafe { *(a1s as uint64) = 4 }
    uint64 a1k = args_desc + 24;  unsafe { *(a1k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a2s = args_desc + 32;  unsafe { *(a2s as uint64) = 8 }
    uint64 a2k = args_desc + 40;  unsafe { *(a2k as uint64) = AMD_ARG_KIND_BY_VALUE }

    // Snapshot the asm text into its own buffer (next kernel's asm_init
    // will clobber asm_text_buf otherwise — same pattern as the
    // existing structural lowerer).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0000        // VGPR granule 0 → 8 VGPRs (we use v0..v5)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            18, 6,                                  // sgpr=18 (s0..s15+exec save), vgpr=6
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// noesis delivery_step lowering.
//
//   @kernel fn delivery_step(
//       uint64 fired_ptr, uint64 col_tgt_ptr, uint64 col_w_ptr,
//       uint64 col_is_inh_ptr, uint64 s_exc_ptr, uint64 s_inh_ptr,
//       uint64 n, uint64 syn_per
//   ) {
//       uint64 src = tid_x()
//       if src < n {
//           if u8(fired[src]) > 0 {
//               for k in 0..syn_per {
//                   slot = src * syn_per + k
//                   tgt  = u64(col_tgt[slot])
//                   w    = f64(col_w[slot])
//                   inh  = u64(col_is_inh[slot])
//                   dst_base = inh > 0 ? s_inh_ptr : s_exc_ptr
//                   atomic_add_f64(&dst_base[tgt], w)
//               }
//           }
//       }
//   }
//
// Kernarg layout (8 args × 8 bytes = 64 bytes total, matches launcher
// kp_deliv byte-for-byte; n and syn_per are stored as u64 by-value but
// HIP runtime size-drives the metadata so we only declare 4 bytes for
// them — matching decay_step's treatment of `n`).
//   [0x00] fired_ptr      (u64*) — GLOBAL_BUFFER
//   [0x08] col_tgt_ptr    (u64*) — GLOBAL_BUFFER
//   [0x10] col_w_ptr      (f64*) — GLOBAL_BUFFER
//   [0x18] col_is_inh_ptr (u64*) — GLOBAL_BUFFER
//   [0x20] s_exc_ptr      (f64*) — GLOBAL_BUFFER
//   [0x28] s_inh_ptr      (f64*) — GLOBAL_BUFFER
//   [0x30] n      (u64 by-value, low 32 bits used) — size 4 + 4 pad
//   [0x38] syn_per (u64 by-value, low 32 bits used) — size 4 + 4 pad
//   total = 64 bytes (the 4-byte declarations leave 4-byte holes that
//   the HIP runtime preserves by dispatched-arg copy size; the launcher
//   writes 8 bytes per slot so the actual segment is 64 bytes regardless
//   of how we declare the trailing two; matches the kp_deliv = alloc(8*8)
//   buffer the launcher hands to hipModuleLaunchKernel).
//
// Register plan:
//   SGPRs: s2..s13 = pointer kernargs; s14 = n; s16 = syn_per;
//          s15 = wg_id_x (rsrc2 reserves it); s18..s21 = EXEC saves +
//          k loop counter.
//   VGPRs: v0..v23. v0..v3 = CAS quad (NEW lo, NEW hi, CMP lo, CMP hi);
//          v4..v5 = scratch byte offset; v6..v7 = fired addr pair;
//          v8..v9 = s_exc splat; v10..v11 = s_inh splat;
//          v12..v13 = tgt b64; v14..v15 = w f64; v16..v17 = inh b64;
//          v18..v19 = dst_base (cndmask result); v20..v21 = tgt*8 pair;
//          v22..v23 = dst_addr pair (= dst_base + tgt*8).
fn amdgpu_lower_noesis_delivery(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()

    // gid in v1 = wg_id_x*256 + tid_in_wg.
    asm_noesis_compute_gid_v1()

    // Prologue: load all 8 kernargs into SGPRs.
    asm_s_load_b64(1, 0)                        // s[2:3]   = fired_ptr
    asm_s_load_b64_off(2, 0, 0x08)              // s[4:5]   = col_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)              // s[6:7]   = col_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)              // s[8:9]   = col_is_inh_ptr
    asm_s_load_b64_off(5, 0, 0x20)              // s[10:11] = s_exc_ptr
    asm_s_load_b64_off(6, 0, 0x28)              // s[12:13] = s_inh_ptr
    asm_s_load_b32(7, 0, 0x30)                  // s14 = n (low 32 bits)
    asm_s_load_b32(8, 0, 0x38)                  // s16 = syn_per (low 32 bits)
    asm_s_waitcnt_lgkmcnt_zero()

    // Bounds check: gid < n  (vcc_lo = (s14 > v1)).
    asm_v_cmp_gt_u32_sgpr_vgpr(14, 1)
    asm_s_and_saveexec_b32_vcc_lo(18)           // s18 = old EXEC; EXEC &= bounds
    // Forward-skip target patched at end of kernel: s_cbranch_execz to s_endpgm.
    uint64 outer_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched)

    // Splat s_exc (s[10:11]) and s_inh (s[12:13]) into VGPR pairs so the
    // per-lane cndmask in the loop can pick between them. SGPR-pair
    // operands are not encodable directly in v_cndmask_b32_e64.
    asm_v_mov_b32(8, 10)                        // v8  = s10 (s_exc lo)
    asm_v_mov_b32(9, 11)                        // v9  = s11 (s_exc hi)
    asm_v_mov_b32(10, 12)                       // v10 = s12 (s_inh lo)
    asm_v_mov_b32(11, 13)                       // v11 = s13 (s_inh hi)
    asm_s_delay_alu(0x02)

    // Build 64-bit address of fired[gid] = fired_ptr + gid*1.
    //   v6 = gid (v1) — byte offset low half
    //   v7 = 0       — byte offset high half
    //   v[6:7] = s[2:3] + v[6:7]    (32-bit add then carry)
    asm_v_mov_b32(6, 0x100 | 1)                 // v6 = v1 (gid)
    asm_v_mov_b32_inline_u(7, 0)                // v7 = 0
    asm_v_add_co_u32_vcc_sv(6, 2, 6)            // v6 = s2 + v6
    asm_v_add_co_ci_u32_null_sv_vcc(7, 3, 7)    // v7 = s3 + v7 + carry
    asm_s_delay_alu(0x01)

    // Load fired[gid] (u8, zero-extended) into v4.
    asm_global_load_u8_offvaddr(4, 6)
    asm_s_waitcnt_vmcnt_zero()

    // Fired guard: vcc_lo = (fired != 0). f > 0 with f a u8 ≡ f != 0.
    asm_v_cmp_ne_u32_imm0_vgpr(4)
    asm_s_and_saveexec_b32_vcc_lo(19)           // s19 = pre-fired EXEC; EXEC &= fired
    uint64 fired_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to k-loop end)

    // Per-lane base = src * syn_per. v1 (=gid=src) × s16 (=syn_per).
    // Result fits in u32: 60M * 4 = 240M < 2^32. v25 (free reg)? Use v5.
    asm_v_mul_lo_u32_vs(5, 1, 16)               // v5 = gid * syn_per

    // SALU k-loop. k lives in s20; bound is s16 (syn_per).
    asm_s_mov_b32_imm0(20)                      // s20 = 0 (k)

    // ── loop_top ──
    uint64 loop_top_off = asm_text_len / 4
    asm_s_cmp_lt_u32(20, 16)                    // SCC = (k < syn_per)
    uint64 scc_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                       // (placeholder, patched to loop_end)

    // slot = base + k. v4 = (base + k) — base in v5 (per-lane), k in s20 (scalar).
    // v_add_nc_u32 with src0 = SGPR encodes as raw SGPR index in src0.
    //   Word: (0x25<<25) | (vdst<<17) | (vsrc1<<9) | (sgpr_src0 & 0x1FF)
    uint64 add_word = (0x25 << 25)
                      | ((4 & 0xFF) << 17)        // vdst = v4
                      | ((5 & 0xFF) << 9)         // vsrc1 = v5
                      | (20 & 0x1FF)              // src0 = s20 (raw SGPR)
    asm_u32(add_word)

    // slot_byte_offset_u32 = (base + k) << 3.
    asm_v_lshlrev_b32_imm(4, 3, 4)              // v4 = v4 * 8
    asm_s_delay_alu(0x01)

    // Per-lane VMEM loads (saddr=raw SGPR pair index of base ptr; v_addr=v4).
    //   tgt = col_tgt[slot]   → v[12:13]   saddr=s4
    //   w   = col_w[slot]     → v[14:15]   saddr=s6
    //   inh = col_is_inh[slot] → v[16:17]  saddr=s8
    asm_global_load_b64(12, 4, 4)               // v[12:13] = tgt
    asm_global_load_b64(14, 4, 6)               // v[14:15] = w
    asm_global_load_b64(16, 4, 8)               // v[16:17] = inh
    asm_s_waitcnt_vmcnt_zero()

    // inh predicate: vcc_lo = (inh_lo != 0).
    asm_v_cmp_ne_u32_imm0_vgpr(16)

    // dst_base = inh ? s_inh : s_exc, per-lane. cndmask src0=false (s_exc=v[8:9]),
    // src1=true (s_inh=v[10:11]). Result → v[18:19].
    asm_v_cndmask_b32_e64_vv_vcc(18, 8, 10)     // v18 = inh ? v10 : v8 (lo)
    asm_v_cndmask_b32_e64_vv_vcc(19, 9, 11)     // v19 = inh ? v11 : v9 (hi)
    asm_s_delay_alu(0x01)

    // tgt * 8 (per-lane 64-bit) → v[20:21].
    asm_v_lshlrev_b64_imm_vv(20, 3, 12)         // v[20:21] = v[12:13] << 3
    asm_s_delay_alu(0x01)

    // dst_addr = dst_base + tgt*8 (per-lane 64-bit) → v[22:23].
    asm_v_add_co_u32_vcc_vv(22, 18, 20)         // v22 = v18 + v20 (lo, sets vcc carry)
    asm_v_add_co_ci_u32_null_vv_vcc(23, 19, 21) // v23 = v19 + v21 + carry
    asm_s_delay_alu(0x01)

    // Prime the CAS: assumed = *dst_addr → v[2:3] (cmp half of CAS quad).
    // Off-saddr form with v_addr = v[22:23] (per-lane 64-bit pair).
    asm_global_load_b64_offvaddr(2, 22)
    asm_s_waitcnt_vmcnt_zero()

    // Save EXEC (= fired-mask intersected with outer-bounds) before the
    // CAS retry narrows it to retrying lanes only.
    asm_s_mov_b32(21, 0x7E)                     // s21 = exec_lo

    // ── CAS retry loop (atomic add f64 at *dst_addr += w) ──
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 14)                  // v[0:1] = assumed + w
    asm_s_delay_alu(0x01)
    asm_global_atomic_cmpswap_b64_offvaddr(0, 22, 0) // v[0:1] = CAS(*v[22:23], v[2:3], v[0:1])
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)                   // vcc = (returned_prev != assumed)
    asm_v_mov_b32(2, 0x100 | 0)                 // v2 = v0 (assumed = returned_prev lo)
    asm_v_mov_b32(3, 0x100 | 1)                 // v3 = v1 (assumed hi)
    asm_s_and_b32_exec_vcc_lo()                 // exec_lo &= vcc_lo (narrow to retrying lanes)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_execnz(cas_delta & 0xFFFF)

    // Restore EXEC = fired-and-bounds mask for the next k iteration.
    asm_s_mov_b32(0x7E, 21)                     // exec_lo = s21

    // k += 1; loop back.
    asm_s_add_u32_imm(20, 20, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_top_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // ── loop_end ── back-patch the scc0 cbranch.
    uint64 loop_end_off = asm_text_len / 4
    uint64 scc_skip = loop_end_off - (scc_patch_off + 1)
    uint64 scc_patch_byte = asm_text_buf + scc_patch_off * 4
    uint32 scc_word = 0xBFA10000 | (scc_skip & 0xFFFF)
    unsafe { *(scc_patch_byte as uint32) = scc_word }

    // Back-patch the fired_skip s_cbranch_execz to land here too. (Both
    // the loop-end and the no-fired-lanes path converge before s_endpgm.)
    uint64 fired_skip_target = asm_text_len / 4
    uint64 fired_skip_dwords = fired_skip_target - (fired_skip_off + 1)
    uint64 fired_skip_byte = asm_text_buf + fired_skip_off * 4
    uint32 fired_skip_word = 0xBFA50000 | (fired_skip_dwords & 0xFFFF)
    unsafe { *(fired_skip_byte as uint32) = fired_skip_word }

    // Back-patch the outer s_cbranch_execz to skip to s_endpgm too.
    uint64 outer_skip_target = asm_text_len / 4
    uint64 outer_skip_dwords = outer_skip_target - (outer_skip_off + 1)
    uint64 outer_skip_byte = asm_text_buf + outer_skip_off * 4
    uint32 outer_skip_word = 0xBFA50000 | (outer_skip_dwords & 0xFFFF)
    unsafe { *(outer_skip_byte as uint32) = outer_skip_word }

    asm_s_endpgm()

    // 8 args, all GLOBAL_BUFFER for the 6 pointers + 2 BY_VALUE u64 for
    // n and syn_per. They're declared u64 (size 8) — not u32 (size 4) —
    // so consecutive 4-byte declarations don't pack tightly into a single
    // 8-byte slot (which would shift syn_per's offset to 0x34 instead of
    // the launcher-expected 0x38). The launcher writes 8 bytes per kernarg
    // slot anyway; the kernel reads only the low 32 bits via s_load_b32.
    uint64 args_desc = alloc(8 * 16)
    uint64 ai = 0
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 8 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    // Snapshot text into private buffer (asm_init clobbers asm_text_buf).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0002                   // VGPR granule=2 → 24 VGPRs (v0..v23)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // sgpr_count: s0..s21 used = 22, +2 for safety = 24.
    // The launcher's kernarg buffer is 64 bytes; the metadata declares
    // 6×8 (ptrs) + 2×4 (u32s) = 56 bytes "payload" but kernarg_segment_size
    // is rounded up to 8-byte alignment => 56 + padding = ... actually the
    // HIP runtime computes kernarg_segment_size from arg metadata sizes
    // with alignment rules. Use 64 to match the launcher's allocated
    // buffer; ROCm tolerates a slightly larger declared kernarg segment
    // (the runtime memcpys arg-by-arg into it).
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 8, 64,
            24, 24,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// noesis lif_step lowering.
//
//   @kernel fn lif_step(
//       uint64 V_ptr, uint64 ref_ptr, uint64 RI_ptr,
//       uint64 s_exc_ptr, uint64 s_inh_ptr, uint64 spike_ptr,
//       uint64 fired_ptr, uint64 n,
//       f64 dt, f64 V_rest, f64 V_reset, f64 V_thresh,
//       f64 tau_m, f64 J_E, f64 J_I, uint64 ref_steps
//   ) {
//       i = tid_x()
//       if i < n {
//           fired[i] = 0  (u8)
//           rc = ref[i]
//           if rc > 0 {
//               ref[i] = rc - 1
//               V[i] = V_reset
//           } else {
//               v = V[i]; ri = RI[i]; se = s_exc[i]; si = s_inh[i]
//               drive = ri + se*J_E - si*J_I
//               dv    = dt * (V_rest - v + drive) / tau_m
//               v_new = v + dv
//               if v_new >= V_thresh {
//                   V[i] = V_reset; ref[i] = ref_steps; spike[i]++; fired[i]=1
//               } else {
//                   V[i] = v_new
//               }
//           }
//       }
//   }
//
// Kernarg layout (16 args × 8 bytes = 128 bytes total, matches launcher
// kp_lif byte-for-byte). Per the lesson from the delivery_step session,
// every kernarg is declared as size=8 — the launcher writes 8 bytes per
// slot regardless of declared type, and HIP runtime auto-alignment from
// declared sizes can slip the offset of a downstream f64 if a u32 sneaks
// in (caused the session-3 illegal-address bug). With size=8 across the
// board, offsets land at 0,8,16,...,120 byte-for-byte.
//
//   [0x00] V_ptr      (u64*)  → s[2:3]
//   [0x08] ref_ptr    (u64*)  → s[4:5]
//   [0x10] RI_ptr     (f64*)  → s[6:7]
//   [0x18] s_exc_ptr  (f64*)  → s[8:9]
//   [0x20] s_inh_ptr  (f64*)  → s[10:11]
//   [0x28] spike_ptr  (u64*)  → s[12:13]
//   [0x30] fired_ptr  (u8*)   → s[16:17]   (skip s[14:15] — s15 = wg_id_x)
//   [0x38] n          (u32 lo)→ s14
//   [0x40] dt         (f64)   → s[18:19]
//   [0x48] V_rest     (f64)   → s[20:21]
//   [0x50] V_reset    (f64)   → s[22:23]
//   [0x58] V_thresh   (f64)   → s[24:25]
//   [0x60] tau_m      (f64)   → s[26:27]
//   [0x68] J_E        (f64)   → s[28:29]
//   [0x70] J_I        (f64)   → s[30:31]
//   [0x78] ref_steps  (u32 lo)→ s32
//
// EXEC saves: s33 = outer (gid<n), s34 = refractory, s35 = spike.
//
// VGPR plan:
//   v0  = tid_in_wg (kernel input)
//   v1  = gid (= wg_id_x*256 + v0)
//   v2  = byte offset (= gid*8) for f64/u64 stores
//   v3  = byte offset (= gid) for the u8 fired store
//   v4  = scratch (0 / 1 inline for fired writes)
//   v[10:11] = V (active) / V_reset splat (refractory + spike)
//   v[12:13] = rc (refractory test) / ref_steps splat (spike)
//   v[14:15] = RI (active) / dt splat / tau_m splat / spike[i] (spike)
//   v[16:17] = se (active) / div scratch sd (active div)
//   v[18:19] = si (active) / div scratch sn
//   v[20:21] = drive accumulator / div scratch t (rcp)
//   v[22:23] = dv_num = (V_rest - V + drive) * dt
//   v[24:25] = div scratch u
//   v[26:27] = dv (= num/den)
//   v[28:29] = v_new (= V + dv)
//   v[30:31] = V_thresh splat
//
// VGPR count: 32 → granule=3 (rsrc1 = 0xE0AF0003).
fn amdgpu_lower_noesis_lif(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()

    // ── Phase 1: gid in v1 = wg_id_x*256 + tid_in_wg ──
    asm_noesis_compute_gid_v1()

    // ── Phase 2: prologue, load all 16 kernargs into SGPRs ──
    asm_s_load_b64(1, 0)                        // s[2:3]   = V_ptr
    asm_s_load_b64_off(2, 0, 0x08)              // s[4:5]   = ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)              // s[6:7]   = RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)              // s[8:9]   = s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)              // s[10:11] = s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)              // s[12:13] = spike_ptr
    // sdata_pair=8 → s[16:17] (skipping s[14:15] which holds wg_id_x's
    // upper half + n).
    asm_s_load_b64_off(8, 0, 0x30)              // s[16:17] = fired_ptr
    asm_s_load_b32(7, 0, 0x38)                  // s14 = n (low 32 bits)
    asm_s_load_b64_off(9, 0, 0x40)              // s[18:19] = dt
    asm_s_load_b64_off(10, 0, 0x48)             // s[20:21] = V_rest
    asm_s_load_b64_off(11, 0, 0x50)             // s[22:23] = V_reset
    asm_s_load_b64_off(12, 0, 0x58)             // s[24:25] = V_thresh
    asm_s_load_b64_off(13, 0, 0x60)             // s[26:27] = tau_m
    asm_s_load_b64_off(14, 0, 0x68)             // s[28:29] = J_E
    asm_s_load_b64_off(15, 0, 0x70)             // s[30:31] = J_I
    asm_s_load_b32(16, 0, 0x78)                 // s32 = ref_steps (low 32 bits)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Phase 3: outer bounds check (gid < n) ──
    asm_v_cmp_gt_u32_sgpr_vgpr(14, 1)           // vcc_lo = (s14 > v1)
    asm_s_and_saveexec_b32_vcc_lo(33)           // s33 = old EXEC; EXEC &= bounds
    uint64 outer_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to s_endpgm)

    // Compute byte offsets used throughout:
    //   v2 = gid*8   (for u64/f64 strided arrays)
    //   v3 = gid     (for u8 fired array)
    asm_v_lshlrev_b32_imm(2, 3, 1)              // v2 = v1 << 3
    asm_v_mov_b32(3, 0x100 | 1)                 // v3 = v1
    asm_s_delay_alu(0x01)

    // ── Phase 4: unconditional fired[i] = 0 (only for active outer lanes) ──
    asm_v_mov_b32_inline_u(4, 0)                // v4 = 0
    asm_global_store_b8_saddr(3, 4, 16)         // store_b8 (s[16:17]+v3) = v4

    // ── Phase 5: load rc = ref[i] into v[12:13] ──
    asm_global_load_b64(12, 2, 4)               // v[12:13] = ref[gid]
    asm_s_waitcnt_vmcnt_zero()

    // ── Phase 6: refractory test (rc > 0) ──
    asm_v_cmp_lt_u64_imm0_vgpr_pair(12)         // vcc = (0 < rc) = (rc > 0)
    asm_s_and_saveexec_b32_vcc_lo(34)           // s34 = bounded EXEC; EXEC &= rc>0
    uint64 ref_then_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to ref_else_label)

    // ── Phase 7: refractory body ──
    //   ref[i] = rc - 1 (u64 with carry chain)
    //   V[i]   = V_reset
    asm_v_add_co_u32_vcc_sv(12, 0xC1, 12)       // v12 = -1 + v12 (low, sets vcc)
    asm_v_add_co_ci_u32_null_sv_vcc(13, 0xC1, 13)  // v13 = -1 + v13 + carry-in
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 12, 4)              // ref[gid] = v[12:13]

    // V[i] = V_reset:
    //   splat V_reset (s[22:23]) into v[10:11], then store.
    asm_v_mov_b32(10, 22)                       // v10 = s22
    asm_v_mov_b32(11, 23)                       // v11 = s23
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 10, 2)              // V[gid] = v[10:11]

    // ── Phase 8: flip EXEC to active branch (bounded ∩ rc==0) ──
    uint64 ref_else_label_off = asm_text_len / 4
    // Back-patch ref_then_skip's execz target → ref_else_label.
    uint64 ref_then_dwords = ref_else_label_off - (ref_then_skip_off + 1)
    uint64 ref_then_patch_byte = asm_text_buf + ref_then_skip_off * 4
    uint32 ref_then_word = 0xBFA50000 | (ref_then_dwords & 0xFFFF)
    unsafe { *(ref_then_patch_byte as uint32) = ref_then_word }
    // exec = exec ^ s34 = (bounded ∩ rc>0) ^ bounded = bounded ∩ rc==0
    asm_s_xor_b32_exec_sgpr(34)

    // Skip the active body if no lanes are active:
    uint64 active_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to outer_end)

    // ── Phase 9: active body — load V, RI, se, si ──
    asm_global_load_b64(10, 2, 2)               // v[10:11] = V[gid]
    asm_global_load_b64(14, 2, 6)               // v[14:15] = RI[gid]
    asm_global_load_b64(16, 2, 8)               // v[16:17] = se[gid]
    asm_global_load_b64(18, 2, 10)              // v[18:19] = si[gid]
    asm_s_waitcnt_vmcnt_zero()

    // ── Phase 10: drive = ri + se*J_E - si*J_I ──
    //   v[20:21] = J_E*se + ri  (fma_f64_s_v_v with s_src=s[28:29], v1=v[16:17], v2=v[14:15])
    asm_v_fma_f64_s_v_v(20, 28, 16, 14)
    asm_s_delay_alu(0x01)
    //   v[20:21] = -J_I*si + drive
    asm_v_fma_f64_neg_s_v_v(20, 30, 18, 20)
    asm_s_delay_alu(0x01)

    // ── Phase 11: dv_num = (V_rest - V + drive) ──
    //   v[22:23] = V_rest + (-V) [V in v[10:11]]
    asm_v_add_f64_s_negv(22, 20, 10)            // s[20:21] = V_rest, -v[10:11] = -V
    asm_s_delay_alu(0x01)
    //   v[22:23] = (V_rest - V) + drive [drive in v[20:21]]
    asm_v_add_f64_vv(22, 22, 20)
    asm_s_delay_alu(0x01)

    // ── Phase 12: numerator = dt * dv_num ──
    //   Splat dt (s[18:19]) into v[14:15], then v_mul_f64.
    asm_v_mov_b32(14, 18)                       // v14 = s18
    asm_v_mov_b32(15, 19)                       // v15 = s19
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(22, 14, 22)                // v[22:23] = dt * dv_num

    // ── Phase 13: dv = numerator / tau_m ──
    //   Splat tau_m (s[26:27]) into v[14:15] (reuse).
    asm_v_mov_b32(14, 26)                       // v14 = s26
    asm_v_mov_b32(15, 27)                       // v15 = s27
    asm_s_delay_alu(0x01)
    //   IEEE-correct f64 div: scratch sd=v[16:17], sn=v[18:19],
    //   t=v[20:21], u=v[24:25]. Result in v[26:27].
    asm_lif_div_f64(22, 14, 26, 16, 18, 20, 24)

    // ── Phase 14: v_new = V + dv ──
    asm_v_add_f64_vv(28, 10, 26)                // v[28:29] = V + dv
    asm_s_delay_alu(0x01)

    // ── Phase 15: spike test (v_new >= V_thresh) ──
    //   Splat V_thresh (s[24:25]) into v[30:31] for v_cmp_ge_f64_vv.
    asm_v_mov_b32(30, 24)                       // v30 = s24
    asm_v_mov_b32(31, 25)                       // v31 = s25
    asm_s_delay_alu(0x01)
    asm_v_cmp_ge_f64_vv(28, 30)                 // vcc = (v_new >= V_thresh)
    asm_s_and_saveexec_b32_vcc_lo(35)           // s35 = active EXEC; EXEC &= spike
    uint64 spike_then_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to spike_else_label)

    // ── Phase 16: spike body ──
    //   V[i] = V_reset
    asm_v_mov_b32(10, 22)                       // v10 = s22 (V_reset lo)
    asm_v_mov_b32(11, 23)                       // v11 = s23 (V_reset hi)
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 10, 2)              // V[gid] = V_reset
    //   ref[i] = ref_steps (u64 with high half = 0)
    asm_v_mov_b32(12, 32)                       // v12 = s32 (ref_steps lo)
    asm_v_mov_b32_inline_u(13, 0)               // v13 = 0
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 12, 4)              // ref[gid] = ref_steps
    //   spike[i] += 1 (per-neuron, no race because i is unique)
    asm_global_load_b64(14, 2, 12)              // v[14:15] = spike[gid]
    asm_s_waitcnt_vmcnt_zero()
    asm_v_add_co_u32_vcc_sv(14, 0x81, 14)       // v14 = 1 + v14 (sets vcc carry)
    asm_v_add_co_ci_u32_null_sv_vcc(15, 0x80, 15)  // v15 = 0 + v15 + carry
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 14, 12)             // spike[gid] = incremented
    //   fired[i] = 1
    asm_v_mov_b32_inline_u(4, 1)                // v4 = 1
    asm_global_store_b8_saddr(3, 4, 16)

    // ── Phase 17: flip to no-spike (active ∩ v_new < V_thresh) ──
    uint64 spike_else_label_off = asm_text_len / 4
    // Back-patch spike_then_skip → spike_else_label.
    uint64 spike_then_dwords = spike_else_label_off - (spike_then_skip_off + 1)
    uint64 spike_then_patch_byte = asm_text_buf + spike_then_skip_off * 4
    uint32 spike_then_word = 0xBFA50000 | (spike_then_dwords & 0xFFFF)
    unsafe { *(spike_then_patch_byte as uint32) = spike_then_word }
    asm_s_xor_b32_exec_sgpr(35)                 // exec = active ∩ no-spike

    // ── Phase 18: no-spike body: V[i] = v_new ──
    asm_global_store_b64(2, 28, 2)              // V[gid] = v_new

    // ── Phase 19: outer end ──
    uint64 outer_end_off = asm_text_len / 4
    // Back-patch outer execz (skip whole body if all lanes failed bounds).
    uint64 outer_dwords = outer_end_off - (outer_skip_off + 1)
    uint64 outer_patch_byte = asm_text_buf + outer_skip_off * 4
    uint32 outer_word = 0xBFA50000 | (outer_dwords & 0xFFFF)
    unsafe { *(outer_patch_byte as uint32) = outer_word }
    // Back-patch active execz (skip active body if all bounded lanes are refractory).
    uint64 active_dwords = outer_end_off - (active_skip_off + 1)
    uint64 active_patch_byte = asm_text_buf + active_skip_off * 4
    uint32 active_word = 0xBFA50000 | (active_dwords & 0xFFFF)
    unsafe { *(active_patch_byte as uint32) = active_word }
    asm_s_endpgm()

    // ── Args desc: 16 entries, all size=8. The first 7 are pointers
    //   (GLOBAL_BUFFER); n is BY_VALUE (u64); 7 f64s are BY_VALUE; the
    //   last (ref_steps) is BY_VALUE. ──
    uint64 args_desc = alloc(16 * 16)
    uint64 ai = 0
    while ai < 7 {                              // 7 pointers
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 16 {                             // n + dt + V_rest + V_reset + V_thresh + tau_m + J_E + J_I + ref_steps = 9 by-values
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    // Snapshot text into private buffer (asm_init clobbers asm_text_buf).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0003                   // VGPR granule=3 → 32 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // sgpr_count: s0..s35 = 36 SGPRs.
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 16, 128,
            36, 32,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Lower one @kernel fn_node into the kernel table. Returns 0 on
// success, 1 on unsupported shape. Recognises the same two shapes
// the M1d/M1e lowerer already handled:
//
//   M1d (1 arg):
//     @kernel fn name(uint64 out) {
//         unsafe { *(out as uint32) = INT_LITERAL }
//     }
//
//   M1e (2 args):
//     @kernel fn name(uint64 out, uint32 value) {
//         unsafe { *(out as uint32) = value }
//     }
fn amdgpu_lower_kernel_to_table(uint64 fn_node, uint64 source) -> uint64 {
    // Kernel name.
    uint32 name_tok = ast_data1(fn_node)
    uint64 ns = tok_text_start(name_tok)
    uint64 nl = tok_text_len(name_tok)
    uint64 kname_ptr = source + ns

    // ── noesis_60m_gpu @kernel routing ────────────────────────────────
    // The four kernels in examples/noesis_60m_gpu.mlr have rich bodies
    // (atomics, branches, multi-arg layouts) that the structural
    // recognisers below don't cover. Detect them by name and route to
    // dedicated emitters that produce ISA matching the noesis launcher's
    // kernarg packing (see examples/noesis_60m_gpu_launch.mlr).
    //
    // SCOPE NOTE: this branch implements decay_step natively. lif_step,
    // delivery_step, and csr_build still flow through hipcc — they need
    // primitives our gfx1100 encoder doesn't yet have (f64 division
    // via Newton + div_fixup; v_mul_lo_u64 + 64-bit unsigned modulo;
    // global_store_b8; v_add_co_u32 + carry chain for 64-bit address
    // arithmetic; CAS-retry loop with backwards-branch patching). Each
    // is in-scope for a follow-up but not deliverable in one session
    // without high silent-corruption risk. See /tmp/native_lowering_report.md
    // for the design plans of the missing three.
    if tok_matches(name_tok, "decay_step", 10) != 0 {
        return amdgpu_lower_noesis_decay(kname_ptr, nl)
    }
    // For the three not-yet-native kernels we emit a warning and
    // return 2 (= "skip"). emit_amdgpu_from_module turns that into a
    // continue, so the .co contains only the kernels that DO lower.
    // The launcher resolves unsupported kernels from a fallback .co
    // via NOESIS_CSR_CO_PATH (see examples/noesis_60m_gpu_launch.mlr).
    // This dual-.co strategy lets us land the kernels one-by-one
    // without blocking the bench writeup on full coverage.
    if tok_matches(name_tok, "lif_step", 8) != 0 {
        return amdgpu_lower_noesis_lif(kname_ptr, nl)
    }
    if tok_matches(name_tok, "delivery_step", 13) != 0 {
        return amdgpu_lower_noesis_delivery(kname_ptr, nl)
    }
    if tok_matches(name_tok, "csr_build", 9) != 0 {
        // csr_build needs splitmix64 (4× 64-bit multiply) and a 64-bit
        // unsigned modulo. Neither has a primitive in our gfx1100
        // encoder yet; implementing them is multi-day work and only
        // amortises across one launch (csr_build runs once at sim
        // start). csr_build is a one-shot startup kernel, so this does
        // not block hot-path benchmarking.
        write(2, "mlrc: amdgpu-native: skipping csr_build (not yet native).\n", 58)
        write(2, "  Build a fallback .co with --target=hip-amd and set\n", 53)
        write(2, "  NOESIS_CSR_CO_PATH at launch time.\n", 37)
        return 2
    }

    // Param list — 1 or 2 params. If there are 2, the 2nd is taken
    // as a u32 by-value scalar and its PARAM name is remembered so
    // we can match it against the PtrStore value Ident.
    uint64 n_params = 0
    uint32 param0_tok = 0
    uint32 param1_tok = 0
    uint32 p = ast_child(fn_node)
    uint64 wp = p
    while wp != 0 {
        if n_params == 0 { param0_tok = ast_data2(wp) }
        if n_params == 1 { param1_tok = ast_data2(wp) }
        n_params = n_params + 1
        uint32 np = ast_next(wp)
        wp = np
    }
    if n_params != 1 && n_params != 2 && n_params != 3 && n_params != 4 && n_params != 5 {
        write(2, "mlrc: amdgpu-native lowering supports 1-5 params (got ", 54)
        uint8[24] cbuf
        uint64 clen = fmt_uint(cbuf, n_params)
        write(2, cbuf, clen)
        write(2, ")\n", 2)
        return 1
    }

    // Body — either a single PtrStore (M1d/M1e shapes) or a
    // VarDecl followed by a PtrStore (M1f tid-aware shape) or a
    // single If stmt guarding a tid-aware block (M1g guarded shape).
    uint32 body = ast_data3(fn_node)
    if body == 0 {
        write(2, "mlrc: amdgpu-native: kernel has empty body\n", 43)
        return 1
    }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 {
        write(2, "mlrc: amdgpu-native: kernel body has no statements\n", 51)
        return 1
    }

    // M1g guarded shape first — recognises:
    //   if tid_x() < PARAM1 {
    //       uint64 p = PARAM0 + tid_x() * 4
    //       unsafe { *(p as uint32) = tid_x() }
    //   }
    // i.e. the M1f tid body wrapped in an if-bounds check. Used when
    // the launch grid has more threads than buffer slots.
    uint64 is_tid_guarded_shape = 0
    uint64 is_decay_shape        = 0
    uint64 is_grid_decay_shape   = 0
    uint64 is_grid_fill_shape    = 0
    uint64 is_grid_relax_shape   = 0
    uint32 s0_kind = ast_kind(stmt0)
    if s0_kind == 13 {
        uint32 after_if = ast_next(stmt0)
        if after_if != 0 {
            write(2, "mlrc: amdgpu-native: guarded shape: expect exactly one If stmt\n", 63)
            return 1
        }
        if n_params != 2 && n_params != 3 && n_params != 4 && n_params != 5 {
            write(2, "mlrc: amdgpu-native: guarded shape expects 2-5 params\n", 54)
            return 1
        }
        // If AST layout (kind 13, per ir.kr): child=cond expr,
        // data1=then block, data2=optional else body.
        // Validate cond = Compare(LT, Call(tid_x), Ident(param1)).
        uint32 cond_node = ast_child(stmt0)
        uint64 wcond = cond_node
        if ast_kind(wcond) != 38 {
            write(2, "mlrc: amdgpu-native: guarded shape: if cond must be a comparison\n", 65)
            return 1
        }
        uint32 cond_op_tok = ast_data1(wcond)
        uint64 cond_op_kind = tok_kind_at_raw(cond_op_tok)
        if cond_op_kind != 37 {
            // 37 = `<` per ir.kr BinOp LT mapping.
            write(2, "mlrc: amdgpu-native: guarded shape: if cond must use `<`\n", 57)
            return 1
        }
        uint32 cond_lhs = ast_child(wcond)
        uint32 cond_rhs = ast_data2(wcond)
        uint64 wclhs = cond_lhs
        uint64 wcrhs = cond_rhs
        // For 2/3-param shapes the cond LHS must be a direct Call
        // to tid_x(). For the 4+-param grid shapes the LHS is a
        // richer expression — `block_id_x() * bdim + tid_x()` —
        // and we trust the user source rather than walking the
        // BinOp here.
        if n_params != 4 && n_params != 5 {
            if ast_kind(wclhs) != 35 {
                write(2, "mlrc: amdgpu-native: guarded shape: cond lhs must be a Call\n", 60)
                return 1
            }
            uint32 lhs_callee = ast_data1(wclhs)
            if tok_matches(lhs_callee, "tid_x", 5) == 0 {
                write(2, "mlrc: amdgpu-native: guarded shape: cond lhs must be tid_x()\n", 61)
                return 1
            }
        }
        if ast_kind(wcrhs) != 32 {
            write(2, "mlrc: amdgpu-native: guarded shape: cond rhs must be an Ident\n", 62)
            return 1
        }
        uint32 rhs_ident = ast_data1(wcrhs)
        if tok_text_eq(rhs_ident, param1_tok) == 0 {
            write(2, "mlrc: amdgpu-native: guarded shape: cond rhs must name the 2nd param\n", 69)
            return 1
        }
        // The then-block content is *assumed* to match the tid body
        // shape — we trust it here since any mismatch just produces
        // wrong results at runtime, not a crash. Full structural
        // validation of the nested Block can land alongside richer
        // lowering.
        if n_params == 2 { is_tid_guarded_shape = 1 }
        if n_params == 3 { is_decay_shape       = 1 }
        if n_params == 4 {
            // Disambiguate grid-decay vs grid-fill by counting the
            // then-block's statements. Decay is 5 stmts (p, v, load,
            // assign, store); fill is 2 stmts (p, store).
            uint32 then_body = ast_data1(stmt0)
            uint64 wthen = then_body
            uint64 then_stmts = 0
            if wthen != 0 {
                uint32 bc = ast_child(wthen)
                uint64 wbc = bc
                while wbc != 0 {
                    then_stmts = then_stmts + 1
                    uint32 nxtbc = ast_next(wbc)
                    wbc = nxtbc
                }
            }
            if then_stmts <= 2 { is_grid_fill_shape  = 1 }
            if then_stmts >= 3 { is_grid_decay_shape = 1 }
        }
        if n_params == 5 { is_grid_relax_shape = 1 }
    }

    uint32 stmt1 = ast_next(stmt0)
    uint64 is_tid_shape = 0
    if is_tid_guarded_shape == 0 && stmt1 != 0 {
        // Two-stmt body → must be VarDecl then PtrStore. The PtrStore's
        // value must be a Call to tid_x(); the VarDecl's init computes
        // the byte offset via `param0 + tid_x() * SCALE` and is trusted
        // (we don't verify the arithmetic yet — that's next cut).
        uint32 third = ast_next(stmt1)
        if third != 0 {
            write(2, "mlrc: amdgpu-native: kernel body has more than 2 stmts\n", 55)
            return 1
        }
        uint64 ws0 = stmt0
        uint64 ws1 = stmt1
        if ast_kind(ws0) != 10 {
            write(2, "mlrc: amdgpu-native: tid shape: first stmt must be VarDecl\n", 59)
            return 1
        }
        if ast_kind(ws1) != 42 {
            write(2, "mlrc: amdgpu-native: tid shape: second stmt must be PtrStore\n", 61)
            return 1
        }
        uint32 ws1_ts = ast_data1(ws1)
        uint64 ws1_tsz = ws1_ts
        if ws1_tsz != 4 {
            write(2, "mlrc: amdgpu-native: tid shape: only u32 store supported\n", 57)
            return 1
        }
        uint32 ws1_val = ast_data2(ws1)
        uint64 wval1 = ws1_val
        if ast_kind(wval1) != 35 {
            write(2, "mlrc: amdgpu-native: tid shape: store value must be a Call\n", 59)
            return 1
        }
        uint32 callee = ast_data1(wval1)
        if tok_matches(callee, "tid_x", 5) == 0 {
            write(2, "mlrc: amdgpu-native: tid shape: only tid_x() calls supported\n", 61)
            return 1
        }
        if n_params != 1 {
            write(2, "mlrc: amdgpu-native: tid shape expects exactly 1 param\n", 55)
            return 1
        }
        is_tid_shape = 1
    }
    uint64 wstmt = 0
    uint32 skind = 0
    if is_tid_shape == 0 && is_tid_guarded_shape == 0 && is_decay_shape == 0 && is_grid_decay_shape == 0 && is_grid_fill_shape == 0 && is_grid_relax_shape == 0 {
        wstmt = stmt0
        skind = ast_kind(wstmt)
        if skind != 42 {
            write(2, "mlrc: amdgpu-native: first stmt must be PtrStore\n", 49)
            return 1
        }
    }
    uint64 is_lit_shape = 0
    uint64 lit32 = 0
    if is_tid_shape == 0 && is_tid_guarded_shape == 0 && is_decay_shape == 0 && is_grid_decay_shape == 0 && is_grid_fill_shape == 0 && is_grid_relax_shape == 0 {
        uint32 ts = ast_data1(wstmt)
        uint64 type_size = ts
        if type_size != 4 {
            write(2, "mlrc: amdgpu-native: only u32 stores supported\n", 47)
            return 1
        }
        uint32 val_node = ast_data2(wstmt)
        uint64 wvn = val_node
        uint32 vkind = ast_kind(wvn)

        // Decide lowering path: IntLit (1-arg sentinel) vs Ident
        // pointing at the 2nd param (2-arg forwarder).
        if vkind == 30 {
            is_lit_shape = 1
            uint32 lit_tok = ast_data1(wvn)
            lit32 = parse_int_token(lit_tok) & 0xFFFFFFFF
            if n_params != 1 {
                write(2, "mlrc: amdgpu-native: 1-arg sentinel shape expects exactly 1 param\n", 66)
                return 1
            }
        } else if vkind == 32 {
            uint32 ident_tok = ast_data1(wvn)
            if n_params != 2 {
                write(2, "mlrc: amdgpu-native: 2-arg forwarder shape expects exactly 2 params\n", 68)
                return 1
            }
            if tok_text_eq(ident_tok, param1_tok) == 0 {
                write(2, "mlrc: amdgpu-native: store value must reference the 2nd kernel param\n", 69)
                return 1
            }
        } else {
            write(2, "mlrc: amdgpu-native: store value must be an IntLit or a param Ident\n", 68)
            return 1
        }
    }

    // Lower to gfx1100 via the encoders. Resource layout mirrors
    // what clang picks for these kernel classes — safe
    // over-approximation until we derive them from analysis.
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408       // KERNARG_SEGMENT_PTR | WAVEFRONT_SIZE32

    asm_init()
    uint64 kernarg_size = 0
    uint64 sgpr_count   = 0
    uint64 n_args       = 0

    // Each kernel owns its own args_desc buffer (alloc instead of
    // stack) because kt_push stores the pointer into the table and
    // reads it back during emit — stack addresses wouldn't survive
    // function return. Same rationale for the kernel text blob.
    // 6 × 16 bytes = up to 6 args × (size, kind); decay uses 3.
    uint64 args_desc = alloc(6 * 16)

    if is_grid_relax_shape != 0 {
        // M1l grid-relax: nv = v + (target - v) * factor.
        // Lowered as  diff = target - v ; nv = fma(factor, diff, v).
        // Kernarg layout (5 args):
        //   0:  buf           u64
        //   8:  n             u32
        //   16: target        f64
        //   24: factor        f64
        //   32: bdim          u32    (= kernarg_size 36)
        //
        //   s_clause 0x1
        //   s_load_b32 s2, s[0:1], 0x20    ; bdim
        //   s_load_b32 s4, s[0:1], 0x8     ; n
        //   s_waitcnt lgkmcnt(0)
        //   v_mad_u32_u24 v1, s2, s15, v0  ; gid
        //   v_cmp_gt_u32 vcc_lo, s4, v1
        //   s_and_saveexec_b32 s3, vcc_lo
        //   s_cbranch_execz 15
        //   s_load_b64 s[2:3], s[0:1], null  ; buf
        //   s_load_b64 s[4:5], s[0:1], 0x10  ; target
        //   s_load_b64_off s[6:7], 0x18       ; factor
        //   v_lshlrev_b32 v4, 3, v1           ; byte offset
        //   s_waitcnt lgkmcnt(0)
        //   global_load_b64 v[0:1], v4, s[2:3]
        //   s_waitcnt vmcnt(0)
        //   v_add_f64 v[2:3], s[4:5], -v[0:1]   ; diff = target - v
        //   v_fma_f64 v[0:1], s[6:7], v[2:3], v[0:1] ; nv = factor*diff + v
        //   global_store_b64 v4, v[0:1], s[2:3]
        //   s_endpgm
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 0x20)                  // s2 = bdim
        asm_s_load_b32(2, 0, 0x8)                   // s4 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_mad_u32_u24(1, 2, 15, 0)              // v1 = gid
        asm_v_cmp_gt_u32_sgpr_vgpr(4, 1)
        asm_s_and_saveexec_b32_vcc_lo(3)
        asm_s_cbranch_execz(15)                     // 15 dwords to s_endpgm
        asm_s_load_b64(1, 0)                        // s[2:3] <- buf
        asm_s_load_b64_off(2, 0, 0x10)              // s[4:5] <- target
        asm_s_load_b64_off(3, 0, 0x18)              // s[6:7] <- factor
        asm_v_lshlrev_b32_imm(4, 3, 1)              // v4 = v1 << 3
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_load_b64(0, 4, 2)                // v[0:1] = buf[gid]
        asm_s_waitcnt_vmcnt_zero()
        asm_v_add_f64_s_negv(2, 4, 0)               // v[2:3] = s[4:5] - v[0:1]
        asm_v_fma_f64_s_v_v(0, 6, 2, 0)             // v[0:1] = s[6:7]*v[2:3] + v[0:1]
        asm_global_store_b64(4, 0, 2)               // buf[gid] = v[0:1]
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;    unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;    unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;   unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;   unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;   unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;   unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp6 = args_desc + 48;   unsafe { *(adp6 as uint64) = 8 }
        uint64 adp7 = args_desc + 56;   unsafe { *(adp7 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp8 = args_desc + 64;   unsafe { *(adp8 as uint64) = 4 }
        uint64 adp9 = args_desc + 72;   unsafe { *(adp9 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 36
        sgpr_count   = 18
        n_args       = 5
    } else if is_grid_fill_shape != 0 {
        // M1k grid-fill: buf[gid] = value for gid < n. Same kernarg
        // layout as grid-decay (buf, n, value, bdim). Body simpler —
        // no load/fma, just a splat from the f64 kernarg pair into
        // v[0:1] and one 8-byte global store.
        //
        //   s_clause 0x1
        //   s_load_b32 s2, s[0:1], 0x18    ; bdim
        //   s_load_b32 s4, s[0:1], 0x8     ; n
        //   s_waitcnt lgkmcnt(0)
        //   v_mad_u32_u24 v1, s2, s15, v0  ; gid
        //   v_cmp_gt_u32 vcc_lo, s4, v1
        //   s_and_saveexec_b32 s3, vcc_lo
        //   s_cbranch_execz 9
        //   s_load_b64 s[2:3], s[0:1], null   ; buf
        //   s_load_b64 s[4:5], s[0:1], 0x10   ; value (f64)
        //   v_lshlrev_b32 v2, 3, v1
        //   s_waitcnt lgkmcnt(0)
        //   v_dual_mov_b32 v0, s4 :: v_dual_mov_b32 v1, s5
        //   global_store_b64 v2, v[0:1], s[2:3]
        //   s_endpgm
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 0x18)                  // s2 = bdim
        asm_s_load_b32(2, 0, 0x8)                   // s4 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_mad_u32_u24(1, 2, 15, 0)              // v1 = s2 * s15 + v0
        asm_v_cmp_gt_u32_sgpr_vgpr(4, 1)            // vcc_lo = (s4 > v1)
        asm_s_and_saveexec_b32_vcc_lo(3)            // save EXEC
        asm_s_cbranch_execz(10)                     // skip 10 dwords (s_load_b64 + s_load_b64_off + v_lshl + s_waitcnt + v_dual_mov + global_store_b64) to s_endpgm
        asm_s_load_b64(1, 0)                        // s[2:3] <- buf
        asm_s_load_b64_off(2, 0, 0x10)              // s[4:5] <- value f64
        asm_v_lshlrev_b32_imm(2, 3, 1)              // v2 = v1 << 3
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_dual_mov_b32_sx_sy(0, 1, 4, 5)        // v[0:1] = s[4:5]
        asm_global_store_b64(2, 0, 2)               // buf[gid] = v[0:1]
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;  unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;  unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp6 = args_desc + 48;  unsafe { *(adp6 as uint64) = 4 }
        uint64 adp7 = args_desc + 56;  unsafe { *(adp7 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 28
        sgpr_count   = 18
        n_args       = 4
    } else if is_grid_decay_shape != 0 {
        // M1j grid-decay shape: decay body with a grid-wide tid.
        //     gid = wg_id_x * bdim + threadIdx.x
        // bdim is supplied as an explicit 4th kernarg (u32) —
        // saves us from wiring up hidden-arg / dispatch-ptr reads
        // for this first pass at grid support.
        //
        // Keep rsrc2 = 0x9E (same as all prior native kernels).
        // That places wg_id_x at s15 per the 15-user-sgpr
        // convention clang also uses; s0..s1 stay as kernarg ptr,
        // s2/s4 hold loaded kernargs (b32 dests must be even-SGPR
        // aligned, so sdata_pair=1 → s2, sdata_pair=2 → s4).
        //
        //   s_clause 0x1
        //   s_load_b32 s2, s[0:1], 0x18    ; s2 = bdim
        //   s_load_b32 s4, s[0:1], 0x8     ; s4 = n
        //   s_waitcnt lgkmcnt(0)
        //   v_mad_u32_u24 v1, s2, s15, v0  ; v1 = bdim*wg_id_x + tid
        //   v_cmp_gt_u32_e32 vcc_lo, s4, v1
        //   s_and_saveexec_b32 s3, vcc_lo
        //   s_cbranch_execz 13             ; skip 13 dwords to s_endpgm
        //   s_load_b64 s[2:3], s[0:1], null
        //   v_lshlrev_b32 v2, 3, v1
        //   s_load_b64 s[0:1], s[0:1], 0x10
        //   s_waitcnt lgkmcnt(0)
        //   global_load_b64 v[0:1], v2, s[2:3]
        //   s_waitcnt vmcnt(0)
        //   v_fma_f64 v[0:1], -s[0:1], v[0:1], v[0:1]
        //   global_store_b64 v2, v[0:1], s[2:3]
        //   s_endpgm
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 0x18)                  // s2 = bdim
        asm_s_load_b32(2, 0, 0x8)                   // s4 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_mad_u32_u24(1, 2, 15, 0)              // v1 = s2 * s15 + v0
        asm_v_cmp_gt_u32_sgpr_vgpr(4, 1)            // vcc_lo = (s4 > v1)
        asm_s_and_saveexec_b32_vcc_lo(3)            // save EXEC in s3
        asm_s_cbranch_execz(13)
        asm_s_load_b64(1, 0)                        // s[2:3] <- buf
        asm_v_lshlrev_b32_imm(2, 3, 1)              // v2 = v1 << 3
        asm_s_load_b64_off(0, 0, 0x10)              // s[0:1] <- factor
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_load_b64(0, 2, 2)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fma_f64_neg_s_v_v(0, 0, 0, 0)
        asm_global_store_b64(2, 0, 2)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;  unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;  unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp6 = args_desc + 48;  unsafe { *(adp6 as uint64) = 4 }
        uint64 adp7 = args_desc + 56;  unsafe { *(adp7 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 28
        sgpr_count   = 18       // s0..s15 + slop — match clang's heuristic
        n_args       = 4
    } else if is_decay_shape != 0 {
        // M1h f64 decay shape — mirrors clang's gfx1100 output for:
        //   @kernel fn decay_step(uint64 buf, uint32 n, f64 factor) {
        //       if tid_x() < n {
        //           uint64 p = buf + tid_x() * 8
        //           f64 v = 0.0
        //           unsafe { *(p as f64) -> v }
        //           v = v - v * factor
        //           unsafe { *(p as f64) = v }
        //       }
        //   }
        //
        // 14 instructions, 76 bytes. Nested body details (the VarDecl
        // ladder and the fma-fused subtract) are trusted; the guard
        // + layout is what we actively match.
        asm_s_load_b32(1, 0, 8)                            // s2 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_cmp_gt_u32_sgpr_vgpr(2, 0)                   // vcc_lo = (s2 > v0)
        asm_s_and_saveexec_b32_vcc_lo(2)                   // save EXEC, mask
        asm_s_cbranch_execz(13)                            // skip 13 dwords to s_endpgm
        asm_s_load_b64(1, 0)                               // s[2:3] <- kernarg[0..7] (buf)
        asm_v_lshlrev_b32_imm(2, 3, 0)                     // v2 = tid*8
        asm_s_load_b64_off(0, 0, 0x10)                     // s[0:1] <- kernarg[0x10..0x17] (factor)
        asm_s_waitcnt_lgkmcnt_zero()
        // NB: FLAT/GLOBAL saddr is a raw SGPR index (not pair-
        // halved), so s[2:3] encodes as 2 here even though the SMEM
        // loaders above take pair indices.
        asm_global_load_b64(0, 2, 2)                       // v[0:1] = buf[tid]  (saddr=s[2:3])
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fma_f64_neg_s_v_v(0, 0, 0, 0)                // v[0:1] = -s[0:1]*v[0:1] + v[0:1]
        asm_global_store_b64(2, 0, 2)                      // buf[tid] = v[0:1]
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;  unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;  unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 24
        sgpr_count   = 6
        n_args       = 3
    } else if is_tid_guarded_shape != 0 {
        // Guarded per-thread shape (mirrors clang's gfx1100 output
        // for `if (i < n) { out[i] = i }`):
        //
        //   s_load_b32 s2, s[0:1], 0x8         ; load bound n
        //   s_waitcnt lgkmcnt(0)
        //   v_cmp_gt_u32_e32 vcc_lo, s2, v0    ; vcc_lo[lane] = (n > tid)
        //   s_and_saveexec_b32 s2, vcc_lo      ; mask inactive lanes
        //   s_cbranch_execz 6                  ; skip 6 dwords if none pass
        //   s_load_b64 s[0:1], s[0:1], null    ; load pointer
        //   v_lshlrev_b32 v1, 2, v0            ; v1 = tid*4
        //   s_waitcnt lgkmcnt(0)
        //   global_store_b32 v1, v0, s[0:1]
        //   s_endpgm
        asm_s_load_b32(1, 0, 8)                    // s2 <- kernarg[8] = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_cmp_gt_u32_sgpr_vgpr(2, 0)           // vcc_lo = (s2 > v0)
        asm_s_and_saveexec_b32_vcc_lo(2)           // save EXEC to s2, gate
        asm_s_cbranch_execz(6)                     // 6 dwords = 24 bytes
        asm_s_load_b64(0, 0)                       // s[0:1] <- kernarg[0..7]
        asm_v_lshlrev_b32_imm(1, 2, 0)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_store_b32(1, 0, 0)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 12
        sgpr_count   = 5       // s0..s4 (kernarg ptr + n + saved exec)
        n_args       = 2
    } else if is_tid_shape != 0 {
        // Per-thread shape: byte_offset = tid * 4, value = tid.
        //
        //   s_load_b64  s[0:1], s[0:1], null
        //   v_lshlrev_b32 v1, 2, v0               ; v1 = tid * 4
        //   s_waitcnt lgkmcnt(0)
        //   global_store_b32 v1, v0, s[0:1]       ; *(s[0:1] + v1) = v0
        //   s_endpgm
        asm_s_load_b64(0, 0)
        asm_v_lshlrev_b32_imm(1, 2, 0)             // vdst=v1, shift=2, src=v0
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_store_b32(1, 0, 0)              // v_addr=v1, v_data=v0, saddr_pair=0
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        kernarg_size = 8
        sgpr_count   = 2
        n_args       = 1
    } else if is_lit_shape != 0 {
        asm_s_load_b64(0, 0)
        asm_v_dual_mov_b32_mov_b32_lit(0, 1, lit32)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_store_b32(0, 1, 0)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        kernarg_size = 8
        sgpr_count   = 2
        n_args       = 1
    } else {
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 8)
        asm_s_load_b64(0, 0)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_dual_mov_b32_mov_b32_sgpr(0, 1, 2)
        asm_global_store_b32(0, 1, 0)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 12
        sgpr_count   = 3
        n_args       = 2
    }

    // Copy the just-assembled kernel text into a dedicated buffer —
    // the next kernel's asm_init() will otherwise clobber it.
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 vgpr_count_k = 2
    if is_decay_shape != 0       { vgpr_count_k = 3 }
    if is_grid_decay_shape != 0  { vgpr_count_k = 3 }
    if is_grid_fill_shape != 0   { vgpr_count_k = 3 }
    if is_grid_relax_shape != 0  { vgpr_count_k = 5 }  // v[0:1] v, v[2:3] diff, v4 byte off
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, n_args, kernarg_size,
            sgpr_count, vgpr_count_k,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}
