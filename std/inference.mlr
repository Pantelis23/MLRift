// MLRift Standard Library — Inference primitives
//
// Small building blocks shared between the Gemma probe harness
// (examples/gemma_probe.mlr) and any future engine that loads weights
// through std/safetensors.kr. Nothing here is Gemma-specific — the
// RMSNorm kernel applies the "weights + 1.0" convention because that
// is what Gemma uses, but callers targeting a different model can
// pass `w_ptr = 0` to skip the weight apply.
//
// Number-format conventions:
//   — Activations are f32, row-major, contiguous.
//   — Weights are BF16 row-major; we convert on the fly per element.
//     BF16 is literally the upper 16 bits of an IEEE-754 binary32, so
//     a BF16 value can be widened to f32 by placing its bytes in the
//     two high bytes of a 4-byte buffer and reading it as f32.
//
// Threading: matmul fan-out uses the std/thread.kr pool. Callers are
// responsible for `thread_pool_init(n)` before the first matmul and
// `thread_pool_shutdown()` once done.

import "safetensors.mlr"
import "thread.mlr"
import "math_float.mlr"
import "matmul.mlr"

// int-to-f32 helper: the compiler has int_to_f64 + f64_to_f32 as
// built-ins but a named wrapper makes callsites readable.
fn int_to_f32(u64 val) -> f32 {
    f64 d = int_to_f64(val)
    f32 f = f64_to_f32(d)
    return f
}

// BF16 -> F32 using a process-wide scratch slot. Called ~1.3 M times per
// 20-token Qwen3-0.6B decode from inside single-threaded helpers
// (qwen3_rmsnorm_bf16, qwen3_bf16_row_to_f32, embed_bf16_scaled_f32).
// The old per-call alloc(4)/dealloc(4) was ~2.6 M mmap/munmap syscalls
// per run and showed up as most of the user-CPU time left after the
// matmul went AVX2. The matmul workers inline their own BF16 decode so
// the static here is only written from serial code paths.
static u64 bf16_to_f32_scratch = 0

fn bf16_to_f32(u64 ptr) -> f32 {
    if bf16_to_f32_scratch == 0 {
        bf16_to_f32_scratch = alloc(4)
        u8 z = 0
        store8(bf16_to_f32_scratch + 0, z)
        store8(bf16_to_f32_scratch + 1, z)
    }
    u64 tp = bf16_to_f32_scratch
    u8 b0u = load8(ptr)
    u8 b1u = load8(ptr + 1)
    store8(tp + 2, b0u)
    store8(tp + 3, b1u)
    f32 val = 0.0f
    unsafe { *(tp as f32) -> val }
    return val
}

// Gemma RMSNorm over a [dim] f32 activation. If `w_ptr` is non-zero
// the normalised row is scaled by `(1 + w)` element-wise, where `w`
// is a BF16 weight row (`dim` BF16 elements). If `w_ptr == 0` the
// weight apply is skipped and the output is the plain unit-norm row.
fn rmsnorm_bf16_weights_f32(u64 out_ptr, u64 in_ptr, u64 w_ptr, u64 dim) {
    f32 sum_sq = 0.0f
    u64 i = 0
    while i < dim {
        f32 val = 0.0f
        unsafe { *((in_ptr + i * 4) as f32) -> val }
        sum_sq = sum_sq + val * val
        i = i + 1
    }

    f32 f_dim = int_to_f32(dim)
    f32 mean_sq = sum_sq / f_dim

    // eps = 1e-6f expressed as its binary32 bit pattern.
    uint64[1] eps_tmp
    u64 ep = eps_tmp
    u8 e0 = 0x61
    u8 e1 = 0x18
    u8 e2 = 0x86
    u8 e3 = 0x35
    store8(ep + 0, e0)
    store8(ep + 1, e1)
    store8(ep + 2, e2)
    store8(ep + 3, e3)
    f32 eps = 0.0f
    unsafe { *(ep as f32) -> eps }

    f32 denom = sqrt_f32(mean_sq + eps)
    f32 one = 1.0f
    f32 rsqrt = one / denom

    i = 0
    while i < dim {
        f32 val = 0.0f
        unsafe { *((in_ptr + i * 4) as f32) -> val }
        f32 w = 0.0f
        if w_ptr != 0 {
            w = bf16_to_f32(w_ptr + i * 2)
        }
        // Gemma: normalise by the row's RMS, then scale by (1 + w).
        f32 final_val = (val * rsqrt) * (one + w)
        unsafe { *((out_ptr + i * 4) as f32) = final_val }
        i = i + 1
    }
}

// Legacy Kahan-on matmul entry, forwarded to the new std/matmul.mlr
// library. The real implementation lives there; this wrapper preserves
// the existing callers (examples/qwen3_forward.mlr,
// examples/qwen3_generate.mlr, std/qwen3.mlr) while the perf work lands.
fn matmul_bf16_weights_f32_mt(u64 out_ptr, u64 x_ptr, u64 w_ptr,
                              u64 M, u64 N, u64 K, u64 num_workers) {
    matmul_bf16_weights_f32(out_ptr, x_ptr, w_ptr, M, N, K, num_workers, 1)
}

// Embed-and-scale: copy the `token_id`-th row out of a BF16 embedding
// matrix into an f32 activation buffer, multiplying by `scale`. Gemma
// uses `scale = sqrt(hidden_dim)`; other models can pass 1.0f.
fn embed_bf16_scaled_f32(u64 out_ptr, u64 embed_ptr,
                         u64 token_id, u64 hidden_dim, f32 scale) {
    u64 row = embed_ptr + token_id * hidden_dim * 2
    u64 i = 0
    while i < hidden_dim {
        f32 v = bf16_to_f32(row + i * 2)
        v = v * scale
        unsafe { *((out_ptr + i * 4) as f32) = v }
        i = i + 1
    }
}
