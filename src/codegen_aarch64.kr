        // User-defined function call
        uint32 arg = ast_child(node)
        uint64 warg = arg
        uint64 arg_count = 0
        uint64 wtmp = arg
        while wtmp != 0 {
            arg_count = arg_count + 1
            uint32 nt2 = ast_next(wtmp)
            wtmp = nt2
        }

        // Allocate temp slots for args
        uint64 arg_slots_base = var_count * 8
        uint64 ac = 0
        while ac < arg_count {
            var_count = var_count + 1
            ac = ac + 1
        }
        var_frame_size = var_count * 8
        uint64 acrem = var_frame_size & 15
        if acrem != 0 { var_frame_size = var_frame_size + 16 - acrem }

        // Evaluate all args and store to temp slots.
        // Track which args are float (0=int, 1=f64, 2=f32).
        uint64[16] arg_float_flags_a
        // Track which args are structs (0xFFFFFFFF = not struct, else struct index)
        uint64[16] arg_struct_flags_a
        uint64 asfi_a = 0
        while asfi_a < 16 {
            uint64 asf_init = arg_struct_flags_a + asfi_a * 8
            uint64 none_val_a = 0xFFFFFFFF
            unsafe { *(asf_init as uint64) = none_val_a }
            asfi_a = asfi_a + 1
        }
        uint64 weval = warg
        uint64 ai = 0
        while weval != 0 {
            gen_expr_a64(weval)
            uint64 aslot = arg_slots_base + ai * 8
            uint64 aff_addr_a = arg_float_flags_a + ai * 8
            if expr_is_float_a64 != 0 {
                // Store float result from d0 to temp slot
                emit_a64_store_d0(aslot)
                unsafe { *(aff_addr_a as uint64) = expr_is_float_a64 }
            } else {
                emit_a64_store_x0(aslot)
                uint64 zero_af = 0
                unsafe { *(aff_addr_a as uint64) = zero_af }
            }
            // Record struct flag for this arg
            uint64 asf_addr_a = arg_struct_flags_a + ai * 8
            uint64 struct_val_a = expr_is_struct_a64
            unsafe { *(asf_addr_a as uint64) = struct_val_a }
            ai = ai + 1
            uint32 anxt = ast_next(weval)
            weval = anxt
        }

        // Load args into registers from temp slots
        // AAPCS64: int args → x0-x7 (independent counter)
        //          float args → d0-d7 (independent counter)
        //          HFA struct args → consecutive d/s registers
        uint64 call_float_idx = 0
        uint64 fi_a = 0
        while fi_a < arg_count {
            uint64 ff_addr_a = arg_float_flags_a + fi_a * 8
            uint64 ff_val_a = 0
            unsafe { *(ff_addr_a as uint64) -> ff_val_a }
            if ff_val_a != 0 && call_float_idx < 8 {
                emit_a64_load_dN(call_float_idx, arg_slots_base + fi_a * 8)
                call_float_idx = call_float_idx + 1
            } else if ff_val_a == 0 {
                // Check if this is an HFA struct arg
                uint64 hfa_saf_addr = arg_struct_flags_a + fi_a * 8
                uint64 hfa_saf_val = 0
                unsafe { *(hfa_saf_addr as uint64) -> hfa_saf_val }
                if hfa_saf_val != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                    uint64 hfa_sflags = struct_abi_flags(hfa_saf_val)
                    uint64 hfa_is = hfa_sflags & 1
                    if hfa_is != 0 {
                        uint64 hfa_count = ((hfa_sflags >> 1) & 3) + 1
                        uint64 hfa_type = (hfa_sflags >> 3) & 3
                        // Load struct pointer from temp slot
                        emit_a64_load_x0(arg_slots_base + fi_a * 8)
                        // Load each field into consecutive d/s registers
                        uint64 hi = 0
                        while hi < hfa_count && call_float_idx < 8 {
                            if hfa_type == 1 {
                                uint64 hoff = hi * 8
                                emit_a64_load_dN_from_ptr(call_float_idx, 0, hoff)
                            } else {
                                uint64 hoff = hi * 4
                                emit_a64_load_sN_from_ptr(call_float_idx, 0, hoff)
                            }
                            call_float_idx = call_float_idx + 1
                            hi = hi + 1
                        }
                    }
                }
            }
            fi_a = fi_a + 1
        }
        // Second pass: load integer args into x0-x7
        uint64 call_int_idx = 0
        uint64 ii_a = 0
        while ii_a < arg_count && call_int_idx < 8 {
            uint64 fi_addr_a = arg_float_flags_a + ii_a * 8
            uint64 fi_val_a = 0
            unsafe { *(fi_addr_a as uint64) -> fi_val_a }
            if fi_val_a == 0 {
                // Check if this is a struct arg
                uint64 saf_addr_c = arg_struct_flags_a + ii_a * 8
                uint64 saf_val_c = 0
                unsafe { *(saf_addr_c as uint64) -> saf_val_c }
                if saf_val_c != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                    // Skip HFA structs — they were handled in the float pass
                    uint64 sflags_skip = struct_abi_flags(saf_val_c)
                    uint64 is_hfa_skip = sflags_skip & 1
                    if is_hfa_skip != 0 {
                        ii_a = ii_a + 1
                        continue
                    }
                    // Struct arg: load eightbytes into consecutive x registers
                    uint64 s_ssize_c = struct_total_size(saf_val_c)
                    if s_ssize_c > 16 {
                        // MEMORY class (>16 bytes): pass pointer in next x register
                        emit_a64_load_x0(arg_slots_base + ii_a * 8)
                        if call_int_idx != 0 {
                            emit_a64_mov(call_int_idx, 0)
                        }
                        call_int_idx = call_int_idx + 1
                    } else {
                    // Load struct pointer from temp slot
                    emit_a64_load_x0(arg_slots_base + ii_a * 8)
                    // Save pointer to temp_slot_0 since loading might clobber it
                    emit_a64_store_x0(temp_slot_0)
                    // Load first eightbyte: ldr xN, [x0, #0]
                    if call_int_idx == 0 {
                        emit_a64_ldr(0, 0, 0)
                    } else {
                        emit_a64_ldr(call_int_idx, 0, 0)
                    }
                    call_int_idx = call_int_idx + 1
                    if s_ssize_c > 8 && call_int_idx < 8 {
                        // Reload pointer from temp
                        emit_a64_load_x0(temp_slot_0)
                        // Load second eightbyte: ldr xN, [x0, #8]
                        emit_a64_ldr(call_int_idx, 0, 8)
                        call_int_idx = call_int_idx + 1
                    }
                    }
                } else {
                    emit_a64_load_x0(arg_slots_base + ii_a * 8)
                    if call_int_idx != 0 {
                        emit_a64_mov(call_int_idx, 0)
                    }
                    call_int_idx = call_int_idx + 1
                }
            }
            ii_a = ii_a + 1
        }
        // Reload x0 from first int arg slot if it was overwritten
        if call_int_idx > 1 {
            // Find the first integer arg and reload it
            uint64 ri_a = 0
            while ri_a < arg_count {
                uint64 ri_addr = arg_float_flags_a + ri_a * 8
                uint64 ri_val = 0
                unsafe { *(ri_addr as uint64) -> ri_val }
                if ri_val == 0 {
                    // Check if first int arg is a struct — reload eightbyte 0
                    uint64 ri_saf = arg_struct_flags_a + ri_a * 8
                    uint64 ri_sv = 0
                    unsafe { *(ri_saf as uint64) -> ri_sv }
                    if ri_sv != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                        // Skip HFA structs — they don't use int regs
                        uint64 ri_hfa_flags = struct_abi_flags(ri_sv)
                        if (ri_hfa_flags & 1) != 0 {
                            ri_a = ri_a + 1
                            continue
                        }
                        uint64 ri_ss = struct_total_size(ri_sv)
                        if ri_ss > 16 {
                            // MEMORY class: pointer is the value to pass
                            emit_a64_load_x0(arg_slots_base + ri_a * 8)
                        } else {
                        // Struct: reload ptr and dereference
                        emit_a64_load_x0(arg_slots_base + ri_a * 8)
                        emit_a64_ldr(0, 0, 0)
                        }
                    } else {
                        emit_a64_load_x0(arg_slots_base + ri_a * 8)
                    }
                    break
                }
                ri_a = ri_a + 1
            }
        }

        // Push overflow args (9+) onto stack (AAPCS64: x0-x7 = first 8 args)
        uint64 stack_args = 0
        if arg_count > 8 {
            stack_args = arg_count - 8
            if (stack_args & 1) != 0 { stack_args = stack_args + 1 }
        }
        if stack_args > 0 {
            uint64 stack_bytes = stack_args * 8
            // sub sp, sp, #stack_bytes
            uint64 sub_insn = 0xD1000000 | (stack_bytes << 10) | (31 << 5) | 31
            emit_a64(sub_insn)
            // Store overflow args at [sp+0], [sp+8], ...
            uint64 real_overflow = arg_count - 8
            uint64 oi = 0
            while oi < real_overflow {
                // Load from temp slot (offset shifted by stack_bytes because sp moved)
                emit_a64_ldr(9, 31, a64_var_base + arg_slots_base + (8 + oi) * 8 + stack_bytes)
                emit_a64_str(9, 31, oi * 8)
                oi = oi + 1
            }
        }

        // If callee returns MEMORY-class struct, allocate sret area and load x8
        uint64 caller_sret_needed_a = 0
        uint64 caller_sret_area_a = 0
        uint64 caller_sret_si_a = fn_ret_struct_lookup(callee_tok)
        if caller_sret_si_a != 0xFFFFFFFF {
            uint64 caller_sret_c0_a = struct_abi_class0(caller_sret_si_a)
            if caller_sret_c0_a == 3 {
                caller_sret_needed_a = 1
                uint64 caller_ret_sz_a = struct_total_size(caller_sret_si_a)
                uint64 caller_ret_sl_a = (caller_ret_sz_a + 7) / 8
                caller_sret_area_a = var_count * 8
                uint64 csi_a = 0
                while csi_a < caller_ret_sl_a { var_count = var_count + 1; csi_a = csi_a + 1 }
                var_frame_size = var_count * 8
                uint64 csrem_a = var_frame_size & 15
                if csrem_a != 0 { var_frame_size = var_frame_size + 16 - csrem_a }
                // Load x8 = address of sret area on stack
                emit_a64_add_imm(8, 31, a64_var_base + caller_sret_area_a)
            }
        }

        // BL rel26 (placeholder, fixup needed)
        uint64 fixup_off = out_len
        emit_a64_bl(0)

        // Clean up overflow args from stack
        if stack_args > 0 {
            uint64 cleanup = stack_args * 8
            uint64 add_insn = 0x91000000 | (cleanup << 10) | (31 << 5) | 31
            emit_a64(add_insn)
        }

        // Set expr_is_float_a64 based on callee's return type
        uint64 wct_ret_a = callee_tok
        uint64 ret_fk_a = fn_ret_float_lookup(wct_ret_a)
        expr_is_float_a64 = ret_fk_a

        // Check if callee returns a struct
        uint64 ret_struct_si_a = fn_ret_struct_lookup(callee_tok)
        if ret_struct_si_a != 0xFFFFFFFF {
            uint64 ret_c0_caller_a = struct_abi_class0(ret_struct_si_a)
            if ret_c0_caller_a == 3 {
                // MEMORY class: data already written to caller_sret_area_a by callee
                // Point x0 at the sret area
                emit_a64_add_imm(0, 31, a64_var_base + caller_sret_area_a)
                expr_is_struct_a64 = ret_struct_si_a
            } else {
                // Check if this is an HFA return
                uint64 ret_sflags_c = struct_abi_flags(ret_struct_si_a)
                uint64 ret_is_hfa_c = ret_sflags_c & 1
                uint64 ret_ssize_a = struct_total_size(ret_struct_si_a)
                uint64 ret_sslots_a = (ret_ssize_a + 7) / 8
                uint64 ret_soff_a = var_count * 8
                uint64 rsi2_a = 0
                while rsi2_a < ret_sslots_a { var_count = var_count + 1; rsi2_a = rsi2_a + 1 }
                var_frame_size = var_count * 8
                uint64 rsrem_a = var_frame_size & 15
                if rsrem_a != 0 { var_frame_size = var_frame_size + 16 - rsrem_a }
                if ret_is_hfa_c != 0 {
                    // HFA return: store d/s registers into stack area
                    uint64 ret_hfa_count_c = ((ret_sflags_c >> 1) & 3) + 1
                    uint64 ret_hfa_type_c = (ret_sflags_c >> 3) & 3
                    uint64 rci = 0
                    while rci < ret_hfa_count_c {
                        if ret_hfa_type_c == 1 {
                            uint64 rcoff = rci * 8
                            emit_a64_store_dN(rci, ret_soff_a + rcoff)
                        } else {
                            uint64 rcoff = rci * 4
                            emit_a64_store_sN(rci, ret_soff_a + rcoff)
                        }
                        rci = rci + 1
                    }
                } else {
                // Eightbyte 0: store from x0
                emit_a64_str(0, 31, a64_var_base + ret_soff_a)
                if ret_ssize_a > 8 {
                    // Eightbyte 1: store from x1
                    emit_a64_str(1, 31, a64_var_base + ret_soff_a + 8)
                }
                }
                // Set x0 = pointer to struct area
                emit_a64_add_imm(0, 31, a64_var_base + ret_soff_a)
                expr_is_struct_a64 = ret_struct_si_a
            }
        }

        // If the callee is an extern fn, record a call site for a linker
        // relocation and skip the internal fixup (the BL's imm26 stays zero
        // until the linker patches it with R_AARCH64_CALL26).
        uint64 wct_ext_a = callee_tok
        uint64 ext_idx_a = extern_fn_lookup(wct_ext_a)
        if ext_idx_a != 0xFFFFFFFF {
            extern_call_record(fixup_off, ext_idx_a)
            return
        }

        // Record fixup (same table as x86_64 — resolve_fixups handles both)
        uint64 fentry = fixup_table + fixup_count * 8
        uint32 fo = fixup_off
        unsafe { *(fentry as uint32) = fo }
        uint64 fe4 = fentry + 4
        uint32 ct = callee_tok
        unsafe { *(fe4 as uint32) = ct }
        fixup_count = fixup_count + 1
        return
    }
}

// ---------------------------------------------------------------------------
// AArch64 statement codegen
// ---------------------------------------------------------------------------

fn gen_stmt_a64(uint64 node) {
    uint32 dbg_tok_sa = ast_tok(node)
    if dbg_tok_sa == 0 { dbg_tok_sa = ast_data1(node) }
    if dbg_tok_sa == 0 { dbg_tok_sa = ast_data2(node) }
    uint64 wdbg_sa = dbg_tok_sa
    if wdbg_sa != 0 { line_table_record(wdbg_sa) }

    uint32 kind = ast_kind(node)

    // Variable declaration
    if kind == 10 {
        uint32 name_tok = ast_data2(node)
        uint32 arr_size_tok = ast_data3(node)
        uint64 was = arr_size_tok
        uint32 struct_marker = ast_data4(node)
        uint64 wsm = struct_marker
        if was != 0 && wsm == 0 {
            uint64 arr_size = parse_int_token(was)
            uint32 type_tok_v = ast_data1(node)
            uint64 elem_size_v = type_tok_elem_size(type_tok_v)
            uint64 total_bytes = arr_size * elem_size_v
            uint64 n_slots = (total_bytes + 7) / 8
            uint64 arr_offset = var_count * 8
            uint64 si = 0
            while si < n_slots { var_count = var_count + 1; si = si + 1 }
            var_frame_size = var_count * 8
            uint64 arem2 = var_frame_size & 15
            if arem2 != 0 { var_frame_size = var_frame_size + 16 - arem2 }
            uint64 ptr_offset = var_declare(name_tok)
            arr_elem_register(name_tok, elem_size_v)
            arr_count_set_last(arr_size)
            emit_a64_add_imm(0, 31, a64_var_base + arr_offset)
            emit_a64_store_x0(ptr_offset)
            return
        }
        if wsm != 0 {
            uint64 sidx = wsm - 1
            // Struct initializer form: `StructName n = expr`
            uint32 sinit_a = ast_child(node)
            uint64 wsinit_a = sinit_a
            if wsinit_a != 0 && was == 0 {
                gen_expr_a64(wsinit_a)
                if expr_is_struct_a64 != 0xFFFFFFFF {
                    // Value semantics: copy struct to own stack area
                    uint64 copy_size_a = struct_total_size(sidx)
                    uint64 copy_slots_a = (copy_size_a + 7) / 8
                    uint64 copy_off_a = var_count * 8
                    uint64 csi_a = 0
                    while csi_a < copy_slots_a {
                        var_count = var_count + 1
                        csi_a = csi_a + 1
                    }
                    var_frame_size = var_count * 8
                    uint64 crem_a = var_frame_size & 15
                    if crem_a != 0 { var_frame_size = var_frame_size + 16 - crem_a }
                    // x0 = source pointer, save it
                    emit_a64_store_x0(temp_slot_0)
                    // Inline copy: qword-at-a-time
                    uint64 qi_a = 0
                    while qi_a < copy_slots_a {
                        emit_a64_load_x0(temp_slot_0)
                        uint64 qoff_a = qi_a * 8
                        // ldr x9, [x0, #qoff]
                        emit_a64_ldr(9, 0, qoff_a)
                        // str x9, [sp, #(a64_var_base + copy_off + qoff)]
                        emit_a64_str(9, 31, a64_var_base + copy_off_a + qoff_a)
                        qi_a = qi_a + 1
                    }
                    // Variable points to local copy
                    uint64 ptr_off_h = var_declare(name_tok)
                    emit_a64_add_imm(0, 31, a64_var_base + copy_off_a)
                    emit_a64_store_x0(ptr_off_h)
                    struct_var_register(name_tok, sidx)
                    expr_is_struct_a64 = 0xFFFFFFFF
                    return
                }
                // Non-struct init (heap pointer): just store
                uint64 ptr_off_h = var_declare(name_tok)
                emit_a64_store_x0(ptr_off_h)
                struct_var_register(name_tok, sidx)
                return
            }
            uint64 ssize = struct_total_size(sidx)
            // Struct array support: count from data3 (if set)
            uint64 count = 1
            if was != 0 { count = parse_int_token(was) }
            uint64 total_bytes = ssize * count
            uint64 n_slots = (total_bytes + 7) / 8
            uint64 struct_off = var_count * 8
            uint64 ssi = 0
            while ssi < n_slots { var_count = var_count + 1; ssi = ssi + 1 }
            var_frame_size = var_count * 8
            uint64 srem = var_frame_size & 15
            if srem != 0 { var_frame_size = var_frame_size + 16 - srem }
            uint64 ptr_off = var_declare(name_tok)
            emit_a64_add_imm(0, 31, a64_var_base + struct_off)
            emit_a64_store_x0(ptr_off)
            struct_var_register(name_tok, sidx)
            return
        }
        uint64 offset = var_declare(name_tok)
        uint32 type_tok_vd = ast_data1(node)
        uint64 wtype_a = tok_kind_at_raw(type_tok_vd)
        var_type_register(name_tok, wtype_a)
        uint32 init_child = ast_child(node)
        uint64 wic = init_child
        if wic != 0 {
            gen_expr_a64(wic)
            if is_float_type(wtype_a) != 0 {
                if is_f32_type(wtype_a) != 0 {
                    emit_a64_store_s0(offset)
                } else {
                    emit_a64_store_d0(offset)
                }
            } else {
                emit_a64_store_x0(offset)
            }
        }
        return
    }

    // Assignment
    if kind == 11 {
        uint32 name_tok = ast_data1(node)
        uint32 val_child = ast_child(node)
        uint64 wvc = val_child
        gen_expr_a64(wvc)
        // Struct assignment: copy bytes for value semantics
        if expr_is_struct_a64 != 0xFFFFFFFF {
            uint64 src_si_a = expr_is_struct_a64
            uint64 copy_size_as = struct_total_size(src_si_a)
            uint64 copy_slots_as = (copy_size_as + 7) / 8
            // x0 = source pointer, save it
            emit_a64_store_x0(temp_slot_0)
            // Get dest pointer from variable
            uint64 dest_off_as = var_lookup(name_tok)
            emit_a64_load_x0(dest_off_as)
            emit_a64_store_x0(temp_slot_1)
            // Copy qword-at-a-time
            uint64 qi_as = 0
            while qi_as < copy_slots_as {
                emit_a64_load_x0(temp_slot_0)
                uint64 qoff_as = qi_as * 8
                // ldr x9, [x0, #qoff]
                emit_a64_ldr(9, 0, qoff_as)
                emit_a64_load_x0(temp_slot_1)
                // str x9, [x0, #qoff]
                emit_a64_str(9, 0, qoff_as)
                qi_as = qi_as + 1
            }
            expr_is_struct_a64 = 0xFFFFFFFF
            return
        }
        uint64 offset = var_lookup(name_tok)
        if offset != 0xFFFFFFFF {
            // Check if this variable is float-typed
            uint64 vtype_as = var_type_lookup(name_tok)
            if is_float_type(vtype_as) != 0 {
                if is_f32_type(vtype_as) != 0 {
                    emit_a64_store_s0(offset)
                } else {
                    emit_a64_store_d0(offset)
                }
            } else {
                emit_a64_store_x0(offset)
            }
        } else {
            uint64 soff = static_lookup(name_tok)
            if soff != 0xFFFFFFFF {
                emit_a64_static_store(soff)
            }
        }
        return
    }

    // Return
    if kind == 12 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        uint32 second_idx_r = ast_data3(node)
        uint64 wsi_r = second_idx_r
        uint32 third_idx_r = ast_data4(node)
        uint64 wti_r = third_idx_r
        if wti_r != 0 && wsi_r != 0 {
            // 3-tuple return: first → x0, second → x1, third → x2
            gen_expr_a64(wec)
            emit_a64_str(0, 31, a64_var_base + temp_slot_0)
            gen_expr_a64(wsi_r)
            emit_a64_str(0, 31, a64_var_base + temp_slot_1)
            gen_expr_a64(wti_r)
            emit_a64(0xAA0003E2)          // mov x2, x0  (ORR x2, xzr, x0)
            // Reload second → x1
            emit_a64_ldr(0, 31, a64_var_base + temp_slot_1)
            emit_a64(0xAA0003E1)          // mov x1, x0  (ORR x1, xzr, x0)
            // Reload first → x0
            emit_a64_ldr(0, 31, a64_var_base + temp_slot_0)
        } else if wsi_r != 0 {
            // 2-tuple return: evaluate first into x0, stash in temp_slot_0,
            // evaluate second into x0, move to x1, reload first into x0.
            // On AAPCS64 x1 is a caller-saved arg/return reg so it flows
            // unchanged through the epilogue to the caller.
            gen_expr_a64(wec)
            emit_a64_str(0, 31, a64_var_base + temp_slot_0)
            gen_expr_a64(wsi_r)
            emit_a64(0xAA0003E1)          // mov x1, x0  (ORR x1, xzr, x0)
            emit_a64_ldr(0, 31, a64_var_base + temp_slot_0)
        } else if wec != 0 {
            gen_expr_a64(wec)
            // Struct return: load eightbytes or copy via sret
            if expr_is_struct_a64 != 0xFFFFFFFF {
                uint64 ret_si_ar = expr_is_struct_a64
                uint64 ret_sz_ar = struct_total_size(ret_si_ar)
                uint64 ret_c0_ar = struct_abi_class0(ret_si_ar)
                if ret_c0_ar == 3 {
                    // MEMORY class: copy struct data to sret buffer [x8]
                    // x0 = source pointer (from gen_expr)
                    emit_a64_mov(9, 0)    // x9 = source
                    // Load saved sret pointer from stack
                    emit_a64_ldr(10, 31, a64_var_base + sret_slot_a64) // x10 = dest (sret)
                    // qword copy loop
                    uint64 aqi_ret = 0
                    uint64 aqslots_ret = (ret_sz_ar + 7) / 8
                    while aqi_ret < aqslots_ret {
                        uint64 aqoff_ret = aqi_ret * 8
                        emit_a64_ldr(11, 9, aqoff_ret)   // x11 = [src + off]
                        emit_a64_str(11, 10, aqoff_ret)   // [dest + off] = x11
                        aqi_ret = aqi_ret + 1
                    }
                } else {
                    // Check if this is an HFA return
                    uint64 ret_sflags = struct_abi_flags(ret_si_ar)
                    uint64 ret_is_hfa = ret_sflags & 1
                    if ret_is_hfa != 0 {
                        // HFA return: load fields into consecutive d/s registers
                        uint64 ret_hfa_count = ((ret_sflags >> 1) & 3) + 1
                        uint64 ret_hfa_type = (ret_sflags >> 3) & 3
                        // x0 = pointer to struct data
                        emit_a64_mov(9, 0)
                        uint64 rhi = 0
                        while rhi < ret_hfa_count {
                            if ret_hfa_type == 1 {
                                uint64 rhoff = rhi * 8
                                emit_a64_load_dN_from_ptr(rhi, 9, rhoff)
                            } else {
                                uint64 rhoff = rhi * 4
                                emit_a64_load_sN_from_ptr(rhi, 9, rhoff)
                            }
                            rhi = rhi + 1
                        }
                    } else {
                    // Small struct: load eightbytes from pointer into x0/x1
                    // x0 = pointer to struct data
                    emit_a64_mov(9, 0)
                    // Load first eightbyte into x0
                    emit_a64_ldr(0, 9, 0)
                    if ret_sz_ar > 8 {
                        // Load second eightbyte into x1
                        emit_a64_ldr(1, 9, 8)
                    }
                    }
                }
                expr_is_struct_a64 = 0xFFFFFFFF
            }
        }
        // Jump to epilogue
        emit_a64_b(0)
        uint64 ret_patch = out_len - 4
        uint64 rentry = ret_fixups + ret_fixup_count * 4
        uint32 rp32 = ret_patch
        unsafe { *(rentry as uint32) = rp32 }
        ret_fixup_count = ret_fixup_count + 1
        return
    }

    // TupleDestruct: (T1 a, T2 b) = rhs_expr
    // Mirrors the x86_64 path: the RHS leaves (x0, x1) from a tuple call.
    if kind == 44 {
        uint32 name1_tok = ast_data2(node)
        uint32 name2_tok = ast_data4(node)
        uint64 off1 = var_declare(name1_tok)
        uint64 off2 = var_declare(name2_tok)
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 {
            gen_expr_a64(wrhs)
            // Store x1 (second) first so the x0 caching isn't needed;
            // then store x0 (first) into slot 1.
            emit_a64_str(1, 31, a64_var_base + off2)
            emit_a64_store_x0(off1)
        }
        return
    }

    // TupleDestruct3: (T1 a, T2 b, T3 c) = rhs_expr
    if kind == 47 {
        uint32 name1_tok = ast_data2(node)
        uint32 name2_tok = ast_data4(node)
        uint32 name3_tok = ast_tok(node)
        uint64 off1 = var_declare(name1_tok)
        uint64 off2 = var_declare(name2_tok)
        uint64 off3 = var_declare(name3_tok)
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 {
            gen_expr_a64(wrhs)
            // Store x2 (third) → slot3
            emit_a64_str(2, 31, a64_var_base + off3)
            // Store x1 (second) → slot2
            emit_a64_str(1, 31, a64_var_base + off2)
            // Store x0 (first) → slot1
            emit_a64_store_x0(off1)
        }
        return
    }

    // If/else
    if kind == 13 {
        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr_a64(wcond)
        // cbz x0, else_target (placeholder)
        uint64 cbz_patch = out_len
        emit_a64_cbz(0, 0)
        // Then body
        uint32 then_idx = ast_data1(node)
        uint64 wthen = then_idx
        gen_block_a64(wthen)
        // b endif (placeholder)
        uint64 b_patch = out_len
        emit_a64_b(0)
        // Patch cbz to here
        uint64 else_target = out_len
        uint64 cbz_disp = else_target - cbz_patch
        patch_u32(cbz_patch, 0xB4000000 | (((cbz_disp / 4) & 0x7FFFF) << 5) | 0)
        // Else body
        uint32 else_idx = ast_data2(node)
        uint64 welse = else_idx
        if welse != 0 {
            uint32 else_kind = ast_kind(welse)
            if else_kind == 13 {
                gen_stmt_a64(welse)
            } else {
                gen_block_a64(welse)
            }
        }
        // Patch b to here
        uint64 endif_target = out_len
        uint64 b_disp = endif_target - b_patch
        patch_u32(b_patch, 0x14000000 | ((b_disp / 4) & 0x3FFFFFF))
        return
    }

    // Block: nested block of statements (used by for-loop desugaring)
    if kind == 15 {
        gen_block_a64(node)
        return
    }

    // While
    if kind == 14 {
        uint64 loop_start = out_len
        uint64 lentry = loop_stack + loop_depth * 16
        unsafe { *(lentry as uint64) = loop_start }
        uint64 lentry8 = lentry + 8
        unsafe { *(lentry8 as uint64) = break_fixup_count }
        loop_depth = loop_depth + 1

        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr_a64(wcond)
        uint64 cbz_patch = out_len
        emit_a64_cbz(0, 0)
        uint32 body_idx = ast_data1(node)
        uint64 wbody = body_idx
        gen_block_a64(wbody)
        // b loop_start
        uint64 back_disp = loop_start - out_len
        emit_a64_b(back_disp & 0xFFFFFFFF)
        // Patch cbz to here
        uint64 loop_end = out_len
        uint64 fwd_disp = loop_end - cbz_patch
        patch_u32(cbz_patch, 0xB4000000 | (((fwd_disp / 4) & 0x7FFFF) << 5) | 0)
        // Patch break fixups
        loop_depth = loop_depth - 1
        uint64 lentry2 = loop_stack + loop_depth * 16 + 8
        uint64 saved_break_start = 0
        unsafe { *(lentry2 as uint64) -> saved_break_start }
        uint64 bi = saved_break_start
        while bi < break_fixup_count {
            uint64 bentry = break_fixups + bi * 4
            uint32 bpatch = 0
            unsafe { *(bentry as uint32) -> bpatch }
            uint64 wbp = bpatch
            uint64 bdisp = loop_end - wbp
            patch_u32(wbp, 0x14000000 | ((bdisp / 4) & 0x3FFFFFF))
            bi = bi + 1
        }
        break_fixup_count = saved_break_start
        return
    }

    // Break
    if kind == 17 {
        uint64 brk_off = out_len
        emit_a64_b(0)
        uint64 brk_entry = break_fixups + break_fixup_count * 4
        uint32 brk32 = brk_off
        unsafe { *(brk_entry as uint32) = brk32 }
        break_fixup_count = break_fixup_count + 1
        return
    }

    // Continue
    if kind == 18 {
        uint64 lentry3 = loop_stack + (loop_depth - 1) * 16
        uint64 cont_target = 0
        unsafe { *(lentry3 as uint64) -> cont_target }
        uint64 cont_disp = cont_target - out_len
        emit_a64_b(cont_disp & 0xFFFFFFFF)
        return
    }

    // Match statement
    if kind == 19 {
        uint32 scrutinee = ast_child(node)
        uint64 wscr = scrutinee
        gen_expr_a64(wscr)
        uint64 match_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 mrem = var_frame_size & 15
        if mrem != 0 { var_frame_size = var_frame_size + 16 - mrem }
        emit_a64_store_x0(match_temp)
        uint64 saved_break = break_fixup_count
        uint32 arm_idx = ast_data1(node)
        uint64 warm = arm_idx
        while warm != 0 {
            uint32 val_idx = ast_data1(warm)
            uint64 wval = val_idx
            uint64 is_wild = 0
            uint32 vk = ast_kind(wval)
            if vk == 32 {
                uint32 wild_tok = ast_data1(wval)
                uint64 wwt = wild_tok
                if tok_matches(wwt, "_", 1) != 0 { is_wild = 1 }
            }
            // For multi-pattern arms (p1, p2, p3 => ...) we emit a chain
            // of B.EQ body-label jumps, then a single B skip_arm for the
            // fall-through (no pattern matched). Capture the body-jumps
            // to patch after body emission.
            uint64 beq_patches = 0
            uint64 beq_count = 0
            uint64 skip_patch = 0
            if is_wild == 0 {
                beq_patches = alloc(64)
                uint64 pat = wval
                while pat != 0 {
                    uint32 pat_k_raw = ast_kind(pat)
                    uint64 pat_k = pat_k_raw
                    if pat_k == 52 {
                        write(2, "error: range patterns require the IR backend (drop --legacy)\n", 62)
                        exit(1)
                    }
                    gen_expr_a64(pat)
                    emit_a64_mov(9, 0)
                    emit_a64_load_x0(match_temp)
                    emit_a64_cmp(0, 9)
                    // B.EQ body (placeholder — cond = 0 = EQ)
                    uint64 beq_p = out_len
                    emit_a64(0x54000000)   // B.EQ +0 (patched)
                    uint64 slot = beq_patches + beq_count * 8
                    unsafe { *(slot as uint64) = beq_p }
                    beq_count = beq_count + 1
                    uint32 pnxt = ast_next(pat)
                    pat = pnxt
                }
                // None matched → jump to skip_arm.
                skip_patch = out_len
                emit_a64(0x14000000)   // B +0 (patched)
            }
            // Body label: patch every B.EQ to land here.
            uint64 body_addr = out_len
            uint64 ji = 0
            while ji < beq_count {
                uint64 slot = beq_patches + ji * 8
                uint64 jp = 0
                unsafe { *(slot as uint64) -> jp }
                uint64 boff = (body_addr - jp) >> 2
                patch_u32(jp, 0x54000000 | ((boff & 0x7FFFF) << 5))
                ji = ji + 1
            }
            // Execute body
            uint32 body_idx = ast_data2(warm)
            uint64 wbody = body_idx
            gen_block_a64(wbody)
            // B end_match (stored in break_fixups)
            uint64 end_patch = out_len
            emit_a64(0x14000000)  // B +0 (patched)
            uint64 bf = break_fixups + break_fixup_count * 4
            uint32 ep32 = end_patch
            unsafe { *(bf as uint32) = ep32 }
            break_fixup_count = break_fixup_count + 1
            // Patch the fall-through B (none matched) to skip_arm = here.
            if is_wild == 0 {
                uint64 skip_off = (out_len - skip_patch) >> 2
                patch_u32(skip_patch, 0x14000000 | (skip_off & 0x3FFFFFF))
            }
            uint32 next_arm = ast_next(warm)
            warm = next_arm
        }
        // Patch end-match jumps
        uint64 end_addr = out_len
        uint64 bi = saved_break
        while bi < break_fixup_count {
            uint64 bfe = break_fixups + bi * 4
            uint32 bp32 = 0
            unsafe { *(bfe as uint32) -> bp32 }
            uint64 wbp = bp32
            uint64 b_off = (end_addr - wbp) >> 2
            patch_u32(wbp, 0x14000000 | (b_off & 0x3FFFFFF))
            bi = bi + 1
        }
        break_fixup_count = saved_break
        return
    }

    // PtrLoad
    if kind == 41 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr_a64(wa)
        if wts == 1 { emit_a64_ldrb(0, 0, 0) }
        else if wts == 2 { emit_a64_ldrh(0, 0, 0) }
        else if wts == 4 { emit_a64_ldr32(0, 0, 0) }
        else { emit_a64_ldr(0, 0, 0) }
        // Volatile barrier after load (DSB SY — ensures device read completes)
        uint32 vol_flag = ast_data3(node)
        uint64 wvf = vol_flag
        if wvf == 1 { emit_a64(0xD5033F9F) }
        uint32 dest_tok = ast_data2(node)
        uint64 doff = var_lookup(dest_tok)
        if doff != 0xFFFFFFFF {
            emit_a64_store_x0(doff)
        } else {
            uint64 soff = static_lookup(dest_tok)
            if soff != 0xFFFFFFFF { emit_a64_static_store(soff) }
        }
        return
    }

    // PtrStore
    if kind == 42 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 val_child = ast_data2(node)
        uint64 wv = val_child
        gen_expr_a64(wv)
        emit_a64_store_x0(temp_slot_0)
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr_a64(wa)
        emit_a64_mov(10, 0)
        emit_a64_load_x0(temp_slot_0)
        // Volatile barrier before store (DSB SY — ensures device write commits)
        uint32 vol_flag2 = ast_data3(node)
        uint64 wvf2 = vol_flag2
        if wvf2 == 1 { emit_a64(0xD5033BBF) }
        if wts == 1 { emit_a64_strb(0, 10, 0) }
        else if wts == 2 { emit_a64_strh(0, 10, 0) }
        else if wts == 4 { emit_a64_str32(0, 10, 0) }
        else { emit_a64_str(0, 10, 0) }
        return
    }

    // Indexed assignment (arr[i] = val): scale index by elem_size, store N bytes.
    if kind == 37 {
        uint32 idx_d3 = ast_data3(node)
        uint64 wd3 = idx_d3
        if wd3 == 1 {
            uint32 rhs_child = ast_data2(node)
            uint64 wrhs = rhs_child
            gen_expr_a64(wrhs)
            emit_a64_store_x0(temp_slot_0)
            uint32 idx_child = ast_child(node)
            uint64 wi = idx_child
            gen_expr_a64(wi)
            emit_a64_store_x0(temp_slot_1)
            uint32 arr_tok = ast_data1(node)
            uint64 warrtb = arr_tok
            uint64 arr_offset = var_lookup(arr_tok)
            uint64 elem_sz_w = arr_elem_lookup(arr_tok)
            if arr_offset != 0xFFFFFFFF {
                emit_a64_load_x0(arr_offset)
            } else {
                uint64 sasb = static_array_size_of(warrtb)
                if sasb != 0xFFFFFFFF && sasb != 0 {
                    uint64 soffb = static_lookup(warrtb)
                    emit_a64_static_lea(soffb)
                } else {
                    arr_offset = 0
                    emit_a64_load_x0(arr_offset)
                }
            }
            emit_a64_mov(10, 0)              // x10 = base
            emit_a64_load_x0(temp_slot_1)    // x0 = index
            uint64 shift_w = 0
            if elem_sz_w == 2 { shift_w = 1 }
            if elem_sz_w == 4 { shift_w = 2 }
            if elem_sz_w == 8 { shift_w = 3 }
            emit_a64_add_lsl(10, 10, 0, shift_w)  // x10 = base + (idx << shift)
            emit_a64_load_x0(temp_slot_0)    // x0 = value
            if elem_sz_w == 1 {
                emit_a64_strb(0, 10, 0)
            } else if elem_sz_w == 2 {
                emit_a64_strh(0, 10, 0)
            } else if elem_sz_w == 4 {
                emit_a64_str32(0, 10, 0)
            } else {
                emit_a64_str(0, 10, 0)
            }
            return
        }
    }

    // Field assignment (var.field = val)
    if kind == 36 {
        uint32 fa_d4 = ast_data4(node)
        uint64 wfad4 = fa_d4
        if wfad4 == 1 {
            uint32 fa_child = ast_child(node)
            uint64 wfachild = fa_child
            uint32 field_tok = ast_data2(node)
            uint32 val_node = ast_data3(node)
            uint64 wval = val_node

            // Struct array element field write: arr[i].field = val
            if wfachild != 0 {
                uint32 cfk_aw = ast_kind(wfachild)
                uint64 wcfk_aw = cfk_aw
                if wcfk_aw == 37 {
                    uint32 ai_tok_aw = ast_data1(wfachild)
                    uint64 wait_aw = ai_tok_aw
                    uint64 sia_aw = struct_var_lookup(ai_tok_aw)
                    if sia_aw != 0xFFFFFFFF {
                        uint64 stride_aw = struct_total_size(sia_aw)
                        uint64 foff_aw = struct_field_offset(sia_aw, field_tok)
                        uint64 fsz_aw = struct_field_size(sia_aw, field_tok)
                        // Evaluate value → save to temp_slot_0
                        gen_expr_a64(wval)
                        emit_a64_store_x0(temp_slot_0)
                        // Evaluate index → x0
                        uint32 idx_ch_aw = ast_child(wfachild)
                        uint64 widx_aw = idx_ch_aw
                        gen_expr_a64(widx_aw)
                        // Multiply by stride
                        emit_a64_mov_imm(10, stride_aw)
                        uint64 mulinsn2 = 0x9B007C00 | (10 << 16) | (0 << 5) | 0
                        emit_a64(mulinsn2)
                        emit_a64_mov(11, 0)
                        // Load base address
                        uint64 aoff_aw = var_lookup(wait_aw)
                        if aoff_aw != 0xFFFFFFFF {
                            emit_a64_load_x0(aoff_aw)
                        }
                        // Addr = base + x11 + foff
                        emit_a64_add(0, 0, 11)
                        if foff_aw != 0 { emit_a64_add_imm(0, 0, foff_aw) }
                        emit_a64_mov(10, 0)
                        emit_a64_load_x0(temp_slot_0)
                        if fsz_aw == 1 { emit_a64_strb(0, 10, 0) }
                        else if fsz_aw == 2 { emit_a64_strh(0, 10, 0) }
                        else if fsz_aw == 4 { emit_a64_str32(0, 10, 0) }
                        else { emit_a64_str(0, 10, 0) }
                        return
                    }
                }
            }

            // Nested struct field write: child is another FieldAccess
            if wfachild != 0 {
                uint32 cfk_nwa = ast_kind(wfachild)
                uint64 wcfk_nwa = cfk_nwa
                if wcfk_nwa == 36 {
                    gen_expr_a64(wval)
                    if expr_is_float_a64 == 1 {
                        // fmov x0, d0
                        emit_a64(0x9E660000)
                    }
                    if expr_is_float_a64 == 2 {
                        // fmov w0, s0
                        emit_a64(0x1E260000)
                    }
                    emit_a64_store_x0(temp_slot_0)
                    gen_expr_a64(wfachild)
                    uint64 nsi_wa = expr_is_struct_a64
                    if nsi_wa != 0xFFFFFFFF {
                        uint64 nfoff_wa = struct_field_offset(nsi_wa, field_tok)
                        uint64 nfsz_wa = struct_field_size(nsi_wa, field_tok)
                        if nfoff_wa != 0 {
                            emit_a64_add_imm(0, 0, nfoff_wa)
                        }
                        emit_a64_mov(10, 0)
                        emit_a64_load_x0(temp_slot_0)
                        if nfsz_wa == 1 { emit_a64_strb(0, 10, 0) }
                        else if nfsz_wa == 2 { emit_a64_strh(0, 10, 0) }
                        else if nfsz_wa == 4 { emit_a64_str32(0, 10, 0) }
                        else { emit_a64_str(0, 10, 0) }
                    }
                    return
                }
            }

            uint32 obj_tok = 0
            if wfachild != 0 {
                uint32 fack = ast_kind(wfachild)
                uint64 wfack = fack
                if wfack == 32 {
                    obj_tok = ast_data1(wfachild)
                }
            }
            // Device field write
            if obj_tok != 0 {
                uint64 wdtwa = obj_tok
                uint64 dev_idx_wa = device_lookup(wdtwa)
                if dev_idx_wa != 0xFFFFFFFF {
                    uint64 wftwa = field_tok
                    uint64 dev_off_wa = device_field_offset_of(dev_idx_wa, wftwa)
                    if dev_off_wa != 0xFFFFFFFF {
                        uint64 dev_sz_wa = device_field_size_of(dev_idx_wa, wftwa)
                        uint64 dev_addr_wa = device_base(dev_idx_wa) + dev_off_wa
                        // Evaluate value to x0
                        gen_expr_a64(wval)
                        emit_a64_mov(1, 0)
                        // x0 = address
                        emit_a64_mov_imm(0, dev_addr_wa)
                        // DSB SY before store
                        emit_a64(0xD5033F9F)
                        if dev_sz_wa == 1 { emit_a64_strb(1, 0, 0) }
                        else if dev_sz_wa == 2 { emit_a64_strh(1, 0, 0) }
                        else if dev_sz_wa == 4 { emit_a64_str32(1, 0, 0) }
                        else { emit_a64_str(1, 0, 0) }
                        return
                    }
                }
            }
            gen_expr_a64(wval)
            uint64 si = struct_var_lookup(obj_tok)
            if si != 0xFFFFFFFF {
                // Check if field is a float type
                uint64 fftk_w = struct_field_type_kind_by_tok(si, field_tok)
                if fftk_w == 96 {
                    // f64 field: value is in d0, save to temp, compute addr, store
                    emit_a64_store_d0(temp_slot_0)
                    uint64 var_off = var_lookup(obj_tok)
                    if var_off == 0xFFFFFFFF { var_off = 0 }
                    uint64 foff = struct_field_offset(si, field_tok)
                    emit_a64_load_x0(var_off)
                    if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                    emit_a64_mov(10, 0)
                    emit_a64_load_d0(temp_slot_0)
                    // str d0, [x10, #0]
                    emit_a64_store_dN_to_ptr(0, 10, 0)
                    return
                }
                if fftk_w == 95 {
                    // f32 field: value is in s0, save to temp, compute addr, store
                    emit_a64_store_s0(temp_slot_0)
                    uint64 var_off = var_lookup(obj_tok)
                    if var_off == 0xFFFFFFFF { var_off = 0 }
                    uint64 foff = struct_field_offset(si, field_tok)
                    emit_a64_load_x0(var_off)
                    if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                    emit_a64_mov(10, 0)
                    emit_a64_load_s0(temp_slot_0)
                    // str s0, [x10, #0]
                    emit_a64_store_sN_to_ptr(0, 10, 0)
                    return
                }
                emit_a64_store_x0(temp_slot_0)
                uint64 var_off = var_lookup(obj_tok)
                if var_off == 0xFFFFFFFF { var_off = 0 }
                uint64 foff = struct_field_offset(si, field_tok)
                uint64 fsz = struct_field_size(si, field_tok)
                emit_a64_load_x0(var_off)
                if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                emit_a64_mov(10, 0)
                emit_a64_load_x0(temp_slot_0)
                if fsz == 1 { emit_a64_strb(0, 10, 0) }
                else if fsz == 2 { emit_a64_strh(0, 10, 0) }
                else if fsz == 4 { emit_a64_str32(0, 10, 0) }
                else { emit_a64_str(0, 10, 0) }
            } else {
                emit_a64_store_x0(temp_slot_0)
            }
            return
        }
    }

    // Inline assembly — see x86_64 gen_stmt for the constraint contract.
    if kind == 43 {
        uint32 cons_head = ast_data3(node)
        uint64 wch_a = cons_head

        // Inputs: `ldr xN, [sp, #slot]`
        uint64 wci = wch_a
        while wci != 0 {
            uint32 ck = ast_data1(wci)
            if ck == 0 {
                uint32 rtok = ast_data2(wci)
                uint32 vtok = ast_data3(wci)
                uint64 wrtok = rtok
                uint64 wvtok = vtok
                uint64 rcode = a64_reg_code(wrtok)
                uint64 voff  = var_lookup(wvtok)
                if rcode != 0xFFFF && voff != 0xFFFFFFFF {
                    emit_a64_ldr(rcode, 31, a64_var_base + voff)
                }
            }
            uint32 nxti = ast_next(wci)
            wci = nxti
        }

        uint32 single_tok = ast_data1(node)
        uint64 ws = single_tok
        if ws != 0 {
            asm_emit_a64(ws)
        }
        uint32 child_str = ast_child(node)
        uint64 wcs = child_str
        while wcs != 0 {
            uint32 stk = ast_data1(wcs)
            uint64 wstk = stk
            asm_emit_a64(wstk)
            uint32 nxt = ast_next(wcs)
            wcs = nxt
        }

        // Outputs: `str xN, [sp, #slot]`
        uint64 wco = wch_a
        while wco != 0 {
            uint32 ck2 = ast_data1(wco)
            if ck2 == 1 {
                uint32 rtok2 = ast_data2(wco)
                uint32 vtok2 = ast_data3(wco)
                uint64 wrtok2 = rtok2
                uint64 wvtok2 = vtok2
                uint64 rcode2 = a64_reg_code(wrtok2)
                uint64 voff2  = var_lookup(wvtok2)
                if rcode2 != 0xFFFF && voff2 != 0xFFFFFFFF {
                    emit_a64_str(rcode2, 31, a64_var_base + voff2)
                }
            }
            uint32 nxto = ast_next(wco)
            wco = nxto
        }
        return
    }

    // Expression statement
    if kind == 16 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        gen_expr_a64(wec)
        return
    }

    // Defer (51): legacy ARM64 codegen doesn't implement defer. Fail
    // loudly so users drop --legacy and use the IR backend where it
    // works.
    if kind == 51 {
        write(2, "error: `defer` requires the IR backend (drop --legacy)\n", 56)
        exit(1)
    }
}

fn gen_block_a64(uint64 block_node) {
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        gen_stmt_a64(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// ---------------------------------------------------------------------------
// AArch64 ELF header emission
// ---------------------------------------------------------------------------

fn emit_elf_header_a64() {
    emit_byte(0x7F); emit_byte(69); emit_byte(76); emit_byte(70)
    emit_byte(2); emit_byte(1); emit_byte(1); emit_byte(0)
    uint64 i = 0
    while i < 8 { emit_byte(0); i = i + 1 }
    emit_u16_le(2)
    emit_u16_le(0xB7)
    emit_u32_le(1)
    emit_u64_le(0)
    emit_u64_le(64)
    emit_u64_le(0)
    emit_u32_le(0)
    emit_u16_le(64)
    emit_u16_le(56)
    emit_u16_le(1)
    emit_u16_le(64)
    emit_u16_le(0)
    emit_u16_le(0)
}

fn emit_program_header_a64(uint64 text_size) {
    uint64 total = 120 + text_size
    emit_u32_le(1)
    emit_u32_le(7)
    emit_u64_le(0)
    emit_u64_le(0x400000)
    emit_u64_le(0x400000)
    emit_u64_le(total)
    emit_u64_le(total)
    emit_u64_le(0x10000)
}

// ---------------------------------------------------------------------------
// AArch64 function codegen (prologue + body + epilogue)
// ---------------------------------------------------------------------------

@export
fn gen_function_a64(uint64 fn_node) {
    uint32 name_tok = ast_data1(fn_node)

    // Check annotation flags: bit 0 = noreturn, bit 1 = naked, bit 3 = extern
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2
    uint64 is_extern_a = ann_flags & 8

    // Extern declarations have no body — skip codegen.
    if is_extern_a != 0 { return }
    uint32 body_check_a = ast_data3(fn_node)
    if body_check_a == 0 { return }

    // Leaf function optimization disabled for now — needs register allocator
    uint64 is_leaf = 0
    uint64 is_noreturn = ann_flags & 1

    // Overflow arg patch tracking (for functions with >8 params)
    uint64[16] a64_overflow_patches
    uint64 a64_overflow_patch_count = 0

    var_reset()
    expr_is_float_a64 = 0
    temp_slot_0 = var_count * 8
    var_count = var_count + 1
    temp_slot_1 = var_count * 8
    var_count = var_count + 1
    var_frame_size = var_count * 8
    uint64 rem0 = var_frame_size & 15
    if rem0 != 0 { var_frame_size = var_frame_size + 16 - rem0 }

    fn_register(name_tok, out_len)

    // Register float return type if applicable
    uint32 ret_type_tok_a = ast_data2(fn_node)
    uint64 wrt_a = ret_type_tok_a
    if wrt_a != 0 {
        uint64 ret_kind_a = tok_kind_at_raw(wrt_a)
        if ret_kind_a == 96 { fn_ret_float_register(name_tok, 1) }
        if ret_kind_a == 95 { fn_ret_float_register(name_tok, 2) }
        // Register struct return type if applicable
        uint64 ret_si_a = struct_lookup(wrt_a)
        if ret_si_a != 0xFFFFFFFF {
            fn_ret_struct_register(name_tok, ret_si_a)
        }
    }

    // Check if return type is a MEMORY-class struct (needs sret via x8)
    sret_slot_a64 = 0xFFFFFFFF
    if wrt_a != 0 {
        uint64 sret_si_a = struct_lookup(wrt_a)
        if sret_si_a != 0xFFFFFFFF {
            uint64 sret_c0_a = struct_abi_class0(sret_si_a)
            if sret_c0_a == 3 {
                // Reserve a stack slot for the x8 sret pointer
                sret_slot_a64 = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 sret_rem_a = var_frame_size & 15
                if sret_rem_a != 0 { var_frame_size = var_frame_size + 16 - sret_rem_a }
            }
        }
    }

    // For main: platform-specific _start trampoline
    uint64 wnt_a64 = name_tok
    if tok_matches(wnt_a64, "main", 4) != 0 && target_os == 2 && freestanding == 0 {
        // All 13 IAT entries are loader-resolved. Call GetCommandLineA directly.
        emit_a64_win_call_iat(7)       // GetCommandLineA → x0 = cmdline
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argv_off_w)
        }
        // Set cli_argc = 0xFFFFFFFF as "needs parsing" sentinel
        emit_a64_mov_imm(0, 0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argc_off_w)
        }
    }
    if tok_matches(wnt_a64, "main", 4) != 0 && target_os != 2 && freestanding == 0 {
        if target_os == 1 {
            // macOS Mach-O: _main receives argc in x0, argv in x1
            uint64 argc_off_mac = static_lookup_by_name("cli_argc", 8)
            if argc_off_mac != 0xFFFFFFFF {
                emit_a64_static_store(argc_off_mac)  // store x0 (argc)
            }
            emit_a64_mov(0, 1)  // x0 = argv (from x1)
            uint64 argv_off_mac = static_lookup_by_name("cli_argv", 8)
            if argv_off_mac != 0xFFFFFFFF {
                emit_a64_static_store(argv_off_mac)
            }
        } else {
            // Linux/Android ELF: argc/argv on stack. [SP]=argc, [SP+8]=&argv[0]
            emit_a64_ldr(0, 31, 0)
            uint64 argc_off_a64 = static_lookup_by_name("cli_argc", 8)
            if argc_off_a64 != 0xFFFFFFFF {
                emit_a64_static_store(argc_off_a64)
            }
            emit_a64_add_imm(0, 31, 8)
            uint64 argv_off_a64 = static_lookup_by_name("cli_argv", 8)
            if argv_off_a64 != 0xFFFFFFFF {
                emit_a64_static_store(argv_off_a64)
            }
        }
        // Compute envp: on Linux/Android = sp + 8 + (argc+1)*8
        // On macOS, envp is apple[0] which comes after argv NULL terminator
        // but argc/argv were passed as function params, not on stack.
        // For macOS, compute from the cli_argv static: envp = argv + (argc+1)*8
        uint64 envp_off_a64 = static_lookup_by_name("cli_envp", 8)
        if envp_off_a64 != 0xFFFFFFFF {
            if target_os == 1 {
                // macOS: envp = argv + (argc+1)*8
                uint64 argc_off_env = static_lookup_by_name("cli_argc", 8)
                if argc_off_env != 0xFFFFFFFF { emit_a64_static_load(argc_off_env) }
                emit_a64_mov(9, 0)               // x9 = argc
                emit_a64_add_imm(9, 9, 1)        // x9 = argc + 1
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)            // x9 = (argc+1)*8
                uint64 argv_off_env = static_lookup_by_name("cli_argv", 8)
                if argv_off_env != 0xFFFFFFFF { emit_a64_static_load(argv_off_env) }
                emit_a64_add(0, 0, 9)             // x0 = argv + (argc+1)*8 = envp
            } else {
                // Linux/Android: envp = sp + 8 + (argc+1)*8
                emit_a64_ldr(9, 31, 0)            // x9 = argc
                emit_a64_add_imm(9, 9, 1)
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)
                emit_a64_add_imm(0, 31, 8)        // x0 = sp + 8
                emit_a64_add(0, 0, 9)
            }
            emit_a64_static_store(envp_off_a64)
        }
    }

    // Clear per-function slice table
    slice_len_count = 0

    // Parse params
    uint32 first_param = ast_child(fn_node)
    uint64 wparam = first_param
    while wparam != 0 {
        uint32 pk = ast_kind(wparam)
        if pk == 3 {
            uint32 param_name = ast_data2(wparam)
            uint64 ptr_off_a = var_declare(param_name)
            // Register float type for float-typed params
            uint32 param_type_reg_a = ast_data1(wparam)
            uint64 pt_kind_a = tok_kind_at_raw(param_type_reg_a)
            if is_float_type(pt_kind_a) != 0 {
                var_type_register(param_name, pt_kind_a)
            }
            // Slice parameter: also reserve a length slot (no name)
            uint32 pflag_a = ast_data4(wparam)
            uint64 wpflag_a = pflag_a
            if wpflag_a == 1 {
                uint64 len_off_a = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 srem_spa = var_frame_size & 15
                if srem_spa != 0 { var_frame_size = var_frame_size + 16 - srem_spa }
                slice_len_register(ptr_off_a, len_off_a)
            }
            // If the param's type is a struct name, register it as a struct var
            uint32 param_type = ast_data1(wparam)
            uint64 wpt = param_type
            uint64 psi = struct_lookup(wpt)
            if psi != 0xFFFFFFFF {
                struct_var_register(param_name, psi)
            }
        }
        uint32 pnxt = ast_next(wparam)
        wparam = pnxt
    }

    // Prologue — for large frames (>4080) we split: pre_sub + prologue_sub
    uint64 pre_sub_patch = out_len
    // NOP placeholder — patched to SUB SP for large frames (>4080 bytes)
    if is_naked == 0 {
        emit_a64(0xD503201F)
    }
    uint64 prologue_start = out_len
    uint64 stp_fp_off = 0
    uint64 stp_callee_off = 0
    if is_naked == 0 {
        emit_a64(0xD1000000)  // SUB SP, SP, #imm (patched)
        stp_fp_off = out_len
        emit_a64(0xA9007BFD)  // stp x29, x30, [sp]
        emit_a64_add_imm(29, 31, 0)  // mov x29, sp
        stp_callee_off = out_len
        emit_a64(0xA90153F3)  // stp x19, x20, [sp, #16]
    }

    uint64 saved_var_base = a64_var_base

    // If this function returns a MEMORY-class struct, save x8 (sret pointer)
    // to the reserved slot.  AAPCS64: x8 is separate from arg registers x0-x7,
    // so no parameter shift is needed.
    if sret_slot_a64 != 0xFFFFFFFF {
        emit_a64_str(8, 31, a64_var_base + sret_slot_a64)
    }

    // Spill params to stack (x0-x7 for int, d0-d7 for float)
    // AAPCS64: separate int/float register counters
    uint64 pidx = 0
    uint64 int_pidx_a = 0
    uint64 float_pidx_a = 0
    uint64 wp2 = first_param
    while wp2 != 0 {
        uint32 pk2 = ast_kind(wp2)
        if pk2 == 3 {
            uint32 pn2 = ast_data2(wp2)
            uint64 poff = var_lookup(pn2)
            uint32 pflag_as = ast_data4(wp2)
            uint64 wpflag_as = pflag_as
            // Check if this param is a float type
            uint32 pt_spill_a = ast_data1(wp2)
            uint64 pt_kind_spill_a = tok_kind_at_raw(pt_spill_a)
            uint64 param_is_float_a = is_float_type(pt_kind_spill_a)
            if poff != 0xFFFFFFFF {
                // Check for struct parameter (by-value receiving, AAPCS64)
                uint64 param_si_spill_a = struct_lookup(pt_spill_a)
                if param_si_spill_a != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                    // AAPCS64 struct by value: allocate struct-sized area on stack
                    uint64 sv_ssize_a = struct_total_size(param_si_spill_a)
                    uint64 sv_sslots_a = (sv_ssize_a + 7) / 8
                    uint64 struct_area_a = var_count * 8
                    uint64 sv_ci_a = 0
                    while sv_ci_a < sv_sslots_a { var_count = var_count + 1; sv_ci_a = sv_ci_a + 1 }
                    var_frame_size = var_count * 8
                    uint64 sv_rem_a = var_frame_size & 15
                    if sv_rem_a != 0 { var_frame_size = var_frame_size + 16 - sv_rem_a }
                    // Check if this is an HFA struct — spill from d/s regs
                    uint64 sflags_c = struct_abi_flags(param_si_spill_a)
                    uint64 is_hfa_c = sflags_c & 1
                    if is_hfa_c != 0 {
                        uint64 hfa_count_c = ((sflags_c >> 1) & 3) + 1
                        uint64 hfa_type_c = (sflags_c >> 3) & 3
                        uint64 field_size_c = 4
                        if hfa_type_c == 1 { field_size_c = 8 }
                        // Spill each d/s register to struct area
                        uint64 ci = 0
                        while ci < hfa_count_c {
                            uint64 foff_c = ci * field_size_c
                            if hfa_type_c == 1 {
                                emit_a64_store_dN(float_pidx_a, struct_area_a + foff_c)
                            } else {
                                emit_a64_store_sN(float_pidx_a, struct_area_a + foff_c)
                            }
                            float_pidx_a = float_pidx_a + 1
                            ci = ci + 1
                        }
                    } else if sv_ssize_a > 16 {
                        // MEMORY class (>16 bytes): register holds a pointer
                        // Copy struct bytes from pointer to local stack area
                        if int_pidx_a <= 7 {
                            // Save source pointer: mov x9, xN
                            emit_a64_mov(9, int_pidx_a)
                        }
                        int_pidx_a = int_pidx_a + 1
                        // Inline qword copy from [x9] to [sp + a64_var_base + struct_area_a]
                        uint64 aqi = 0
                        while aqi < sv_sslots_a {
                            uint64 aqoff = aqi * 8
                            // ldr x10, [x9, #aqoff]
                            emit_a64_ldr(10, 9, aqoff)
                            // str x10, [sp, #(a64_var_base + struct_area_a + aqoff)]
                            emit_a64_str(10, 31, a64_var_base + struct_area_a + aqoff)
                            aqi = aqi + 1
                        }
                    } else {
                    // Spill register(s) into contiguous struct area
                    if int_pidx_a <= 7 {
                        emit_a64_str(int_pidx_a, 31, a64_var_base + struct_area_a)
                    }
                    int_pidx_a = int_pidx_a + 1
                    if sv_ssize_a > 8 && int_pidx_a <= 7 {
                        emit_a64_str(int_pidx_a, 31, a64_var_base + struct_area_a + 8)
                        int_pidx_a = int_pidx_a + 1
                    }
                    }
                    // Store pointer to struct area in the variable's slot
                    // add x0, sp, #(a64_var_base + struct_area_a)
                    emit_a64_add_imm(0, 31, a64_var_base + struct_area_a)
                    emit_a64_str(0, 31, a64_var_base + poff)
                    pidx = pidx + 1
                    uint32 pn3_sv = ast_next(wp2)
                    wp2 = pn3_sv
                    continue
                }
                if param_is_float_a != 0 {
                    // Float param: spill dN to stack
                    if float_pidx_a <= 7 {
                        emit_a64_store_dN(float_pidx_a, poff)
                    }
                    float_pidx_a = float_pidx_a + 1
                } else {
                    // Integer param: spill xN to stack
                    uint64 reg = int_pidx_a
                    if reg <= 7 {
                        emit_a64_str(reg, 31, a64_var_base + poff)
                    }
                    if reg >= 8 {
                        // Stack-passed arg: emit ldr x0, [sp, #PLACEHOLDER]
                        // Offset will be patched when frame_size is known
                        uint64 patch_loc = out_len
                        emit_a64(0xF9400000 | (31 << 5) | 0) // ldr x0, [sp, #0] placeholder
                        // str x0, [sp, #(a64_var_base + poff)]
                        emit_a64_str(0, 31, a64_var_base + poff)
                        // Save patch location
                        uint64 opi = reg - 8
                        uint64 op_entry = a64_overflow_patches + opi * 8
                        uint32 pl32 = patch_loc
                        unsafe { *(op_entry as uint32) = pl32 }
                        a64_overflow_patch_count = opi + 1
                    }
                    int_pidx_a = int_pidx_a + 1
                    // Slice param: spill length register to the length slot
                    if wpflag_as == 1 {
                        uint64 len_off_as = slice_len_lookup(poff)
                        if len_off_as != 0xFFFFFFFF {
                            uint64 reg2 = int_pidx_a
                            if reg2 <= 7 {
                                emit_a64_str(reg2, 31, a64_var_base + len_off_as)
                            }
                        }
                        int_pidx_a = int_pidx_a + 1
                    }
                }
                pidx = pidx + 1
            }
        }
        uint32 pn3 = ast_next(wp2)
        wp2 = pn3
    }

    ret_fixup_count = 0

    // Generate body
    uint32 body_idx = ast_data3(fn_node)
    uint64 wbody = body_idx
    if wbody != 0 {
        gen_block_a64(wbody)
    }

    // Epilogue — patch return jumps here
    uint64 epilogue_start = out_len
    uint64 ri = 0
    while ri < ret_fixup_count {
        uint64 rentry = ret_fixups + ri * 4
        uint32 rpatch = 0
        unsafe { *(rentry as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 disp = epilogue_start - wrp
        // Patch B instruction
        patch_u32(wrp, 0x14000000 | ((disp / 4) & 0x3FFFFFF))
        ri = ri + 1
    }

    // For @naked functions, skip epilogue entirely
    if is_naked != 0 {
        return
    }

    // For main: auto-insert exit(0) so programs don't segfault on return
    // Skip when in freestanding mode
    uint64 wnt_ep = name_tok
    if tok_matches(wnt_ep, "main", 4) != 0 && freestanding == 0 {
        emit_a64_mov_imm(0, 0)
        if target_os == 2 {
            emit_a64_win_call_iat(0)
        } else {
            if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }
            emit_a64_svc()
        }
    }

    uint64 ldp_callee_off = out_len
    emit_a64(0xA94153F3)  // ldp x19, x20, [sp, #16]
    uint64 ldp_fp_off = out_len
    emit_a64(0xA9407BFD)  // ldp x29, x30, [sp]
    // add sp, sp, #FRAME (placeholder, patched)
    uint64 epilogue_add = out_len
    emit_a64(0x91000000)
    uint64 post_add_patch = out_len
    // NOP placeholder — patched to ADD SP for large frames (>4080 bytes)
    if is_naked == 0 {
        emit_a64(0xD503201F)
    }
    // ret
    emit_a64_ret()

    // Restore a64_var_base
    a64_var_base = saved_var_base

    // Patch prologue and epilogue frame sizes
    uint64 frame = a64_var_base + var_frame_size
    uint64 fmod = frame & 15
    if fmod != 0 { frame = frame + 16 - fmod }

    if frame > 4080 {
        // Split: pre_sub does (frame>>12)*4096 via LSL#12, prologue_sub does remainder
        uint64 hi = frame >> 12
        uint64 lo = frame & 0xFFF
        // Ensure lo is 16-aligned
        uint64 lmod = lo & 15
        if lmod != 0 { lo = lo + 16 - lmod; hi = (frame - lo) >> 12 }
        // pre_sub: SUB SP, SP, #hi, LSL #12 (0xD1400000)
        patch_u32(pre_sub_patch, 0xD1400000 | (hi << 10) | (31 << 5) | 31)
        // prologue: SUB SP, SP, #lo
        patch_u32(prologue_start, 0xD1000000 | (lo << 10) | (31 << 5) | 31)
        // Epilogue: ADD SP, SP, #lo then ADD SP, SP, #hi, LSL #12 (0x91400000)
        patch_u32(epilogue_add, 0x91000000 | (lo << 10) | (31 << 5) | 31)
        patch_u32(post_add_patch, 0x91400000 | (hi << 10) | (31 << 5) | 31)
    } else {
        // pre_sub stays NOP, prologue does the full frame
        patch_u32(prologue_start, 0xD1000000 | (frame << 10) | (31 << 5) | 31)
        // epilogue does the full frame, post_add stays NOP
        patch_u32(epilogue_add, 0x91000000 | (frame << 10) | (31 << 5) | 31)
    }

    // Patch overflow arg offsets (9+ params, AAPCS64)
    // After SUB SP, SP, #frame + STP x29,x30,[sp]:
    // [sp + frame] = saved x29/x30 (16 bytes via STP)
    // [sp + frame + 0]  = overflow arg 0
    // [sp + frame + 8]  = overflow arg 1
    // Actually the caller pushed overflow args BELOW the return address.
    // The BL stores return address in LR (x30), not on stack.
    // So overflow args are at [sp + frame + i*8] from callee's perspective.
    if a64_overflow_patch_count > 0 {
        uint64 oi = 0
        while oi < a64_overflow_patch_count {
            uint64 op_e = a64_overflow_patches + oi * 8
            uint32 ploc = 0
            unsafe { *(op_e as uint32) -> ploc }
            uint64 wploc = ploc
            uint64 soff = frame + oi * 8
            // Patch LDR x0, [sp, #soff]: F9400000 | (imm12<<10) | (31<<5) | 0
            uint64 imm12 = soff / 8
            patch_u32(wploc, 0xF9400000 | (imm12 << 10) | (31 << 5) | 0)
            oi = oi + 1
        }
    }

    // Leaf function optimization: if no BL was emitted, NOP out the STP/LDP
    // Stack layout stays the same (a64_var_base=32), just skip the memory ops
    if is_naked == 0 {
        uint64 has_bl = 0
        uint64 scan = prologue_start
        while scan + 4 <= out_len {
            uint64 sp2 = out_buf + scan
            uint32 si = 0
            unsafe { *(sp2 as uint32) -> si }
            uint64 wsi = si
            // BL rel26: 0x94000000 (direct call)
            // BLR Xn:  0xD63F0000 (indirect call, used by Windows IAT)
            if (wsi & 0xFC000000) == 0x94000000 { has_bl = 1; break }
            if (wsi & 0xFFFFF000) == 0xD63F0000 { has_bl = 1; break }
            scan = scan + 4
        }
        if has_bl == 0 {
            // Leaf: NOP out STP x29,x30 + MOV x29,sp + STP x19,x20
            patch_u32(stp_fp_off, 0xD503201F)
            patch_u32(stp_fp_off + 4, 0xD503201F)
            patch_u32(stp_callee_off, 0xD503201F)
            // NOP out LDP x19,x20 + LDP x29,x30
            patch_u32(ldp_callee_off, 0xD503201F)
            patch_u32(ldp_fp_off, 0xD503201F)
        }
    }
}

// ---------------------------------------------------------------------------
// AArch64 fixup resolution
// ---------------------------------------------------------------------------

@export
fn resolve_fixups_a64() {
    uint64 i = 0
    while i < fixup_count {
        uint64 fentry = fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 target_tok = 0
        unsafe { *(fe4 as uint32) -> target_tok }

        uint64 wtt = target_tok
        uint64 target_off = fn_lookup(wtt)
        if target_off != 0xFFFFFFFF {
            uint64 wpo = patch_off
            uint64 disp = target_off - wpo
            // Patch BL instruction: BL rel26
            patch_u32(wpo, 0x94000000 | ((disp / 4) & 0x3FFFFFF))
        }
        i = i + 1
    }
}

// Resolve fn_addr fixups for ARM64: ADRP+ADD → patch to function address
fn resolve_fnaddr_fixups_a64() {
    uint64 i = 0
    while i < fnaddr_fixup_count {
        uint64 fentry = fnaddr_fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 str_tok = 0
        unsafe { *(fe4 as uint32) -> str_tok }

        uint64 wst = str_tok
        uint64 sstart = tok_text_start(wst)
        uint64 slen = tok_text_len(wst)
        uint64 name_start = sstart + 1
        uint64 name_len = slen - 2

        // Search function table
        uint64 found = 0
        uint64 target_off = 0
        uint64 fi = 0
        while fi < fn_count {
            uint64 fentry2 = fn_table + fi * 8
            uint32 fn_name_tok = 0
            unsafe { *(fentry2 as uint32) -> fn_name_tok }
            uint64 wfn = fn_name_tok
            uint64 fn_start = tok_text_start(wfn)
            uint64 fn_len = tok_text_len(wfn)
            if fn_len == name_len {
                uint64 eq = 1
                uint64 ci = 0
                while ci < name_len {
                    uint64 ca = cg_source + name_start + ci
                    uint64 cb = cg_source + fn_start + ci
                    uint64 va = 0
                    uint64 vb = 0
                    unsafe { *(ca as uint8) -> va }
                    unsafe { *(cb as uint8) -> vb }
                    if va != vb { eq = 0 }
                    ci = ci + 1
                }
                if eq != 0 {
                    uint64 fe4_2 = fentry2 + 4
                    uint32 foff = 0
                    unsafe { *(fe4_2 as uint32) -> foff }
                    target_off = foff
                    found = 1
                }
            }
            fi = fi + 1
        }

        if found != 0 {
            uint64 wpo = patch_off
            // For ARM64, ADRP+ADD is PC-relative
            // ADRP uses page-aligned PC-relative addressing
            // For simplicity in flat binary: use ADR x0, target (if within ±1MB)
            // ADR: bits [31]=0, [30:29]=immlo, [28:24]=10000, [23:5]=immhi, [4:0]=Rd
            uint64 disp = target_off - wpo
            uint64 imm21 = disp & 0x1FFFFF
            uint64 immlo = imm21 & 3
            uint64 immhi = (imm21 >> 2) & 0x7FFFF
            // ADR x0, disp
            uint32 adr_instr = 0x10000000 | (immlo << 29) | (immhi << 5) | 0
            patch_u32(wpo, adr_instr)
            // NOP the second instruction (ADD)
            patch_u32(wpo + 4, 0xD503201F)
        } else {
            write(2, "error: fn_addr: undefined function '", 36)
            write(2, cg_source + name_start, name_len)
            write(2, "'\n", 2)
            exit(1)
        }
        i = i + 1
    }
}

// AArch64 static access uses absolute addresses loaded via MOV immediate sequence
// The fixup patches the MOV sequence to point to the correct address
//
// VA computation depends on target format:
//   ELF:    VA = 0x400000 + file_offset
//   Mach-O: VA = 0x100000000 + file_offset
//   PE:     VA = 0x140000000 + 0x1000 + (file_offset - 0x200)
//                = 0x140000E00 + file_offset

// Compute VA from a raw file offset based on target_os
fn a64_compute_va(uint64 file_offset) -> uint64 {
    if target_os == 2 {
        // PE: image_base(0x140000000) + text_rva(0x1000) + (file_off - header_size(0x200))
        return 0x140000E00 + file_offset
    }
    if target_os == 1 {
        // Mach-O: vmaddr(0x100000000) + file_offset
        return 0x100000000 + file_offset
    }
    if target_os == 3 {
        // Android PIE: PT_LOAD maps file offset 0 to VA 0
        return file_offset
    }
    // ELF: load at 0x400000
    return 0x400000 + file_offset
}

@export
fn resolve_static_fixups_a64(uint64 data_start) {
    uint64 i = 0
    while i < static_fixup_count {
        uint64 fentry = static_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 data_off = 0
        unsafe { *(fe4 as uint32) -> data_off }
        uint64 wdo = data_off
        uint64 wco = code_off
        // All ARM64: patch ADRP + LDR/STR with PC-relative offsets
        uint64 code_va = a64_compute_va(wco)
        uint64 target_va = a64_compute_va(data_start + wdo)
        uint64 code_page = code_va >> 12
        uint64 target_page = target_va >> 12
        uint64 page_delta = target_page - code_page
        uint64 page_off = target_va & 0xFFF
        // Patch ADRP X16
        uint64 immlo = page_delta & 3
        uint64 immhi = (page_delta >> 2) & 0x7FFFF
        patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
        // Patch LDR/STR X?, [X16, #offset] OR ADD X?, X16, #offset
        uint64 insn_off = wco + 4
        uint64 insn_ptr = out_buf + insn_off
        uint32 existing = 0
        unsafe { *(insn_ptr as uint32) -> existing }
        uint64 wex = existing
        // Detect ADD (immediate, 64-bit): top 8 bits = 0x91
        uint64 opbyte = (wex >> 24) & 0xFF
        if opbyte == 0x91 {
            // ADD: unshifted 12-bit byte offset
            uint64 imm12_add = page_off & 0xFFF
            uint64 base_add = wex & 0xFFC003FF
            patch_u32(insn_off, base_add | (imm12_add << 10))
        } else {
            // LDR/STR: offset is scaled by element width (8 for X reg)
            uint64 imm12 = (page_off >> 3) & 0xFFF
            uint64 base_insn = wex & 0xFFC003FF
            patch_u32(insn_off, base_insn | (imm12 << 10))
        }
        i = i + 1
    }
}

@export
fn resolve_string_fixups_a64(uint64 str_data_start) {
    uint64 i = 0
    while i < str_fixup_count {
        uint64 fentry = str_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 str_off = 0
        unsafe { *(fe4 as uint32) -> str_off }
        uint64 wso = str_off
        uint64 wco = code_off
        if target_os == 2 || target_os == 3 {
            // PE/Android: patch ADRP + ADD with PC-relative offsets
            uint64 code_va = a64_compute_va(wco)
            uint64 target_va = a64_compute_va(str_data_start + wso)
            uint64 code_page = code_va >> 12
            uint64 target_page = target_va >> 12
            uint64 page_delta = target_page - code_page
            uint64 page_off = target_va & 0xFFF
            uint64 immlo = page_delta & 3
            uint64 immhi = (page_delta >> 2) & 0x7FFFF
            patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
            // ADD Xd, X16, #page_off (preserve Rd from original instruction)
            uint32 existing_add = 0
            uint64 add_addr = out_buf + wco + 4
            unsafe { *(add_addr as uint32) -> existing_add }
            uint64 rd = existing_add & 0x1F
            patch_u32(wco + 4, 0x91000200 | (page_off << 10) | rd)
        } else {
            // ELF/Mach-O: ADRP + ADD (PC-relative, position-independent)
            uint64 code_va = a64_compute_va(wco)
            uint64 target_va = a64_compute_va(str_data_start + wso)
            uint64 code_page = code_va >> 12
            uint64 target_page = target_va >> 12
            uint64 page_delta = target_page - code_page
            uint64 page_off = target_va & 0xFFF
            uint64 immlo = page_delta & 3
            uint64 immhi = (page_delta >> 2) & 0x7FFFF
            patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
            uint32 existing_add = 0
            uint64 add_addr = out_buf + wco + 4
            unsafe { *(add_addr as uint32) -> existing_add }
            uint64 rd = existing_add & 0x1F
            patch_u32(wco + 4, 0x91000200 | (page_off << 10) | rd)
        }
        i = i + 1
    }
}
