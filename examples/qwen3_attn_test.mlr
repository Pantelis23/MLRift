// Unit test for qwen3_attn_cached.
//
// Test 1 (seq_len=1, symmetry): single position, K=V=Q=[[1,0]] → out=V[0].
//
// Test 2 (seq_len=2, balanced softmax):
//   Q = [[1, 1]]
//   K = [[1, 0], [0, 1]]        (two kv-positions, 1 kv head)
//   V = [[0.1, 0.2], [0.3, 0.4]]
//   scores[0] = Q·K[0] = 1
//   scores[1] = Q·K[1] = 1
//   scaled   = 1/sqrt(2) ≈ 0.707 for both
//   softmax  = [0.5, 0.5]
//   output   = 0.5*[0.1,0.2] + 0.5*[0.3,0.4] = [0.2, 0.3]
//
// Test 3 (seq_len=2, asymmetric, max-subtraction matters):
//   Q = [[1, 0]]
//   K = [[3, 0], [0, 0.5]]
//   V = [[1, 0], [0, 1]]
//   scores (pre-scale) = [3, 0], after 1/sqrt(2) = [2.121, 0]
//   softmax = [e^2.121 / (e^2.121+1), 1 / (e^2.121+1)]
//           ≈ [8.340/9.340, 1/9.340] ≈ [0.8929, 0.1071]
//   output  ≈ [0.8929, 0.1071]

import "../std/qwen3.mlr"
import "../std/inference.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"

fn put(u64 s) { print_str(s) }
fn putf(f32 v, u64 decimals) {
    u64 s = fmt_f32(v, decimals)
    put(s); dealloc(s)
}

fn set_f32(u64 ptr, u64 idx, f32 val) {
    unsafe { *((ptr + idx * 4) as f32) = val }
}
fn get_f32(u64 ptr, u64 idx) -> f32 {
    f32 v = 0.0f
    unsafe { *((ptr + idx * 4) as f32) -> v }
    return v
}

fn test_seq1() {
    put("-- Test 1: seq_len=1, single head, head_dim=2 --\n")
    u64 n_heads = 1
    u64 n_kv = 1
    u64 hd = 2
    u64 max_seq = 4

    u64 q = alloc(n_heads * hd * 4)
    u64 kc = alloc(max_seq * n_kv * hd * 4)
    u64 vc = alloc(max_seq * n_kv * hd * 4)
    u64 out = alloc(n_heads * hd * 4)

    // Q = [[1, 0]]
    set_f32(q, 0, 1.0f); set_f32(q, 1, 0.0f)
    // K[0] = [1, 0]; V[0] = [7, 11]
    set_f32(kc, 0, 1.0f); set_f32(kc, 1, 0.0f)
    set_f32(vc, 0, 7.0f); set_f32(vc, 1, 11.0f)

    qwen3_attn_cached(out, q, kc, vc, 1, n_heads, n_kv, hd)

    put("  out = [")
    putf(get_f32(out, 0), 4); put(", ")
    putf(get_f32(out, 1), 4); put("]   expect [7, 11]\n")

    dealloc(q); dealloc(kc); dealloc(vc); dealloc(out)
}

fn test_seq2_balanced() {
    put("-- Test 2: seq_len=2 balanced softmax --\n")
    u64 n_heads = 1
    u64 n_kv = 1
    u64 hd = 2
    u64 max_seq = 4

    u64 q = alloc(n_heads * hd * 4)
    u64 kc = alloc(max_seq * n_kv * hd * 4)
    u64 vc = alloc(max_seq * n_kv * hd * 4)
    u64 out = alloc(n_heads * hd * 4)

    // Q = [[1, 1]]
    set_f32(q, 0, 1.0f); set_f32(q, 1, 1.0f)
    // K[0] = [1, 0]; V[0] = [0.1, 0.2]
    set_f32(kc, 0, 1.0f); set_f32(kc, 1, 0.0f)
    set_f32(vc, 0, 0.1f); set_f32(vc, 1, 0.2f)
    // K[1] = [0, 1]; V[1] = [0.3, 0.4]
    set_f32(kc, 2, 0.0f); set_f32(kc, 3, 1.0f)
    set_f32(vc, 2, 0.3f); set_f32(vc, 3, 0.4f)

    qwen3_attn_cached(out, q, kc, vc, 2, n_heads, n_kv, hd)

    put("  out = [")
    putf(get_f32(out, 0), 4); put(", ")
    putf(get_f32(out, 1), 4); put("]   expect [0.2, 0.3]\n")

    dealloc(q); dealloc(kc); dealloc(vc); dealloc(out)
}

fn test_seq2_asymmetric() {
    put("-- Test 3: seq_len=2 asymmetric (max-subtraction test) --\n")
    u64 n_heads = 1
    u64 n_kv = 1
    u64 hd = 2
    u64 max_seq = 4

    u64 q = alloc(n_heads * hd * 4)
    u64 kc = alloc(max_seq * n_kv * hd * 4)
    u64 vc = alloc(max_seq * n_kv * hd * 4)
    u64 out = alloc(n_heads * hd * 4)

    // Q = [[1, 0]]
    set_f32(q, 0, 1.0f); set_f32(q, 1, 0.0f)
    // K[0] = [3, 0]; V[0] = [1, 0]
    set_f32(kc, 0, 3.0f); set_f32(kc, 1, 0.0f)
    set_f32(vc, 0, 1.0f); set_f32(vc, 1, 0.0f)
    // K[1] = [0, 0.5]; V[1] = [0, 1]
    set_f32(kc, 2, 0.0f); set_f32(kc, 3, 0.5f)
    set_f32(vc, 2, 0.0f); set_f32(vc, 3, 1.0f)

    qwen3_attn_cached(out, q, kc, vc, 2, n_heads, n_kv, hd)

    put("  out = [")
    putf(get_f32(out, 0), 4); put(", ")
    putf(get_f32(out, 1), 4); put("]   expect [0.893, 0.107]\n")

    dealloc(q); dealloc(kc); dealloc(vc); dealloc(out)
}

fn main() {
    test_seq1()
    test_seq2_balanced()
    test_seq2_asymmetric()
    exit(0)
}
