// KernRift self-hosted compiler -- AArch64 IR backend
//
// Emits ARM64 machine code from the shared SSA IR infrastructure (ir.kr).
// Uses the graph-colouring register allocator with 10 callee-saved registers
// (x19-x28) and the emit_a64_* instruction helpers from codegen_aarch64.kr.
//
// Frame layout (growing downward):
//   [old SP]
//     x29, x30          (STP, 16 bytes)
//     x19-x28           (5 STP pairs, 80 bytes)
//     spill slots        (ir_spill_count * 8 bytes, 16-aligned)
//   [new SP]

// Scratchpad offset within frame: a permanent 32-byte area reserved in the
// prologue for mid-function temp buffers (fmt_uint digits, timespec, argv, etc).
// Avoids dynamic SP shifts that would invalidate spill slot addresses.
static uint64 ir_a64_scratch_off = 0

// ADD Xd, SP, Xm  (extended register form, needed because register 31
// in the standard ADD encoding means XZR, not SP)
fn ir_a64_add_sp_reg(uint64 rd, uint64 rm) {
    // ADD Xd, SP, Xm, UXTX #0: 0x8B206000 | (Xm << 16) | (31 << 5) | Xd
    uint64 insn = 0x8B206000 | (rm << 16) | (31 << 5) | rd
    emit_a64(insn)
}

// STP Xt1, Xt2, [SP, #off]  — store-pair of two 64-bit regs at one
// 8-byte-aligned offset. Halves prologue size (one insn per pair vs
// two STRs). Offset must be multiple of 8 in range 0..504 for the
// unsigned form we use here.
fn ir_a64_stp_sp(uint64 rt1, uint64 rt2, uint64 off) {
    uint64 imm7 = (off / 8) & 0x7F
    uint64 insn = 0xA9000000 | (imm7 << 15) | (rt2 << 10) | (31 << 5) | rt1
    emit_a64(insn)
}

// LDP Xt1, Xt2, [SP, #off]
fn ir_a64_ldp_sp(uint64 rt1, uint64 rt2, uint64 off) {
    uint64 imm7 = (off / 8) & 0x7F
    uint64 insn = 0xA9400000 | (imm7 << 15) | (rt2 << 10) | (31 << 5) | rt1
    emit_a64(insn)
}

// ---------------------------------------------------------------------------
// Register allocator setup for ARM64
// ---------------------------------------------------------------------------

fn ir_regalloc_init_arm64() {
    // Allocate or reuse the phys_regs table (10 entries for ARM64; x86's
    // ir_regalloc_init now also allocates 10 so the buffer is reusable).
    IR_NUM_REGS = 10
    if ir_phys_regs == 0 { ir_phys_regs = alloc(10 * 8) }
    uint64 p0 = ir_phys_regs
    unsafe { *(p0 as uint64) = 19 }       // color 0 -> x19
    uint64 p1 = ir_phys_regs + 8
    unsafe { *(p1 as uint64) = 20 }       // color 1 -> x20
    uint64 p2 = ir_phys_regs + 16
    unsafe { *(p2 as uint64) = 21 }       // color 2 -> x21
    uint64 p3 = ir_phys_regs + 24
    unsafe { *(p3 as uint64) = 22 }       // color 3 -> x22
    uint64 p4 = ir_phys_regs + 32
    unsafe { *(p4 as uint64) = 23 }       // color 4 -> x23
    uint64 p5 = ir_phys_regs + 40
    unsafe { *(p5 as uint64) = 24 }       // color 5 -> x24
    uint64 p6 = ir_phys_regs + 48
    unsafe { *(p6 as uint64) = 25 }       // color 6 -> x25
    uint64 p7 = ir_phys_regs + 56
    unsafe { *(p7 as uint64) = 26 }       // color 7 -> x26
    uint64 p8 = ir_phys_regs + 64
    unsafe { *(p8 as uint64) = 27 }       // color 8 -> x27
    uint64 p9 = ir_phys_regs + 72
    unsafe { *(p9 as uint64) = 28 }       // color 9 -> x28
}

// ---------------------------------------------------------------------------
// ARM64 spill helpers
// ---------------------------------------------------------------------------

// Number of bytes reserved at the BOTTOM of every function's stack
// frame to hold overflow-call-arguments (args 9+ under AAPCS64). With
// this space pre-reserved the SP-at-BL already points at the arg slots
// (callee reads `[SP + callee_frame + (idx-8)*8]` and finds our
// values), so we never SUB SP around a call — SUB would invalidate
// every spill offset we need to read between the overflow args.
// 128 = 16 slots, more than any call in the compiler today needs.
static uint64 IR_A64_OVERFLOW_RESERVE = 128

// Compute the spill slot offset for a spilled vreg. Spill slots live
// above the overflow-arg reservation so they remain addressable at a
// stable offset across calls.
fn ir_a64_spill_offset(uint64 vreg) -> uint64 {
    uint64 slot = vreg - IR_NUM_REGS - 1
    return IR_A64_OVERFLOW_RESERVE + slot * 8
}

// Peephole tracking for spill-reload elision (same pattern as the x86
// backend uses in ir.kr). If the last bytes emitted were exactly
// `store_spill reg, vreg` and the very next emission would be
// `load_spill reg, vreg` (same reg + same vreg, no bytes in between),
// the reload is redundant — the value is still in the register.
static uint64 ir_a64_last_spill_vreg = 0xFFFFFFFF
static uint64 ir_a64_last_spill_reg = 0xFFFFFFFF
static uint64 ir_a64_last_spill_end = 0xFFFFFFFFFFFFFFFF

@export
fn ir_a64_peephole_reset() {
    ir_a64_last_spill_vreg = 0xFFFFFFFF
    ir_a64_last_spill_reg = 0xFFFFFFFF
    ir_a64_last_spill_end = 0xFFFFFFFFFFFFFFFF
}

// Load a spilled vreg into scratch register (x9 or x10).
// ARM64 LDR Xt,[Xn,#imm] uses a 12-bit scaled field: max offset = 4095*8 = 32760.
// For larger offsets, use a scratch register to form the address.
fn ir_a64_load_spill(uint64 scratch, uint64 vreg) {
    // Peephole: if the prior emission was `store_spill scratch, vreg`
    // and nothing's been emitted since, the value is still in scratch.
    if vreg == ir_a64_last_spill_vreg && scratch == ir_a64_last_spill_reg && out_len == ir_a64_last_spill_end {
        ir_a64_last_spill_end = 0xFFFFFFFFFFFFFFFF   // one-shot
        return
    }
    uint64 off = ir_a64_spill_offset(vreg)
    ir_a64_ldr_sp(scratch, off)
}

// Store a register to the spill slot for vreg.
fn ir_a64_emit_store_spill(uint64 reg, uint64 vreg) {
    uint64 off = ir_a64_spill_offset(vreg)
    ir_a64_str_sp(reg, off)
    ir_a64_last_spill_vreg = vreg
    ir_a64_last_spill_reg = reg
    ir_a64_last_spill_end = out_len
}

// Large-offset-safe LDR/STR from SP.
// ARM64 LDR Xt,[Xn,#imm] max offset = 4095*8 = 32760 bytes.
// For larger offsets, compute address in x11 first.
fn ir_a64_ldr_sp(uint64 rt, uint64 off) {
    if off <= 32760 {
        emit_a64_ldr(rt, 31, off)
    } else {
        emit_a64_mov_imm(11, off)
        ir_a64_add_sp_reg(11, 11)
        emit_a64_ldr(rt, 11, 0)
    }
}

fn ir_a64_str_sp(uint64 rt, uint64 off) {
    if off <= 32760 {
        emit_a64_str(rt, 31, off)
    } else {
        emit_a64_mov_imm(11, off)
        ir_a64_add_sp_reg(11, 11)
        emit_a64_str(rt, 11, 0)
    }
}

// Resolve a vreg to a physical register. If spilled, load into scratch (9 or 10).
fn ir_a64_resolve_src(uint64 vreg, uint64 scratch) -> uint64 {
    if vreg == 0 { return scratch }
    uint64 phys = ir_get_phys_reg(vreg)
    if phys != 0xFFFFFFFF { return phys }
    ir_a64_load_spill(scratch, vreg)
    return scratch
}

// ---------------------------------------------------------------------------
// ARM64 syscall number mapping
// ---------------------------------------------------------------------------
// The IR uses x86_64 Linux abstract syscall numbers. Map to ARM64 Linux.

fn ir_a64_syscall_nr(uint64 abstract_nr) -> uint64 {
    if target_os == 1 {
        // macOS ARM64: same numbers as macOS x86_64 (with 0x2000000 prefix removed,
        // macOS ARM64 uses the raw Darwin numbers directly)
        if abstract_nr == 231 { return 1 }    // exit_group -> exit(1)
        if abstract_nr == 1 { return 4 }      // write -> 4
        if abstract_nr == 0 { return 3 }      // read -> 3
        if abstract_nr == 2 { return 5 }      // open -> 5
        if abstract_nr == 3 { return 6 }      // close -> 6
        if abstract_nr == 8 { return 199 }    // lseek -> 199
        if abstract_nr == 9 { return 197 }    // mmap -> 197
        if abstract_nr == 11 { return 73 }    // munmap -> 73
        if abstract_nr == 59 { return 59 }    // execve -> 59
        if abstract_nr == 228 { return 228 }  // clock_gettime
        if abstract_nr == 15 { return 15 }    // chmod
        if abstract_nr == 90 { return 15 }    // fchmod -> chmod
        if abstract_nr == 257 { return 5 }    // openat -> open
        return abstract_nr
    }
    // Linux (0) and Android (3): ARM64 Linux syscall numbers
    if abstract_nr == 231 { return 93 }    // exit_group -> exit (93)
    if abstract_nr == 1 { return 64 }      // write -> 64
    if abstract_nr == 0 { return 63 }      // read -> 63
    if abstract_nr == 2 { return 56 }      // open -> openat (56)
    if abstract_nr == 3 { return 57 }      // close -> 57
    if abstract_nr == 8 { return 62 }      // lseek -> 62
    if abstract_nr == 9 { return 222 }     // mmap -> 222
    if abstract_nr == 11 { return 215 }    // munmap -> 215
    if abstract_nr == 59 { return 221 }    // execve -> 221
    if abstract_nr == 228 { return 113 }   // clock_gettime -> 113
    if abstract_nr == 15 { return 53 }     // chmod -> fchmodat (53)
    if abstract_nr == 90 { return 53 }     // fchmod -> fchmodat (53)
    if abstract_nr == 257 { return 56 }    // openat -> 56
    return abstract_nr
}

// ---------------------------------------------------------------------------
// ARM64 Windows syscall emitter (IAT-based)
// ---------------------------------------------------------------------------

fn ir_emit_arm64_win_syscall(uint64 abstract_nr, uint64 dest_v, uint64 dst_r) {
    if abstract_nr == 231 {
        // exit(code): ExitProcess(x0=exit_code)
        // IR_ARG already placed exit code in x0, no shuffling needed
        emit_a64_win_call_iat(0)
        return
    }

    if abstract_nr == 1 {
        // write(fd, buf, len): IR_ARG placed fd=x0, buf=x1, len=x2
        // If fd <= 2, convert via GetStdHandle; otherwise fd is already a handle.
        // Save buf and len across GetStdHandle call
        emit_a64_mov(11, 1)               // x11 = buf (save)
        emit_a64_mov(12, 2)               // x12 = len (save)
        // Check if fd <= 2: CMP x0, #2; B.HI skip_getstdhandle
        emit_a64_mov_imm(9, 2)
        emit_a64_cmp(0, 9)
        // B.HI +8 insns: skip NEG(1)+MOVZ(1)+SUB(1)+IAT(3)+B(1) = 7 insns, land on NOP at +8
        emit_a64(0x54000108)              // B.HI +8 insns (32 bytes)
        // GetStdHandle: x0 = -(fd + 10)
        emit_a64_neg(0, 0)
        emit_a64_mov_imm(9, 10)
        emit_a64_sub(0, 0, 9)
        emit_a64_win_call_iat(1)          // GetStdHandle -> x0 = handle
        emit_a64(0x14000002)              // B +2 (skip NOP, land on common path)
        // skip_getstdhandle: fd > 2, x0 already holds the native handle
        emit_a64(0xD503201F)              // NOP (landing pad for B.HI)
        // WriteFile(handle=x0, buf=x1, len=x2, &written=x3, overlapped=x4=NULL).
        // MSDN: lpNumberOfBytesWritten may be NULL only when lpOverlapped is
        // non-NULL. We do synchronous writes, so a real scratch slot is
        // required. Allocate 16 bytes on the stack for alignment, pre-zero
        // the DWORD slot, and point x3 at it; the value isn't read back
        // because write() ignores its return count for now.
        emit_a64_sub_sp_imm(16)           // sub sp, sp, #16
        emit_a64_mov_imm(9, 0)
        emit_a64(0xF90003E9)              // str x9, [sp]   — pre-zero
        emit_a64(0x910003E3)              // add x3, sp, #0 (&written)
        emit_a64_mov_imm(4, 0)            // x4 = NULL (overlapped)
        emit_a64_mov(2, 12)               // x2 = len
        emit_a64_mov(1, 11)               // x1 = buf
        emit_a64_win_call_iat(2)          // WriteFile
        emit_a64_add_sp_imm(16)           // add sp, sp, #16
    }

    if abstract_nr == 0 {
        // read(fd, buf, len): IR_ARG placed fd=x0, buf=x1, len=x2
        // If fd <= 2, convert via GetStdHandle.
        emit_a64_mov(11, 1)               // x11 = buf (save)
        emit_a64_mov(12, 2)               // x12 = len (save)
        emit_a64_mov_imm(9, 2)
        emit_a64_cmp(0, 9)
        // B.HI +8 insns: skip NEG(1)+MOVZ(1)+SUB(1)+IAT(3)+B(1) = 7 insns, land on NOP at +8
        emit_a64(0x54000108)              // B.HI +8 insns (32 bytes)
        // GetStdHandle: x0 = -(fd + 10)
        emit_a64_neg(0, 0)
        emit_a64_mov_imm(9, 10)
        emit_a64_sub(0, 0, 9)
        emit_a64_win_call_iat(1)          // GetStdHandle -> x0 = handle
        emit_a64(0x14000002)              // B +2 (skip NOP, land on common path)
        emit_a64(0xD503201F)              // NOP (landing pad for B.HI)
        // ReadFile(handle=x0, buf=x1, len=x2, &bytesRead=x3, overlapped=x4=NULL).
        // The 4th arg MUST be a real DWORD*: ReadFile returns BOOL in x0, and
        // without an out-slot we'd hand that BOOL back as file_read's byte
        // count (which made the CI test read 1 instead of 8 on ARM64 Windows).
        // Use [sp,#0] as an aligned 8-byte scratch slot for the DWORD.
        emit_a64_sub_sp_imm(16)           // sub sp, sp, #16
        emit_a64_mov_imm(9, 0)
        emit_a64(0xF90003E9)              // str x9, [sp]   — pre-zero the slot
        emit_a64(0x910003E3)              // add x3, sp, #0 (&bytesRead)
        emit_a64_mov_imm(4, 0)            // x4 = NULL (overlapped)
        emit_a64_mov(2, 12)               // x2 = len
        emit_a64_mov(1, 11)               // x1 = buf
        emit_a64_win_call_iat(4)          // ReadFile
        emit_a64(0xB94003E0)              // ldr w0, [sp]   — bytesRead (zero-extends)
        emit_a64_add_sp_imm(16)           // add sp, sp, #16
    }

    if abstract_nr == 2 {
        // open(path, flags): IR_ARG placed path=x0, flags=x1
        // CreateFileA(path, access, share, security, disposition, flags, template)
        // Save path and flags
        emit_a64_mov(11, 0)               // x11 = path
        emit_a64_mov(12, 1)               // x12 = flags (0=read, nonzero=write)
        // Compute access: if flags==0 -> GENERIC_READ (0x80000000), else GENERIC_WRITE (0x40000000)
        emit_a64_mov_imm(1, 0x80000000)   // default: GENERIC_READ (2 insns: MOVZ+MOVK)
        emit_a64_cbz(12, 12)              // if flags==0, skip GENERIC_WRITE (2 insns = 8 bytes)
        emit_a64_mov_imm(1, 0x40000000)   // GENERIC_WRITE (2 insns: MOVZ+MOVK)
        // x2 = FILE_SHARE_READ = 1
        emit_a64_mov_imm(2, 1)
        // x3 = NULL (security)
        emit_a64_mov_imm(3, 0)
        // x4 = disposition: if flags==0 -> OPEN_EXISTING(3), else CREATE_ALWAYS(2)
        emit_a64_mov_imm(4, 3)            // default: OPEN_EXISTING (1 insn)
        emit_a64_cbz(12, 8)               // if flags==0, skip CREATE_ALWAYS (1 insn = 4 bytes)
        emit_a64_mov_imm(4, 2)            // CREATE_ALWAYS (1 insn)
        // x5 = FILE_ATTRIBUTE_NORMAL = 0x80
        emit_a64_mov_imm(5, 0x80)
        // x6 = NULL (template)
        emit_a64_mov_imm(6, 0)
        // x0 = path
        emit_a64_mov(0, 11)
        emit_a64_win_call_iat(3)          // CreateFileA
    }

    if abstract_nr == 3 {
        // close(fd): CloseHandle(x0=handle)
        // IR_ARG already placed handle in x0
        emit_a64_win_call_iat(5)          // CloseHandle
    }

    if abstract_nr == 8 {
        // lseek(fd, offset, whence): GetFileSizeEx(handle, &size)
        // Used by file_size() builtin. SEEK_SET rewind return is unused, so this is safe.
        // IR_ARG: x0=handle, x1=offset, x2=whence
        // Allocate 16 bytes on scratchpad for output
        emit_a64_add_imm(11, 31, ir_a64_scratch_off)
        // Zero the output area
        emit_a64_mov_imm(9, 0)
        emit_a64_str(9, 11, 0)
        // x1 = &output (X11)
        emit_a64_mov(1, 11)
        // x0 = handle (already in place)
        emit_a64_win_call_iat(8)          // GetFileSizeEx
        // x11 is caller-saved (x0..x18) and is clobbered by the IAT call.
        // Recompute it from SP before loading the result — otherwise the
        // ldr dereferences whatever GetFileSizeEx left in x11 and the
        // process segfaults deep inside compile() the moment anyone calls
        // file_size() on Windows ARM64.
        emit_a64_add_imm(11, 31, ir_a64_scratch_off)
        // Load size from [X11]
        emit_a64_ldr(0, 11, 0)
    }

    // Move result to dest
    if dst_r != 0xFFFFFFFF && dst_r != 0 {
        emit_a64_mov(dst_r, 0)
    }
    if dst_r == 0xFFFFFFFF {
        ir_a64_emit_store_spill(0, dest_v)
    }
}

// ---------------------------------------------------------------------------
// Per-instruction emitter
// ---------------------------------------------------------------------------

fn ir_emit_arm64_insn(uint64 ii) {
    uint64 op = ir_insn_opcode(ii)
    uint64 dest_v = ir_insn_dest(ii)
    uint64 s1_v = ir_insn_src1(ii)
    uint64 s2_v = ir_insn_src2(ii)
    uint64 imm = ir_insn_imm(ii)

    // DWARF line-table recording — see ir.kr's ir_emit_x86_insn.
    uint64 ir_src_tok = ir_insn_src_tok_at(ii)
    if ir_src_tok != 0 { line_table_record(ir_src_tok) }

    uint64 dst_r = ir_get_phys_reg(dest_v)

    // ----- IR_STR_CONST (79): dst = lea string data -----
    if op == 79 {
        uint64 str_offset = imm
        // emit_a64_static_lea puts address in x0
        // Record string fixup
        if str_fixup_count >= 4096 {
            write(2, "error: str_fixups overflow (max 4096)\n", 38)
            exit(1)
        }
        uint64 fentry = str_fixups + str_fixup_count * 8
        uint32 cp = out_len
        unsafe { *(fentry as uint32) = cp }
        uint64 fe4 = fentry + 4
        uint32 so = str_offset
        unsafe { *(fe4 as uint32) = so }
        str_fixup_count = str_fixup_count + 1
        // ADRP + ADD sequence (patched by static fixup resolver)
        emit_a64(0x90000010)    // ADRP X16, #0
        emit_a64(0x91000200)    // ADD X0, X16, #0
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 0)
        } else {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
    }

    // ----- IR_CONST (1): dst = imm64 -----
    if op == 1 {
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov_imm(dst_r, imm)
        } else {
            emit_a64_mov_imm(9, imm)
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_ADD (2) -----
    if op == 2 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_add(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_SUB (3) -----
    if op == 3 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_sub(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_MUL (4) -----
    if op == 4 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_mul(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_DIV (5) -----
    if op == 5 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        // Debug-mode div-by-zero trap: ARM64 UDIV silently returns 0
        // for b==0 (no CPU trap), unlike x86 DIV which #DE's. Emit an
        // explicit exit(1) guard so programs behave the same under
        // --debug on both architectures.
        if debug_mode != 0 {
            uint64 dz_cbnz = out_len
            emit_a64(0xB5000000 | (b_reg & 0x1F))   // CBNZ xB, skip — patched below
            emit_a64_mov_imm(0, 1)
            emit_a64_mov_imm(8, 93)                  // exit syscall
            emit_a64_svc()
            uint64 dz_delta = (out_len - dz_cbnz) / 4
            patch_u32(dz_cbnz, 0xB5000000 | ((dz_delta & 0x7FFFF) << 5) | (b_reg & 0x1F))
        }
        emit_a64_udiv(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_MOD (6): dst = src1 % src2 = src1 - (src1/src2)*src2 -----
    if op == 6 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        if debug_mode != 0 {
            uint64 dz_cbnz = out_len
            emit_a64(0xB5000000 | (b_reg & 0x1F))
            emit_a64_mov_imm(0, 1)
            emit_a64_mov_imm(8, 93)
            emit_a64_svc()
            uint64 dz_delta = (out_len - dz_cbnz) / 4
            patch_u32(dz_cbnz, 0xB5000000 | ((dz_delta & 0x7FFFF) << 5) | (b_reg & 0x1F))
        }
        // x11 = a / b
        emit_a64_udiv(11, a_reg, b_reg)
        // d = a - x11 * b (MSUB d, x11, b, a)
        emit_a64_msub(d, 11, b_reg, a_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_AND (7) -----
    if op == 7 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_and(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_OR (8) -----
    if op == 8 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_orr(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_XOR (9) -----
    if op == 9 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_eor(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_SHL (10) -----
    if op == 10 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_lsl(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_SHR (11) -----
    if op == 11 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_lsr(d, a_reg, b_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_NEG (12) -----
    if op == 12 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_neg(d, a_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_NOT (13) -----
    if op == 13 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_mvn(d, a_reg)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_CMP_EQ (14) through IR_CMP_GE (19) -----
    if op >= 14 && op <= 19 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        emit_a64_cmp(a_reg, b_reg)
        // ARM64 condition codes for unsigned comparisons:
        // EQ=0, NE=1, LO(CC)=3, LS=9, HI=8, HS(CS)=2
        uint64 cond = 0
        if op == 14 { cond = 0 }   // EQ
        if op == 15 { cond = 1 }   // NE
        if op == 16 { cond = 3 }   // LO (unsigned <)
        if op == 17 { cond = 9 }   // LS (unsigned <=)
        if op == 18 { cond = 8 }   // HI (unsigned >)
        if op == 19 { cond = 2 }   // HS (unsigned >=)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_cset(d, cond)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_SCMP_LT (120) through IR_SCMP_GE (123) -----
    if op >= 120 && op <= 123 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 b_reg = ir_a64_resolve_src(s2_v, 10)
        emit_a64_cmp(a_reg, b_reg)
        // Signed condition codes: LT=11, LE=13, GT=12, GE=10
        uint64 cond = 0
        if op == 120 { cond = 11 }  // LT
        if op == 121 { cond = 13 }  // LE
        if op == 122 { cond = 12 }  // GT
        if op == 123 { cond = 10 }  // GE
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_cset(d, cond)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_LOAD (30): dest = *(src1), width in imm -----
    if op == 30 {
        uint64 addr_reg = ir_a64_resolve_src(s1_v, 10)
        if imm == 0 && s2_v != 0 { imm = s2_v }
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        if imm == 8 {
            emit_a64_ldr(d, addr_reg, 0)
        } else if imm == 4 {
            emit_a64_ldr32(d, addr_reg, 0)
        } else if imm == 2 {
            emit_a64_ldrh(d, addr_reg, 0)
        } else {
            emit_a64_ldrb(d, addr_reg, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_STORE (31): *(src1) = src2, width in dest_v -----
    if op == 31 {
        uint64 addr_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 val_reg = ir_a64_resolve_src(s2_v, 10)
        uint64 width = dest_v
        if width == 8 {
            emit_a64_str(val_reg, addr_reg, 0)
        } else if width == 4 {
            emit_a64_str32(val_reg, addr_reg, 0)
        } else if width == 2 {
            emit_a64_strh(val_reg, addr_reg, 0)
        } else {
            emit_a64_strb(val_reg, addr_reg, 0)
        }
        return
    }

    // ----- IR_STACK_ADDR (32): compute address of stack slot -----
    if op == 32 {
        // imm = offset from frame base (spill area start)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_add_imm(d, 31, imm)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_COPY (61) -----
    if op == 61 {
        if s1_v != 0 {
            uint64 src_reg = ir_a64_resolve_src(s1_v, 9)
            if dst_r != 0xFFFFFFFF {
                emit_a64_mov(dst_r, src_reg)
            } else {
                if src_reg != 9 { emit_a64_mov(9, src_reg) }
                ir_a64_emit_store_spill(9, dest_v)
            }
        } else {
            // Param init: imm = param index
            // AAPCS64: x0-x7 for first 8 params
            if imm < 8 {
                uint64 pr = imm
                if dst_r != 0xFFFFFFFF {
                    emit_a64_mov(dst_r, pr)
                } else {
                    emit_a64_mov(9, pr)
                    ir_a64_emit_store_spill(9, dest_v)
                }
            } else if imm >= 100 {
                // ASM output: read from physical register (imm - 100)
                uint64 phys_src = imm - 100
                if dst_r != 0xFFFFFFFF {
                    emit_a64_mov(dst_r, phys_src)
                } else {
                    emit_a64_mov(9, phys_src)
                    ir_a64_emit_store_spill(9, dest_v)
                }
            } else {
                // Overflow param (8+): load from caller stack frame
                // After prologue: [SP + frame_size] = saved regs start
                // caller stack args at [SP + frame_size + (imm-8)*8]
                uint64 overflow_off = ir_frame_size + (imm - 8) * 8
                uint64 d = dst_r
                if d == 0xFFFFFFFF { d = 9 }
                ir_a64_ldr_sp(d, overflow_off)
                if dst_r == 0xFFFFFFFF {
                    ir_a64_emit_store_spill(9, dest_v)
                }
            }
        }
        return
    }

    // ----- IR_RET (42): move result to x0 then branch to epilogue -----
    if op == 42 {
        uint64 ret_r = ir_a64_resolve_src(s1_v, 9)
        if ret_r != 0 { emit_a64_mov(0, ret_r) }
        // B to epilogue (patched later)
        uint64 rfp = ir_ret_fixups + ir_ret_fixup_count * 4
        uint32 rpo = out_len
        unsafe { *(rfp as uint32) = rpo }
        ir_ret_fixup_count = ir_ret_fixup_count + 1
        emit_a64(0x14000000)    // B #0 (placeholder)
        return
    }

    // ----- IR_RET_VOID (43): branch to epilogue -----
    if op == 43 {
        uint64 rfp = ir_ret_fixups + ir_ret_fixup_count * 4
        uint32 rpo = out_len
        unsafe { *(rfp as uint32) = rpo }
        ir_ret_fixup_count = ir_ret_fixup_count + 1
        emit_a64(0x14000000)    // B #0 (placeholder)
        return
    }

    // ----- IR_ARG (51): move value to argument register x0-x7 -----
    if op == 51 {
        // AAPCS64: x0-x7 for first 8 arguments
        if imm < 8 {
            uint64 target = imm
            uint64 src_reg = ir_a64_resolve_src(s1_v, 9)
            emit_a64_mov(target, src_reg)
        } else if imm >= 100 {
            // Direct register target (ASM I/O constraints)
            uint64 phys_target = imm - 100
            uint64 src_reg = ir_a64_resolve_src(s1_v, 9)
            emit_a64_mov(phys_target, src_reg)
        } else {
            // Overflow arg (AAPCS64: the 9th+ parameter). The caller's
            // frame already reserves IR_A64_OVERFLOW_RESERVE bytes at
            // the bottom, so SP at the upcoming BL will sit exactly on
            // top of those slots — no SUB/ADD needed. Just STR the
            // arg value at [SP + (imm-8)*8].
            uint64 oi = imm - 8
            if oi < 16 {
                uint64 src_reg = ir_a64_resolve_src(s1_v, 9)
                ir_a64_str_sp(src_reg, oi * 8)
            }
        }
        return
    }

    // ----- IR_CALL (50): bl with fixup -----
    if op == 50 {
        // Overflow args (>8 args) were already written to [SP + oi*8]
        // by IR_ARG — the caller's bottom-of-frame overflow reserve
        // lines them up with the callee's arg-9 slot.
        uint64 call_patch = out_len
        emit_a64(0x94000000)    // BL #0 (placeholder)
        // Record fixup: imm holds the callee token
        uint64 fentry = fixup_table + fixup_count * 8
        uint32 fo = call_patch
        unsafe { *(fentry as uint32) = fo }
        uint64 fe4 = fentry + 4
        uint32 ct = imm
        unsafe { *(fe4 as uint32) = ct }
        fixup_count = fixup_count + 1
        ir_overflow_arg_count = 0
        // Result in x0
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            emit_a64_mov(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
    }

    // ----- IR_SYSCALL (52) -----
    if op == 52 {
        if target_os == 2 {
            ir_emit_arm64_win_syscall(imm, dest_v, dst_r)
            return
        }
        // ARM64 Linux/Android: open(2) → openat(56) needs arg shift
        // IR_ARG sets x0=path, x1=flags, x2=mode
        // openat needs x0=AT_FDCWD(-100), x1=path, x2=flags, x3=mode
        if imm == 2 && target_os != 1 {
            emit_a64_mov(3, 2)          // x3 = mode (was x2)
            emit_a64_mov(2, 1)          // x2 = flags (was x1)
            emit_a64_mov(1, 0)          // x1 = path (was x0)
            emit_a64_mov_imm(0, 0xFFFFFFFFFFFFFF9C)  // x0 = AT_FDCWD (-100)
        }
        // Map abstract syscall number to ARM64 number
        uint64 real_nr = ir_a64_syscall_nr(imm)
        emit_a64_syscall_nr(real_nr)
        emit_a64_svc()
        // Result in x0
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            emit_a64_mov(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
    }

    // ----- IR_ALLOC (70): inline mmap / VirtualAlloc -----
    if op == 70 {
        // src1 = size vreg (if != 0), or imm = constant size
        uint64 size_reg = 0
        if s1_v != 0 {
            size_reg = ir_a64_resolve_src(s1_v, 9)
        } else {
            emit_a64_mov_imm(9, imm)
            size_reg = 9
        }
        // Save original size in x11 (scratch)
        emit_a64_mov(11, size_reg)
        if target_os == 2 {
            // Windows ARM64: VirtualAlloc(NULL, size+8, MEM_COMMIT|MEM_RESERVE, PAGE_READWRITE)
            emit_a64_mov_imm(0, 0)
            emit_a64_add_imm(1, size_reg, 8)
            emit_a64_mov_imm(2, 0x3000)
            emit_a64_mov_imm(3, 4)
            emit_a64_win_call_iat(6)
            // x0 = raw ptr. Store header: [x0] = original size (x11)
            emit_a64_str(11, 0, 0)
            // x0 = x0 + 8 (return ptr past header)
            emit_a64_add_imm(0, 0, 8)
        } else {
            // AAPCS64 mmap: x0=addr, x1=len, x2=prot, x3=flags, x4=fd, x5=offset
            // x0 = 0 (addr)
            emit_a64_mov_imm(0, 0)
            // x1 = size + 8
            emit_a64_add_imm(1, size_reg, 8)
            // x2 = PROT_READ|PROT_WRITE = 3
            emit_a64_mov_imm(2, 3)
            // x3 = MAP_PRIVATE|MAP_ANON — 0x22 on Linux, 0x1002 on macOS. The
            // old hardcoded 0x22 made every mmap on macOS ARM64 return an
            // invalid pointer, which is what SIGSEGV'd the alloc/fileio tests
            // and every self-compile on native arm64 macOS CI.
            uint64 a64_mmap_flags = 0x22
            if target_os == 1 { a64_mmap_flags = 0x1002 }
            emit_a64_mov_imm(3, a64_mmap_flags)
            // x4 = -1 (fd)
            emit_a64_mov_imm(4, 0xFFFFFFFFFFFFFFFF)
            // x5 = 0 (offset)
            emit_a64_mov_imm(5, 0)
            // syscall (mmap)
            uint64 mmap_nr = ir_a64_syscall_nr(9)
            emit_a64_syscall_nr(mmap_nr)
            emit_a64_svc()
            // x0 = raw ptr. Store header: [x0] = original size (x11)
            emit_a64_str(11, 0, 0)
            // x0 = x0 + 8 (return ptr past header)
            emit_a64_add_imm(0, 0, 8)
        }
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            emit_a64_mov(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
    }

    // ----- IR_DEALLOC (71): inline munmap / VirtualFree -----
    if op == 71 {
        uint64 ptr_reg = ir_a64_resolve_src(s1_v, 9)
        if target_os == 2 {
            // Windows ARM64: VirtualFree(ptr-8, 0, MEM_RELEASE=0x8000)
            emit_a64_mov_imm(10, 8)
            emit_a64_sub(0, ptr_reg, 10)
            emit_a64_mov_imm(1, 0)
            emit_a64_mov_imm(2, 0x8000)
            emit_a64_win_call_iat(13)
        } else {
            // x0 = ptr - 8 (real base)
            emit_a64_mov_imm(10, 8)
            emit_a64_sub(0, ptr_reg, 10)
            // x1 = *(x0) + 8 (total length)
            emit_a64_ldr(1, 0, 0)
            emit_a64_add_imm(1, 1, 8)
            // munmap syscall
            uint64 munmap_nr = ir_a64_syscall_nr(11)
            emit_a64_syscall_nr(munmap_nr)
            emit_a64_svc()
        }
        return
    }

    // ----- IR_MEMCPY (72): byte copy loop -----
    if op == 72 {
        uint64 mc_dst = ir_a64_resolve_src(s1_v, 9)
        uint64 mc_src = ir_a64_resolve_src(s2_v, 10)
        // Resolve len from imm (stored as vreg index)
        uint64 mc_len_vreg = imm
        uint64 mc_len = 0
        if mc_len_vreg > 0 && mc_len_vreg < ir_vreg_next {
            mc_len = ir_get_phys_reg(mc_len_vreg)
            if mc_len == 0xFFFFFFFF {
                ir_a64_load_spill(11, mc_len_vreg)
                mc_len = 11
            }
        }
        // x0 = dst, x1 = src, x2 = len
        emit_a64_mov(0, mc_dst)
        emit_a64_mov(1, mc_src)
        emit_a64_mov(2, mc_len)
        // Save dst for return value
        emit_a64_mov(11, mc_dst)
        // Loop: CBZ x2, done; LDRB w3, [x1], #1; STRB w3, [x0], #1; SUB x2, x2, #1; B loop
        uint64 mc_loop = out_len
        // CBZ x2, done (skip 4 instructions = 16 bytes)
        emit_a64_cbz(2, 20)
        // LDRB w3, [x1], #1 (post-index byte load)
        emit_a64(0x38401423)
        // STRB w3, [x0], #1 (post-index byte store)
        emit_a64(0x38001403)
        // SUB x2, x2, #1
        emit_a64(0xD1000442)
        // B loop
        uint64 mc_back = mc_loop - out_len
        emit_a64(0x14000000 | ((mc_back / 4) & 0x3FFFFFF))
        // Return original dst
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 11)
        } else {
            emit_a64_mov(9, 11)
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_STRLEN (73): byte scan loop -----
    if op == 73 {
        uint64 sl_str = ir_a64_resolve_src(s1_v, 9)
        // x0 = str (current ptr), x1 = str (start)
        emit_a64_mov(0, sl_str)
        emit_a64_mov(1, sl_str)
        // Loop: LDRB w2, [x0]; CBZ w2, done; ADD x0, x0, #1; B loop
        uint64 sl_loop = out_len
        emit_a64_ldrb(2, 0, 0)
        // CBZ w2, done (skip 2 insns = 8 bytes) -- use 32-bit CBZ for byte register
        emit_a64(0x34000062)    // CBZ w2, +3 insns (12 bytes)
        emit_a64_add_imm(0, 0, 1)
        uint64 sl_back = sl_loop - out_len
        emit_a64(0x14000000 | ((sl_back / 4) & 0x3FFFFFF))
        // done: length = x0 - x1
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_sub(d, 0, 1)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_FMT_UINT (74): format uint to buffer -----
    if op == 74 {
        uint64 fu_buf = ir_a64_resolve_src(s1_v, 9)
        uint64 fu_val = ir_a64_resolve_src(s2_v, 10)
        // x0 = buf, x1 = val, x2 = digit count, x3 = divisor (10)
        emit_a64_mov(0, fu_buf)
        emit_a64_mov(1, fu_val)
        emit_a64_mov_imm(2, 0)
        emit_a64_mov_imm(3, 10)
        // Use the permanent 32-byte scratchpad in the frame (no SP shift)
        // x12 = SP + ir_a64_scratch_off (digit area base)
        emit_a64_mov_imm(12, ir_a64_scratch_off)
        ir_a64_add_sp_reg(12, 12)

        // Digit extraction loop: divide by 10, store remainder + '0'
        uint64 fu_loop = out_len
        emit_a64_udiv(4, 1, 3)       // x4 = val / 10
        emit_a64_msub(5, 4, 3, 1)    // x5 = val - (val/10)*10 = remainder
        emit_a64_add_imm(5, 5, 48)   // x5 += '0'
        // Store digit byte at [x12 + x2]
        // STRB w5, [x12, x2]
        emit_a64(0x38226985)
        // x2++
        emit_a64_add_imm(2, 2, 1)
        // val = quotient
        emit_a64_mov(1, 4)
        // CBNZ x1, loop
        uint64 fu_back = fu_loop - out_len
        emit_a64(0xB5000000 | (((fu_back / 4) & 0x7FFFF) << 5) | 1)

        // Copy digits in reverse order to output buffer
        // x6 = digit count (save)
        emit_a64_mov(6, 2)
        // Copy loop: x2 = remaining, x0 = output ptr
        uint64 fu_copy = out_len
        // CBZ x2, done
        emit_a64_cbz(2, 20)
        // x2--
        emit_a64(0xD1000442)    // SUB x2, x2, #1
        // LDRB w5, [x12, x2]
        emit_a64(0x38626985)
        // STRB w5, [x0], #1
        emit_a64(0x38001405)
        // B copy_loop
        uint64 fu_copy_back = fu_copy - out_len
        emit_a64(0x14000000 | ((fu_copy_back / 4) & 0x3FFFFFF))

        // Restore stack (removed, using static scratchpad)
        // emit_a64_add_sp_imm(32)

        // Return digit count (x6)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_mov(d, 6)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_STR_EQ (75): byte-by-byte string compare -----
    if op == 75 {
        uint64 se_a = ir_a64_resolve_src(s1_v, 9)
        uint64 se_b = ir_a64_resolve_src(s2_v, 10)
        emit_a64_mov(0, se_a)
        emit_a64_mov(1, se_b)
        // Loop: LDRB w2, [x0]; LDRB w3, [x1]; CMP w2, w3; B.NE not_equal;
        //       CBZ w2, equal; ADD x0,x0,1; ADD x1,x1,1; B loop
        uint64 se_loop = out_len
        emit_a64_ldrb(2, 0, 0)
        emit_a64_ldrb(3, 1, 0)
        // CMP w2, w3 (32-bit) — SUBS WZR, w2, w3 so flags are set but w2
        // is preserved. The old encoding used Rd=w2, which destroyed w2
        // whenever the bytes matched (SUBS w2,w2,w3 = 0), making the
        // subsequent CBZ w2 *always* treat equal-byte positions as
        // end-of-string and return 1 (equal) immediately. Classic case:
        // str_eq("ab","a") returned 1 because the first match byte 'a'
        // got subtracted into 0 and CBZ fired on the synthesized zero.
        emit_a64(0x6B03005F)
        // B.NE not_equal (+5 insns). imm19 field sits at [23:5], so the
        // instruction-count goes in bits 9:5 for small offsets — 5 << 5 = 0xA0.
        // The old constants here (0x54000141, 0x34000102) had imm19 shifted by
        // 6 instead of 5, doubling every branch offset and falling off the end
        // of the comparator — that made str_eq return the first byte instead
        // of a 0/1 result.
        emit_a64(0x540000A1)    // B.NE +5
        // CBZ w2, equal (+6 insns) — need 6 to hop over the back-edge
        // branch AND the not_equal path's MOVZ+B pair.
        emit_a64(0x340000C2)    // CBZ w2, +6
        emit_a64_add_imm(0, 0, 1)
        emit_a64_add_imm(1, 1, 1)
        uint64 se_back = se_loop - out_len
        emit_a64(0x14000000 | ((se_back / 4) & 0x3FFFFFF))
        // not_equal: result = 0
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        emit_a64_mov_imm(d, 0)
        // B done (+2 insns = 8 bytes)
        emit_a64(0x14000002)
        // equal: result = 1
        emit_a64_mov_imm(d, 1)
        // done:
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_MEMSET (76): byte fill loop -----
    if op == 76 {
        uint64 ms_dst = ir_a64_resolve_src(s1_v, 9)
        uint64 ms_val = ir_a64_resolve_src(s2_v, 10)
        uint64 ms_len_vreg = imm
        uint64 ms_len = 0
        if ms_len_vreg > 0 && ms_len_vreg < ir_vreg_next {
            ms_len = ir_get_phys_reg(ms_len_vreg)
            if ms_len == 0xFFFFFFFF {
                ir_a64_load_spill(11, ms_len_vreg)
