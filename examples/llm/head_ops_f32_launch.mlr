// head_extract / head_insert verifier — round-trip check.
//
//   tmp[s, d] = extract(in[s, h*HD+d])    for one head h
//   out[s, h*HD+d] = insert(tmp[s, d])    for the same head h
//
// After running on EVERY head: out should equal in exactly.
// Bit-exact gather/scatter — no precision drift expected.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-head-extract-f32=/tmp/head_extract_f32.co dummy
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-head-insert-f32=/tmp/head_insert_f32.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/head_ops_f32_launch.mlr -o /tmp/head_ops_f32_kfd
// Run:
//   /tmp/head_ops_f32_kfd

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n; tmp = val
    while i > 0 { i = i - 1; uint64 d = tmp - (tmp / 10) * 10; uint64 p = buf + i; uint8 c = d + 48; unsafe { *(p as uint8) = c }; tmp = tmp / 10 }
    return n
}
fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128); uint64 i = 0
    while i < label_len { uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }; uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }; i = i + 1 }
    uint64 cp = buf + label_len; uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1; uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}
fn die(uint64 msg, uint64 code) { puts(msg); print_label_val("e", 1, code); exit(1) }

fn load_kernel(uint64 co_path, uint64 fname) -> uint64 {
    uint64 fd = file_open(co_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("missing co"); puts(co_path); exit(1) }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    uint32 err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, fname); if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }
    return fh
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    uint64 fh_ext = load_kernel("/tmp/head_extract_f32.co", "head_extract_f32")
    uint64 fh_ins = load_kernel("/tmp/head_insert_f32.co",  "head_insert_f32")

    uint64 SEQ   = 32
    uint64 HEADS = 4
    uint64 HD    = 256
    uint64 HIDDEN = HEADS * HD

    uint64 io_bytes  = SEQ * HIDDEN * 4
    uint64 tmp_bytes = SEQ * HD * 4

    uint64 d_in = 0; uint64 d_tmp = 0; uint64 d_out = 0
    uint64 slot
    slot = alloc(8); err = hipMalloc(slot, io_bytes);  if err != 0 { die("mIn",  err) }; unsafe { *(slot as uint64) -> d_in }
    slot = alloc(8); err = hipMalloc(slot, tmp_bytes); if err != 0 { die("mTmp", err) }; unsafe { *(slot as uint64) -> d_tmp }
    slot = alloc(8); err = hipMalloc(slot, io_bytes);  if err != 0 { die("mOut", err) }; unsafe { *(slot as uint64) -> d_out }

    // Fill input with deterministic distinct u32 bit patterns.
    uint64 h_in = alloc(io_bytes)
    uint64 i = 0
    while i < SEQ * HIDDEN {
        uint64 p = h_in + i * 4
        uint32 v = i | 0x40000000
        unsafe { *(p as uint32) = v }
        i = i + 1
    }
    err = hipMemcpy(d_in, h_in, io_bytes, 1); if err != 0 { die("H2D", err) }

    // Run extract→insert for each head, accumulating into d_out.
    uint64 h = 0
    while h < HEADS {
        // extract: d_tmp[s, d] = d_in[s, h*HD + d]
        uint64 e_in   = alloc(8); unsafe { *(e_in   as uint64) = d_in }
        uint64 e_out  = alloc(8); unsafe { *(e_out  as uint64) = d_tmp }
        uint64 e_hd   = alloc(8); unsafe { *(e_hd   as uint64) = HD }
        uint64 e_hd2  = alloc(8); unsafe { *(e_hd2  as uint64) = HEADS }
        uint64 e_h    = alloc(8); unsafe { *(e_h    as uint64) = h }
        uint64 kp_e = alloc(5 * 8)
        unsafe { *(kp_e        as uint64) = e_in }
        unsafe { *((kp_e +  8) as uint64) = e_out }
        unsafe { *((kp_e + 16) as uint64) = e_hd }
        unsafe { *((kp_e + 24) as uint64) = e_hd2 }
        unsafe { *((kp_e + 32) as uint64) = e_h }
        err = hipModuleLaunchKernel(fh_ext, SEQ, 1, 1, HD, 1, 1, 0, 0, kp_e, 0)
        if err != 0 { die("L extract", err) }

        // insert: d_out[s, h*HD + d] = d_tmp[s, d]
        uint64 i_in   = alloc(8); unsafe { *(i_in   as uint64) = d_tmp }
        uint64 i_out  = alloc(8); unsafe { *(i_out  as uint64) = d_out }
        uint64 i_hd   = alloc(8); unsafe { *(i_hd   as uint64) = HD }
        uint64 i_hd2  = alloc(8); unsafe { *(i_hd2  as uint64) = HEADS }
        uint64 i_h    = alloc(8); unsafe { *(i_h    as uint64) = h }
        uint64 kp_i = alloc(5 * 8)
        unsafe { *(kp_i        as uint64) = i_in }
        unsafe { *((kp_i +  8) as uint64) = i_out }
        unsafe { *((kp_i + 16) as uint64) = i_hd }
        unsafe { *((kp_i + 24) as uint64) = i_hd2 }
        unsafe { *((kp_i + 32) as uint64) = i_h }
        err = hipModuleLaunchKernel(fh_ins, SEQ, 1, 1, HD, 1, 1, 0, 0, kp_i, 0)
        if err != 0 { die("L insert", err) }

        h = h + 1
    }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    uint64 h_out = alloc(io_bytes)
    err = hipMemcpy(h_out, d_out, io_bytes, 2); if err != 0 { die("D2H", err) }

    // Bit-exact check: out should equal in.
    uint64 mismatch = 0
    i = 0
    while i < SEQ * HIDDEN {
        uint64 ip = h_in  + i * 4
        uint64 op = h_out + i * 4
        uint32 ib = 0; uint32 ob = 0
        unsafe { *(ip as uint32) -> ib }
        unsafe { *(op as uint32) -> ob }
        if ib != ob { mismatch = mismatch + 1 }
        i = i + 1
    }

    print_label_val("SEQ",      3, SEQ)
    print_label_val("HEADS",    5, HEADS)
    print_label_val("HD",       2, HD)
    print_label_val("cells",    5, SEQ * HIDDEN)
    print_label_val("mismatch", 8, mismatch)

    hipFree(d_in); hipFree(d_tmp); hipFree(d_out)
    exit(0)
}
